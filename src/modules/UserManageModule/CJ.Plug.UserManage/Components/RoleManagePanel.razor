@using CJ.Plug.UserManageModels
@using CJ.Plug.UserManage.Pages
@using CJ.Plug.AuthModels
@using CJ.Plug.AuthApiClient
@using CJ.Plug.Models.Shared
@using CJ.Plug.SharedPages.Contracts
@using MudBlazor
@using System.Text.Json

@inject IRoleManageApiClient RoleApiClient
@inject IAuthApiClient AuthApiClient
@inject IDomInteropService DomInteropService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudStack Row AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h6">角色管理</MudText>
    <MudSpacer />
    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" OnClick="@OpenCreateDialog">创建角色</MudButton>
    <MudButton OnClick="Refresh" StartIcon="@Icons.Material.Filled.Refresh" Variant="Variant.Filled" Color="Color.Primary">刷新</MudButton>
</MudStack>

<MudDataGrid @ref="_dataGrid"
             T="RoleManageDto"
             ServerData="LoadData"
             Dense="true"
             Hover="true"
             Elevation="0"
             SortMode="SortMode.Single"
             RowStyle="cursor: default;"
             MultiSelection="true"
             SelectedItems="_selectedRoles"
             SelectOnRowClick="false">
    <ToolBarContent>
        <MudTextField T="string" @bind-Value="_searchString" Margin="Margin.Dense" Placeholder="搜索角色名、描述"
                      Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Outlined.Search"
                      Adornment="Adornment.End" Clearable="true" DebounceInterval="500" Immediate="true" Class="me-3" />
    </ToolBarContent>
    <Columns>
        <SelectColumn T="RoleManageDto" />
        <TemplateColumn Title="角色名" Sortable="true">
            <CellTemplate><MudText>@context.Item.Name</MudText></CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="描述">
            <CellTemplate><MudText Typo="Typo.body2">@context.Item.Description</MudText></CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="角色类型">
            <CellTemplate>
                <MudChip Color="@(context.Item.IsSystem ? Color.Info : Color.Default)" Variant="Variant.Filled" Size="Size.Small">
                    @(context.Item.RoleType ?? "自定义角色")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="系统角色">
            <CellTemplate>
                <MudChip Color="@(context.Item.IsSystem ? Color.Info : Color.Default)" Variant="Variant.Filled" Size="Size.Small">
                    @(context.Item.IsSystem ? "是" : "否")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="状态">
            <CellTemplate>
                @{
                    var status = context.Item.Status;
                    var chipColor = status switch
                    {
                        DataStatus.Authorizing => Color.Warning,
                        DataStatus.Disabled => Color.Default,
                        DataStatus.Active => Color.Success,
                        _ => Color.Default
                    };
                    var statusText = status switch
                    {
                        DataStatus.Authorizing => "授权中",
                        DataStatus.Disabled => "禁用",
                        DataStatus.Active => "启用",
                        _ => "未知"
                    };
                }
                <MudChip Color="@chipColor" Variant="Variant.Filled" Size="Size.Small">
                    @statusText
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="创建时间" Sortable="true">
            <CellTemplate>
                @(context.Item.CreatedAt > DateTimeOffset.MinValue
                    ? context.Item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")
                    : "-")
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Style="text-align:right" Title="操作">
            <CellTemplate>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert">
                    <MudMenuItem OnClick="@(()=>OpenEditDialog(context.Item))" Icon="@Icons.Material.Outlined.Edit">编辑</MudMenuItem>
                    <MudMenuItem OnClick="@(()=>DeleteRole(context.Item))" Icon="@Icons.Material.Outlined.Delete">删除</MudMenuItem>
                </MudMenu>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <NoRecordsContent><MudText>没有角色数据</MudText></NoRecordsContent>
    <LoadingContent><MudText>加载中...</MudText></LoadingContent>
    <PagerContent><MudDataGridPager RowsPerPageString="每页展示条数" /></PagerContent>
</MudDataGrid>

@code {
    private MudDataGrid<RoleManageDto> _dataGrid = default!;
    private HashSet<RoleManageDto> _selectedRoles = new();
    private string? _searchString;
    private List<RoleManageDto> _allRoles = [];
    private bool _isLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData_Internal();
        _isLoaded = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _isLoaded)
        {
            await _dataGrid.ReloadServerData();
        }
    }

    private async Task LoadData_Internal()
    {
        try { _allRoles = await RoleApiClient.GetAllAsync(); }
        catch { _allRoles = []; }
    }

    public async Task Refresh()
    {
        await LoadData_Internal();
        await _dataGrid.ReloadServerData();
    }

    private async Task<GridData<RoleManageDto>> LoadData(GridState<RoleManageDto> state, CancellationToken token)
    {
        var query = _allRoles.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_searchString))
        {
            var s = _searchString.Trim();
            query = query.Where(r =>
                (!string.IsNullOrEmpty(r.Name) && r.Name.Contains(s, StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrEmpty(r.Description) && r.Description.Contains(s, StringComparison.OrdinalIgnoreCase)));
        }
        var sortDef = state.SortDefinitions?.FirstOrDefault();
        if (sortDef?.SortBy == "Name")
            query = sortDef.Descending ? query.OrderByDescending(r => r.Name) : query.OrderBy(r => r.Name);
        else if (sortDef?.SortBy == "CreatedAt")
            query = sortDef.Descending ? query.OrderByDescending(r => r.CreatedAt) : query.OrderBy(r => r.CreatedAt);
        else
            query = query.OrderByDescending(r => r.Id);

        var items = query.ToList();
        var total = items.Count;
        var pageItems = items.Skip(state.Page * state.PageSize).Take(state.PageSize).ToArray();
        return new GridData<RoleManageDto> { TotalItems = total, Items = pageItems };
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters
        {
            { "RoleName", "" },
            { "RoleDescription", "" },
            { "RoleType", "自定义角色" }
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateRoleDialog>("创建角色（需授权）", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled && result.Data is CreateRoleRequest request)
        {
            await CreateAuthRequest(AuthOperationType.CreateRole, $"角色: {request.Name}", JsonSerializer.Serialize(request));
        }
    }

    private async Task OpenEditDialog(RoleManageDto role)
    {
        var parameters = new DialogParameters
        {
            { "RoleId", role.Id },
            { "RoleName", role.Name ?? "" },
            { "RoleDescription", role.Description ?? "" },
            { "RoleType", role.RoleType ?? "自定义角色" }
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EditRoleDialog>("编辑角色（需授权）", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled && result.Data is UpdateRoleRequest request)
        {
            await CreateAuthRequest(AuthOperationType.UpdateRole, $"角色: {role.Name}", JsonSerializer.Serialize(request));
        }
    }

    private async Task DeleteRole(RoleManageDto role)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("确认删除", $"确定要提交删除角色 \"{role.Name}\" 的授权请求吗？", yesText: "提交请求", cancelText: "取消");
        if (confirm != true) return;
        await CreateAuthRequest(AuthOperationType.DeleteRole, $"角色: {role.Name}", JsonSerializer.Serialize(new { RoleId = role.Id, RoleName = role.Name }));
    }

    private async Task CreateAuthRequest(AuthOperationType operationType, string targetDescription, string operationData)
    {
        try
        {
            var currentUser = await DomInteropService.GetCurrentUserName();
            if (string.IsNullOrEmpty(currentUser))
            {
                currentUser = "anonymous";
                Snackbar.Add("未检测到登录用户，请先登录", Severity.Warning);
            }

            var request = new CreateAuthRequestDto
            {
                OperationType = operationType,
                TargetDescription = targetDescription,
                OperationData = operationData,
                RequestedBy = currentUser
            };

            await AuthApiClient.CreateAsync(request);
            Snackbar.Add($"已创建{targetDescription}，状态为「授权中」，等待审批", Severity.Success);
            await Refresh();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"提交授权请求失败: {ex.Message}", Severity.Error);
        }
    }
}
