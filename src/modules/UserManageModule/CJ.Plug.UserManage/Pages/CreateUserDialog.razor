@using CJ.Plug.UserManageModels
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="Model.UserName"
                          Label="用户名"
                          Variant="Variant.Outlined"
                          Required="true" />

            <MudTextField @bind-Value="Model.Email"
                          Label="邮箱"
                          Variant="Variant.Outlined"
                          Required="false"
                          InputType="InputType.Email" />

            @* <MudTextField @bind-Value="Model.Password"
                          Label="密码"
                          Variant="Variant.Outlined"
                          Required="true"
                          InputType="InputType.Password" />

            <MudTextField @bind-Value="Model.ConfirmPassword"
                          Label="确认密码"
                          Variant="Variant.Outlined"
                          Required="true"
                          InputType="InputType.Password"
                          Error="@(!string.IsNullOrEmpty(_confirmPasswordError))"
                          ErrorText="@_confirmPasswordError" /> *@

            <MudDivider />

            <MudTextField @bind-Value="Model.FirstName"
                          Label="姓"
                          Variant="Variant.Outlined" />

            <MudTextField @bind-Value="Model.LastName"
                          Label="名"
                          Variant="Variant.Outlined" />

            <MudTextField @bind-Value="Model.PhoneNumber"
                          Label="电话"
                          Variant="Variant.Outlined"
                          InputType="InputType.Telephone" />

            <MudSelect T="int?"
                       @bind-Value="Model.DepartmentId"
                       Label="部门"
                       Variant="Variant.Outlined"
                       Required="true"
                       Placeholder="请选择部门">
                @foreach (var dept in Departments)
                {
                    <MudSelectItem T="int?" Value="@((int?)dept.Id)">@dept.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="string"
                       @bind-SelectedValues="SelectedRoleNames"
                       Label="角色"
                       Variant="Variant.Outlined"
                       MultiSelection="true"
                       Clearable="true"
                       Placeholder="请选择角色">
                @foreach (var role in Roles)
                {
                    <MudSelectItem T="string" Value="@role">@role</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">取消</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">创建</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    [Parameter] public List<DepartmentManageDto> Departments { get; set; } = [];
    [Parameter] public List<string> Roles { get; set; } = [];

    private CreateUserForm Model { get; set; } = new();
    private IReadOnlyCollection<string> SelectedRoleNames { get; set; } = [];
    private string _confirmPasswordError = string.Empty;

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        _confirmPasswordError = string.Empty;

        if (string.IsNullOrWhiteSpace(Model.UserName))
        {
            Snackbar.Add("请输入用户名", Severity.Warning);
            return;
        }
        // if (string.IsNullOrWhiteSpace(Model.Email))
        // {
        //     Snackbar.Add("请输入邮箱", Severity.Warning);
        //     return;
        // }
        if (Model.DepartmentId == null)
        {
            Snackbar.Add("请选择部门", Severity.Warning);
            return;
        }
        // if (string.IsNullOrWhiteSpace(Model.Password))
        // {
        //     Snackbar.Add("请输入密码", Severity.Warning);
        //     return;
        // }
        // if (Model.Password != Model.ConfirmPassword)
        // {
        //     _confirmPasswordError = "两次输入的密码不一致";
        //     Snackbar.Add("两次输入的密码不一致", Severity.Warning);
        //     return;
        // }

        MudDialog.Close(DialogResult.Ok(new CreateUserRequest
        {
            UserName = Model.UserName.Trim(),
            Email = Model.Email.Trim(),
            Password = "123456",
            FirstName = Model.FirstName?.Trim(),
            LastName = Model.LastName?.Trim(),
            PhoneNumber = Model.PhoneNumber?.Trim(),
            DepartmentId = Model.DepartmentId,
            RoleNames = SelectedRoleNames.ToList()
        }));
    }

    private class CreateUserForm
    {
        public string UserName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? PhoneNumber { get; set; }
        public int? DepartmentId { get; set; }
    }
}
