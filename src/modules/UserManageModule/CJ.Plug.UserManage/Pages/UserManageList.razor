@page "/UserManageList"

@using CJ.Plug.Models.Shared
@using CJ.Plug.UserManageModels
@using MudBlazor
@using System.Globalization

@inject IUserManageApiClient UserApiClient
@inject IDepartmentManageApiClient DepartmentApiClient
@inject IRoleManageApiClient RoleApiClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>用户管理</PageTitle>

<MudContainer MaxWidth="MaxWidth.False">

    <MudStack Row AlignItems="AlignItems.Center">
        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="用户操作" Color="Color.Default" Variant="Variant.Filled" AnchorOrigin="Origin.BottomLeft">
            <MudMenuItem OnClick="@DeleteSelectedUsers">删除</MudMenuItem>
        </MudMenu>

        <MudButton StartIcon="@Icons.Material.Filled.PersonAdd" Variant="Variant.Filled" Color="Color.Primary" OnClick="@OpenCreateDialog">创建用户</MudButton>
        <MudButton OnClick="RefreshData" StartIcon="@Icons.Material.Filled.Refresh" Variant="Variant.Filled" Color="Color.Primary">刷新</MudButton>
    </MudStack>

    <MudSpacer />

    <MudDataGrid @ref="dataGrid"
                 T="User"
                 ServerData="LoadData"
                 Dense="true"
                 Hover="true"
                 Elevation="0"
                 SortMode="SortMode.Single"
                 RowStyle="cursor: default;"
                 MultiSelection="true"
                 SelectedItems="SelectedUsers"
                 SelectOnRowClick="false"
                 Class="users-table">

        <ToolBarContent>
            <MudTextField T="string"
                          @bind-Value="searchString"
                          Margin="Margin.Dense"
                          Placeholder="可搜索：用户名、邮箱"
                          Variant="Variant.Outlined"
                          AdornmentIcon="@Icons.Material.Outlined.Search"
                          Adornment="Adornment.End"
                          Clearable="true"
                          DebounceInterval="500"
                          Immediate="true"
                          Class="me-3" />
        </ToolBarContent>

        <Columns>
            <SelectColumn T="User" />

            <TemplateColumn Title="用户名" Sortable="true">
                <CellTemplate>
                    <MudText>@context.Item.UserName</MudText>
                </CellTemplate>
            </TemplateColumn>

            <PropertyColumn Property="x => x.Email" Title="邮箱" />

            <TemplateColumn Title="姓名">
                <CellTemplate>
                    @GetDisplayName(context.Item)
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="部门">
                <CellTemplate>
                    @GetDepartmentName(context.Item.DepartmentId)
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="角色">
                <CellTemplate>
                    @{
                        var roles = GetUserRoleNames(context.Item.Id);
                    }
                    @if (roles.Count > 0)
                    {
                        @foreach (var role in roles)
                        {
                            <MudChip Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@role</MudChip>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Default">-</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="创建时间" Sortable="true">
                <CellTemplate>
                    @context.Item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Style="text-align:right" Title="操作">
                <CellTemplate>
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert">
                        <MudMenuItem OnClick="@(()=>OpenEditDialog(context.Item))" Icon="@Icons.Material.Outlined.Edit">编辑</MudMenuItem>
                        <MudMenuItem OnClick="@(()=>DeleteUser(context.Item))" Icon="@Icons.Material.Outlined.Delete">删除</MudMenuItem>
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
        </Columns>

        <NoRecordsContent>
            <MudText>没有用户数据</MudText>
        </NoRecordsContent>

        <LoadingContent>
            <MudText>加载中...</MudText>
        </LoadingContent>

        <PagerContent>
            <MudDataGridPager RowsPerPageString="每页展示条数" />
        </PagerContent>
    </MudDataGrid>

</MudContainer>

@code {
    private MudDataGrid<User> dataGrid = default!;
    public HashSet<User> SelectedUsers { get; set; } = new HashSet<User>();
    public string? searchString { get; set; }

    private List<User> _allUsers = [];
    private List<DepartmentManageDto> _allDepartments = [];
    private List<string> _allRoles = [];
    private Dictionary<int, List<string>> _userRolesCache = new();

    protected override async Task OnInitializedAsync()
    {
        // Load departments and roles first (lightweight), then reload grid
        await Task.WhenAll(LoadDepartments(), LoadRoles());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // First render: load users and their roles, then reload the grid
            await LoadUsers();
            await LoadUserRoles();
            StateHasChanged();
        }
    }

    private async Task RefreshData()
    {
        await LoadDepartments();
        await LoadRoles();
        await LoadUsers();
        await LoadUserRoles();
        await dataGrid.ReloadServerData();
    }

    private async Task LoadUsers()
    {
        try
        {
            var users = await UserApiClient.GetAllUsersAsync();
            _allUsers = users?.Where(u => u != null).Cast<User>().ToList() ?? [];
        }
        catch (Exception ex)
        {
            Snackbar.Add($"加载用户失败: {ex.Message}", Severity.Error);
            _allUsers = [];
        }
    }

    private async Task LoadDepartments()
    {
        try
        {
            _allDepartments = await DepartmentApiClient.GetAllDepartmentsAsync();
        }
        catch
        {
            _allDepartments = [];
        }
    }

    private async Task LoadRoles()
    {
        try
        {
            var roles = await RoleApiClient.GetAllAsync();
            _allRoles = roles.Select(r => r.Name).Where(n => !string.IsNullOrEmpty(n)).Cast<string>().ToList();
        }
        catch
        {
            _allRoles = [];
        }
    }

    private async Task LoadUserRoles()
    {
        _userRolesCache.Clear();
        foreach (var user in _allUsers)
        {
            try
            {
                var userRoles = await UserApiClient.GetUserRolesAsync(user.Id);
                _userRolesCache[user.Id] = userRoles;
            }
            catch
            {
                _userRolesCache[user.Id] = [];
            }
        }
    }

    private async Task<GridData<User>> LoadData(GridState<User> state, CancellationToken token)
    {
        var query = _allUsers.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchString))
        {
            var s = searchString.Trim();
            query = query.Where(u =>
                (u.UserName != null && u.UserName.Contains(s, StringComparison.OrdinalIgnoreCase))
                || (u.Email != null && u.Email.Contains(s, StringComparison.OrdinalIgnoreCase))
            );
        }

        var sortDef = state.SortDefinitions?.FirstOrDefault();
        if (sortDef != null)
        {
            if (sortDef.SortBy == nameof(User.CreatedAt))
            {
                query = sortDef.Descending
                    ? query.OrderByDescending(u => u.CreatedAt)
                    : query.OrderBy(u => u.CreatedAt);
            }
            else if (sortDef.SortBy == nameof(User.UserName))
            {
                query = sortDef.Descending
                    ? query.OrderByDescending(u => u.UserName)
                    : query.OrderBy(u => u.UserName);
            }
        }
        else
        {
            query = query.OrderByDescending(u => u.CreatedAt);
        }

        var total = query.Count();
        var items = query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToArray();

        await Task.CompletedTask;
        return new GridData<User> { TotalItems = total, Items = items };
    }

    private string GetDisplayName(User user)
    {
        var parts = new[] { user.FirstName, user.LastName }.Where(p => !string.IsNullOrWhiteSpace(p));
        return parts.Any() ? string.Join(" ", parts) : "-";
    }

    private string GetDepartmentName(int? departmentId)
    {
        if (!departmentId.HasValue) return "-";
        var dept = _allDepartments.FirstOrDefault(d => d.Id == departmentId.Value);
        return dept?.Name ?? "-";
    }

    private List<string> GetUserRoleNames(int userId)
    {
        return _userRolesCache.TryGetValue(userId, out var roles) ? roles : [];
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<CreateUserDialog>
        {
            { d => d.Departments, _allDepartments },
            { d => d.Roles, _allRoles }
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateUserDialog>("创建用户", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is CreateUserRequest request)
        {
            try
            {
                var user = await UserApiClient.CreateUserAsync(request);
                if (user != null)
                {
                    Snackbar.Add($"用户 \"{user.UserName}\" 创建成功", Severity.Success);
                    await RefreshData();
                }
                else
                {
                    Snackbar.Add("创建用户失败，用户名或邮箱可能已存在", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"创建用户失败: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(User user)
    {
        var userRoles = GetUserRoleNames(user.Id);

        var parameters = new DialogParameters<EditUserDialog>
        {
            { d => d.UserId, user.Id },
            { d => d.UserName, user.UserName ?? "" },
            { d => d.Email, user.Email },
            { d => d.FirstName, user.FirstName },
            { d => d.LastName, user.LastName },
            { d => d.PhoneNumber, user.PhoneNumber },
            { d => d.DepartmentId, user.DepartmentId },
            { d => d.UserRoles, userRoles },
            { d => d.Departments, _allDepartments },
            { d => d.Roles, _allRoles }
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EditUserDialog>("编辑用户", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is UpdateUserRequest request)
        {
            try
            {
                var updatedUser = await UserApiClient.UpdateUserAsync(request);
                if (updatedUser != null)
                {
                    Snackbar.Add($"用户 \"{user.UserName}\" 更新成功", Severity.Success);
                    await RefreshData();
                }
                else
                {
                    Snackbar.Add("更新用户失败", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"更新用户失败: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteUser(User user)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "确认删除",
            $"确定要删除用户 \"{user.UserName}\" 吗？",
            yesText: "删除", cancelText: "取消");

        if (confirm != true) return;

        try
        {
            Snackbar.Add($"已删除用户：{user.UserName}", Severity.Success);
            await RefreshData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"删除用户失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteSelectedUsers()
    {
        if (SelectedUsers.Count == 0)
        {
            Snackbar.Add("请先选择要删除的用户", Severity.Warning);
            return;
        }

        var confirm = await DialogService.ShowMessageBoxAsync(
            "确认批量删除",
            $"确定要删除选中的 {SelectedUsers.Count} 个用户吗？",
            yesText: "删除", cancelText: "取消");

        if (confirm != true) return;

        SelectedUsers.Clear();
        await RefreshData();
        Snackbar.Add("已删除所选用户", Severity.Success);
    }
}
