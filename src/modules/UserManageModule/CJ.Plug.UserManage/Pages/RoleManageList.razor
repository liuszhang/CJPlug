@page "/RoleManageList"

@using CJ.Plug.UserManageModels
@using MudBlazor
@using System.Globalization

@inject IRoleManageApiClient RoleApiClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>角色管理</PageTitle>

<MudContainer MaxWidth="MaxWidth.False">

    <MudStack Row AlignItems="AlignItems.Center">
        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="角色操作" Color="Color.Default" Variant="Variant.Filled" AnchorOrigin="Origin.BottomLeft">
            <MudMenuItem OnClick="@DeleteSelectedRoles">删除</MudMenuItem>
        </MudMenu>

        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" OnClick="@OpenCreateDialog">创建角色</MudButton>
        <MudButton OnClick="async()=>await dataGrid.ReloadServerData()" StartIcon="@Icons.Material.Filled.Refresh" Variant="Variant.Filled" Color="Color.Primary">刷新</MudButton>
    </MudStack>

    <MudDataGrid @ref="dataGrid"
                 T="RoleManageDto"
                 ServerData="LoadData"
                 Dense="true"
                 Hover="true"
                 Elevation="0"
                 SortMode="SortMode.Single"
                 RowStyle="cursor: default;"
                 MultiSelection="true"
                 SelectedItems="SelectedRoles"
                 SelectOnRowClick="false"
                 Class="roles-table">

        <ToolBarContent>
            <MudTextField T="string"
                          @bind-Value="searchString"
                          Margin="Margin.Dense"
                          Placeholder="可搜索：角色名、描述"
                          Variant="Variant.Outlined"
                          AdornmentIcon="@Icons.Material.Outlined.Search"
                          Adornment="Adornment.End"
                          Clearable="true"
                          DebounceInterval="500"
                          Immediate="true"
                          Class="me-3" />
        </ToolBarContent>

        <Columns>
            <SelectColumn T="RoleManageDto" />

            <TemplateColumn Title="角色名" Sortable="true">
                <CellTemplate>
                    <MudText>@context.Item.Name</MudText>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="描述">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@context.Item.Description</MudText>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="角色类型">
                <CellTemplate>
                    <MudChip Color="@(context.Item.IsSystem ? Color.Info : Color.Default)" Variant="Variant.Filled" Size="Size.Small">
                        @(context.Item.RoleType ?? "自定义角色")
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="系统角色">
                <CellTemplate>
                    <MudChip Color="@(context.Item.IsSystem ? Color.Info : Color.Default)" Variant="Variant.Filled" Size="Size.Small">
                        @(context.Item.IsSystem ? "是" : "否")
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="创建时间" Sortable="true">
                <CellTemplate>
                    @(context.Item.CreatedAt > DateTimeOffset.MinValue
                        ? context.Item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)
                        : "-")
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Style="text-align:right" Title="操作">
                <CellTemplate>
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert">
                        <MudMenuItem OnClick="@(()=>OpenEditDialog(context.Item))" Icon="@Icons.Material.Outlined.Edit">编辑</MudMenuItem>
                        <MudMenuItem OnClick="@(()=>DeleteRole(context.Item))" Icon="@Icons.Material.Outlined.Delete">删除</MudMenuItem>
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
        </Columns>

        <NoRecordsContent>
            <MudText>没有角色数据</MudText>
        </NoRecordsContent>

        <LoadingContent>
            <MudText>加载中...</MudText>
        </LoadingContent>

        <PagerContent>
            <MudDataGridPager RowsPerPageString="每页展示条数" />
        </PagerContent>
    </MudDataGrid>

</MudContainer>

@code {
    private MudDataGrid<RoleManageDto> dataGrid = default!;
    public HashSet<RoleManageDto> SelectedRoles { get; set; } = new HashSet<RoleManageDto>();
    public string? searchString { get; set; }
    private List<RoleManageDto> _allRoles = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadRoles();
            StateHasChanged();
        }
    }

    private async Task LoadRoles()
    {
        try
        {
            _allRoles = await RoleApiClient.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"加载角色失败: {ex.Message}", Severity.Error);
            _allRoles = [];
        }
    }

    private async Task<GridData<RoleManageDto>> LoadData(GridState<RoleManageDto> state, CancellationToken token)
    {
        var query = _allRoles.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchString))
        {
            var s = searchString.Trim();
            query = query.Where(r =>
                (!string.IsNullOrEmpty(r.Name) && r.Name.Contains(s, StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrEmpty(r.Description) && r.Description.Contains(s, StringComparison.OrdinalIgnoreCase))
            );
        }

        var sortDef = state.SortDefinitions?.FirstOrDefault();
        if (sortDef != null)
        {
            if (sortDef.SortBy == "Name")
                query = sortDef.Descending
                    ? query.OrderByDescending(r => r.Name)
                    : query.OrderBy(r => r.Name);
            else if (sortDef.SortBy == "CreatedAt")
                query = sortDef.Descending
                    ? query.OrderByDescending(r => r.CreatedAt)
                    : query.OrderBy(r => r.CreatedAt);
        }
        else
        {
            query = query.OrderByDescending(r => r.Id);
        }

        var items = query.ToList();
        var total = items.Count;
        var pageItems = items.Skip(state.Page * state.PageSize).Take(state.PageSize).ToArray();
        return new GridData<RoleManageDto> { TotalItems = total, Items = pageItems };
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<CreateRoleDialog>
        {
            { d => d.RoleName, "" },
            { d => d.RoleDescription, "" },
            { d => d.RoleType, "自定义角色" }
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateRoleDialog>("创建角色", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is CreateRoleRequest request)
        {
            try
            {
                await RoleApiClient.CreateAsync(request);
                Snackbar.Add($"角色 \"{request.Name}\" 创建成功", Severity.Success);
                await LoadRoles();
                await dataGrid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"创建角色失败: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(RoleManageDto role)
    {
        var parameters = new DialogParameters<EditRoleDialog>
        {
            { d => d.RoleId, role.Id },
            { d => d.RoleName, role.Name ?? "" },
            { d => d.RoleDescription, role.Description ?? "" },
            { d => d.RoleType, role.RoleType ?? "自定义角色" }
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EditRoleDialog>("编辑角色", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is UpdateRoleRequest request)
        {
            try
            {
                await RoleApiClient.UpdateAsync(request);
                Snackbar.Add($"角色 \"{request.Name}\" 更新成功", Severity.Success);
                await LoadRoles();
                await dataGrid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"更新角色失败: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteRole(RoleManageDto role)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "确认删除",
            $"确定要删除角色 \"{role.Name}\" 吗？",
            yesText: "删除", cancelText: "取消");

        if (confirm != true) return;

        try
        {
            var success = await RoleApiClient.DeleteAsync(role.Id);
            if (success)
            {
                Snackbar.Add($"已删除角色：{role.Name}", Severity.Success);
                await LoadRoles();
                await dataGrid.ReloadServerData();
            }
            else
            {
                Snackbar.Add("删除角色失败：角色不存在", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"删除角色失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteSelectedRoles()
    {
        if (SelectedRoles.Count == 0)
        {
            Snackbar.Add("请先选择要删除的角色", Severity.Warning);
            return;
        }

        var confirm = await DialogService.ShowMessageBoxAsync(
            "确认批量删除",
            $"确定要删除选中的 {SelectedRoles.Count} 个角色吗？",
            yesText: "删除", cancelText: "取消");

        if (confirm != true) return;

        var failedCount = 0;
        foreach (var r in SelectedRoles.ToList())
        {
            try
            {
                await RoleApiClient.DeleteAsync(r.Id);
            }
            catch
            {
                failedCount++;
            }
        }

        SelectedRoles.Clear();
        await LoadRoles();
        await dataGrid.ReloadServerData();

        if (failedCount == 0)
            Snackbar.Add("已删除所选角色", Severity.Success);
        else
            Snackbar.Add($"已删除 {SelectedRoles.Count - failedCount} 个角色，{failedCount} 个删除失败", Severity.Warning);
    }
}
