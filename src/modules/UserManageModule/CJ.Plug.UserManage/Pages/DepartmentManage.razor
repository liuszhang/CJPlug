@page "/DepartmentManage"

@using CJ.Plug.UserManageModels
@using MudBlazor
@using System.Globalization

@inject IDepartmentManageApiClient DepartmentApiClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>部门管理</PageTitle>

<MudContainer MaxWidth="MaxWidth.False">
    <MudStack Row AlignItems="AlignItems.Center">
        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="部门操作" Color="Color.Default" Variant="Variant.Filled" AnchorOrigin="Origin.BottomLeft">
            <MudMenuItem OnClick="@DeleteSelectedDepartments">删除</MudMenuItem>
        </MudMenu>

        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" OnClick="@OpenCreateDialog">创建部门</MudButton>
        <MudButton OnClick="async ()=> await dataGrid.ReloadServerData()" StartIcon="@Icons.Material.Filled.Refresh" Variant="Variant.Filled" Color="Color.Primary">刷新</MudButton>
    </MudStack>

    <MudSpacer />

    <MudDataGrid @ref="dataGrid"
                 T="DepartmentManageDto"
                 ServerData="LoadData"
                 Dense="true"
                 Hover="true"
                 Elevation="0"
                 SortMode="SortMode.Single"
                 RowStyle="cursor: default;"
                 MultiSelection="true"
                 SelectedItems="SelectedDepartments"
                 SelectOnRowClick="false"
                 Class="departments-table">

        <ToolBarContent>
            <MudTextField T="string"
                          @bind-Value="searchString"
                          Margin="Margin.Dense"
                          Placeholder="可搜索：部门名、编码、负责人"
                          Variant="Variant.Outlined"
                          AdornmentIcon="@Icons.Material.Outlined.Search"
                          Adornment="Adornment.End"
                          Clearable="true"
                          DebounceInterval="500"
                          Immediate="true"
                          Class="me-3" />
        </ToolBarContent>

        <Columns>
            <SelectColumn T="DepartmentManageDto" />

            <TemplateColumn Title="部门名称" Sortable="true">
                <CellTemplate>
                    <MudText>@context.Item.Name</MudText>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="编码">
                <CellTemplate>
                    @(context.Item.Code ?? "-")
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="上级部门">
                <CellTemplate>
                    @(context.Item.ParentName ?? "-")
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="负责人">
                <CellTemplate>
                    @(context.Item.Manager ?? "-")
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="状态">
                <CellTemplate>
                    @{
                        var status = context.Item.Status;
                        var chipColor = status switch
                        {
                            DataStatus.Authorizing => Color.Warning,
                            DataStatus.Disabled => Color.Default,
                            DataStatus.Active => Color.Success,
                            _ => Color.Default
                        };
                        var statusText = status switch
                        {
                            DataStatus.Authorizing => "授权中",
                            DataStatus.Disabled => "禁用",
                            DataStatus.Active => "启用",
                            _ => "未知"
                        };
                    }
                    <MudChip Color="@chipColor" Variant="Variant.Filled" Size="Size.Small">
                        @statusText
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="创建时间" Sortable="true">
                <CellTemplate>
                    @context.Item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Style="text-align:right" Title="操作">
                <CellTemplate>
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert">
                        <MudMenuItem OnClick="@(()=>OpenEditDialog(context.Item))" Icon="@Icons.Material.Outlined.Edit">编辑</MudMenuItem>
                        <MudMenuItem OnClick="@(()=>DeleteDepartment(context.Item))" Icon="@Icons.Material.Outlined.Delete">删除</MudMenuItem>
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
        </Columns>

        <NoRecordsContent>
            <MudText>没有部门数据</MudText>
        </NoRecordsContent>

        <LoadingContent>
            <MudText>加载中...</MudText>
        </LoadingContent>

        <PagerContent>
            <MudDataGridPager RowsPerPageString="每页展示条数" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    private MudDataGrid<DepartmentManageDto> dataGrid = default!;
    public HashSet<DepartmentManageDto> SelectedDepartments { get; set; } = new HashSet<DepartmentManageDto>();
    public string? searchString { get; set; }
    private List<DepartmentManageDto> _allDepartments = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDepartments();
            StateHasChanged();
        }
    }

    private async Task LoadDepartments()
    {
        try
        {
            _allDepartments = await DepartmentApiClient.GetAllDepartmentsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"加载部门失败: {ex.Message}", Severity.Error);
            _allDepartments = [];
        }
    }

    private async Task<GridData<DepartmentManageDto>> LoadData(GridState<DepartmentManageDto> state, CancellationToken token)
    {
        var query = _allDepartments.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchString))
        {
            var s = searchString.Trim();
            query = query.Where(d =>
                (!string.IsNullOrEmpty(d.Name) && d.Name.Contains(s, StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrEmpty(d.Code) && d.Code.Contains(s, StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrEmpty(d.Manager) && d.Manager.Contains(s, StringComparison.OrdinalIgnoreCase))
            );
        }

        var sortDef = state.SortDefinitions?.FirstOrDefault();
        if (sortDef != null)
        {
            if (sortDef.SortBy == nameof(DepartmentManageDto.Name))
                query = sortDef.Descending
                    ? query.OrderByDescending(d => d.Name)
                    : query.OrderBy(d => d.Name);
            else if (sortDef.SortBy == nameof(DepartmentManageDto.CreatedAt))
                query = sortDef.Descending
                    ? query.OrderByDescending(d => d.CreatedAt)
                    : query.OrderBy(d => d.CreatedAt);
        }
        else
        {
            query = query.OrderByDescending(d => d.Id);
        }

        var items = query.ToList();
        var total = items.Count;
        var pageItems = items.Skip(state.Page * state.PageSize).Take(state.PageSize).ToArray();
        return new GridData<DepartmentManageDto> { TotalItems = total, Items = pageItems };
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<DepartmentDialog>
        {
            { d => d.IsEdit, false },
            { d => d.DepartmentId, 0 },
            { d => d.DepartmentName, "" },
            { d => d.DepartmentCode, "" },
            { d => d.ParentId, (int?)null },
            { d => d.Manager, "" },
            { d => d.Status, DataStatus.Authorizing },
            { d => d.Departments, _allDepartments }
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<DepartmentDialog>("创建部门", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is CreateDepartmentRequest request)
        {
            try
            {
                await DepartmentApiClient.CreateDepartmentAsync(request);
                Snackbar.Add($"部门 \"{request.Name}\" 创建成功", Severity.Success);
                await LoadDepartments();
                await dataGrid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"创建部门失败: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(DepartmentManageDto dept)
    {
        var parameters = new DialogParameters<DepartmentDialog>
        {
            { d => d.IsEdit, true },
            { d => d.DepartmentId, dept.Id },
            { d => d.DepartmentName, dept.Name ?? "" },
            { d => d.DepartmentCode, dept.Code },
            { d => d.ParentId, dept.ParentId },
            { d => d.Manager, dept.Manager },
            { d => d.Status, dept.Status },
            { d => d.Departments, _allDepartments }
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<DepartmentDialog>("编辑部门", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is UpdateDepartmentRequest request)
        {
            try
            {
                await DepartmentApiClient.UpdateDepartmentAsync(request);
                Snackbar.Add($"部门 \"{request.Name}\" 更新成功", Severity.Success);
                await LoadDepartments();
                await dataGrid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"更新部门失败: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteDepartment(DepartmentManageDto dept)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "确认删除",
            $"确定要删除部门 \"{dept.Name}\" 吗？",
            yesText: "删除", cancelText: "取消");

        if (confirm != true) return;

        try
        {
            var success = await DepartmentApiClient.DeleteDepartmentAsync(dept.Id);
            if (success)
            {
                Snackbar.Add($"已删除部门：{dept.Name}", Severity.Success);
                await LoadDepartments();
                await dataGrid.ReloadServerData();
            }
            else
            {
                Snackbar.Add("删除部门失败：部门不存在", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"删除部门失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteSelectedDepartments()
    {
        if (SelectedDepartments.Count == 0)
        {
            Snackbar.Add("请先选择要删除的部门", Severity.Warning);
            return;
        }

        var confirm = await DialogService.ShowMessageBoxAsync(
            "确认批量删除",
            $"确定要删除选中的 {SelectedDepartments.Count} 个部门吗？",
            yesText: "删除", cancelText: "取消");

        if (confirm != true) return;

        var failedCount = 0;
        foreach (var d in SelectedDepartments.ToList())
        {
            try
            {
                await DepartmentApiClient.DeleteDepartmentAsync(d.Id);
            }
            catch
            {
                failedCount++;
            }
        }

        SelectedDepartments.Clear();
        await LoadDepartments();
        await dataGrid.ReloadServerData();

        if (failedCount == 0)
            Snackbar.Add("已删除所选部门", Severity.Success);
        else
            Snackbar.Add($"已删除 {SelectedDepartments.Count - failedCount} 个部门，{failedCount} 个删除失败", Severity.Warning);
    }
}
