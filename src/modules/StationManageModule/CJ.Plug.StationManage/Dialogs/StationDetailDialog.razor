@using CJ.Plug.Models.Station
@using System.Text.Json
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6">
                图站详情 - @Station?.StationName (@Station?.StationIp)
            </MudText>
            <MudChip T="string" Color="@(Station?.IsStarted == true ? Color.Success : Color.Error)"
                     Size="Size.Small"
                     Text="@(Station?.IsStarted == true ? "在线" : "离线")" />
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (Loading)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" />
        }
        else
        {
            <MudExpansionPanels>
                @* 工具部署和安装情况 *@
                <MudExpansionPanel Text="工具部署与安装情况" IsExpanded="true">
                    <MudPaper Elevation="0" Class="pa-3">
                        @if (ToolError != null)
                        {
                            <MudAlert Severity="Severity.Warning">@ToolError</MudAlert>
                        }
                        else if (ConfigToolList == null || ConfigToolList.Count == 0)
                        {
                            <MudText Typo="Typo.body2">暂无工具部署配置</MudText>
                        }
                        else
                        {
                            <MudTable Items="ConfigToolList" Hover="true" Dense="true" Elevation="0">
                                <HeaderContent>
                                    <MudTh Style="width:60px;">编号</MudTh>
                                    <MudTh>工具名称</MudTh>
                                    <MudTh>工具类型</MudTh>
                                    <MudTh>版本</MudTh>
                                    <MudTh>状态</MudTh>
                                    <MudTh>安装路径</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="编号">@context.Id</MudTd>
                                    <MudTd DataLabel="工具名称">@context.ToolName</MudTd>
                                    <MudTd DataLabel="工具类型">@context.ToolType</MudTd>
                                    <MudTd DataLabel="版本">@context.ToolVersion</MudTd>
                                    <MudTd DataLabel="状态">
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@GetStatusColor(context.DeploymentStatus)"
                                                 Text="@(context.DeploymentStatus ?? "未知")" />
                                    </MudTd>
                                    <MudTd DataLabel="安装路径">
                                        <MudText Typo="Typo.body2" Style="max-width:300px; word-break:break-all;">
                                            @(string.IsNullOrEmpty(context.ToolPath) ? "-" : context.ToolPath)
                                        </MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudPaper>
                </MudExpansionPanel>

                @* 图站负载状态 *@
                <MudExpansionPanel Text="图站负载状态">
                    @if (LoadError != null)
                    {
                        <MudAlert Severity="Severity.Warning">@LoadError</MudAlert>
                    }
                    else if (LoadStatus != null)
                    {
                        <MudPaper Elevation="0" Class="pa-3">
                            <MudStack Spacing="3">
                                @* CPU 使用率 *@
                                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Style="width:120px;">CPU 使用率</MudText>
                                    <MudProgressLinear Value="@LoadStatus.CpuUsagePercent"
                                                       Color="@(LoadStatus.CpuUsagePercent > 80 ? Color.Error :
                                                                LoadStatus.CpuUsagePercent > 60 ? Color.Warning : Color.Success)"
                                                       Size="Size.Small" Style="flex:1; margin:0 12px;" />
                                    <MudText Typo="Typo.body2" Style="width:50px; text-align:right;">
                                        @($"{LoadStatus.CpuUsagePercent:F1}%")
                                    </MudText>
                                </MudStack>

                                @* 内存使用率 *@
                                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Style="width:120px;">内存</MudText>
                                    <MudProgressLinear Value="@LoadStatus.MemoryUsagePercent"
                                                       Color="@(LoadStatus.MemoryUsagePercent > 80 ? Color.Error :
                                                                LoadStatus.MemoryUsagePercent > 60 ? Color.Warning : Color.Success)"
                                                       Size="Size.Small" Style="flex:1; margin:0 12px;" />
                                    <MudText Typo="Typo.body2" Style="width:50px; text-align:right;">
                                        @($"{LoadStatus.MemoryUsagePercent:F1}%")
                                    </MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2" Style="margin-left: 120px;">
                                    已用 @($"{LoadStatus.MemoryUsedMB} MB") / 共 @($"{LoadStatus.MemoryTotalMB} MB")
                                </MudText>

                                @* 磁盘使用情况 *@
                                @if (LoadStatus.Disks != null && LoadStatus.Disks.Count > 0)
                                {
                                    <MudDivider />
                                    <MudText Typo="Typo.subtitle2">磁盘</MudText>
                                    foreach (var disk in LoadStatus.Disks)
                                    {
                                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2" Style="width:120px;">
                                                @disk.Name (@disk.Label)
                                            </MudText>
                                            <MudProgressLinear Value="@disk.UsagePercent"
                                                               Color="@(disk.UsagePercent > 80 ? Color.Error :
                                                                        disk.UsagePercent > 60 ? Color.Warning : Color.Success)"
                                                               Size="Size.Small" Style="flex:1; margin:0 12px;" />
                                            <MudText Typo="Typo.body2" Style="width:50px; text-align:right;">
                                                @($"{disk.UsagePercent:F0}%")
                                            </MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="margin-left: 120px;">
                                            已用 @($"{disk.UsedGB:F1} GB") / 共 @($"{disk.TotalGB:F1} GB") / 剩余 @($"{disk.FreeGB:F1} GB")
                                        </MudText>
                                    }
                                }

                                @* 更新时间 *@
                                <MudDivider />
                                <MudText Typo="Typo.body2" Align="Align.Right">
                                    数据采集时间: @LoadStatus.Timestamp
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    }
                    else
                    {
                        <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Small" />
                    }
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="RefreshData" StartIcon="@Icons.Material.Filled.Refresh" Color="Color.Secondary">刷新</MudButton>
        <MudButton OnClick="Close">关闭</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public Station? Station { get; set; }

    private List<Tool> ConfigToolList { get; set; } = new();
    private bool Loading = true;
    private string? LoadError = null;
    private string? ToolError = null;

    private StationLoadStatus? LoadStatus { get; set; }

    public class StationLoadStatus
    {
        public double CpuUsagePercent { get; set; }
        public long MemoryTotalMB { get; set; }
        public long MemoryUsedMB { get; set; }
        public double MemoryUsagePercent { get; set; }
        public List<DiskInfo> Disks { get; set; } = new();
        public string Timestamp { get; set; } = "";
    }

    public class DiskInfo
    {
        public string Name { get; set; } = "";
        public string Label { get; set; } = "";
        public double TotalGB { get; set; }
        public double UsedGB { get; set; }
        public double FreeGB { get; set; }
        public double UsagePercent { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        Loading = true;
        LoadError = null;

        try
        {
            await Task.WhenAll(
                LoadStationConfigs(),
                LoadStationLoadStatus()
            );
        }
        catch (Exception ex)
        {
            Snackbar.Add($"加载图站详情失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            Loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadStationConfigs()
    {
        try
        {
            if (Station == null || string.IsNullOrEmpty(Station.StationIp)) return;

            var baseUrl = Station.StationIp.TrimEnd('/');
            var toolsUrl = $"{baseUrl}/api/station/tools";
            using var httpClient = new HttpClient { Timeout = TimeSpan.FromSeconds(8) };
            var response = await httpClient.GetAsync(toolsUrl);

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var tools = JsonSerializer.Deserialize<List<Tool>>(json, options);
                if (tools != null)
                    ConfigToolList = tools;
            }
            else
            {
                ToolError = $"无法获取工具列表 (HTTP {(int)response.StatusCode})";
            }
        }
        catch (TaskCanceledException)
        {
            ToolError = "工具列表请求超时（图站可能离线或网络不可达）";
        }
        catch (HttpRequestException)
        {
            ToolError = "图站不可达，请检查网络连接";
        }
        catch (Exception ex)
        {
            ToolError = $"获取工具列表失败: {ex.Message}";
        }
    }

    private async Task LoadStationLoadStatus()
    {
        try
        {
            if (Station == null || string.IsNullOrEmpty(Station.StationIp)) return;

            // Station.StationIp 已经是完整 URL（如 http://192.168.1.100:7660），直接拼接路径即可
            var baseUrl = Station.StationIp.TrimEnd('/');
            var stationUrl = $"{baseUrl}/api/station/load-status";
            using var httpClient = new HttpClient { Timeout = TimeSpan.FromSeconds(8) };
            var response = await httpClient.GetAsync(stationUrl);

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                LoadStatus = JsonSerializer.Deserialize<StationLoadStatus>(json, options);
            }
            else
            {
                LoadError = $"无法获取负载状态 (HTTP {response.StatusCode})";
            }
        }
        catch (TaskCanceledException)
        {
            LoadError = "图站连接超时（可能离线或网络不可达）";
        }
        catch (HttpRequestException)
        {
            LoadError = "图站不可达，请检查网络连接";
        }
        catch (Exception ex)
        {
            LoadError = $"获取负载状态失败: {ex.Message}";
        }
    }

    private async Task RefreshData()
    {
        ConfigToolList.Clear();
        LoadStatus = null;
        LoadError = null;
        ToolError = null;
        await LoadData();
    }

    private void Close() => MudDialog.Close();

    private static Color GetStatusColor(string? status) => status switch
    {
        "已就绪" => Color.Success,
        "已安装" => Color.Success,
        "未安装" => Color.Warning,
        "未找到" => Color.Error,
        _ => Color.Default
    };
}
