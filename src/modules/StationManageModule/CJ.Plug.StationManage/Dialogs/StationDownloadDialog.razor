@using MudBlazor
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<MudDialog DisableBackdropClick="true">
    <DialogContent>
        <MudStack Spacing="3">
            @* 平台选择 *@
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">选择平台</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudRadioGroup T="string" @bind-SelectedOption="_selectedPlatform">
                        <MudRadio T="string" Option="@("win-x64")" Color="Color.Primary">
                            <MudText>Windows x64</MudText>
                            <MudText Typo="Typo.caption">适用于Windows 64位系统</MudText>
                        </MudRadio>
                        <MudRadio T="string" Option="@("linux-x64")" Color="Color.Primary">
                            <MudText>Linux x64</MudText>
                            <MudText Typo="Typo.caption">适用于Linux 64位系统</MudText>
                        </MudRadio>
                        <MudRadio T="string" Option="@("osx-x64")" Color="Color.Primary">
                            <MudText>macOS x64</MudText>
                            <MudText Typo="Typo.caption">适用于macOS Intel处理器</MudText>
                        </MudRadio>
                        <MudRadio T="string" Option="@("win-arm64")" Color="Color.Primary">
                            <MudText>Windows ARM64</MudText>
                            <MudText Typo="Typo.caption">适用于Windows ARM64系统</MudText>
                        </MudRadio>
                        <MudRadio T="string" Option="@("linux-arm64")" Color="Color.Primary">
                            <MudText>Linux ARM64</MudText>
                            <MudText Typo="Typo.caption">适用于Linux ARM64系统</MudText>
                        </MudRadio>
                        <MudRadio T="string" Option="@("osx-arm64")" Color="Color.Primary">
                            <MudText>macOS ARM64</MudText>
                            <MudText Typo="Typo.caption">适用于macOS Apple Silicon处理器</MudText>
                        </MudRadio>
                    </MudRadioGroup>
                </MudCardContent>
            </MudCard>

            @* 下载按钮 *@
            <MudCard>
                <MudCardContent>
                    <div class="d-flex align-center flex-wrap">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Secondary"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick="StartStationDownloadAsync"
                                   Disabled="_isStationDownloading">
                            @if (_isStationDownloading)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                <MudText Class="ms-2">正在生成图站部署包并下载...</MudText>
                            }
                            else
                            {
                                <MudText>下载图站部署包</MudText>
                            }
                        </MudButton>

                        <MudText Typo="Typo.caption" Class="ml-4">
                            文件大小约 50-100 MB，生成时间约 1-2 分钟
                        </MudText>
                    </div>
                </MudCardContent>
            </MudCard>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelAsync">关闭</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    private string _selectedPlatform = "win-x64";
    private bool _isStationDownloading = false;

    /// <summary>
    /// 浏览器原生下载：导航到 GET 端点，由服务端返回 Content-Disposition: attachment 触发下载
    /// NavigateTo(forceLoad: false) 不会卸载当前组件，loading 状态会持续显示在页面上
    /// </summary>
    private async Task StartStationDownloadAsync()
    {
        _isStationDownloading = true;

        var apiBaseUrl = $"http://{new Uri(NavigationManager.Uri).Host}:8687";
        var downloadUrl = $"{apiBaseUrl}/api/package/download-station-direct?platform={_selectedPlatform}";

        // 延迟让 Blazor 先渲染 loading UI，再触发下载
        await Task.Delay(100);
        NavigationManager.NavigateTo(downloadUrl, false);
    }

    private void CancelAsync()
    {
        MudDialog.Close();
    }
}
