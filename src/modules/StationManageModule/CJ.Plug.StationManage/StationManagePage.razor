@page "/StationManage"
<PageTitle>图站管理</PageTitle>

@using CJ.Plug.Models.Station
@using CJ.Plug.StationManage.Pages
@using CJ.Plug.StationManageApiClient
@using Microsoft.AspNetCore.SignalR.Client

@inject HubConnectionManagerService HubConnectionManagerService
@inject IStationManageApiClient StationManageApiClient

<StationStatusList AllStations="AllStations" OnlineStations="OnlineStations"
                   OnGetStationStatus="GetStationStatus"
                   OnSelectedStationChanged="OnSelectedStationChanged">
</StationStatusList>

@code {
    public List<Station>? AllStations { get; set; } = new();
    public List<Station>? OnlineStations { get; set; } = new();

    /// <summary>
    /// 用户手动选择的图站 IP，为空时自动分配
    /// </summary>
    public string? SelectedStationIp { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            HubConnectionManagerService._hubConnection.On<string, string, string>("StatusInfo", (ip, status, toolsRootPath) =>
              {
                  InvokeAsync(async () =>
                  {
                      Console.WriteLine(ip);
                      Console.WriteLine(toolsRootPath);
                      await ProcessStationList(ip, toolsRootPath);
                      StateHasChanged();
                  });
              });
            await GetStationStatus();
        }
    }

    private void OnSelectedStationChanged(string? stationIp)
    {
        SelectedStationIp = stationIp;
        StateHasChanged();
    }

    private async Task ProcessStationList(string ip, string toolsRootPath)
    {
        // 在现有列表中查找匹配的图站并更新状态
        // 注意：不能重新从 DB 拉取覆盖 AllStations，否则之前已标记为在线的其他图站 IsStarted 会被重置为 false
        var existingStation = AllStations?.FirstOrDefault(s => s.StationIp == ip);
        if (existingStation != null)
        {
            existingStation.IsStarted = true;
            existingStation.StationBasePath = toolsRootPath;
        }
        else
        {
            // 新上线的图站（AllStations 中尚不存在），从 DB 刷新列表获取新条目
            var latestStations = await StationManageApiClient.GetAllStationsAsync();
            if (latestStations != null && latestStations.Count > 0)
            {
                // 保留已有在线状态的图站：遍历新的 DB 列表，对已在线的不重置
                foreach (var station in latestStations)
                {
                    var alreadyOnline = AllStations?.FirstOrDefault(s => s.StationIp == station.StationIp);
                    if (alreadyOnline != null)
                    {
                        // 保留已在线图站的状态，仅更新 StationBasePath
                        if (!string.IsNullOrEmpty(station.StationBasePath))
                            alreadyOnline.StationBasePath = station.StationBasePath;
                    }
                    else
                    {
                        // DB 中新增的图站
                        station.IsStarted = false;
                        AllStations?.Add(station);
                    }
                }
            }
            existingStation = AllStations?.FirstOrDefault(s => s.StationIp == ip);
            if (existingStation != null)
            {
                existingStation.IsStarted = true;
                existingStation.StationBasePath = toolsRootPath;
            }
        }

        // 按 StationIp 去重，避免重复添加
        OnlineStations = OnlineStations
            .GroupBy(s => s.StationIp)
            .Select(g => g.First())
            .ToList();

        // 将该 IP 添加到在线列表（如果尚未存在）
        if (existingStation != null && !OnlineStations.Any(s => s.StationIp == ip))
        {
            OnlineStations.Add(existingStation);
        }
    }

    private async Task GetStationStatus()
    {
        AllStations = await StationManageApiClient.GetAllStationsAsync() ?? new List<Station>();
        OnlineStations.Clear();
        await HubConnectionManagerService.ConnectAsync();
        await HubConnectionManagerService.InvokeAsync<string>("TellMeStatus", null);
    }
}
