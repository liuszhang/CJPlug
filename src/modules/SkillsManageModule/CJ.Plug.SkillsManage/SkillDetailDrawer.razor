@using CJ.Plug.Models.Skills
@using CJ.Plug.Models.Shared
@using CJ.Plug.SkillApiClient
@using MudBlazor
@using CJ.Plug.SharedPages.SharedComponents
@using CJ.Plug.SharedPages.Services
@using Microsoft.AspNetCore.Components.Forms

@inject ISnackbar Snackbar

<MudDrawer @bind-Open="IsOpen"
           Anchor="Anchor.Right"
           Variant="DrawerVariant.Temporary"
           OverlayAutoClose="true"
           Width="650px">
    <MudContainer>
        <div class="d-flex align-center justify-space-between mt-4 mb-2">
            <MudText Typo="Typo.h5">@(Skill?.DisplayName ?? Skill?.Name)</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           OnClick="CloseDrawer"
                           Size="Size.Small"
                           Color="Color.Default" />
        </div>

        @if (Skill is not null)
        {
            <MudChip T="string"
                     Color="@(Skill.IsEnabled ? Color.Success : Color.Error)"
                     Variant="Variant.Filled"
                     Size="Size.Small"
                     Class="mb-4">
                @(Skill.IsEnabled ? "已启用" : "已禁用")
            </MudChip>
        }

        <MudTabs @bind-ActivePanelIndex="_activeTabIndex" Class="mt-2">
            <MudTabPanel Text="技能描述">
                @if (Skill is not null)
                {
                    <div class="markdown-body" style="max-height: calc(100vh - 280px); overflow-y: auto; padding-right: 8px;">
                        @if (_readmeLoading)
                        {
                            <div class="d-flex justify-center pa-8">
                                <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                            </div>
                        }
                        else if (_readmeContent is not null)
                        {
                            @RenderMarkdown(_readmeContent)
                        }
                        else
                        {
                            <MudPaper Elevation="0" Class="pa-8" Style="background-color: var(--mud-palette-background-grey);">
                                <MudStack Spacing="3" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Default" />
                                    <MudText Typo="Typo.body2" Class="text-muted">
                                        尚未创建技能描述文件 (@($"{Skill.Name}.md"))
                                    </MudText>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.Add"
                                               OnClick="CreateReadme"
                                               Disabled="_readmeCreating">
                                        @if (_readmeCreating)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                            @:创建中...
                                        }
                                        else
                                        {
                                            @:创建描述文件
                                        }
                                    </MudButton>
                                </MudStack>
                            </MudPaper>
                        }
                    </div>
                }
            </MudTabPanel>
            <MudTabPanel Text="文件列表">
                @if (Skill is not null)
                {
                    <div class="skill-file-list" style="max-height: calc(100vh - 280px); overflow-y: auto; padding-right: 8px;">
                        @if (_fileNodes.Any())
                        {
                            <div class="d-flex align-center justify-space-between mb-3">
                                <MudText Typo="Typo.subtitle2" Class="text-muted">
                                    共 @_fileNodes.Count 个文件
                                </MudText>
                                <div class="d-flex align-center gap-2">
                                    @if (_uploading)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                        <MudText Typo="Typo.caption" Class="text-muted">上传中...</MudText>
                                    }
                                    else
                                    {
                                        <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                                                       Multiple="true"
                                                       FilesChanged="HandleMudFileUpload"
                                                       Accept="*/*"
                                                       MaxFileSize="512000000">
                                            <CustomContent>
                                                <MudButton Variant="Variant.Outlined"
                                                           OnClick="@context.OpenFilePickerAsync"
                                                           Color="Color.Primary"
                                                           Size="Size.Small"
                                                           StartIcon="@Icons.Material.Filled.Upload">
                                                    上传文件
                                                </MudButton>
                                            </CustomContent>
                                            <SelectedTemplate></SelectedTemplate>
                                        </MudFileUpload>
                                        <FolderUploader ButtonText="上传文件夹"
                                                       OnFilesSelected="HandleFolderUpload"
                                                       Disabled="@(Skill == null)"
                                                       ShowFileList="false"
                                                       @ref="_folderUploader" />
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Archive"
                                                   OnClick="DownloadAllFiles">
                                            打包下载
                                        </MudButton>
                                    }
                                </div>
                            </div>

                            <FileTree Items="@_fileNodes"
                                      ShowDownloadButton="true"
                                      ShowDeleteButton="true"
                                      Class="mb-2" />
                        }
                        else
                        {
                            <MudPaper Elevation="0" Class="pa-4" Style="background-color: var(--mud-palette-background-grey);">
                                <MudStack Spacing="2">
                                    <div class="d-flex justify-center mb-2">
                                        <MudIcon Icon="@Icons.Material.Filled.FolderOff" Size="Size.Large" Color="Color.Error" />
                                    </div>
                                    <MudText Typo="Typo.body2" Class="text-muted text-center">
                                        暂无关联文件
                                    </MudText>
                                    <MudText Typo="Typo.caption" Class="text-muted text-center">
                                        上传文件或文件夹到该 Skill
                                    </MudText>
                                    <div class="d-flex justify-center gap-2 mt-2">
                                        @if (_uploading)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                            <MudText Typo="Typo.caption" Class="text-muted">上传中...</MudText>
                                        }
                                        else
                                        {
                                            <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                                                           Multiple="true"
                                                           FilesChanged="HandleMudFileUpload"
                                                           Accept="*/*"
                                                           MaxFileSize="512000000">
                                                <CustomContent>
                                                    <MudButton Variant="Variant.Outlined"
                                                               Color="Color.Primary"
                                                               Size="Size.Small"
                                                               StartIcon="@Icons.Material.Filled.Upload">
                                                        上传文件
                                                    </MudButton>
                                                </CustomContent>
                                                <SelectedTemplate></SelectedTemplate>
                                            </MudFileUpload>
                                            <FolderUploader ButtonText="上传文件夹"
                                                           OnFilesSelected="HandleFolderUpload"
                                                           Disabled="@(Skill == null)"
                                                           ShowFileList="false"
                                                           @ref="_folderUploader" />
                                        }
                                    </div>
                                </MudStack>
                            </MudPaper>
                        }
                    </div>
                }
            </MudTabPanel>
        </MudTabs>
    </MudContainer>
</MudDrawer>

@code {
    [Parameter] public Skill? Skill { get; set; }
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public ISkillApiClient SkillApiClient { get; set; } = default!;
    [Parameter] public FileDownloadService FileDownloadService { get; set; } = default!;

    private int _activeTabIndex;
    private List<FileSystemNode> _fileNodes = new();
    private FolderUploader? _folderUploader;
    private bool _filesLoaded;
    private int? _lastSkillId;

    // ===== 技能描述 =====
    private string? _readmeContent;
    private bool _readmeLoaded;
    private bool _readmeLoading;
    private bool _readmeCreating;

    // ===== 上传状态 =====
    private bool _uploading;

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && Skill is not null)
        {
            // 如果 Skill 变化了，重置加载状态
            if (_lastSkillId != Skill.Id)
            {
                _filesLoaded = false;
                _readmeLoaded = false;
                _lastSkillId = Skill.Id;
            }

            if (!_filesLoaded)
            {
                _filesLoaded = true;
                _activeTabIndex = 0;
                _fileNodes = await LoadFileNodesAsync(Skill);
            }

            if (!_readmeLoaded)
            {
                _readmeLoaded = true;
                _ = LoadReadmeAsync(Skill);
            }
        }
        else if (!IsOpen)
        {
            _filesLoaded = false;
            _readmeLoaded = false;
            _lastSkillId = null;
            _fileNodes.Clear();
            _readmeContent = null;
        }
    }

    private async Task CloseDrawer()
    {
        await IsOpenChanged.InvokeAsync(false);
    }

    // ===== 技能描述文件操作 =====

    private async Task LoadReadmeAsync(Skill skill)
    {
        try
        {
            _readmeLoading = true;
            StateHasChanged();
            _readmeContent = await SkillApiClient.GetSkillReadmeAsync(skill.Id);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"加载描述文件失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _readmeLoading = false;
            StateHasChanged();
        }
    }

    private async Task CreateReadme()
    {
        if (Skill == null) return;
        try
        {
            _readmeCreating = true;
            StateHasChanged();
            _readmeContent = await SkillApiClient.CreateSkillReadmeAsync(Skill.Id, DefaultReadmeContent);
            if (_readmeContent != null)
                Snackbar.Add("描述文件创建成功", Severity.Success);
            else
                Snackbar.Add("描述文件创建失败", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"创建描述文件失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _readmeCreating = false;
            StateHasChanged();
        }
    }

