    // ===== 文件操作 =====

    private async Task<List<FileSystemNode>> LoadFileNodesAsync(Skill skill)
    {
        try
        {
            // 使用 Skills 自己的文件列表 API（路径基于 MainFileServerPathRoot）
            var skillFiles = await SkillApiClient.GetSkillFilesAsync(skill.Id);

            if (skillFiles == null || skillFiles.Count == 0)
                return new List<FileSystemNode>();

            // 将 SkillFileInfo 列表转换为 FileSystemNode 树结构
            var rootNodes = BuildFileTreeFromSkillFiles(skill.Id, skillFiles);

            // 为每个文件节点设置 GetStreamAsync 和 DeletePath
            SetupFileNodeCallbacks(rootNodes);

            return rootNodes;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"加载文件列表失败: {ex.Message}", Severity.Error);
            return new();
        }
    }

    /// <summary>
    /// 将 SkillFileInfo 平面列表转换为 FileSystemNode 树结构
    /// </summary>
    private List<FileSystemNode> BuildFileTreeFromSkillFiles(int skillId, List<SkillFileInfo> skillFiles)
    {
        var rootNodes = new List<FileSystemNode>();
        var directoryMap = new Dictionary<string, FileSystemNode>(StringComparer.OrdinalIgnoreCase);

        foreach (var fileInfo in skillFiles)
        {
            var relativePath = fileInfo.FilePath ?? fileInfo.FileName;
            var parts = relativePath.Replace('\\', '/').Split('/');
            var skillBasePath = $"Skills/{skillId}";

            if (parts.Length == 1)
            {
                // 根级文件
                var fullPath = $"{skillBasePath}/{fileInfo.FileName}";
                var node = new FileSystemNode(fullPath, fileInfo.FileName, false)
                {
                    FullPath = fullPath,
                    Name = fileInfo.FileName,
                    IsDirectory = false,
                    Size = fileInfo.FileSize,
                    FileType = fileInfo.FileType,
                    LastWriteTime = fileInfo.ModifiedTime
                };
                rootNodes.Add(node);
            }
            else
            {
                // 有子目录的文件，逐级创建目录节点
                var currentPath = skillBasePath;
                FileSystemNode? parentDir = null;

                for (int i = 0; i < parts.Length - 1; i++)
                {
                    currentPath = $"{currentPath}/{parts[i]}";
                    if (!directoryMap.TryGetValue(currentPath, out var dirNode))
                    {
                        dirNode = new FileSystemNode(currentPath, parts[i], true)
                        {
                            FullPath = currentPath,
                            Name = parts[i],
                            IsDirectory = true
                        };
                        directoryMap[currentPath] = dirNode;

                        if (parentDir == null)
                            rootNodes.Add(dirNode);
                        else
                            parentDir.Children!.Add(dirNode);
                    }
                    parentDir = dirNode;
                }

                // 添加文件节点
                var fileFullPath = $"{currentPath}/{parts[^1]}";
                var fileNode = new FileSystemNode(fileFullPath, parts[^1], false)
                {
                    FullPath = fileFullPath,
                    Name = parts[^1],
                    IsDirectory = false,
                    Size = fileInfo.FileSize,
                    FileType = fileInfo.FileType,
                    LastWriteTime = fileInfo.ModifiedTime
                };
                parentDir?.Children!.Add(fileNode);
            }
        }

        return rootNodes;
    }

    private async Task DownloadAllFiles()
    {
        if (!_fileNodes.Any()) { Snackbar.Add("没有可下载的文件。", Severity.Warning); return; }
        if (Skill == null) return;
        try
        {
            var stream = await SkillApiClient.DownloadSkillFilesArchiveAsync(Skill.Id);
            if (stream == null) { Snackbar.Add("打包下载失败", Severity.Error); return; }
            var zipFileName = $"{Skill.Name}_files.zip";
            await FileDownloadService.DownloadFileFromStreamAsync(zipFileName, stream);
            Snackbar.Add($"打包下载成功，共 {_fileNodes.Count} 个文件", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"打包下载失败: {ex.Message}", Severity.Error); }
    }

    // ===== 递归设置文件节点回调 =====
    private void SetupFileNodeCallbacks(List<FileSystemNode> nodes)
    {
        var skillBasePrefix = $"Skills/{Skill?.Id}/";
        foreach (var node in nodes)
        {
            if (!node.IsDirectory)
            {
                var fullPath = node.FullPath;
                // 从 FullPath 中提取相对于 Skill 目录的文件名（用于 Skills 专用 API）
                var relativeFileName = fullPath?.StartsWith(skillBasePrefix) == true
                    ? fullPath.Substring(skillBasePrefix.Length)
                    : fullPath;
                node.GetStreamAsync = async () =>
                {
                    try
                    {
                        return await SkillApiClient.DownloadSkillFileAsync(Skill!.Id, relativeFileName!);
                    }
                    catch (Exception ex)
                    {
                        Snackbar.Add($"获取文件流失败: {ex.Message}", Severity.Error);
                        return null;
                    }
                };
                // 使用 DeleteAsync 委托调用 Skills 专用删除 API（而非 DeletePath 走 FileManage 模块）
                node.DeleteAsync = async () =>
                {
                    try
                    {
                        return await SkillApiClient.DeleteSkillFileAsync(Skill!.Id, relativeFileName!);
                    }
                    catch (Exception ex)
                    {
                        Snackbar.Add($"删除文件失败: {ex.Message}", Severity.Error);
                        return false;
                    }
                };
            }
            else
            {
                // 文件夹节点：支持打包下载和递归删除
                var fullPath = node.FullPath;
                var relativeFolderPath = fullPath?.StartsWith(skillBasePrefix) == true
                    ? fullPath.Substring(skillBasePrefix.Length)
                    : fullPath;
                node.GetStreamAsync = async () =>
                {
                    try
                    {
                        return await SkillApiClient.DownloadSkillFolderArchiveAsync(Skill!.Id, relativeFolderPath!);
                    }
                    catch (Exception ex)
                    {
                        Snackbar.Add($"打包下载文件夹失败: {ex.Message}", Severity.Error);
                        return null;
                    }
                };
                node.DeleteAsync = async () =>
                {
                    try
                    {
                        return await SkillApiClient.DeleteSkillFolderAsync(Skill!.Id, relativeFolderPath!);
                    }
                    catch (Exception ex)
                    {
                        Snackbar.Add($"删除文件夹失败: {ex.Message}", Severity.Error);
                        return false;
                    }
                };

                if (node.Children?.Any() == true)
                {
                    SetupFileNodeCallbacks(node.Children);
                }
            }
        }
    }

    // ===== 文件上传 =====

    private async Task HandleMudFileUpload(IReadOnlyList<IBrowserFile> files)
    {
        if (Skill == null || files.Count == 0 || _uploading) return;
        _uploading = true;
        StateHasChanged();
        try
        {
            await UploadFilesInternal(files.ToList());
        }
        finally
        {
            _uploading = false;
            StateHasChanged();
        }
    }

    private async Task HandleFolderUpload(List<FolderUploader.FolderFileEntry> entries)
    {
        if (Skill == null || entries.Count == 0 || _uploading) return;
        _uploading = true;
        StateHasChanged();
        try
        {
            await UploadFolderFilesInternal(entries);
            if (_folderUploader != null)
                await _folderUploader.ClearSelectionAsync();
        }
        finally
        {
            _uploading = false;
            StateHasChanged();
        }
    }

    private async Task UploadFolderFilesInternal(List<FolderUploader.FolderFileEntry> entries)
    {
        if (Skill == null) return;
        var fileItems = new List<(Stream Stream, string FileName, string? RelativePath)>();
        var streamsToDispose = new List<Stream>();
        try
        {
            if (_folderUploader == null)
            {
                Snackbar.Add("文件夹上传组件未初始化，请重新选择文件夹", Severity.Error);
                return;
            }
            foreach (var entry in entries)
            {
                try
                {
                    var bytes = await _folderUploader.GetFileBytesAsync(entry.RelativePath);
                    if (bytes != null && bytes.Length > 0)
                    {
                        var stream = new MemoryStream(bytes);
                        streamsToDispose.Add(stream);
                        // 保留相对路径信息
                        fileItems.Add((stream, entry.FileName, entry.RelativePath));
                    }
                    else { Snackbar.Add($"文件 '{entry.FileName}' 读取失败，请重新选择", Severity.Warning); }
                }
                catch (Exception ex) { Snackbar.Add($"读取 '{entry.FileName}' 失败: {ex.Message}", Severity.Warning); }
            }
            if (fileItems.Count == 0) { Snackbar.Add("没有可上传的文件", Severity.Warning); return; }
            await UploadSkillFilesWithPathsAsync(Skill.Id, fileItems);
            Snackbar.Add($"成功上传 {fileItems.Count} 个文件", Severity.Success);
            _fileNodes = await LoadFileNodesAsync(Skill);
            StateHasChanged();
        }
        catch (Exception ex) { Snackbar.Add($"上传失败: {ex.Message}", Severity.Error); }
        finally { foreach (var s in streamsToDispose) await s.DisposeAsync(); }
    }

    private async Task UploadFilesInternal(List<IBrowserFile> files)
    {
        if (Skill == null) return;
        var fileItems = new List<(Stream Stream, string FileName, string? RelativePath)>();
        var streamsToDispose = new List<Stream>();
        try
        {
            foreach (var file in files)
            {
                var stream = file.OpenReadStream(maxAllowedSize: 512000000);
                streamsToDispose.Add(stream);
                fileItems.Add((stream, file.Name, null)); // 单个文件没有相对路径
            }
            await UploadSkillFilesWithPathsAsync(Skill.Id, fileItems);
            Snackbar.Add($"成功上传 {files.Count} 个文件", Severity.Success);
            _fileNodes = await LoadFileNodesAsync(Skill);
            StateHasChanged();
        }
        catch (Exception ex) { Snackbar.Add($"上传失败: {ex.Message}", Severity.Error); }
        finally { foreach (var s in streamsToDispose) await s.DisposeAsync(); }
    }

    private async Task UploadSkillFilesWithPathsAsync(int skillId, List<(Stream Stream, string FileName, string? RelativePath)> fileItems)
    {
        await SkillApiClient.UploadSkillFilesWithPathsAsync(skillId, fileItems);
    }

    // ===== Markdown 渲染 =====

    private MarkupString RenderMarkdown(string? markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown))
            return new MarkupString("<span class='text-muted'>暂无内容</span>");
        var html = ConvertMarkdownToHtml(markdown);
        return new MarkupString(html);
    }

    private string ConvertMarkdownToHtml(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown)) return string.Empty;
        var lines = markdown.Split('\n');
        var result = new System.Text.StringBuilder();
        bool inCodeBlock = false;
        var codeBlockLang = string.Empty;
        var codeBlockContent = new System.Text.StringBuilder();
        bool inList = false;

        for (int i = 0; i < lines.Length; i++)
        {
            var line = lines[i].TrimEnd('\r');
            if (line.TrimStart().StartsWith("```"))
            {
                if (!inCodeBlock) {
                    if (inList) { result.AppendLine("</ul>"); inList = false; }
                    inCodeBlock = true;
                    codeBlockLang = line.TrimStart().Substring(3).Trim();
                    codeBlockContent.Clear();
                    continue;
                }
                else {
                    inCodeBlock = false;
                    var langAttr = string.IsNullOrEmpty(codeBlockLang) ? "" : $" class=\"language-{EscapeHtml(codeBlockLang)}\"";
                    result.AppendLine($"<pre><code{langAttr}>{EscapeHtml(codeBlockContent.ToString().TrimEnd())}</code></pre>");
                    continue;
                }
            }
            if (inCodeBlock) { codeBlockContent.AppendLine(line); continue; }
            if (string.IsNullOrWhiteSpace(line)) { if (inList) { result.AppendLine("</ul>"); inList = false; } continue; }

            var trimmed = line.TrimStart();
            if (trimmed == "---" || trimmed == "***" || trimmed == "___") { if (inList) { result.AppendLine("</ul>"); inList = false; } result.AppendLine("<hr />"); continue; }
            if (trimmed.StartsWith("# ") || trimmed.StartsWith("## ") || trimmed.StartsWith("### ") || trimmed.StartsWith("#### "))
            {
                if (inList) { result.AppendLine("</ul>"); inList = false; }
                int level = 1;
                var content = trimmed;
                while (content.StartsWith("#")) { content = content.Substring(1); level++; }
                content = content.Trim();
                if (level > 4) level = 4;
                if (level == 1) level = 1;
                result.AppendLine($"<h{Math.Min(level, 4)}>{ProcessInlineMarkdown(content)}</h{Math.Min(level, 4)}>");
                continue;
            }
            if ((trimmed.StartsWith("- ") || trimmed.StartsWith("* ")) && !trimmed.StartsWith("**")) {
                if (!inList) { result.AppendLine("<ul>"); inList = true; }
                result.AppendLine($"<li>{ProcessInlineMarkdown(trimmed.Substring(2).Trim())}</li>");
                continue;
            }
            var olMatch = System.Text.RegularExpressions.Regex.Match(trimmed, @"^(\d+)\.\s+(.*)");
            if (olMatch.Success) {
                if (!inList) { result.AppendLine("<ul>"); inList = true; }
                result.AppendLine($"<li>{ProcessInlineMarkdown(olMatch.Groups[2].Value)}</li>");
                continue;
            }
            if (inList) { result.AppendLine("</ul>"); inList = false; }
            if (trimmed.StartsWith("> ")) {
                result.AppendLine($"<blockquote style=\"margin:8px 0;padding:8px 16px;border-left:3px solid var(--mud-palette-primary);background:var(--mud-palette-background-grey);\">{ProcessInlineMarkdown(trimmed.Substring(2).Trim())}</blockquote>");
                continue;
            }
            result.AppendLine($"<p style=\"margin:4px 0;\">{ProcessInlineMarkdown(trimmed)}</p>");
        }
        if (inCodeBlock) {
            var langAttr = string.IsNullOrEmpty(codeBlockLang) ? "" : $" class=\"language-{EscapeHtml(codeBlockLang)}\"";
            result.AppendLine($"<pre><code{langAttr}>{EscapeHtml(codeBlockContent.ToString().TrimEnd())}</code></pre>");
        }
        if (inList) result.AppendLine("</ul>");
        return result.ToString();
    }

    private string ProcessInlineMarkdown(string text)
    {
        if (string.IsNullOrEmpty(text)) return string.Empty;
        text = EscapeHtml(text);
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"(?<!\*)\*(?!\*)(.+?)(?<!\*)\*(?!\*)", "<em>$1</em>");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"`([^`]+)`", "<code style=\"background:var(--mud-palette-background-grey);padding:1px 4px;border-radius:3px;font-family:monospace;font-size:0.9em;\">$1</code>");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\[([^\]]+)\]\(([^)]+)\)", "<a href=\"$2\" target=\"_blank\" style=\"color:var(--mud-palette-primary);\">$1</a>");
        return text;
    }

    private string EscapeHtml(string text)
    {
        return text.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;").Replace("\"", "&quot;");
    }
}
