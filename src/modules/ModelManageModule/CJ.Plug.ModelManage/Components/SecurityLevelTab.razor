@using CJ.Plug.ModelManageModel.Models
@using CJ.Plug.ModelManageApiClient
@using CJ.Plug.ModelManage.Dialogs
@using MudBlazor

@inject IOntologyManageApiClient ApiClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudPaper Elevation="0" Class="pa-3" Style="min-height: 300px;">
    @if (isLoading)
    {
        <MudProgressLinear Indeterminate="true" Class="mb-3" />
    }

    @if (dataLevelEnum == null && personnelLevelEnum == null && !isLoading)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-3">暂未配置密级枚举，请先运行种子数据初始化。</MudAlert>
    }
    else
    {
        <MudGrid>
            @* 左栏：数据密级 *@
            <MudItem xs="12" md="6">
                @if (dataLevelEnum == null)
                {
                    <MudAlert Severity="Severity.Warning">暂未配置数据密级枚举</MudAlert>
                }
                else
                {
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                        <MudText Typo="Typo.h6">数据密级</MudText>
                        <MudSpacer />
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenDataLevelAddDialog">新增数据密级</MudButton>
                    </MudStack>
                    <MudDataGrid Items="@(dataLevelEnum.Items ?? new())" T="BasicEnumItem" Dense="true" Hover="true" Elevation="0">
                        <Columns>
                            <PropertyColumn Property="x => x.SortOrder" Title="排序" />
                            <PropertyColumn Property="x => x.Code" Title="代码" />
                            <PropertyColumn Property="x => x.DisplayName" Title="显示名" />
                            <PropertyColumn Property="x => x.Description" Title="说明" />
                            <TemplateColumn Style="text-align:right">
                                <CellTemplate>
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                   OnClick="@(() => OpenDataLevelEditDialog(context.Item))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="@(() => DeleteDataLevelItemAsync(context.Item))" />
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <NoRecordsContent><MudText>暂无数据密级项</MudText></NoRecordsContent>
                    </MudDataGrid>
                }
            </MudItem>

            @* 右栏：人员密级 *@
            <MudItem xs="12" md="6">
                @if (personnelLevelEnum == null)
                {
                    <MudAlert Severity="Severity.Warning">暂未配置人员密级枚举</MudAlert>
                }
                else
                {
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                        <MudText Typo="Typo.h6">人员密级</MudText>
                        <MudSpacer />
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenPersonnelLevelAddDialog">新增人员密级</MudButton>
                    </MudStack>
                    <MudDataGrid Items="@(personnelLevelEnum.Items ?? new())" T="BasicEnumItem" Dense="true" Hover="true" Elevation="0">
                        <Columns>
                            <PropertyColumn Property="x => x.SortOrder" Title="排序" />
                            <PropertyColumn Property="x => x.Code" Title="代码" />
                            <PropertyColumn Property="x => x.DisplayName" Title="显示名" />
                            <PropertyColumn Property="x => x.Description" Title="说明" />
                            <TemplateColumn Style="text-align:right">
                                <CellTemplate>
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                   OnClick="@(() => OpenPersonnelLevelEditDialog(context.Item))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="@(() => DeletePersonnelLevelItemAsync(context.Item))" />
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <NoRecordsContent><MudText>暂无人员密级项</MudText></NoRecordsContent>
                    </MudDataGrid>
                }
            </MudItem>
        </MudGrid>
    }
</MudPaper>

@code {
    private BasicEnum? dataLevelEnum;
    private BasicEnum? personnelLevelEnum;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            var allEnums = await ApiClient.GetAllBasicEnumsAsync();
            var casted = allEnums.Where(e => e != null).Cast<BasicEnum>().ToList();
            dataLevelEnum = casted.FirstOrDefault(e => e.Code == "data_secret_level");
            personnelLevelEnum = casted.FirstOrDefault(e => e.Code == "personnel_secret_level");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SecurityLevelTab] 加载失败: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    // ======== 数据密级 ========
    private async Task OpenDataLevelAddDialog()
    {
        var parameters = new DialogParameters
        {
            ["EnumItem"] = new BasicEnumItem(),
            ["EnumId"] = dataLevelEnum?.Id ?? 0
        };
        var dialog = await DialogService.ShowAsync<DataSecurityEditDialog>("新增数据密级", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadData();
    }

    private async Task OpenDataLevelEditDialog(BasicEnumItem item)
    {
        var parameters = new DialogParameters
        {
            ["EnumItem"] = item,
            ["EnumId"] = dataLevelEnum?.Id ?? 0
        };
        var dialog = await DialogService.ShowAsync<DataSecurityEditDialog>($"编辑数据密级 — {item.DisplayName}", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadData();
    }

    private async Task DeleteDataLevelItemAsync(BasicEnumItem item)
    {
        bool? result = await DialogService.ShowMessageBoxAsync("确认删除",
            $"确定删除数据密级「{item.DisplayName}」吗？", yesText: "删除", cancelText: "取消");
        if (result == true)
        {
            await ApiClient.DeleteEnumItemAsync(item.Id);
            await LoadData();
        }
    }

    // ======== 人员密级 ========
    private async Task OpenPersonnelLevelAddDialog()
    {
        var parameters = new DialogParameters
        {
            ["EnumItem"] = new BasicEnumItem(),
            ["EnumId"] = personnelLevelEnum?.Id ?? 0,
            ["DataLevelEnumId"] = dataLevelEnum?.Id ?? 0
        };
        var dialog = await DialogService.ShowAsync<PersonnelSecurityEditDialog>("新增人员密级", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadData();
    }

    private async Task OpenPersonnelLevelEditDialog(BasicEnumItem item)
    {
        var parameters = new DialogParameters
        {
            ["EnumItem"] = item,
            ["EnumId"] = personnelLevelEnum?.Id ?? 0,
            ["DataLevelEnumId"] = dataLevelEnum?.Id ?? 0
        };
        var dialog = await DialogService.ShowAsync<PersonnelSecurityEditDialog>($"编辑人员密级 — {item.DisplayName}", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadData();
    }

    private async Task DeletePersonnelLevelItemAsync(BasicEnumItem item)
    {
        bool? result = await DialogService.ShowMessageBoxAsync("确认删除",
            $"确定删除人员密级「{item.DisplayName}」吗？\n（关联的访问权限映射将一并删除）", yesText: "删除", cancelText: "取消");
        if (result == true)
        {
            await ApiClient.DeleteSecurityLevelAccessAsync(item.Id);
            await ApiClient.DeleteEnumItemAsync(item.Id);
            await LoadData();
        }
    }
}
