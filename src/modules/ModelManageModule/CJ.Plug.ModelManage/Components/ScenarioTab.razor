@using CJ.Plug.ModelManageModel.Models
@using CJ.Plug.ModelManageApiClient
@using CJ.Plug.ModelManage.Dialogs
@using MudBlazor

@inject IOntologyManageApiClient ApiClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudPaper Elevation="1" Class="pa-3">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudText Typo="Typo.h6">场景列表</MudText>
        <MudSpacer />
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog">新增场景</MudButton>
    </MudStack>

    <MudDataGrid Items="@scenarios" T="Scenario" Dense="true" Hover="true" Elevation="0"
                 SelectedItem="@selectedScenario" SelectedItemChanged="@OnSelected">
        <Columns>
            <PropertyColumn Property="x => x.Name" Title="名称" />
            <PropertyColumn Property="x => x.Code" Title="代码" />
            <PropertyColumn Property="x => x.Description" Title="描述" />
            <TemplateColumn Title="状态">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.IsActive ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(context.Item.IsActive ? Color.Success : Color.Default)" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Style="text-align:right">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => EditScenario(context.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteScenario(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent><MudText>暂无场景</MudText></NoRecordsContent>
    </MudDataGrid>
</MudPaper>

@code {
    private List<Scenario> scenarios = new();
    private Scenario? selectedScenario;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        var result = await ApiClient.GetAllScenariosAsync();
        scenarios = result?.Where(s => s != null).Cast<Scenario>().ToList() ?? new();
        StateHasChanged();
    }

    private void OnSelected(Scenario? item) => selectedScenario = item;

    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters { ["Scenario"] = new Scenario() };
        var dialog = await DialogService.ShowAsync<ScenarioEditDialog>("新建场景", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
            await LoadData();
    }

    private async Task EditScenario(Scenario scenario)
    {
        var parameters = new DialogParameters { ["Scenario"] = scenario };
        var dialog = await DialogService.ShowAsync<ScenarioEditDialog>("编辑场景", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
            await LoadData();
    }

    private async Task DeleteScenario(Scenario scenario)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync("确认删除",
            $"确定删除场景「{scenario.Name}」吗？", yesText: "删除", cancelText: "取消");
        if (confirm == true)
        {
            var success = await ApiClient.DeleteScenarioAsync(scenario.Id);
            if (success) { Snackbar.Add("删除成功", Severity.Success); await LoadData(); }
            else Snackbar.Add("删除失败", Severity.Error);
        }
    }
}
