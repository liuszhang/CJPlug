@using CJ.Plug.ModelManageModel.Models
@using CJ.Plug.ModelManageApiClient
@using CJ.Plug.ModelManage.Dialogs
@using MudBlazor

@inject IOntologyManageApiClient ApiClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudPaper Elevation="1" Class="pa-3">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudText Typo="Typo.h6">外部系统列表</MudText>
        <MudSpacer />
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddSystemDialog">新增系统</MudButton>
    </MudStack>

    <MudDataGrid Items="@systems" T="ExternalSystem" Dense="true" Hover="true" Elevation="0"
                 SelectedItem="@selectedSystem" SelectedItemChanged="@OnSystemSelected">
        <Columns>
            <PropertyColumn Property="x => x.Name" Title="名称" />
            <PropertyColumn Property="x => x.Code" Title="代码" />
            <PropertyColumn Property="x => x.Description" Title="描述" />
            <PropertyColumn Property="x => x.BaseUrl" Title="BaseUrl" />
            <TemplateColumn Title="认证">
                <CellTemplate>
                    <MudChip Label="true" Size="Size.Small" Color="Color.Info">@context.Item.AuthType</MudChip>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Style="text-align:right">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => EditSystem(context.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteSystem(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent><MudText>暂无外部系统</MudText></NoRecordsContent>
    </MudDataGrid>

    @if (selectedSystem != null)
    {
        <MudDivider Class="my-3" />
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
            <MudText Typo="Typo.subtitle1">接口契约 — @selectedSystem.Name</MudText>
            <MudSpacer />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddContractDialog">新增接口</MudButton>
        </MudStack>

        <MudDataGrid Items="@contracts" T="InterfaceContract" Dense="true" Hover="true" Elevation="0">
            <Columns>
                <PropertyColumn Property="x => x.Name" Title="名称" />
                <PropertyColumn Property="x => x.Code" Title="代码" />
                <TemplateColumn Title="方法">
                    <CellTemplate>
                        <MudChip Label="true" Size="Size.Small" Color="Color.Success">@context.Item.Method</MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Endpoint" Title="端点" />
                <TemplateColumn Title="状态">
                    <CellTemplate>
                        <MudChip Label="true" Size="Size.Small"
                                  Color="@(context.Item.Status == "Active" ? Color.Success : context.Item.Status == "Deprecated" ? Color.Warning : Color.Default)">
                            @context.Item.Status
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Style="text-align:right">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => EditContract(context.Item))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteContract(context.Item))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <NoRecordsContent><MudText>暂无接口契约</MudText></NoRecordsContent>
        </MudDataGrid>
    }
</MudPaper>

@code {
    private List<ExternalSystem> systems = new();
    private List<InterfaceContract> contracts = new();
    private ExternalSystem? selectedSystem;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        var result = await ApiClient.GetAllExternalSystemsAsync();
        systems = result?.Where(s => s != null).Cast<ExternalSystem>().ToList() ?? new();
        StateHasChanged();
    }

    private async Task OnSystemSelected(ExternalSystem? item)
    {
        selectedSystem = item;
        if (item != null)
        {
            var result = await ApiClient.GetInterfaceContractsByExternalSystemIdAsync(item.Id);
            contracts = result?.Where(c => c != null).Cast<InterfaceContract>().ToList() ?? new();
        }
        else contracts = new();
        StateHasChanged();
    }

    private async Task OpenAddSystemDialog()
    {
        var parameters = new DialogParameters { ["ExternalSystem"] = new ExternalSystem() };
        var dialog = await DialogService.ShowAsync<ExternalSystemEditDialog>("新建外部系统", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadData();
    }

    private async Task EditSystem(ExternalSystem system)
    {
        var parameters = new DialogParameters { ["ExternalSystem"] = system };
        var dialog = await DialogService.ShowAsync<ExternalSystemEditDialog>("编辑外部系统", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadData();
    }

    private async Task DeleteSystem(ExternalSystem system)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync("确认删除",
            $"确定删除外部系统「{system.Name}」吗？关联的接口契约也将被删除。", yesText: "删除", cancelText: "取消");
        if (confirm == true)
        {
            var ok = await ApiClient.DeleteExternalSystemAsync(system.Id);
            if (ok) { Snackbar.Add("删除成功", Severity.Success); await LoadData(); }
            else Snackbar.Add("删除失败", Severity.Error);
        }
    }

    private async Task OpenAddContractDialog()
    {
        if (selectedSystem == null) return;
        var contract = new InterfaceContract { ExternalSystemId = selectedSystem.Id };
        var parameters = new DialogParameters { ["InterfaceContract"] = contract };
        var dialog = await DialogService.ShowAsync<InterfaceContractEditDialog>("新建接口契约", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled && selectedSystem != null)
            await OnSystemSelected(selectedSystem);
    }

    private async Task EditContract(InterfaceContract contract)
    {
        var parameters = new DialogParameters { ["InterfaceContract"] = contract };
        var dialog = await DialogService.ShowAsync<InterfaceContractEditDialog>("编辑接口契约", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled && selectedSystem != null)
            await OnSystemSelected(selectedSystem);
    }

    private async Task DeleteContract(InterfaceContract contract)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync("确认删除",
            $"确定删除接口契约「{contract.Name}」吗？", yesText: "删除", cancelText: "取消");
        if (confirm == true)
        {
            var ok = await ApiClient.DeleteInterfaceContractAsync(contract.Id);
            if (ok) { Snackbar.Add("删除成功", Severity.Success); if (selectedSystem != null) await OnSystemSelected(selectedSystem); }
            else Snackbar.Add("删除失败", Severity.Error);
        }
    }
}
