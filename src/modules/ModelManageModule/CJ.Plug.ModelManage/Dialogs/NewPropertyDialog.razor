@using CJ.Plug.ModelManageModel.Models
@using CJ.Plug.ModelManageApiClient
@using MudBlazor

@inject IOntologyManageApiClient OntologyManageApiClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField T="string" Label="属性标识 *" @bind-Value="prop.Name" Required="true" />
            <MudTextField T="string" Label="显示名称 *" @bind-Value="prop.DisplayName" Required="true" />
            <MudSelect T="string" Label="属性类型 *" @bind-Value="prop.PropertyType" Required="true">
                <MudSelectItem Value="@("Text")">文本(Text)</MudSelectItem>
                <MudSelectItem Value="@("Number")">数字(Number)</MudSelectItem>
                <MudSelectItem Value="@("Select")">下拉选择(Select)</MudSelectItem>
                <MudSelectItem Value="@("Date")">日期(Date)</MudSelectItem>
                <MudSelectItem Value="@("Boolean")">布尔(Boolean)</MudSelectItem>
                <MudSelectItem Value="@("JsonText")">JSON文本(JsonText)</MudSelectItem>
            </MudSelect>
            <MudTextField T="string" Label="描述" @bind-Value="prop.Description" />
            <MudTextField T="string" Label="默认值" @bind-Value="prop.Value" />
            <MudStack Row Spacing="4">
                <MudCheckBox T="bool" Label="必填" @bind-Checked="prop.IsRequired" />
                <MudCheckBox T="bool" Label="可浏览" @bind-Checked="prop.IsBrowsable" />
            </MudStack>
            <MudNumericField T="int" Label="排序" @bind-Value="prop.SortOrder" />
            <MudTextField T="string" Label="UI提示" @bind-Value="prop.UIHint" />
            <MudNumericField T="int?" Label="最大长度" @bind-Value="prop.Length" />
            <MudTextField T="string" Label="字典编码" @bind-Value="prop.DictCode" />
            <MudTextField T="string" Label="校验规则" @bind-Value="prop.ValidationRule" />

            @if (prop.Id > 0)
            {
                <MudDivider Class="my-2" />
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.subtitle1">属性约束</MudText>
                    <MudSpacer />
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="AddConstraint">添加约束</MudButton>
                </MudStack>
                <MudDataGrid Items="@constraints" T="PropertyConstraint" Dense="true" Hover="true" Elevation="0">
                    <Columns>
                        <PropertyColumn Property="x => x.SortOrder" Title="排序" />
                        <TemplateColumn Title="约束类型">
                            <CellTemplate>
                                <MudChip Label="true" Size="Size.Small" Color="Color.Info">@context.Item.ConstraintType</MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x => x.Value" Title="值" />
                        <PropertyColumn Property="x => x.Message" Title="消息" />
                        <TemplateColumn Style="text-align:right">
                            <CellTemplate>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => EditConstraint(context.Item))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteConstraint(context.Item))" />
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudText>暂无约束</MudText>
                    </NoRecordsContent>
                </MudDataGrid>
            }

            @if (prop.PropertyType == "Select")
            {
                <MudTextField T="string" Label="下拉选项(JSON数组)" @bind-Value="prop.SelectOptions" Placeholder='["选项A","选项B"]' />
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">取消</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">确定</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Property Property { get; set; } = new();

    private Property prop = new();
    private List<PropertyConstraint> constraints = new();

    protected override async Task OnParametersSetAsync()
    {
        prop = Property;
        if (prop.Id > 0)
            await LoadConstraints();
    }

    private async Task LoadConstraints()
    {
        var result = await OntologyManageApiClient.GetConstraintsByPropertyIdAsync(prop.Id);
        constraints = result?.Where(c => c != null).Cast<PropertyConstraint>().OrderBy(c => c.SortOrder).ToList() ?? new();
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(prop.Name) || string.IsNullOrWhiteSpace(prop.DisplayName))
        {
            Snackbar.Add("属性标识和显示名称不能为空", Severity.Warning);
            return;
        }

        Property? result;
        if (prop.Id == 0)
        {
            result = await OntologyManageApiClient.CreatePropertyAsync(prop);
        }
        else
        {
            result = await OntologyManageApiClient.UpdatePropertyAsync(prop);
        }

        if (result != null)
        {
            Snackbar.Add(prop.Id == 0 ? "添加成功" : "更新成功", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            Snackbar.Add(prop.Id == 0 ? "添加失败" : "更新失败", Severity.Error);
        }
    }

    private async Task AddConstraint()
    {
        var constraint = new PropertyConstraint { PropertyId = prop.Id, SortOrder = constraints.Count };
        var parameters = new DialogParameters { ["Constraint"] = constraint };
        var dialog = await DialogService.ShowAsync<ConstraintEditDialog>("添加约束", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled && result.Data is PropertyConstraint newConstraint)
        {
            var created = await OntologyManageApiClient.CreateConstraintAsync(newConstraint.PropertyId, newConstraint);
            if (created != null)
            {
                Snackbar.Add("约束已添加", Severity.Success);
                await LoadConstraints();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add("添加约束失败", Severity.Error);
            }
        }
    }

    private async Task EditConstraint(PropertyConstraint constraint)
    {
        var parameters = new DialogParameters { ["Constraint"] = constraint };
        var dialog = await DialogService.ShowAsync<ConstraintEditDialog>("编辑约束", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled && result.Data is PropertyConstraint updated)
        {
            updated.Id = constraint.Id;
            var saved = await OntologyManageApiClient.UpdateConstraintAsync(updated.Id, updated);
            if (saved != null)
            {
                Snackbar.Add("约束已更新", Severity.Success);
                await LoadConstraints();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add("更新约束失败", Severity.Error);
            }
        }
    }

    private async Task DeleteConstraint(PropertyConstraint constraint)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync("确认删除", $"确定要删除此约束吗？", yesText: "删除", cancelText: "取消");
        if (confirm == true)
        {
            var success = await OntologyManageApiClient.DeleteConstraintAsync(constraint.Id);
            if (success)
            {
                Snackbar.Add("约束已删除", Severity.Success);
                await LoadConstraints();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add("删除约束失败", Severity.Error);
            }
        }
    }
}
