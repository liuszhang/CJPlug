@using CJ.Plug.ModelManageModel.Models
@using CJ.Plug.ModelManageApiClient
@using MudBlazor

@inject IOntologyManageApiClient OntologyManageApiClient
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudSelect T="int?" Label="关联对象（可选）" @bind-Value="associatedOntologyId" Clearable="true">
                @foreach (var o in ontologies)
                {
                    <MudSelectItem T="int?" Value="o.Id">@o.DisplayName</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="int?" Label="关联行为（可选）" @bind-Value="associatedBehaviorId" Clearable="true">
                @foreach (var b in behaviors)
                {
                    <MudSelectItem T="int?" Value="b.Id">@(b.Description ?? $"行为 #{b.Id}")</MudSelectItem>
                }
            </MudSelect>
            <MudTextField T="string" Label="规则名称" @bind-Value="rule.Name" />
            <MudTextField T="string" Label="规则描述" @bind-Value="rule.Description" Lines="3" />
            <MudDateRangePicker T="DateTime?" Label="生效日期范围" @bind-DateRange="dateRange" Clearable="true" />
            <MudTextField T="string" Label="规则表达式" @bind-Value="rule.RuleExpression" Lines="3" />
            <MudTextField T="string" Label="规则条件(JSON)" @bind-Value="rule.RuleCondition" Lines="3" Placeholder='{"field":"status","op":"eq","value":"active"}' />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">取消</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">确定</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    private OntologyRule rule = new();
    private List<ObjectBehavior> behaviors = new();
    private List<Ontology> ontologies = new();
    private int? associatedOntologyId;
    private int? associatedBehaviorId;
    private DateRange? dateRange;

    protected override async Task OnInitializedAsync()
    {
        var behaviorTask = OntologyManageApiClient.GetAllBehaviorsAsync();
        var ontologyTask = OntologyManageApiClient.GetAllOntologiesAsync();

        await Task.WhenAll(behaviorTask, ontologyTask);

        behaviors = (behaviorTask.Result ?? Enumerable.Empty<ObjectBehavior?>())
            .Where(b => b != null).Cast<ObjectBehavior>().ToList();
        ontologies = (ontologyTask.Result ?? Enumerable.Empty<Ontology?>())
            .Where(o => o != null).Cast<Ontology>().ToList();
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Save()
    {
        rule.EffectiveFrom = dateRange?.Start;
        rule.EffectiveTo = dateRange?.End;

        var result = await OntologyManageApiClient.CreateRuleAsync(
            rule,
            associatedOntologyId: associatedOntologyId,
            associatedBehaviorId: associatedBehaviorId);

        if (result != null)
        {
            Snackbar.Add("创建成功", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            Snackbar.Add("创建失败", Severity.Error);
        }
    }
}
