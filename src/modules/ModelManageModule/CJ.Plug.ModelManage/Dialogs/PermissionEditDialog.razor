@using CJ.Plug.ModelManageModel.Models
@using CJ.Plug.ModelManageApiClient
@using MudBlazor

@inject IOntologyManageApiClient ApiClient
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField Label="名称 *" @bind-Value="model.Name" Required="true" />
            <MudTextField T="string" Label="代码 *" @bind-Value="model.Code" Required="true" />
            <MudTextField T="string" Label="资源类型" @bind-Value="model.ResourceType" />
            <MudTextField Label="资源ID" @bind-Value="model.ResourceId" />
            <MudSelect T="string" Label="操作 *" @bind-Value="model.Action" Required="true">
                <MudSelectItem Value="@("Read")">读取(Read)</MudSelectItem>
                <MudSelectItem Value="@("Write")">写入(Write)</MudSelectItem>
                <MudSelectItem Value="@("Delete")">删除(Delete)</MudSelectItem>
                <MudSelectItem Value="@("Execute")">执行(Execute)</MudSelectItem>
                <MudSelectItem Value="@("Admin")">管理(Admin)</MudSelectItem>
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">取消</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">确定</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Permission Permission { get; set; } = new();

    private Permission model = new();

    protected override void OnParametersSet()
    {
        model = Permission;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(model.Name) || string.IsNullOrWhiteSpace(model.Code))
        {
            Snackbar.Add("名称和代码不能为空", Severity.Warning);
            return;
        }
        Permission? result;
        if (model.Id == 0)
            result = await ApiClient.CreatePermissionAsync(model);
        else
            result = await ApiClient.UpdatePermissionAsync(model);
        if (result != null) { Snackbar.Add(model.Id == 0 ? "创建成功" : "更新成功", Severity.Success); MudDialog.Close(DialogResult.Ok(true)); }
        else Snackbar.Add(model.Id == 0 ? "创建失败" : "更新失败", Severity.Error);
    }
}
