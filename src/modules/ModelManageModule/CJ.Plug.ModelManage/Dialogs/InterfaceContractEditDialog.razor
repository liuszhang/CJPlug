@using CJ.Plug.ModelManageModel.Models
@using CJ.Plug.ModelManageApiClient
@using MudBlazor

@inject IOntologyManageApiClient ApiClient
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField T="string" Label="名称 *" @bind-Value="model.Name" Required="true" />
            <MudTextField T="string" Label="代码 *" @bind-Value="model.Code" Required="true" />
            <MudTextField T="string" Label="描述" @bind-Value="model.Description" Lines="3" />
            <MudSelect T="string" Label="HTTP方法" @bind-Value="model.Method">
                <MudSelectItem Value="@("GET")">GET</MudSelectItem>
                <MudSelectItem Value="@("POST")">POST</MudSelectItem>
                <MudSelectItem Value="@("PUT")">PUT</MudSelectItem>
                <MudSelectItem Value="@("DELETE")">DELETE</MudSelectItem>
                <MudSelectItem Value="@("PATCH")">PATCH</MudSelectItem>
            </MudSelect>
            <MudTextField T="string" Label="Endpoint" @bind-Value="model.Endpoint" />
            <MudTextField T="string" Label="RequestSchema (JSON)" @bind-Value="model.RequestSchema" Lines="4" />
            <MudTextField T="string" Label="ResponseSchema (JSON)" @bind-Value="model.ResponseSchema" Lines="4" />
            <MudSelect T="string" Label="状态" @bind-Value="model.Status">
                <MudSelectItem Value="@("Active")">活跃(Active)</MudSelectItem>
                <MudSelectItem Value="@("Deprecated")">弃用(Deprecated)</MudSelectItem>
                <MudSelectItem Value="@("Draft")">草稿(Draft)</MudSelectItem>
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">取消</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">确定</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public InterfaceContract InterfaceContract { get; set; } = new();

    private InterfaceContract model = new();

    protected override void OnParametersSet()
    {
        model = InterfaceContract;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(model.Name) || string.IsNullOrWhiteSpace(model.Code))
        {
            Snackbar.Add("名称和代码不能为空", Severity.Warning);
            return;
        }
        InterfaceContract? result;
        if (model.Id == 0)
            result = await ApiClient.CreateInterfaceContractAsync(model);
        else
            result = await ApiClient.UpdateInterfaceContractAsync(model);
        if (result != null) { Snackbar.Add(model.Id == 0 ? "创建成功" : "更新成功", Severity.Success); MudDialog.Close(DialogResult.Ok(true)); }
        else Snackbar.Add(model.Id == 0 ? "创建失败" : "更新失败", Severity.Error);
    }
}
