    private string GetRelationTypeDisplayName(string? code)
    {
        if (string.IsNullOrEmpty(code)) return code ?? "";
        var item = allBasicEnums
            .FirstOrDefault(e => e.Code == "Relation")?
            .Items.FirstOrDefault(i => i.Code == code);
        return item?.DisplayName ?? code;
    }

    private List<BasicEnumItem> GetRelationEnumItems()
    {
        return allBasicEnums
            .FirstOrDefault(e => e.Code == "Relation")?
            .Items.OrderBy(i => i.SortOrder).ToList() ?? new();
    }

    private List<Ontology> filteredOntologies => Filter(allOntologies, o =>
        o.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
        o.DisplayName.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
        (o.Category ?? "").Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
        (o.Description ?? "").Contains(searchString, StringComparison.OrdinalIgnoreCase));

    private List<OntologyRelationship> filteredRelationships => Filter(allRelationships, r =>
        r.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
        r.DisplayName.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
        r.Code.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
        GetOntologyName(r.SourceOntologyId).Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
        GetOntologyName(r.TargetOntologyId).Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
        (r.Description ?? "").Contains(searchString, StringComparison.OrdinalIgnoreCase));

    private List<OntologyRule> filteredRules => Filter(allRules, r =>
        (r.Description ?? "").Contains(searchString, StringComparison.OrdinalIgnoreCase));

    private List<T> Filter<T>(List<T> source, Func<T, bool> predicate)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return source;
        return source.Where(predicate).ToList();
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadData();
    }

    private async Task ReloadData()
    {
        allOntologies = (await OntologyManageApiClient.GetAllOntologiesAsync()).Where(o => o != null).Cast<Ontology>().ToList();
        var rels = await OntologyManageApiClient.GetAllRelationshipsAsync();
        allRelationships = rels.Where(r => r != null).Cast<OntologyRelationship>().ToList();
        var bhvs = await OntologyManageApiClient.GetAllBehaviorsAsync();
        allBehaviors = bhvs.Where(b => b != null).Cast<ObjectBehavior>().ToList();
        var rules = await OntologyManageApiClient.GetAllRulesAsync();
        allRules = rules.Where(r => r != null).Cast<OntologyRule>().ToList();
        var basicEnums = await OntologyManageApiClient.GetAllBasicEnumsAsync();
        allBasicEnums = basicEnums.Where(e => e != null).Cast<BasicEnum>().ToList();

        ontologyNameMap = allOntologies.ToDictionary(o => o.Id, o => o.DisplayName);

        // 首次加载时自动选中第一个基础枚举
        if (selectedBasicEnumId == null && allBasicEnums.Any())
        {
            selectedBasicEnumId = allBasicEnums.First().Id;
        }

        StateHasChanged();
    }

    private string GetOntologyName(int? id)
    {
        if (id == null) return "（全局）";
        return ontologyNameMap.TryGetValue(id.Value, out var name) ? name : $"ID:{id}";
    }

    private void OnTabChanged(int index)
    {
        selectedTabIndex = index;
        ruleDrawerOpen = false;
    }

    private void SelectBehaviorOntology(int id)
    {
        selectedBehaviorOntologyId = id;
        StateHasChanged();
    }

    private void ToggleBehaviorOntologyExpand(int ontologyId)
    {
        if (expandedBehaviorOntologyIds.Contains(ontologyId))
            expandedBehaviorOntologyIds.Remove(ontologyId);
        else
            expandedBehaviorOntologyIds.Add(ontologyId);
        StateHasChanged();
    }

    private async Task SelectBehavior(int behaviorId)
    {
        selectedBehaviorId = behaviorId;
        selectedBehaviorRules = new();
        StateHasChanged();

        try
        {
            var rules = await OntologyManageApiClient.GetRulesByBehaviorIdAsync(behaviorId);
            selectedBehaviorRules = rules.Where(r => r != null).Cast<OntologyRule>().ToList();
        }
        catch
        {
            selectedBehaviorRules = new();
        }
        StateHasChanged();
    }

    private async Task EditBehavior(ObjectBehavior behavior)
    {
        var parameters = new DialogParameters { ["BehaviorId"] = behavior.Id };
        var dialog = await DialogService.ShowAsync<Dialogs.EditBehaviorDialog>("编辑行为", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
        {
            await ReloadData();
            if (selectedBehaviorId == behavior.Id)
                await SelectBehavior(behavior.Id);
        }
    }

    private async Task DeleteBehavior(ObjectBehavior behavior)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync("确认删除", $"确定删除行为「{behavior.Description}」吗？",
            yesText: "删除", cancelText: "取消");
        if (confirm == true)
        {
            var success = await OntologyManageApiClient.DeleteBehaviorAsync(behavior.Id);
            if (success)
            {
                if (selectedBehaviorId == behavior.Id)
                {
                    selectedBehaviorId = null;
                    selectedBehaviorRules = new();
                }
                Snackbar.Add("删除成功", Severity.Success);
                await ReloadData();
            }
            else
            {
                Snackbar.Add("删除失败", Severity.Error);
            }
        }
    }

    private void OnOntologyRowClick(DataGridRowClickEventArgs<Ontology> e)
