    {
        selectedRelationshipType = typeCode;
    }

    private void ClearRelationshipType()
    {
        selectedRelationshipType = null;
    }

    private void ClearRelationshipFilters()
    {
        filterSourceOntologyId = null;
        filterTargetOntologyId = null;
        filterCardinality = null;
    }

