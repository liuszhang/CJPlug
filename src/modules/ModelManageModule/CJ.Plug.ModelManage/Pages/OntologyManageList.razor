    private async Task DeleteOntology(Ontology ontology)
    {
        if (ontology.IsSystem)
        {
            Snackbar.Add("系统内置本体不可删除", Severity.Warning);
            return;
        }
        bool? result = await DialogService.ShowMessageBoxAsync("确认删除", $"确定要删除本体 '{ontology.DisplayName}' 吗？这将同时删除其所有属性、关系和规则。", yesText: "删除", cancelText: "取消");
        if (result == true)
        {
            var success = await OntologyManageApiClient.DeleteOntologyAsync(ontology.Id);
            if (success)
            {
                Snackbar.Add("删除成功", Severity.Success);
                await ReloadData();
            }
            else
            {
                Snackbar.Add("删除失败", Severity.Error);
            }
        }
    }
