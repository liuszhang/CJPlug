@page "/OntologyManage"
@using CJ.Plug.ModelManage.Components
@using CJ.Plug.ModelManageApiClient
@using CJ.Plug.ModelManageModel.Models
@using MudBlazor

@inject IOntologyManageApiClient OntologyManageApiClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>本体管理</PageTitle>

<MudContainer MaxWidth="MaxWidth.False">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenAddDialog">添加对象</MudButton>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadData">刷新</MudButton>
    </MudStack>

    <MudTabs Elevation="0" Rounded="true" Class="elevation-1"
             ActivePanelIndex="selectedTabIndex"
             ActivePanelIndexChanged="OnTabChanged">

        @* ========== Tab 0: M0 基础语义 ========== *@
        <MudTabPanel Text="M0 基础语义">
            @if (!loadedTabs[0]) { loadedTabs[0] = true; }
            <BasicSemanticTab />
        </MudTabPanel>

        @* ========== Tab 1: M1 对象结构 ========== *@
        <MudTabPanel Text="@($"M1 对象结构 ({CountTreeNodes(dim1Tree)})")">
            @if (!loadedTabs[1]) { loadedTabs[1] = true; BuildDim1Tree(); }
            <div class="d-flex" style="min-height: 500px;">
                <div class="col-sm-4 pa-0" style="border-right: 1px solid var(--mud-palette-divider);">
                    <OntologyTreePanel
                        TreeData="dim1Tree"
                        SelectedNode="@dim1SelectedNode"
                        SelectedNodeChanged="@(v => { dim1SelectedNode = v; StateHasChanged(); })"
                        OnAddRoot="HandleAddRootM1"
                        OnAddChild="HandleAddChildM1"
                        OnEditSelected="HandleEditSelectedM1"
                        OnDeleteSelected="HandleDeleteSelectedM1" />
                </div>
                <div class="col-sm-8 pa-0">
                    <OntologyDetailPanel
                        ActiveOntology="dim1SelectedNode"
                        DataChanged="ReloadData" />
                </div>
            </div>
        </MudTabPanel>

        @* ========== Tab 2: M1.5 关系模型 ========== *@
        <MudTabPanel Text="关系模型">
            @if (!loadedTabs[2]) { loadedTabs[2] = true; }
            <RelationTab />
        </MudTabPanel>

        @* ========== Tab 3: M2 行为 ========== *@
        <MudTabPanel Text="M2 行为">
            @if (!loadedTabs[3]) { loadedTabs[3] = true; }
            <BehaviorTab />
        </MudTabPanel>

        @* ========== Tab 4: M3 规则 ========== *@
        <MudTabPanel Text="M3 规则">
            @if (!loadedTabs[4]) { loadedTabs[4] = true; }
            <RuleTab />
        </MudTabPanel>

        @* ========== Tab 5: M4 场景 ========== *@
        <MudTabPanel Text="M4 场景">
            @if (!loadedTabs[5]) { loadedTabs[5] = true; }
            <ScenarioTab />
        </MudTabPanel>

        @* ========== Tab 6: M5 主体 ========== *@
        <MudTabPanel Text="M5 主体">
            @if (!loadedTabs[6]) { loadedTabs[6] = true; }
            <SubjectTab />
        </MudTabPanel>

        @* ========== Tab 7: M5.5 接口契约 ========== *@
        <MudTabPanel Text="接口契约">
            @if (!loadedTabs[7]) { loadedTabs[7] = true; }
            <InterfaceContractTab />
        </MudTabPanel>

        @* ========== Tab 8: M6 可靠性 ========== *@
        <MudTabPanel Text="M6 可靠性">
            @if (!loadedTabs[8]) { loadedTabs[8] = true; }
            <ReliabilityTab />
        </MudTabPanel>

        @* ========== Tab 9: M7 质量 ========== *@
        <MudTabPanel Text="M7 质量">
            @if (!loadedTabs[9]) { loadedTabs[9] = true; }
            <QualityTab />
        </MudTabPanel>

    </MudTabs>
</MudContainer>

@code {
    private List<Ontology> allOntologies = new();
    private List<Ontology> treeData = new();
    private Dictionary<int, string> ontologyNameMap = new();
    private int selectedTabIndex = 0;

    // 懒加载标记（10 个 Tab）
    private bool[] loadedTabs = new bool[10];

    // M1 对象结构页签专用：过滤后的树 + 选中节点
    private List<Ontology> dim1Tree = new();
    private Ontology? dim1SelectedNode;

    // ====== 生命周期 ======
    protected override async Task OnInitializedAsync()
    {
        try { await ReloadData(); }
        catch (Exception ex) { Console.WriteLine($"[OntologyManageList] OnInitializedAsync 加载失败: {ex.Message}"); }
    }

    private async Task ReloadData()
    {
        try { treeData = (await OntologyManageApiClient.GetOntologyTreeAsync()).Where(o => o != null).Cast<Ontology>().ToList(); }
        catch (Exception ex) { Console.WriteLine($"[OntologyManageList] GetOntologyTreeAsync 失败: {ex.Message}"); }

        try { allOntologies = (await OntologyManageApiClient.GetAllOntologiesAsync()).Where(o => o != null).Cast<Ontology>().ToList(); }
        catch (Exception ex) { Console.WriteLine($"[OntologyManageList] GetAllOntologiesAsync 失败: {ex.Message}"); }

        ontologyNameMap = allOntologies.ToDictionary(o => o.Id, o => o.DisplayName);

        // 重建 M1 过滤树
        if (loadedTabs[1]) BuildDim1Tree();

        StateHasChanged();
    }

    // ====== M1 对象结构 Tree 过滤 ======
    private void BuildDim1Tree()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(treeData,
            new System.Text.Json.JsonSerializerOptions { ReferenceHandler = System.Text.Json.Serialization.ReferenceHandler.IgnoreCycles });
        var copy = System.Text.Json.JsonSerializer.Deserialize<List<Ontology>>(json,
            new System.Text.Json.JsonSerializerOptions { ReferenceHandler = System.Text.Json.Serialization.ReferenceHandler.IgnoreCycles });
        dim1Tree = FilterInPlace(copy ?? new(), MetaModelDimension.M1);
    }

    private static List<Ontology> FilterInPlace(List<Ontology> nodes, MetaModelDimension dim)
    {
        for (int i = nodes.Count - 1; i >= 0; i--)
        {
            var node = nodes[i];
            bool match = node.Dimension == dim;
            if (node.Children != null && node.Children.Count > 0)
                FilterInPlace(node.Children, dim);
            if (!match && (node.Children == null || node.Children.Count == 0))
                nodes.RemoveAt(i);
        }
        return nodes;
    }

    // ====== Tab 切换 ======
    private void OnTabChanged(int index)
    {
        selectedTabIndex = index;
        StateHasChanged();
    }

    // ====== 工具方法 ======
    private string GetOntologyName(int? id)
    {
        if (id == null) return "（全局）";
        return ontologyNameMap.TryGetValue(id.Value, out var name) ? name : $"ID:{id}";
    }

    private int CountTreeNodes(List<Ontology> nodes)
    {
        int count = 0;
        foreach (var node in nodes)
            count += CountTreeNodes(node);
        return count;
    }

    private int CountTreeNodes(Ontology node)
    {
        int count = 1;
        if (node.Children != null)
            foreach (var child in node.Children)
                count += CountTreeNodes(child);
        return count;
    }

    // ====== M1 树形面板事件 ======
    private async Task HandleAddRootM1()
    {
        var ontology = new Ontology { ParentId = null, Dimension = MetaModelDimension.M1 };
        var parameters = new DialogParameters { ["Ontology"] = ontology };
        var dialog = await DialogService.ShowAsync<Dialogs.NewOntologyDialog>("新建根对象", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await ReloadData();
    }

    private async Task HandleAddChildM1()
    {
        if (dim1SelectedNode == null) return;
        var ontology = new Ontology { ParentId = dim1SelectedNode.Id, Dimension = MetaModelDimension.M1 };
        var parameters = new DialogParameters { ["Ontology"] = ontology };
        var dialog = await DialogService.ShowAsync<Dialogs.NewOntologyDialog>($"新建 {dim1SelectedNode.DisplayName} 的子对象", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await ReloadData();
    }

    private async Task HandleEditSelectedM1()
    {
        if (dim1SelectedNode == null) return;
        await EditOntology(dim1SelectedNode);
    }

    private async Task HandleDeleteSelectedM1()
    {
        if (dim1SelectedNode == null) return;
        await DeleteOntology(dim1SelectedNode);
    }

    private async Task OpenAddDialog()
    {
        if (selectedTabIndex == 1) await HandleAddRootM1();
    }

    // ====== 通用 Ontology 编辑/删除 ======
    private async Task EditOntology(Ontology ontology)
    {
        var parameters = new DialogParameters { ["OntologyId"] = ontology.Id };
        var dialog = await DialogService.ShowAsync<Dialogs.OntologyEditDialog>("编辑本体", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await ReloadData();
    }

    private async Task DeleteOntology(Ontology ontology)
    {
        if (ontology.IsSystem) { Snackbar.Add("系统内置本体不可删除", Severity.Warning); return; }
        bool? result = await DialogService.ShowMessageBoxAsync("确认删除",
            $"确定要删除本体 '{ontology.DisplayName}' 吗？这将同时删除其所有属性、关系和规则。",
            yesText: "删除", cancelText: "取消");
        if (result == true)
        {
            var success = await OntologyManageApiClient.DeleteOntologyAsync(ontology.Id);
            if (success) { Snackbar.Add("删除成功", Severity.Success); await ReloadData(); }
            else Snackbar.Add("删除失败", Severity.Error);
        }
    }
}
