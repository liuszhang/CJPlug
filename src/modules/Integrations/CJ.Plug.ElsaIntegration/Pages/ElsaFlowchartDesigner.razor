    public async Task SaveAsync()
    {
        var root = await Designer.ReadFlowchartAsync();

        // 流程图数据保存到插头的 ActivityJsonData
        var plug = await TASApiClient.GetPlugByDefinitionIdAsync(ProcessDefinitionId);
        if (plug != null)
        {
            plug.SetFlowchartJson(root);
            await TASApiClient.UpdatePlugAsync(plug.Id, plug);
        }

        //var oldActivityIds = PlugDataZone?.GetFlowchartData(ProcessDefinitionId)?.GetActivities().Select(a=>a.GetId()).ToList();
        var oldActivityIds = PlugDataZone?.PlugDatas?.Select(a=>a.PlugDefinitionId).ToList();
        //保存流程图数据
        //Log.Information("更新流程图数据成功");
        //对比流程图和插头列表，进行插头的删除
        var newActivityIds = root.GetActivities().Select(a => a.GetId()).ToList();
        foreach (var activityId in oldActivityIds)
        {
            if (!newActivityIds.Contains(activityId) && activityId != ProcessDefinitionId)  //这里需要注意不要把流程图本身删除了，所以需要排除掉ProcessDefinitionId
            {
                //await MainApiClient.DeletePlugByDefinitionId(activity);
                CLog.Warning($"删除插头:{activityId}",PlugDataZone?.PDZId);

                PlugDataZone.PlugDatas.RemoveAll(x => x.PlugDefinitionId == activityId);   //删除相关插头数据
                PlugDataZone.PlugVariableDatas.RemoveAll(x => x.PlugDefinitionId == activityId);   //删除相关插头参数数据
                PlugDataZone.PlugStatusDatas.RemoveAll(x => x.PlugDefinitionId == activityId);   //删除相关插头状态数据
                PlugDataZone.ActionDatas.RemoveAll(x => x.PlugDefinitionId == activityId);   //删除相关插头动作数据
                PlugDataZone.ActionVariableDatas.RemoveAll(x => x.PlugDefinitionId == activityId);   //删除相关插头动作参数数据
                // 流程图数据已迁移至插头定义层，不再从 PDZ 删除
                // PlugDataZone.FlowchartDatas.RemoveAll(x => x.PlugDefinitionId == activityId);   //删除相关插头流程图数据
                PlugDataZone.DataFlowDatas.RemoveAll(x => x.SourcePlugDefinitionId == activityId || x.TargetPlugDefinitionId == activityId);   //删除相关数据流数据

                //保存插头数据，由于要更新太多，就直接使用PDZ更新了
                PlugDataZone = await PDZApiClient.CreateOrUpdatePDZ(PlugDataZone);

                //只有在有删除操作时才选择画布
                await OnCanvasSelected();

            }
        }
        //await MainApiClient.CreateOrUpdatePDZ(PlugDataZone);

        await OnSave.InvokeAsync(false);
    }

    private async Task AddNewActivityAsync(ActivityDescriptor activityDescriptor, double x, double y)
    {
        //Console.WriteLine(">>>>>>>>>>start add activity2");

        var activities = Flowchart.GetActivities().ToList();
        var newActivityId = RandomLongIdentityGenerator.GenerateId();

        var newActivity = new JsonObject(new Dictionary<string, JsonNode?>
            {
                ["id"] = newActivityId,
                ["nodeId"] = $"{Flowchart.GetNodeId()}:{newActivityId}",
                ["definitionId"] = newActivityId,
                ["PlugDefinitionId"] = newActivityId,
                ["name"] = ElsaNameGenerator.GenerateNextActivityName(activities, activityDescriptor),
            //["type"] = (activityDescriptor.Description.Contains("CommonCorePlugActivity") ? "CJ.CommonCorePlugActivity" : activityDescriptor.TypeName),
            //["type"] = (activityDescriptor.IsContainer) ? "Elsa.Flowchart" : activityDescriptor.TypeName,
                ["type"] = activityDescriptor.TypeName,
            //["displayType"] = activityDescriptor.TypeName,
            //["version"] = activityDescriptor.Version
                ["version"] = activityDescriptor.Version,
                ["isContainer"]=activityDescriptor.IsContainer
            //["workflowDefinitionId"] = WorkflowDefinition.DefinitionId
            });

        newActivity.SetDesignerMetadata(new ActivityDesignerMetadata
            {
                Position = new Elsa.Api.Client.Shared.Models.Position(x, y)
            });


        // Copy constructor values from the activity descriptor.
        foreach (var property in activityDescriptor.ConstructionProperties)
        {
            var valueNode = JsonSerializer.SerializeToNode(property.Value);
            var propertyName = property.Key.Camelize();
            newActivity.SetProperty(valueNode, propertyName);
        }

        // If the activity is a trigger, and it's the first trigger on the flowchart, set the trigger property to true.
        if (activityDescriptor.Kind == ActivityKind.Trigger && activities.All(activity => activity.GetCanStartWorkflow() != true))
            newActivity.SetCanStartWorkflow(true);

        //newActivity.SetCanStartWorkflow(true);
        newActivity.SetDisplayText(newActivity.GetName());
        //newActivity.SetProperty(newActivityId, "PlugDefinitionId");
        //newActivity.SetProperty(newActivityId, "definitionId");
        newActivity.Remove("workflowDefinitionId");
        newActivity.Remove("workflowDefinitionVersionId");
        //newActivity.GetIsWorkflowDefinitionActivity();
        //需要把版本设置为1，否则会报错，elsa默认创建的活动版本必须从1开始（存疑）
        //newActivity.SetProperty(1, "version");

        // if (activityDescriptor.IsContainer)
        // {
        //     //var id = RandomLongIdentityGenerator.GenerateId();
        //     newActivity.SetProperty(
        //         new JsonObject(new Dictionary<string, JsonNode?>
        //             {
        //                 ["id"] = newActivityId + "body",
        //                 ["definitionId"] = newActivityId + "body",
        //                 ["type"] = "Elsa.Flowchart",
        //                 ["name"] = newActivity.GetName() + "-body"
        //             }),
        //         "body");

        //     PlugDataZone.PDZVariables.Add(new PDZVariable()
        //         {
        //             PlugDefinitionId = newActivityId,
        //             Name = newActivity.GetName() + "-子流程图",
        //             Tag = PDZVariableTagEnum.FlowchartTag.ToString(),
        //             Value = new JsonObject(new Dictionary<string, JsonNode?>
        //             {
        //                 ["id"] = newActivityId + "body",
        //                 ["definitionId"] = newActivityId + "body",
        //                 ["type"] = "Elsa.Flowchart",
        //                 ["name"] = newActivity.GetName() + "-body"
        //             }).ToJsonString(),
        //         });
        // }


        Console.WriteLine(">>>>>>>>>>prepare to add activity:" + JsonSerializer.Serialize(newActivity));

        //接下来需要添加同步保存为系统的PLUG插头的接口调用,也可以考虑在打开配置窗口时再创建插头
        //插头数据来源于原始插头，但是有些插头是引擎自带的，也需要能够兼容参数数据
        var newPlug = newActivity.ToPlug();
        newPlug.ParentPlugDefinitionId = ProcessDefinitionId;
        newPlug.Creater = await DomInteropService.GetCurrentUserName();
        newPlug.CreateType = PlugCreateTypeEnum.InstancePlug.ToString();
        newPlug.IsContainerPlug = activityDescriptor.IsContainer;
        //将引擎自带活动的参数添加到新建的插头中
        foreach (var t in activityDescriptor?.Inputs)
        {
            var inputName = t.Name.Camelize();
            var valueNode = JsonSerializer.SerializeToNode(t.DefaultValue);

            PlugDataZone.PlugVariableDatas.Add(new PlugVariableData()
            {
                PlugDefinitionId = newPlug.DefinitionId,
                Name = inputName,
                DisplayName = t.DisplayName,
                Type = t.TypeName,
                Description = t.Description,
                Value = valueNode?.ToString(),
                DefaultValue = valueNode?.ToString(),
                IsInitVariable = true,
                IsBrowsable = t.IsBrowsable,
            });

        }
        //如果是通过平台根活动创建的插头，则需要从根活动中获取插头参数信息放入PDZ中
        var rootPlug = await TASApiClient.GetRootPlugByTypeNameAsync(newActivity.GetTypeName());
        if (rootPlug != null)
        {
            //Log.Information($"获取根插头成功：{rootPlug.DefinitionId}({rootPlug.Id})");
            //newPlug = rootPlug.DeepCopy();//如果原始插头存在，可以考虑这种方式
            newPlug.PlugTypeKey = rootPlug?.PlugTypeKey;
            newPlug.PlugSettingsJson = rootPlug?.PlugSettingsJson;
            newPlug.Category = rootPlug?.Category;
            newPlug.OnlyExecuteAction = rootPlug.OnlyExecuteAction;
            newPlug.ToolId = rootPlug.ToolId;
            newPlug.ToolName = rootPlug.ToolName;
            newPlug.ToolVersion = rootPlug.ToolVersion;
            newPlug.ToolDisplayName = rootPlug.ToolDisplayName;
            newPlug.ToolCommandLineShema = rootPlug.ToolCommandLineShema;

            foreach (var p in rootPlug.PlugVariables)
            {
                PlugDataZone.PlugVariableDatas.Add(new PlugVariableData()
                    {
                        PlugDefinitionId = newPlug.DefinitionId,
                        Name = p.Name,
                        Value = p.Value,
                        DefaultValue = p.DefaultValue,
                        Type = p.Type,
                        IsInitVariable = p.IsInitVariable,
                        IsBrowsable = p.IsBrowsable,
                        IsArray = p.IsArray,
                    });
            }
        }
        //将新建的插头以参数数据的形式添加到PDZ中
        var newPlugData = new PlugData()
            {
            //PlugDataZoneId = PlugDataZone.Id,
                PlugDefinitionId = newActivityId,
                ParentPlugDefinitionId = ProcessDefinitionId,
                Name = newActivity.GetName(),
                PlugType = newActivity.GetTypeName(),
                PlugTypeKey = rootPlug?.PlugTypeKey,
                WorkPath=Path.Combine(PlugDataZone.PDZWorkPath,newActivityId),
                PlugPosition = $"{x} {y}",//记录插头坐标值，用于绘制数据流等功能
            };
        PlugDataZone.PlugDatas.Add(newPlugData);
        try
        {
            await Designer.AddActivityAsync(newActivity);

            //这里也要更新插头数据、插头参数数据，所以直接使用PDZ更新
            PlugDataZone=await PDZApiClient.CreateOrUpdatePDZ(PlugDataZone);
            //CLog.Information($"创建插头成功，插头ID：{newPlugData?.PlugDefinitionId}", PlugDataZone.PDZId);

            await OnActivitySelected(newActivity);
        }
        catch (Exception ex)
        {
            CLog.Information(ex.Message);
            CLog.Information(ex.StackTrace);
        }
    }

    private async Task OnActivityDoubleClick(JsonObject activity)
