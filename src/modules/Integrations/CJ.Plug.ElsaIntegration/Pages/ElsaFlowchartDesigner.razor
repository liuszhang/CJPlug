                if (newActivity != null)
                {
                    //需要更新一下引擎活动，以兼容引擎自带的活动组件，后期可以取消
                    //Console.WriteLine("start update activity:" + newActivity);
                    //await Designer.UpdateActivityAsync(activity.GetId(), newActivity);
                }
            }

        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }

    }


    public void SetHubListener()
    {
        HubConnectionManagerService._hubConnection.Remove(LogTypeEnum.PlugUpdated.ToString());
        //通过长连接添加插头更新监听
        HubConnectionManagerService._hubConnection.On<string>(LogTypeEnum.PlugUpdated.ToString(), 
        (PlugDefiniitonId) =>
           {
               Console.WriteLine($"PlugDefiniitonId:{PlugDefiniitonId}");
               InvokeAsync(async () =>
               {                   
                   var UpdatedActivity = await PDZApiClient.GetPlugDataByDefinitionId(PlugDefiniitonId);
                   var activity = Flowchart?.GetActivities().Where(a => a.GetId() == PlugDefiniitonId).FirstOrDefault();
                   //Log.Information($"原始组件名称：{activity?.GetName()}（{PlugDefiniitonId}）");
                   activity?.SetName(UpdatedActivity?.Name);
                   activity?.SetDisplayText(UpdatedActivity?.Name);
                   activity?.SetDescription(UpdatedActivity?.Description);
                   //Log.Information($"更新活动名称：{activity?.GetName()}({activity.ToJsonString()})");
                   await Designer.UpdateActivityAsync(PlugDefiniitonId, activity);                   
               });
           });
    }

