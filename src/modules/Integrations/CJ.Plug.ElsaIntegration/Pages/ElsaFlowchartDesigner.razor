    protected override async Task OnInitializedAsync()
    {
        // 关键：用 InvokeAsync 包装防抖回调，确保在 UI 线程执行
        _rateLimitedSaveChangesAsync = Debouncer.Debounce(
            async () => await InvokeAsync(SaveAsync), // 切换到 UI 线程后调用 SaveAsync
            TimeSpan.FromMilliseconds(500)
        );
    }

    protected override async Task OnParametersSetAsync()
