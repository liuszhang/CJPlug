    private async Task OnDrop(DragEventArgs e)
    {
        //Log.Information($"droped!({Plug?.Name})");
        if (IsReadOnly)
        {
            return;
        }    
        try
        {
            var Payload = await DomInteropService.GetDragPayload();
            DragDropManager.Payload = JsonSerializer.Deserialize<ActivityDescriptor>(Payload?.ToString());
        }
        catch (Exception ex)
        {
            Log.Information(ex.Message);
            Log.Information("别啥都往里拖");
            return;
        }
        Console.WriteLine(">>>>>>>>>>>>drop in is a:" + DragDropManager?.Payload);
        var x = e.PageX;
        var y = e.PageY;
        if (DragDropManager.Payload is ActivityDescriptor activityDescriptor)
        {
            Console.WriteLine(">>>>>>>>>>start add activity");
            //添加并创建新插头
            await AddNewActivityAsync(activityDescriptor, x, y);
            //更新整个流程，无需更新，画面更新后会自动保存
            //await SaveAsync();

            await DomInteropService.SetDragPayload(null);
            DragDropManager.Payload = null;
            return;
        }
        DragDropManager.Payload = null;
        Log.Information("别啥都往里拖");
    }

