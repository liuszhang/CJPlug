@using System.Text.Json
@using Microsoft.JSInterop


<div id="@_id"></div>

@code {
    [Inject] public IJSRuntime Js { get; set; }
    //連넣殮쌈눈뒵Json뚤蹶
    [Parameter] public object? Data { get; set; }

    //커품꽃痰string쏵契GUI鑒앴괏닸뵨눈뒵
    [Parameter] public string? JsonStringData { get; set; }
    private string _id = "amis-" + Guid.NewGuid().ToString("N");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (Data != null)
            {
                var json = JsonSerializer.Serialize(Data);
                await Js.InvokeAsync<string>("amisLoad", _id, json);
                return;
            }

            await Js.InvokeAsync<string>("amisLoad", _id, JsonStringData);


            // var json = JsonSerializer.Serialize(Data);
            // await Js.InvokeAsync<string>("amisLoad", _id, json);
            //await Js.InvokeAsync<string>("amisLoad", _id, JsonStringData);
        }

        await base.OnAfterRenderAsync(firstRender);
    }

