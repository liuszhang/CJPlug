    private async Task ImportPlugs(List<Plug> importPlugs)
    {
        try
        {
            // 获取所有现有插头用于匹配
            var allExistingPlugs = await MainApiClient.GetPlugs();
            var importCount = 0;
            var updateCount = 0;
            var createCount = 0;

            foreach (var importPlug in importPlugs)
            {
                // 根据 Type 查找现有插头
                var existingPlug = allExistingPlugs.FirstOrDefault(p => p.Type == importPlug.Type);

                if (existingPlug != null)
                {
                    // 插头已存在，更新它
                    // 保留一些关键属性
                    var plugId = existingPlug.Id;
                    var definitionId = existingPlug.DefinitionId;

                    // 更新插头数据
                    existingPlug.Name = importPlug.Name;
                    existingPlug.Description = importPlug.Description;
                    existingPlug.GroupName = importPlug.GroupName;
                    existingPlug.PlugSettingsJson = importPlug.PlugSettingsJson;
                    existingPlug.PlugVariables = importPlug.PlugVariables;
                    existingPlug.Value = importPlug.Value;
                    existingPlug.RealValuePath = importPlug.RealValuePath;
                    existingPlug.WorkPath = importPlug.WorkPath;
                    existingPlug.ToolId = importPlug.ToolId;
                    existingPlug.ToolName = importPlug.ToolName;
                    existingPlug.ToolDisplayName = importPlug.ToolDisplayName;
                    existingPlug.ToolCommandLineShema = importPlug.ToolCommandLineShema;
                    existingPlug.ToolVersion = importPlug.ToolVersion;
                    existingPlug.ToolVersions = importPlug.ToolVersions;
                    existingPlug.IsContainerPlug = importPlug.IsContainerPlug;
                    existingPlug.ShowInPlugLibrary = importPlug.ShowInPlugLibrary;
                    existingPlug.OnlyExecuteAction = importPlug.OnlyExecuteAction;
                    existingPlug.ActivityJsonData = importPlug.ActivityJsonData;
                    existingPlug.GuiJsonData = importPlug.GuiJsonData;

                    // 保留 ID 和 DefinitionId
                    existingPlug.Id = plugId;
                    existingPlug.DefinitionId = definitionId;

                    await MainApiClient.UpdatePlugAsync(existingPlug.Id, existingPlug);
                    updateCount++;
                }
                else
                {
                    // 新插头，创建它
                    importPlug.DefinitionId = RandomLongIdentityGenerator.GenerateId();
                    importPlug.Id = null;

                    // 设置为用户创建的插头
                    importPlug.CreateType = PlugCreateTypeEnum.RootPlug.ToString();
                    importPlug.Creater = await DomInteropService.GetCurrentUserName();

                    await MainApiClient.CreateNewPlug(importPlug);
                    createCount++;
                }
                importCount++;
            }

            await GetAllRootPlugs();
            var message = $"导入完成: 新建 {createCount} 个, 更新 {updateCount} 个, 共 {importCount} 个";
            Snackbar.Add(message, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"导入失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task ShowExportDialog()
    {
        // 确保插头数据已加载
        if (RootPlugs == null || RootPlugs.Count == 0)
        {
            Snackbar.Add("正在加载插头数据，请稍后重试", Severity.Warning);
            await GetAllRootPlugs();
        }

        var parameters = new DialogParameters<ExportPlugs>
        {
            { x => x.AllPlugs, RootPlugs },
            { x => x.SelectedPlug, SelectedPlug }
        };
        var options = new DialogOptions { CloseOnEscapeKey = false, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ExportPlugs>("导出插头", parameters, options);
        await dialog.Result;
    }

