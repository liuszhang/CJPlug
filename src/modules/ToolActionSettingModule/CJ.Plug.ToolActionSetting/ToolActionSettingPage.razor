        RefreshContainer();

    }

    private async Task GetSysInitRootPlugs()
    {        
        var AllPlugs = await MainApiClient.GetPlugs();
        //获取系统依赖注入的插头
        foreach (var pcsc in PlugCommonSettingContent)
        {
            if (pcsc == null)
            {
                Console.WriteLine("pcsc is null");
                continue;
            }
            var EachPlugSetting = await pcsc.GetPlugBaseSetting();
            if (EachPlugSetting == null)
            {
                continue;
            }
            var AlreadyExistPlug = AllPlugs.FirstOrDefault(t => t.Type == EachPlugSetting.PlugType);
            //Console.WriteLine(EachPlugSetting.PlugDisplayName + ":" + JsonSerializer.Serialize(EachPlugSetting));
            //Log.Information(EachPlugSetting.PlugDisplayName + ":" + JsonSerializer.Serialize(EachPlugSetting));
            var PlugFromSetting = new Plug
            {
                Name = EachPlugSetting.PlugDisplayName,
                Type = EachPlugSetting.PlugType,
                PlugTypeKey = EachPlugSetting.PlugTypeKey,
                Category = EachPlugSetting.GetSetting(PlugSettingKey.Category.ToString()),
                GroupName = EachPlugSetting.GetSetting(PlugSettingKey.Group.ToString()),
                ToolName = EachPlugSetting.GetSetting(PlugSettingKey.ToolName.ToString()),
                ToolVersion = EachPlugSetting.GetSetting(PlugSettingKey.ToolVersion.ToString()),
                ToolDisplayName = EachPlugSetting.GetSetting(PlugSettingKey.ToolDisplayName.ToString()),
                //ToolCommandLineShema = EachPlugSetting.GetSetting(PlugSettingKey.CommandLineShema.ToString()),
                IsContainerPlug = EachPlugSetting.GetSetting(PlugSettingKey.IsContainerPlug.ToString()) == "true" ? true : false,
                //DefinitionId = RandomLongIdentityGenerator.GenerateId(),
                //IsRootPlug = true,
                //IsSystemInitPlug = true,
                CreateType = PlugCreateTypeEnum.SystemInitPlug.ToString(),
                Creater = PlugCreateTypeEnum.SystemInitPlug.ToString(),
                PlugSettingsJson = EachPlugSetting.GetSettingsJson()
            };
            List<BaseVariable>? varList = new List<BaseVariable>();
            if (PlugFromSetting.ToolName != null || PlugFromSetting.ToolDisplayName != null)
            {
                //Log.Information("获取工具信息：" + PlugFromSetting.ToolName + " " + PlugFromSetting.ToolDisplayName);
                var tool = await StationAndToolApiClient.GetToolByDisplayNameAsync(PlugFromSetting.ToolDisplayName ?? $"{PlugFromSetting.ToolName}({PlugFromSetting.ToolVersion})");
                PlugFromSetting.ToolCommandLineShema = tool?.CommandParameter ?? EachPlugSetting.GetSetting(PlugSettingKey.CommandLineShema.ToString());
                PlugFromSetting.Category = tool?.ToolType ?? EachPlugSetting.GetSetting(PlugSettingKey.Category.ToString());
                PlugFromSetting.ToolDisplayName = $"{tool?.ToolName}({tool?.ToolVersion})";
                PlugFromSetting.ToolId = tool?.Id;
                PlugFromSetting.ToolVersion = tool?.ToolVersion;
                PlugFromSetting.ToolName = tool?.ToolName;
                varList = tool?.GetVariablesFromToolCommand();
            }
            var varListJson = EachPlugSetting.GetSetting(PlugSettingKey.InitVariables.ToString());
            if (!string.IsNullOrEmpty(varListJson))
            {
                try
                {
                    varList?.AddRange(JsonSerializer.Deserialize<List<BaseVariable>?>(varListJson));
                }
                catch (Exception ex)
                {
                    Console.WriteLine(ex.Message);
                    CLog.Information(ex.Message);
                }
            }
            var varListFromSetting = EachPlugSetting.InitVariables;
            varList?.AddRange(varListFromSetting ?? []);


            if (varList != null)
            {
                foreach (var v in varList)
                {
                    //Log.Information(EachPlugSetting.PlugDisplayName + ":" + v.Name);
                    PlugFromSetting.PlugVariables.Add(new PlugVariable()
                    {
                        Name = v.Name,
                        Type = v.Type,
                        IsBrowsable = v.IsBrowsable,
                        IsArray = v.IsArray,
                        DefaultValue = v.DefaultValue,
                        Value = v.DefaultValue,  //将插头中定义的默认值作为值，因为前端参数表格渲染时，使用的是值字段
                        IsInitVariable = true
                    });
                }
            }
            //添加插头通用默认参数
            PlugFromSetting.PlugVariables.AddRange(PlugSharedInitVariables.GetInitVariables());


            if (AlreadyExistPlug != null)
            {
                Console.WriteLine("----------->>>>>update plug:" + PlugFromSetting.Type);
                //更新插头信息但不更新插入状态、ID等信息
                PlugFromSetting.DefinitionId = AlreadyExistPlug.DefinitionId;
                PlugFromSetting.ShowInPlugLibrary = AlreadyExistPlug.ShowInPlugLibrary;
                var result = await MainApiClient.UpdatePlugAsync(AlreadyExistPlug.Id, PlugFromSetting);
                //RootPlugs.Add(AlreadyExistPlug);
            }
            else
            {
                PlugFromSetting.DefinitionId = RandomLongIdentityGenerator.GenerateId();
                Console.WriteLine("===============>>>>>>>>>create plug:" + JsonSerializer.Serialize(PlugFromSetting));
                //创建插头
                var result = await MainApiClient.CreateNewPlug(PlugFromSetting);
                //Console.WriteLine(JsonSerializer.Serialize(result));
                RootPlugs.Add(result);
            }
        }


        //还需要根据关系表中插头动作的引用关系获取用于展示的“影子”插头
        // foreach (var p in RootPlugs)
        // {
        //     var tmpAction = await MainApiClient.GetPlugActionsByPlugIdAsync(p.Id);
        // }
        //ShadowPlugActions = await MainApiClient.GetPlugActionsByPlugIdAsync();

        //PlugActionItems = SelectedPlug?.PlugActions?.Where(a => a.ToolItemVersion == SelectedPlug.ToolVersion).ToList() ?? new();
        //PlugActionItems = await MainApiClient.GetPlugActionsByPlugIdAsync(SelectedPlug?.Id)??new();
        // PlugActionItems = AllPlugs.Where(
        //     t => t.CreateType == PlugCreateTypeEnum.ActionRootPlug.ToString() ||
        //     t.CreateType == PlugCreateTypeEnum.SystemInitActionPlug.ToString()
        // ).ToList();
        isItemLoading = false;
        Console.WriteLine("load sys init plug data done");
        UpdateFilteredPlugs();
        RefreshContainer();

    }


    private async Task GetAllRootPlugs()
    {
        RootPlugs.Clear();

        var AllPlugs = await MainApiClient.GetPlugs();
        //获取用户或管理员创建的源插头及源插头动作
        var _RootPlugs = AllPlugs.Where(t => 
            t.CreateType == PlugCreateTypeEnum.RootPlug.ToString() ||
            t.CreateType == PlugCreateTypeEnum.RootAdminPlug.ToString() ||
            t.CreateType == PlugCreateTypeEnum.ActionRootPlug.ToString()
        ).ToList();
        RootPlugs.AddRange(_RootPlugs);
        _RootPlugs = AllPlugs.Where(t=>            
            t.CreateType == PlugCreateTypeEnum.SystemInitPlug.ToString() ||
            t.CreateType == PlugCreateTypeEnum.SystemInitActionPlug.ToString()
        ).ToList();
        RootPlugs.AddRange(_RootPlugs);

        // 同步 _actionPanelPlug：如果 SelectedPlug 仍有效则保持，否则重置
        if (SelectedPlug != null)
        {
            var fresh = RootPlugs.FirstOrDefault(p => p.Id == SelectedPlug.Id);
            if (fresh != null)
            {
                SelectedPlug = fresh;
                _actionPanelPlug = fresh;
            }
            else
            {
                SelectedPlug = null;
                _actionPanelPlug = null;
            }
        }

        isItemLoading = false;
        Console.WriteLine("load all root plug data done");
        UpdateFilteredPlugs();
        RefreshContainer();

    }
    private async Task OnShowSystemToolChanged(bool value)
    {
        IsShowSystemTool = value;
        UpdateFilteredPlugs();
        RefreshContainer();
    }

    private void RefreshContainer()
    {
        if (RootPlugs.Count > 0 && SelectedPlug is null)
        {
            SelectedPlug = RootPlugs[0];
            _actionPanelPlug = RootPlugs[0];
        }
        // StateHasChanged is called by UpdateFilteredPlugs
    }

    private void UpdateFilteredPlugs()
    {
        var query = RootPlugs ?? new List<Plug>();

        // 根据显示系统插头选项过滤
        if (!IsShowSystemTool)
        {
            query = query.Where(p => p.CreateType != PlugCreateTypeEnum.SystemInitPlug.ToString()).ToList();
        }

        // 根据搜索关键字过滤
        if (!string.IsNullOrEmpty(Search))
        {
            var searchLower = Search.ToLower();
            query = query.Where(p =>
                (p.Name?.ToLower().Contains(searchLower) == true) ||
                (p.Type?.ToLower().Contains(searchLower) == true) ||
                (p.Id?.ToString().ToLower().Contains(searchLower) == true) ||
                (p.ToolVersion?.ToLower().Contains(searchLower) == true) ||
                (p.GroupName?.ToLower().Contains(searchLower) == true) ||
                (p.Description?.ToLower().Contains(searchLower) == true)
            ).ToList();
        }

        RootPlugsToShow = query.ToList(); // 确保创建新的列表引用
        StateHasChanged();
        _container.Refresh();
    }

    private async Task PlugInAll()
    {
        foreach (var p in RootPlugs)
        {
            if (!p.ShowInPlugLibrary)
            {
                p.ShowInPlugLibrary = true;
                await MainApiClient.UpdatePlugAsync(p.Id, p);
            }
        }
        UpdateFilteredPlugs();
        RefreshContainer();
        Snackbar.Add("已插入所有插头", Severity.Success);
    }
    private async Task PlugOutAll()
    {
        foreach (var p in RootPlugs)
        {
            if (p.ShowInPlugLibrary)
            {
                p.ShowInPlugLibrary = false;
                await MainApiClient.UpdatePlugAsync(p.Id, p);
            }
        }
        UpdateFilteredPlugs();
        RefreshContainer();
        Snackbar.Add("已拔出所有插头", Severity.Success);
    }

    private async void RemoveToolItem(Plug toolItem)
    {
        try
        {
            RootPlugs?.Remove(toolItem);
            RootPlugsToShow?.Remove(toolItem);
            await MainApiClient.DeletePlug(toolItem.Id);
            //await WorkflowDefinitionService.DeleteAsync(toolItem.DefinitionId);
            await ElsaEngineService.DeleteWorkflowByDefinitionId(toolItem.DefinitionId);
            UpdateFilteredPlugs();
            _container.Refresh();
            StateHasChanged();
            //await GetRootPlugs();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }

    }
