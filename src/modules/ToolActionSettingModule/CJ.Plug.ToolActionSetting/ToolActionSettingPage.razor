    private async Task LoadMcpTools()
    {
        try
        {
            var tools = await MainApiClient.GetAllMCPToolsAsync();
            _mcpTools = tools?.Where(t => t != null).Cast<MCPTool>().ToList() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"LoadMcpTools error: {ex.Message}");
            _mcpTools = new();
        }
    }

    private bool IsSelectedPlugPublished()
    {
        if (SelectedPlug == null || string.IsNullOrEmpty(SelectedPlug.DefinitionId))
            return false;
        return _mcpTools.Any(t => t.SourcePlugId == SelectedPlug.DefinitionId);
    }

    private async Task PublishSelectedPlug()
    {
        if (SelectedPlug == null)
        {
            Snackbar.Add("请先选择一个插头", Severity.Warning);
            return;
        }

        try
        {
            var mcpTool = new MCPTool
            {
                Name = SelectedPlug.Name,
                Description = SelectedPlug.Description ?? $"{SelectedPlug.Name} - 由插头管理发布",
                SourcePlugId = SelectedPlug.DefinitionId,
                IsEnabled = true,
                Version = SelectedPlug.ToolVersion ?? "1.0",
                Author = SelectedPlug.Creater ?? "System",
                Category = SelectedPlug.Category,
                GroupName = SelectedPlug.GroupName,
                Type = SelectedPlug.PlugTypeKey,
                ToolType = "Plugin",
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };

            var result = await MainApiClient.CreateMCPToolAsync(mcpTool);
            await LoadMcpTools();

            if (result != null)
            {
                var successParams = new DialogParameters<PublishSuccessDialog>
                {
                    { x => x.Tool, result },
                    { x => x.EntryVariables, SelectedPlug.PlugVariables }
                };
                await DialogService.ShowAsync<PublishSuccessDialog>("发布成功", successParams);
            }
            else
            {
                Snackbar.Add($"已发布 '{SelectedPlug.Name}' 为 MCP Tool", Severity.Success);
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"发布失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task UnpublishSelectedPlug()
    {
        if (SelectedPlug == null || string.IsNullOrEmpty(SelectedPlug.DefinitionId))
            return;

        var existing = _mcpTools.FirstOrDefault(t => t.SourcePlugId == SelectedPlug.DefinitionId);
        if (existing == null)
        {
            Snackbar.Add("该插头未发布", Severity.Warning);
            return;
        }

        try
        {
            await MainApiClient.DeleteMCPToolAsync(existing.Id);
            await LoadMcpTools();
            Snackbar.Add($"已取消发布 '{SelectedPlug.Name}' 的 MCP Tool", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"取消发布失败: {ex.Message}", Severity.Error);
        }
    }
