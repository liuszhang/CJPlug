    private void UpdateFilteredPlugs()
    {
        var query = RootPlugs ?? new List<Plug>();

        // 根据显示系统插头选项过滤
        if (!IsShowSystemTool)
        {
            query = query.Where(p =>
                p.CreateType != PlugCreateTypeEnum.SystemInitPlug.ToString() &&
                p.CreateType != PlugCreateTypeEnum.SystemInitActionPlug.ToString()
            ).ToList();
        }

        // 根据搜索关键字过滤
        if (!string.IsNullOrEmpty(Search))
        {
            var searchLower = Search.ToLower();
            query = query.Where(p =>
                (p.Name?.ToLower().Contains(searchLower) == true) ||
                (p.PlugTypeKey?.ToLower().Contains(searchLower) == true) ||
                (p.Id?.ToString().ToLower().Contains(searchLower) == true) ||
                (p.ToolVersion?.ToLower().Contains(searchLower) == true) ||
                (p.GroupName?.ToLower().Contains(searchLower) == true) ||
                (p.Description?.ToLower().Contains(searchLower) == true)
            ).ToList();
        }

        // 按插头类型分类：插头 vs 动作
        PlugItemsToShow = query.Where(p =>
            p.CreateType == PlugCreateTypeEnum.RootPlug.ToString() ||
            p.CreateType == PlugCreateTypeEnum.RootAdminPlug.ToString() ||
            p.CreateType == PlugCreateTypeEnum.SystemInitPlug.ToString()
        ).ToList();

        // 按显示分组排序，组内按 SortOrder 再按名称排序
        var groupOrder = PlugCategoryGroupHelper.GroupOrder;
        PlugItemsToShow = PlugItemsToShow
            .OrderBy(p => Array.IndexOf(groupOrder, PlugCategoryGroupHelper.GetDisplayGroup(p.Category)))
            .ThenBy(p => p.SortOrder ?? int.MaxValue)
            .ThenBy(p => p.Name)
            .ToList();

        // 构建分组字典
        _groupedPlugItems = PlugItemsToShow
            .GroupBy(p => PlugCategoryGroupHelper.GetDisplayGroup(p.Category))
            .OrderBy(g => Array.IndexOf(groupOrder, g.Key))
            .ToDictionary(g => g.Key, g => g.ToList());

        ActionItemsToShow = query.Where(p =>
            p.CreateType == PlugCreateTypeEnum.ActionRootPlug.ToString() ||
            p.CreateType == PlugCreateTypeEnum.SystemInitActionPlug.ToString()
        ).ToList();

        AllPlugsToShow = PlugItemsToShow.Concat(ActionItemsToShow).ToList();
        RootPlugsToShow = AllPlugsToShow;
        StateHasChanged();
        _container.Refresh();
    }

