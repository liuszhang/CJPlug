<PageTitle>工具动作配置</PageTitle>


<MudContainer MaxWidth="MaxWidth.False">


    <div id="instance-file-upload-button-wrapper" class="d-none">
        <MudFileUpload T="IReadOnlyList<IBrowserFile>" />
    </div>
    <MudStack Row AlignItems="AlignItems.Center">
        <MudButton OnClick="CreateToolItem" StartIcon="@Icons.Material.Filled.Create" Variant="Variant.Outlined" Color="Color.Primary">创建插头</MudButton>
        <MudButton OnClick="RefreshContainer" StartIcon="@Icons.Material.Filled.AppRegistration" Variant="Variant.Filled" Color="Color.Primary">刷新</MudButton>

        @* <MudButton StartIcon="@Icons.Material.Filled.NewReleases" Variant="Variant.Filled" Color="Color.Primary">创建接口类插头</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Javascript" Variant="Variant.Filled" Color="Color.Primary">创建脚本类插头</MudButton> *@
        <MudButton StartIcon="@Icons.Material.Filled.FileUpload" Variant="Variant.Filled" Color="Color.Primary">导入</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.FileDownload" Variant="Variant.Filled" Color="Color.Primary">导出</MudButton>
        <MudButton OnClick="GetSysInitRootPlugs" StartIcon="@Icons.Material.Filled.DevicesFold" Variant="Variant.Outlined" Color="Color.Primary">重置默认插头</MudButton>
        <MudSpacer></MudSpacer>
        <MudTextField T="string"
        Margin="Margin.Dense"
        Placeholder="可搜索： 名称, ID, 版本, 流程"
        Variant="Variant.Outlined"
        AdornmentIcon="@Icons.Material.Outlined.Search"
        Adornment="Adornment.End"
        Clearable="true"
        DebounceInterval="1500"
        Immediate="true"
        Class="me-3" />
    </MudStack>

    <MudDivider />

    <MudDropContainer T="Plug" Items="RootPlugsToShow" @ref="_container" ItemsSelector="@((item, dropzone) => item.Tag == dropzone)" ItemDropped="ItemDroped">


        <ChildContent>
            <CascadingValue Value="SelectedPlug">

                <RadzenSplitter>
                    <RadzenSplitterPane Size="25%" Min="200px" Collapsed="PlugListPanelCollapsed">

                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.Center">
                            <MudButton OnClick="PlugInAll" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">一键插入</MudButton>
                            <MudButton OnClick="PlugOutAll" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">一键拔出</MudButton>
                            <MudCheckBox Dense @bind-Value="IsShowSystemTool" @bind-Value:after="RefreshContainer" Label="显示系统插头" Color="Color.Primary"></MudCheckBox>

                        </MudStack>
                        <VerticalWell ExtraPadding="100">


                            <MudStack AlignItems="AlignItems.Stretch">

                                @if (isItemLoading)
                                {
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true"></MudProgressCircular>
                                }
                                else
                                {
                                    <MudList T="Plug" @bind-SelectedValue="SelectedPlug" Color="Color.Primary" SelectionMode="SelectionMode.SingleSelection">
                                        <MudDropZone T="Plug" Identifier="@("Plug")" AllowReorder="true">

                                        </MudDropZone>
                                    </MudList>
                                }

                            </MudStack>
                        </VerticalWell>
                    </RadzenSplitterPane>
                    <RadzenSplitterPane Size="75%" Min="200px">
                        <RadzenSplitter Orientation="Orientation.Vertical" Resize="OnResize">
                            <RadzenSplitterPane Size="65%" Min="100px">
                                <RadzenSplitter>
                                    <RadzenSplitterPane Size="70%" Min="100px">
                                        <MudStack Style="height:100%">                                            
                                            @* <MudStack Row>
                                                <MudButton Size="Size.Small" Variant=Variant.Outlined Color=Color.Primary >保存</MudButton>
                                                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.ZoomOutMap" Color=Color.Primary></MudIconButton>
                                                <MudButton OnClick="@(() => StateHasChanged())" Size="Size.Small" Variant=Variant.Outlined Color=Color.Primary >刷新</MudButton>
                                                <MudTextField @bind-Value="PlugId"></MudTextField>

                                            </MudStack> *@
                                            <CascadingValue Value="SetMaxGuiDesignerNotify">

                                                <GUIEditor></GUIEditor>

                                            </CascadingValue>
                                        </MudStack>

                                    </RadzenSplitterPane>
                                    <RadzenSplitterPane Size="30%" Min="100px" Collapsed="PlugActionPanelCollapsed">
                                        <VerticalPercentWell SplitterPanelPercent="@(100-SplitterPanelPercent)">
                                            <MudStack AlignItems="AlignItems.Stretch">
                                                @if (isActionLoading)
                                                {
                                                    <MudProgressLinear Indeterminate="true"></MudProgressLinear>
                                                }
                                                <MudList T="Plug" @bind-SelectedValue="SelectedToolActionItem" Color="Color.Success" CheckBoxColor="Color.Tertiary">
                                                    <MudDropZone Style="height:100%" T="Plug" Identifier="@(SelectedPlug?.DefinitionId + "Action")" AllowReorder="true">
                                                        <MudStack Spacing="0" Justify="Justify.Center" AlignItems="AlignItems.Center">
                                                            <MudStack Row>
                                                                <MudButton OnClick="CreatePlugActionItem" Disabled="@(SelectedPlug == null)" StartIcon="@Icons.Material.Filled.Create" Variant="Variant.Outlined" Color="Color.Primary">创建动作</MudButton>
                                                                <MudButton OnClick="CreatePlugActionItem" Disabled="@(SelectedPlug == null)" StartIcon="@Icons.Material.Filled.Create" Variant="Variant.Outlined" Color="Color.Primary">关联现有</MudButton>
                                                            </MudStack>
                                                            @if (SelectedPlug != null)
                                                            {
                                                                <MudText Typo="Typo.body2">---@SelectedPlug.Name @SelectedPlug.ToolVersion 动作清单---</MudText>
                                                                <MudText Typo="Typo.body2" Color="Color.Info">(拖动插头至此处添加动作)</MudText>
                                                            }
                                                        </MudStack>
                                                    </MudDropZone>
                                                </MudList>


                                            </MudStack>
                                        </VerticalPercentWell>
                                    </RadzenSplitterPane>

                                </RadzenSplitter>
                            </RadzenSplitterPane>
                            <RadzenSplitterPane Size="35%" Min="100px" Collapsed="PlugVariablePanelCollapsed">
                                <PlugVariableDataGrid Plug="SelectedPlug" HeightPercent="SplitterPanelPercent"></PlugVariableDataGrid>
                            </RadzenSplitterPane>
                        </RadzenSplitter>
                    </RadzenSplitterPane>



                </RadzenSplitter>

            </CascadingValue>

        </ChildContent>


        <ItemRenderer>

            @if (context.CreateType == PlugCreateTypeEnum.SystemInitPlug.ToString() && IsShowSystemTool == false)
            {

            }
            else if (context.Tag == "Plug")
            {
                <MudListItem T="Plug" Value="@context">
                    <TASPlugItem Plug="@context" OnDelete="() => RemoveToolItem(context)" OnChangeVersion="() => ChangeToolVersion(context)"></TASPlugItem>
                </MudListItem>
            }
            else if (context.Tag.Contains("Action"))
            {
                <MudListItem T="Plug" Value="@context">
                    <TASPlugActionItem SelectedPlug="SelectedPlug" PlugActionItem="@context" OnDelete="() => RemovePlugActionItem(context)"></TASPlugActionItem>

                </MudListItem>
            }


        </ItemRenderer>

    </MudDropContainer>



</MudContainer>


@code {

    private MudDropContainer<Plug> _container;
