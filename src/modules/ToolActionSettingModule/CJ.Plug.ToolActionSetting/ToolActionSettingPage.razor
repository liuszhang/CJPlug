<PageTitle>工具动作配置</PageTitle>


<MudContainer MaxWidth="MaxWidth.False">


    <div id="instance-file-upload-button-wrapper" class="d-none">
        <MudFileUpload T="IReadOnlyList<IBrowserFile>" />
    </div>
    <MudStack Row AlignItems="AlignItems.Center">
        <MudButton OnClick="CreateToolItem" StartIcon="@Icons.Material.Filled.Create" Variant="Variant.Outlined" Color="Color.Primary">创建插头</MudButton>
        <MudButton OnClick="PlugInAll" Variant="Variant.Outlined" Color="Color.Primary">一键插入</MudButton>
        <MudButton OnClick="PlugOutAll" Variant="Variant.Outlined" Color="Color.Primary">一键拔出</MudButton>
       
        @if (IsSelectedPlugPublished())
        {
            <MudButton OnClick="UnpublishSelectedPlug" StartIcon="@Icons.Material.Filled.CancelPresentation" Variant="Variant.Outlined" Color="Color.Warning">取消发布MCP</MudButton>
        }
        else
        {
            <MudButton OnClick="PublishSelectedPlug" Disabled="@(SelectedPlug == null)" StartIcon="@Icons.Material.Filled.Publish" Variant="Variant.Outlined" Color="Color.Tertiary">发布为MCP Tool</MudButton>
        }
        <MudButton OnClick="GetSysInitRootPlugs" StartIcon="@Icons.Material.Filled.DevicesFold" Variant="Variant.Outlined" Color="Color.Primary">重置默认插头</MudButton>
        <MudButton OnClick="ShowImportDialog" StartIcon="@Icons.Material.Filled.FileUpload" Variant="Variant.Filled" >导入</MudButton>
        <MudButton OnClick="ShowExportDialog" StartIcon="@Icons.Material.Filled.FileDownload" Variant="Variant.Filled" >导出</MudButton>
        <MudButton OnClick="RefreshContainer" StartIcon="@Icons.Material.Filled.Refresh" Variant="Variant.Filled" >刷新</MudButton>

        @* <MudSpacer></MudSpacer> *@
        <MudTextField T="string"
        Margin="Margin.Dense"
        Placeholder="可搜索： 名称, ID, 版本, 流程"
        Variant="Variant.Outlined"
        AdornmentIcon="@Icons.Material.Outlined.Search"
        Adornment="Adornment.End"
        Clearable="true"
        Immediate="true"
        Class="me-3"
        @bind-Value="Search" />
    </MudStack>

    <MudDivider />

    <MudDropContainer T="Plug" Items="AllPlugsToShow" @ref="_container" ItemsSelector="@IsItemInZone" ItemPicked="@((args) => { _isDragging = true; _selectionUpdateCts?.Cancel(); StateHasChanged(); })" ItemDropped="ItemDroped" Style="height: calc(100vh - 120px);">


        <ChildContent>
            <CascadingValue Value="SelectedPlug">

                <RadzenSplitter Style="height: 100%;">
                    <RadzenSplitterPane Size="25%" Min="200px" Collapsed="PlugListPanelCollapsed">

                        <VerticalWell ExtraPadding="100">

                            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                @* TODO: 下拉框暂时隐藏，后续根据需求恢复 *@
                                @* <MudSelect T="int" Dense Margin="Margin.Dense" Variant="Variant.Outlined" @bind-Value="_plugListTabIndex" Style="width:120px">
                                    <MudSelectItem Value="0">插头</MudSelectItem>
                                    <MudSelectItem Value="1">动作</MudSelectItem>
                                </MudSelect> *@
                                @if (_plugListTabIndex == 0)
                                {
                                    <MudCheckBox T="bool" Dense Value="IsShowSystemTool" ValueChanged="OnShowSystemToolChanged" Label="显示系统插头" Color="Color.Primary"></MudCheckBox>
                                }
                            </MudStack>

                            <MudStack AlignItems="AlignItems.Stretch">
                                @if (isItemLoading)
                                {
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true"></MudProgressCircular>
                                }
                                else if (_plugListTabIndex == 0)
                                {
                                    <MudExpansionPanels>
                                        @foreach (var group in _groupedPlugItems)
                                        {
                                            var groupKey = group.Key;
                                            var isCollapsed = _collapsedGroups.Contains(groupKey);
                                            <MudExpansionPanel Text="@($"{groupKey} ({group.Value.Count})")"
                                                               IsExpanded="@(!isCollapsed)"
                                                               IsExpandedChanged="@((bool expanded) => OnGroupToggled(groupKey, expanded))">
                                                <ChildContent>
                                                    <MudList T="Plug" SelectedValue="SelectedPlug"
                                                             SelectedValueChanged="OnPlugSelected"
                                                             Color="Color.Primary"
                                                             SelectionMode="SelectionMode.SingleSelection">
                                                    <div data-sort-group="@groupKey">
                                                        <MudDropZone T="Plug" Identifier='@("Plug_" + groupKey)' AllowReorder="true">
                                                        </MudDropZone>
                                                    </div>
                                                    </MudList>
                                                </ChildContent>
                                            </MudExpansionPanel>
                                        }
                                    </MudExpansionPanels>
                                }
                                else
                                {
                                    <MudList T="Plug" SelectedValue="SelectedPlug" SelectedValueChanged="OnPlugSelected" Color="Color.Primary" SelectionMode="SelectionMode.SingleSelection">
                                        @foreach (var actionItem in ActionItemsToShow)
                                        {
                                            <MudListItem T="Plug" Value="@actionItem">
                                                <TASPlugActionItem SelectedPlug="SelectedPlug" PlugActionItem="@actionItem" OnDelete="() => RemovePlugActionItem(actionItem)"></TASPlugActionItem>
                                            </MudListItem>
                                        }
                                    </MudList>
                                }
                            </MudStack>

                        </VerticalWell>
                    </RadzenSplitterPane>
                    <RadzenSplitterPane Size="75%" Min="200px">
                        <RadzenSplitter Style="height: 100%;" Orientation="Orientation.Vertical" Resize="OnResize">
                            <RadzenSplitterPane Size="65%" Min="100px">
                                <RadzenSplitter Style="height: 100%;">
                                    <RadzenSplitterPane Size="70%" Min="100px">
                                        <MudStack Style="height:100%;overflow:auto">                                            
                                            @* <MudStack Row>
                                                <MudButton Size="Size.Small" Variant=Variant.Outlined Color=Color.Primary >保存</MudButton>
                                                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.ZoomOutMap" Color=Color.Primary></MudIconButton>
                                                <MudButton OnClick="@(() => StateHasChanged())" Size="Size.Small" Variant=Variant.Outlined Color=Color.Primary >刷新</MudButton>
                                                <MudTextField @bind-Value="PlugId"></MudTextField>

                                            </MudStack> *@
                                            <CascadingValue Value="SetMaxGuiDesignerNotify">

                                                <GUIEditor></GUIEditor>

                                            </CascadingValue>
                                        </MudStack>

                                    </RadzenSplitterPane>
                                    <RadzenSplitterPane Size="30%" Min="100px" Collapsed="PlugActionPanelCollapsed">
                                        <VerticalPercentWell SplitterPanelPercent="@(100-SplitterPanelPercent)">
                                            <MudStack AlignItems="AlignItems.Stretch">
                                                @if (isActionLoading)
                                                {
                                                    <MudProgressLinear Indeterminate="true"></MudProgressLinear>
                                                }
                                            <MudList T="Plug" @bind-SelectedValue="SelectedToolActionItem" Color="Color.Success" CheckBoxColor="Color.Tertiary">
                                                    <MudDropZone Style="height:100%" T="Plug" Identifier="@(_actionPanelPlug?.DefinitionId + "Action")" AllowReorder="true">
                                                        <MudStack Spacing="0" Justify="Justify.Center" AlignItems="AlignItems.Center">
                                                            <MudStack Row>
                                                                <MudButton OnClick="CreatePlugActionItem" Disabled="@(_actionPanelPlug == null)" StartIcon="@Icons.Material.Filled.Create" Variant="Variant.Outlined" Color="Color.Primary">创建动作</MudButton>
                                                                <MudButton OnClick="CreatePlugActionItem" Disabled="@(_actionPanelPlug == null)" StartIcon="@Icons.Material.Filled.Create" Variant="Variant.Outlined" Color="Color.Primary">关联现有</MudButton>
                                                            </MudStack>
                                                            @if (_actionPanelPlug != null)
                                                            {
                                                                <MudText Typo="Typo.body2">---@_actionPanelPlug.Name @_actionPanelPlug.ToolVersion 动作清单---</MudText>
                                                                <MudText Typo="Typo.body2" Color="Color.Info">@( _isDragging ? "(拖拽中...)" : "(拖动插头至此处添加动作)" )</MudText>
                                                            }
                                                        </MudStack>
                                                    </MudDropZone>
                                                </MudList>


                                            </MudStack>
                                        </VerticalPercentWell>
                                    </RadzenSplitterPane>

                                </RadzenSplitter>
                            </RadzenSplitterPane>
                            <RadzenSplitterPane Size="35%" Min="100px" Collapsed="PlugVariablePanelCollapsed">
                                <PlugVariableDataGrid Plug="SelectedPlug" HeightPercent="SplitterPanelPercent"></PlugVariableDataGrid>
                            </RadzenSplitterPane>
                        </RadzenSplitter>
                    </RadzenSplitterPane>



                </RadzenSplitter>

            </CascadingValue>

        </ChildContent>


        <ItemRenderer>

            @if (context.CreateType == PlugCreateTypeEnum.SystemInitPlug.ToString() && IsShowSystemTool == false)
            {

            }
            else if (context.Tag == "Plug")
            {
                <MudListItem T="Plug" Value="@context" data-plug-id="@(context.Id?.ToString())">
                    <TASPlugItem Plug="@context" OnDelete="() => RemoveToolItem(context)" OnChangeVersion="() => ChangeToolVersion(context)"></TASPlugItem>
                </MudListItem>
            }
            else if (context.Tag.Contains("Action"))
            {
                <MudListItem T="Plug" Value="@context">
                    <TASPlugActionItem SelectedPlug="SelectedPlug" PlugActionItem="@context" OnDelete="() => RemovePlugActionItem(context)"></TASPlugActionItem>

                </MudListItem>
            }


        </ItemRenderer>

    </MudDropContainer>



</MudContainer>


@code {

    private MudDropContainer<Plug> _container;
    private Plug? _actionPanelPlug;
    private bool _isDragging = false;
    private CancellationTokenSource? _selectionUpdateCts;
    public double? Amount { get; set; }
    public int? Weight { get; set; }
    private string _search;
    public string Search
    {
        get => _search;
        set
        {
            _search = value;
            UpdateFilteredPlugs();
        }
    }
    public bool isItemLoading { get; set; } = true;
    public bool isActionLoading { get; set; } = false;
    public bool IsShowSystemTool { get; set; } = true;
    public string PlugId = "0";

    public bool ReadOnly;

    private List<Plug>? RootPlugs { get; set; } = new();
    private List<Plug>? RootPlugsToShow { get; set; } = new();
    private List<Plug>? PlugItemsToShow { get; set; } = new();
    private List<Plug>? ActionItemsToShow { get; set; } = new();
    private List<Plug>? AllPlugsToShow { get; set; } = new();
    private Dictionary<string, List<Plug>> _groupedPlugItems = new();
    private HashSet<string> _collapsedGroups = new();
    private int _plugListTabIndex = 0;
    private List<Plug>? ShadowPlugActions { get; set; } = new();
    private Plug? SelectedPlug { get; set; }
    private Plug? SelectedToolActionItem { get; set; }
    private List<MCPTool> _mcpTools = new();

    private bool PlugListPanelCollapsed { get; set; } = false;
    private bool PlugVariablePanelCollapsed { get; set; } = false;
    private bool PlugActionPanelCollapsed { get; set; } = true; @* 默认折叠，后续如需恢复改为 false *@
    public double SplitterPanelPercent { get; set; } = 35;

    public SetMaxGuiDesignerNotify? SetMaxGuiDesignerNotify { get; set; }

    void OnResize(RadzenSplitterResizeEventArgs args)
    {
        //Log.Information($"Pane {args.PaneIndex} Resize (New size {args.NewSize})");
        SplitterPanelPercent = 100 - args.NewSize;
    }

    private async Task ItemDroped(MudItemDropInfo<Plug> dropItem)
    {
        // _isDragging 保持 true，防止 drop 后 MudBlazor 的 SelectedValueChanged 选中被拖拽插头
        Console.WriteLine(dropItem.DropzoneIdentifier);
        var prevPlugId = _actionPanelPlug?.Id;

        // 情况1：插头拖入 Action 区域 → 创建新动作插头
        if (dropItem.DropzoneIdentifier.Contains("Action") && dropItem.Item.Tag == "Plug")
        {
            var newPlug = dropItem.Item;
            newPlug.Id = null;
            newPlug.Tag = dropItem.DropzoneIdentifier;
            newPlug.CreateType = PlugCreateTypeEnum.ActionRootPlug.ToString();
            foreach (var variable in newPlug.PlugVariables)
            {
                variable.Id = null;
            }
            var result = await MainApiClient.CreateNewPlug(newPlug);
            Console.WriteLine(JsonSerializer.Serialize(result));

            await GetAllRootPlugs();
        }
        // 情况2：同组内拖拽重排 → 持久化排序
        // MudBlazor 内部维护自己的一份排序副本；_container.Items 和 @bind-Items
        // 返回的都是 Blazor 参数值（拖拽前的列表），不反映内部重排后的顺序。
        // 必须通过 JS 读取 DOM 中 MudListItem 的实际顺序来获取正确的拖拽后排列。
        else if (dropItem.DropzoneIdentifier.StartsWith("Plug_") && dropItem.Item.Tag == "Plug")
        {
            var groupKey = dropItem.DropzoneIdentifier.Substring("Plug_".Length);

            try
            {
                // 从 DOM 读取 MudBlazor 内部重排后的实际顺序
                var orderedIds = await JSRuntime.InvokeAsync<List<int>>("getPlugSortOrder", groupKey);
                if (orderedIds == null || orderedIds.Count <= 1)
                    return;

                Console.WriteLine($"[SortOrder] DOM 返回 {groupKey} 组顺序: {string.Join(", ", orderedIds)}");

                var sortOrders = orderedIds
                    .Select((id, index) => new PlugSortOrderDto { Id = id, SortOrder = index })
                    .Where(dto => dto.Id > 0)
                    .ToList();

                if (sortOrders.Count == 0)
                    return;

                await MainApiClient.BatchUpdateSortOrdersAsync(sortOrders);
                // 同步更新内存中的 SortOrder
                foreach (var dto in sortOrders)
                {
                    var memPlug = RootPlugs.FirstOrDefault(p => p.Id == dto.Id);
                    if (memPlug != null)
                        memPlug.SortOrder = dto.SortOrder;
                }
                // 从已更新 SortOrder 的 RootPlugs 重建 AllPlugsToShow
                UpdateFilteredPlugs();
                Console.WriteLine($"[SortOrder] 已保存 {groupKey} 组排序，共 {sortOrders.Count} 项");
                Snackbar.Add($"{groupKey} 组排序已保存", Severity.Success, config => { config.VisibleStateDuration = 1500; });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[SortOrder] 排序保存失败: {ex.Message}");
                Snackbar.Add($"排序保存失败: {ex.Message}", Severity.Error);
            }
        }

        // 用 Id 从刷新后的列表中找回新对象引用，保证 MudList 能匹配高亮
        if (prevPlugId != null)
        {
            var fresh = RootPlugs.FirstOrDefault(p => p.Id == prevPlugId);
            if (fresh != null)
            {
                SelectedPlug = fresh;
                _actionPanelPlug = fresh;
            }
        }

        _isDragging = false;
        StateHasChanged();
    }

    private void OnGroupToggled(string groupKey, bool expanded)
    {
        if (expanded)
            _collapsedGroups.Remove(groupKey);
        else
            _collapsedGroups.Add(groupKey);
    }

    private bool IsItemInZone(Plug item, string dropzone)
    {
        if (item.Tag == "Plug" && dropzone.StartsWith("Plug_"))
            return $"Plug_{PlugCategoryGroupHelper.GetDisplayGroup(item.Category)}" == dropzone;
        return item.Tag == dropzone;
    }

    private async Task OnPlugSelected(Plug? plug)
    {
        SelectedPlug = plug;

        if (_isDragging)
        {
            // 正在拖拽中，不更新动作面板
            return;
        }

        // 延迟100ms更新，如果在100ms内进入了拖拽状态则取消更新
        _selectionUpdateCts?.Cancel();
        _selectionUpdateCts = new CancellationTokenSource();
        var token = _selectionUpdateCts.Token;
        try
        {
            await Task.Delay(100, token);
            if (!token.IsCancellationRequested)
            {
                _actionPanelPlug = plug;
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { }
    }

    protected override async Task OnInitializedAsync()
    {
        //GlobalEventBus.OnMaxGuiDesigner += OnMaxGuiDesigner;
        EventCallback<bool> SetMaxGuiDesigner = EventCallback.Factory.Create<bool>(this, OnMaxGuiDesigner);
        SetMaxGuiDesignerNotify = new SetMaxGuiDesignerNotify(SetMaxGuiDesigner);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 注入 JS 辅助函数：从 DOM 读取 MudBlazor 内部重排后的插头顺序
            await JSRuntime.InvokeVoidAsync("eval",
                "window.getPlugSortOrder=function(g){" +
                "var w=document.querySelector('div[data-sort-group=\"'+g+'\"]');" +
                "if(!w)return[];" +
                "var r=[];" +
                "w.querySelectorAll('[data-plug-id]').forEach(function(e){" +
                "var i=e.getAttribute('data-plug-id');if(i)r.push(parseInt(i))" +
                "});" +
                "return r;}");
            await GetAllRootPlugs();
            await LoadMcpTools();
            _actionPanelPlug = SelectedPlug;
            StateHasChanged();

            // 监听图站执行事件：直接运行插头时触发远程桌面弹窗
            HubConnectionManagerService._hubConnection.Remove(LogTypeEnum.StationExecuting.ToString());
            HubConnectionManagerService._hubConnection.On(
                LogTypeEnum.StationExecuting.ToString(),
                new[] { typeof(string), typeof(string), typeof(string), typeof(string) },
                (args, _) =>
                {
                    var pdzId = (string?)args[0];
                    var plugDefinitionId = (string?)args[1];
                    var stationIp = (string?)args[2];
                    var protocol = (string?)args[3] ?? "vnc";
                    if (string.IsNullOrEmpty(stationIp)) return Task.CompletedTask;
                    InvokeAsync(async () =>
                    {
                        var host = stationIp;
                        try { host = new Uri(stationIp).Host; } catch { }
                        Snackbar.Add($"图站 {host} 开始执行，正在打开远程桌面 ({protocol})...", Severity.Info);
                        await JSRuntime.InvokeVoidAsync("open", $"/remote/{host}/{protocol}", "_blank");
                    });
                    return Task.CompletedTask;
                },
                null);
        }
    }

    public void Dispose()
    {
        HubConnectionManagerService._hubConnection.Remove(LogTypeEnum.StationExecuting.ToString());
    }

    private void OnMaxGuiDesigner(bool isMax)
    {
        InvokeAsync(() =>
        {
            //Console.WriteLine("start max flow designer");
            PlugListPanelCollapsed = isMax;
            PlugVariablePanelCollapsed = isMax;
            PlugActionPanelCollapsed = isMax;
            StateHasChanged();
        });
    }

    private async Task GetUserCreatedRootPlugs()
    {
        //isItemLoading = true;
        var AllPlugs = await MainApiClient.GetPlugs();
        //获取用户或管理员创建的源插头及源插头动作
        //var UserCreatedRootPlugs = AllPlugs.Where(t => t.IsRootPlug == true && t.IsSystemInitPlug == false).ToList();
        var UserCreatedRootPlugs = AllPlugs.Where(
            t => t.CreateType == PlugCreateTypeEnum.RootPlug.ToString() ||
            t.CreateType == PlugCreateTypeEnum.RootAdminPlug.ToString() ||
            t.CreateType == PlugCreateTypeEnum.ActionRootPlug.ToString() ||
            t.CreateType == PlugCreateTypeEnum.SystemInitActionPlug.ToString()
        ).ToList();
        RootPlugs.AddRange(UserCreatedRootPlugs);
        isItemLoading = false;
        Console.WriteLine("load user root plug data done");
        UpdateFilteredPlugs();
        RefreshContainer();

    }

    private async Task GetSysInitRootPlugs()
    {        
        var AllPlugs = await MainApiClient.GetPlugs();
        //获取系统依赖注入的插头
        foreach (var pcsc in PlugCommonSettingContent)
        {
            if (pcsc == null)
            {
                Console.WriteLine("pcsc is null");
                continue;
            }
            var EachPlugSetting = await pcsc.GetPlugBaseSetting();
            if (EachPlugSetting == null)
            {
                continue;
            }
            var AlreadyExistPlug = AllPlugs.FirstOrDefault(t => t.PlugTypeKey == EachPlugSetting.PlugTypeKey);
            //Console.WriteLine(EachPlugSetting.PlugDisplayName + ":" + JsonSerializer.Serialize(EachPlugSetting));
            //Log.Information(EachPlugSetting.PlugDisplayName + ":" + JsonSerializer.Serialize(EachPlugSetting));
            var PlugFromSetting = new Plug
            {
                Name = EachPlugSetting.PlugDisplayName,
                PlugTypeKey = EachPlugSetting.PlugTypeKey,
                Category = EachPlugSetting.GetSetting(PlugSettingKey.Category.ToString()),
                GroupName = EachPlugSetting.GetSetting(PlugSettingKey.Group.ToString()),
                ToolName = EachPlugSetting.GetSetting(PlugSettingKey.ToolName.ToString()),
                ToolVersion = EachPlugSetting.GetSetting(PlugSettingKey.ToolVersion.ToString()),
                ToolDisplayName = EachPlugSetting.GetSetting(PlugSettingKey.ToolDisplayName.ToString()),
                //ToolCommandLineShema = EachPlugSetting.GetSetting(PlugSettingKey.CommandLineShema.ToString()),
                IsContainerPlug = EachPlugSetting.GetSetting(PlugSettingKey.IsContainerPlug.ToString()) == "true" ? true : false,
                //DefinitionId = RandomLongIdentityGenerator.GenerateId(),
                //IsRootPlug = true,
                //IsSystemInitPlug = true,
                CreateType = PlugCreateTypeEnum.SystemInitPlug.ToString(),
                Creater = PlugCreateTypeEnum.SystemInitPlug.ToString(),
                PlugSettingsJson = EachPlugSetting.GetSettingsJson()
            };
            List<BaseVariable>? varList = new List<BaseVariable>();
            if (PlugFromSetting.ToolName != null || PlugFromSetting.ToolDisplayName != null)
            {
                //Log.Information("获取工具信息：" + PlugFromSetting.ToolName + " " + PlugFromSetting.ToolDisplayName);
                var tool = await MainApiClient.GetToolByDisplayNameAsync(PlugFromSetting.ToolDisplayName ?? $"{PlugFromSetting.ToolName}({PlugFromSetting.ToolVersion})");
                PlugFromSetting.ToolCommandLineShema = tool?.CommandParameter ?? EachPlugSetting.GetSetting(PlugSettingKey.CommandLineShema.ToString());
                PlugFromSetting.Category = tool?.ToolType ?? EachPlugSetting.GetSetting(PlugSettingKey.Category.ToString());
                PlugFromSetting.ToolDisplayName = $"{tool?.ToolName}({tool?.ToolVersion})";
                PlugFromSetting.ToolId = tool?.Id;
                PlugFromSetting.ToolVersion = tool?.ToolVersion;
                PlugFromSetting.ToolName = tool?.ToolName;
                varList = tool?.GetVariablesFromToolCommand();
            }
            var varListJson = EachPlugSetting.GetSetting(PlugSettingKey.InitVariables.ToString());
            if (!string.IsNullOrEmpty(varListJson))
            {
                try
                {
                    varList?.AddRange(JsonSerializer.Deserialize<List<BaseVariable>?>(varListJson));
                }
                catch (Exception ex)
                {
                    Console.WriteLine(ex.Message);
                    CLog.Information(ex.Message);
                }
            }
            var varListFromSetting = EachPlugSetting.InitVariables;
            varList?.AddRange(varListFromSetting ?? []);


            if (varList != null)
            {
                foreach (var v in varList)
                {
                    //Log.Information(EachPlugSetting.PlugDisplayName + ":" + v.Name);
                    PlugFromSetting.PlugVariables.Add(new PlugVariable()
                    {
                        Name = v.Name,
                        Type = v.Type,
                        IsBrowsable = v.IsBrowsable,
                        IsArray = v.IsArray,
                        Value = v.Value,  // 从InitVariables传递预设值
                        IsInitVariable = true
                    });
                }
            }
            //添加插头通用默认参数
            PlugFromSetting.PlugVariables.AddRange(PlugSharedInitVariables.GetInitVariables());


            if (AlreadyExistPlug != null)
            {
                Console.WriteLine("----------->>>>>update plug:" + PlugFromSetting.PlugTypeKey);
                //更新插头信息但不更新插入状态、ID等信息
                PlugFromSetting.DefinitionId = AlreadyExistPlug.DefinitionId;
                PlugFromSetting.ShowInPlugLibrary = AlreadyExistPlug.ShowInPlugLibrary;
                var result = await MainApiClient.UpdatePlugAsync(AlreadyExistPlug.Id, PlugFromSetting);
