@using CJ.Plug.Models.Plug
@using CJ.Plug.Models.Shared
@using CJ.Plug.Models.Station
@using CJ.Plug.Models.VariableType
@using CJ.Plug.Models.VariableType.TypeSettings
@using CJ.Plug.SharedPages
@using CJ.Plug.SharedPages.Contracts
@using CJ.Plug.SharedPages.Variable
@using CJ.Plug.VariableUIHandler.Components
@using CJ.Plug.VariableUIHandler.Models
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.RegularExpressions

@inject MainApiClient MainApiClient
@inject IDialogService DialogService

<MudDivider Class="my-2"></MudDivider>
<MudText Typo="Typo.subtitle2" Color="Color.Primary">桌面工具配置</MudText>

@{
    bool showTabs = ExistingPlug == null
        || (!ExistingPlug.ToolId.HasValue
            && string.IsNullOrEmpty(ExistingPlug.GetVariableValue("ToolPath"))
            && !(ExistingPlug.ToolVersionPath?.StartsWith("uploaded://") ?? false));
}

@if (showTabs)
{
    @* 页签模式：新建插头 或 编辑时未能匹配已有配置方式，回退到完整页签展示 *@
    <MudTabs Elevation="0" ApplyEffectsToContainer="true" PanelClass="pa-2" @bind-ActivePanelIndex="_activeTabIndex">
        <MudTabPanel Text="从工具库选择">
            <MudSelect T="Tool" Value="SelectedTool" ValueChanged="OnSelectedToolChanged" Label="选择工具" Clearable
                       Placeholder="选择一个已配置的工具" Margin="Margin.Dense" Dense Variant="Variant.Outlined">
                @foreach (var t in Tools)
                {
                    <MudSelectItem Value="t">
                        <MudStack Row AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.PanToolAlt" Color="Color.Primary"></MudIcon>
                            <MudText>@($"{t.ToolName}({t.ToolVersion})")</MudText>
                        </MudStack>
                    </MudSelectItem>
                }
            </MudSelect>
            @if (SelectedTool != null)
            {
                <MudTextField @bind-Value="@SelectedTool.ToolType" Margin="Margin.Dense" Label="工具类型" ReadOnly Variant="Variant.Filled"></MudTextField>
                @foreach (var variable in ToolVariablesFromSelectedTool)
                {
                    @if(variable.Name == "ToolPath")
                    {
                        continue;
                    }
                    <MudStack Row AlignItems="AlignItems.Center">
                        @if (variable.Type == VariableTypeEnum.File.ToString())
                        {
                            <MudText>@($"设置变量：{variable.Name}默认值：")</MudText>
                            <FileUpload EditorContext="new DisplayInputEditorContext { Variable = variable }" />
                        }
                        else
                        {
                            <MudTextField T="string" Margin="Margin.Dense" Label="@($"设置变量：{variable.Name}默认值")"
                                          @bind-Value="@variable.Value" Variant="Variant.Outlined"></MudTextField>
                        }
                        <MudSelect @bind-Value="variable.Type" Label="参数类型" Required Margin="@Margin.Dense"
                                   ToStringFunc="@(t => VariableTypeConverter.GetTypeDisplayName(t))">
                            <MudSelectItem T="string" Value="@VariableTypeEnum.String.ToString()">
                                @VariableTypeConverter.GetTypeDisplayName(VariableTypeEnum.String.ToString())
                            </MudSelectItem>
                            <MudSelectItem T="string" Value="@VariableTypeEnum.File.ToString()">
                                @VariableTypeConverter.GetTypeDisplayName(VariableTypeEnum.File.ToString())
                            </MudSelectItem>
                        </MudSelect>
                        @if (variable.Type == VariableTypeEnum.File.ToString())
                        {
                            <MudTooltip Text="如果参数类型设置为文件，调用工具时将自动处理为文件路径；如果勾选参数为输出，则工具执行完成后将自动把文件更新至参数中">
                                <MudCheckBox Dense T="bool" @bind-Value="@variable.IsInput" Color="Color.Primary">输入</MudCheckBox>
                            </MudTooltip>
                            <MudTooltip Text="如果参数类型设置为文件，调用工具时将自动处理为文件路径；如果勾选参数为输出，则工具执行完成后将自动把文件更新至参数中">
                                <MudCheckBox Dense T="bool" @bind-Value="@variable.IsOutput" Color="Color.Primary">输出</MudCheckBox>
                            </MudTooltip>
                        }
                    </MudStack>
                }
            }
        </MudTabPanel>
        <MudTabPanel Text="手动输入路径">
            <MudTextField Value="@ManualToolPath" ValueChanged="@(async (string v) => await OnManualToolPathChanged(v))" Margin="Margin.Dense" Label="工具完整路径"
                          Placeholder="例如：C:\Program Files\Tool\tool.exe" Variant="Variant.Outlined"
                          HelperText="输入工具在图站上的完整路径"></MudTextField>
            <MudTextField @bind-Value="@ManualToolName" Margin="Margin.Dense" Label="工具名称"
                          Placeholder="自定义工具名称" Variant="Variant.Outlined"></MudTextField>
        </MudTabPanel>
        <MudTabPanel Text="上传文件夹">
            <FolderUploader @ref="_folderUploader"
                            ServerBaseUrl="@ServerBaseUrl"
                            PlugFolder="@(PlugFolder ?? "")"
                            Username="@Username"
                            IsSystemPlug="@IsSystemPlug"
                            OnFolderSelected="OnFolderPicked" />
            @if (_folderUploader != null && _folderUploader.HasSelection)
            {
                <MudTextField @bind-Value="@FolderToolName" Margin="Margin.Dense" Label="工具名称"
                              Placeholder="自定义工具名称" Variant="Variant.Outlined"></MudTextField>
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.Center">
                <MudTextField Value="@FolderEntryFile" ValueChanged="@(async (string v) => await OnFolderEntryFileChanged(v))" Margin="Margin.Dense" Label="入口程序"
                              Placeholder="例如：app.exe 或 main.py" Variant="Variant.Outlined"
                              HelperText="指定文件夹中的入口执行程序"
                              Adornment="Adornment.End">                    
                </MudTextField>
                <MudIconButton Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small"
                               OnClick="OpenServerFilePicker" />
                </MudStack>
            }
        </MudTabPanel>
    </MudTabs>
}
else
{
    @* 编辑模式：根据已有配置展示对应内容 *@
    @if (!string.IsNullOrEmpty(ExistingPlug!.ToolVersionPath) &&
         ExistingPlug.ToolVersionPath.StartsWith("uploaded://"))
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary">配置方式：上传文件夹</MudText>
        <FolderUploader @ref="_folderUploader"
                        ServerBaseUrl="@ServerBaseUrl"
                        PlugFolder="@(PlugFolder ?? "")"
                        Username="@Username"
                        IsSystemPlug="@IsSystemPlug"
                        OnFolderSelected="OnFolderPicked" />
        <MudTextField @bind-Value="@FolderToolName" Margin="Margin.Dense" Label="工具名称"
                      Placeholder="自定义工具名称" Variant="Variant.Outlined"></MudTextField>
        
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.Center">
            <MudTextField Value="@FolderEntryFile" ValueChanged="@(async (string v) => await OnFolderEntryFileChanged(v))" Margin="Margin.Dense" Label="入口程序"
                          Placeholder="例如：app.exe 或 main.py" Variant="Variant.Outlined"
                          HelperText="指定文件夹中的入口执行程序"
                          Adornment="Adornment.End">
            </MudTextField>
            <MudIconButton Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small"
                           OnClick="OpenServerFilePicker" />
        </MudStack>
    }
    else if (!string.IsNullOrEmpty(ExistingPlug!.GetVariableValue("ToolPath")))
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary">配置方式：手动输入路径</MudText>
        <MudTextField Value="@ManualToolPath" ValueChanged="@(async (string v) => await OnManualToolPathChanged(v))" Margin="Margin.Dense" Label="工具完整路径"
                      Placeholder="例如：C:\Program Files\Tool\tool.exe" Variant="Variant.Outlined"
                      HelperText="输入工具在图站上的完整路径"></MudTextField>
        <MudTextField @bind-Value="@ManualToolName" Margin="Margin.Dense" Label="工具名称"
                      Placeholder="自定义工具名称" Variant="Variant.Outlined"></MudTextField>
    }
    else if (ExistingPlug!.ToolId.HasValue)
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary">配置方式：从工具库选择</MudText>
        @if (SelectedTool != null)
        {
            <MudTextField Value="@($"{SelectedTool.ToolName}({SelectedTool.ToolVersion})")" Margin="Margin.Dense" Label="已选工具" ReadOnly Variant="Variant.Filled"></MudTextField>
            <MudTextField @bind-Value="@SelectedTool.ToolType" Margin="Margin.Dense" Label="工具类型" ReadOnly Variant="Variant.Filled"></MudTextField>
            @foreach (var variable in ToolVariablesFromSelectedTool)
            {
                @if (variable.Name == "ToolPath") { continue; }
                <MudStack Row AlignItems="AlignItems.Center">
                    @if (variable.Type == VariableTypeEnum.File.ToString())
                    {
                        <MudText>@($"设置变量：{variable.Name}默认值：")</MudText>
                        <FileUpload EditorContext="new DisplayInputEditorContext { Variable = variable }" />
                    }
                    else
                    {
                        <MudTextField T="string" Margin="Margin.Dense" Label="@($"设置变量：{variable.Name}默认值")"
                                      @bind-Value="@variable.Value" Variant="Variant.Outlined"></MudTextField>
                    }
                    <MudSelect @bind-Value="variable.Type" Label="参数类型" Required Margin="@Margin.Dense"
                               ToStringFunc="@(t => VariableTypeConverter.GetTypeDisplayName(t))">
                        <MudSelectItem T="string" Value="@VariableTypeEnum.String.ToString()">
                            @VariableTypeConverter.GetTypeDisplayName(VariableTypeEnum.String.ToString())
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@VariableTypeEnum.File.ToString()">
                            @VariableTypeConverter.GetTypeDisplayName(VariableTypeEnum.File.ToString())
                        </MudSelectItem>
                    </MudSelect>
                    @if (variable.Type == VariableTypeEnum.File.ToString())
                    {
                        <MudTooltip Text="如果参数类型设置为文件，调用工具时将自动处理为文件路径；如果勾选参数为输出，则工具执行完成后将自动把文件更新至参数中">
                            <MudCheckBox Dense T="bool" @bind-Value="@variable.IsInput" Color="Color.Primary">输入</MudCheckBox>
                        </MudTooltip>
                        <MudTooltip Text="如果参数类型设置为文件，调用工具时将自动处理为文件路径；如果勾选参数为输出，则工具执行完成后将自动把文件更新至参数中">
                            <MudCheckBox Dense T="bool" @bind-Value="@variable.IsOutput" Color="Color.Primary">输出</MudCheckBox>
                        </MudTooltip>
                    }
                </MudStack>
            }
        }
    }
}

<MudCheckBox Value="@SupportRemoteView" ValueChanged="@OnSupportRemoteViewChanged" T="bool" Label="支持远程视图" Color="Color.Primary" Dense></MudCheckBox>

@code {
    /// <summary>服务器 API 基地址</summary>
    [Parameter] public string ServerBaseUrl { get; set; } = "";

    /// <summary>上传目标子文件夹（如 plugDefinitionId）</summary>
    [Parameter] public string? PlugFolder { get; set; }

    /// <summary>当前用户名</summary>
    [Parameter] public string Username { get; set; } = "";

    /// <summary>是否为系统插头</summary>
    [Parameter] public bool IsSystemPlug { get; set; }

    /// <summary>执行命令展示值变化回调</summary>
    [Parameter] public EventCallback<string> CommandDisplayChanged { get; set; }

    /// <summary>编辑模式下的现有 Plug，用于回显桌面工具配置状态</summary>
    [Parameter] public Plug? ExistingPlug { get; set; }

    private List<Tool> Tools { get; set; } = new();
    private Tool? SelectedTool { get; set; }
    private IEnumerable<BaseVariable> ToolVariablesFromSelectedTool { get; set; } = new List<BaseVariable>();

    // 手动输入路径
    private string? ManualToolPath { get; set; }
    private string? ManualToolName { get; set; }

    // 文件夹上传
    private FolderUploader? _folderUploader;
    private string? FolderToolName { get; set; }
    private string? FolderEntryFile { get; set; }
    /// <summary>用户实际选择的文件夹名（来自 FolderUploader JS 回调），避免依赖 FolderUploader 实例状态</summary>
    private string? _selectedUploadFolderName;

    private bool _loaded;
    private bool _restored;
    private int _activeTabIndex;
    private bool SupportRemoteView { get; set; }

    private async Task OnSupportRemoteViewChanged(bool value)
    {
        SupportRemoteView = value;
        // 立即写入 Plug 对象，防止组件因切换插头类型等操作被重建后状态丢失
        if (ExistingPlug != null)
        {
            ExistingPlug.SetPlugSetting(PlugSettingKey.SupportRemoteView.ToString(),
                                        value.ToString().ToLower());
        }
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        if (!_loaded)
        {
            _loaded = true;
            Tools = await MainApiClient.GetAllToolsAsync();
            await TryRestoreFromExistingPlug();
        }
    }

    private async Task TryRestoreFromExistingPlug()
    {
        if (ExistingPlug == null || _restored) return;
        _restored = true;

        SupportRemoteView = ExistingPlug.GetPlugSetting(PlugSettingKey.SupportRemoteView.ToString()) == "true";

        // 上传文件夹模式：根据 ToolVersionPath 识别（优先判断，因 EnsureToolAsync 后三种模式均有 ToolId）
        if (!string.IsNullOrEmpty(ExistingPlug.ToolVersionPath) &&
            ExistingPlug.ToolVersionPath.StartsWith("uploaded://"))
        {
            _activeTabIndex = 2;
            FolderToolName = ExistingPlug.ToolName;
            // 从 uploaded:// 路径提取真实文件夹名（新格式: uploaded://{user}/{folder}）
            var pathPart = ExistingPlug.ToolVersionPath["uploaded://".Length..];
            var pathParts = pathPart.Split('/');
            if (pathParts.Length >= 2)
            {
                _selectedUploadFolderName = pathParts[1];
            }
            // FolderEntryFile 从 ToolCommandLineShema 或 PlugSettings 解析
            // 新格式: entryFile 独立存储在 PlugSettings["UploadedEntryFile"]
            var savedEntryFile = ExistingPlug.GetPlugSetting("UploadedEntryFile");
            if (!string.IsNullOrEmpty(savedEntryFile))
            {
                FolderEntryFile = savedEntryFile;
            }
            else if (!string.IsNullOrEmpty(ExistingPlug.ToolCommandLineShema))
            {
                // 兼容旧格式: [ToolPath]\entryFile.exe
                var match = Regex.Match(ExistingPlug.ToolCommandLineShema, @"\[ToolPath\]\\([^\s\]]+)");
                if (match.Success)
                {
                    FolderEntryFile = match.Groups[1].Value;
                }
            }
            await NotifyCommandDisplayChanged();
        }
        // 手动输入路径模式：根据 ToolPath 变量恢复
        else if (!string.IsNullOrEmpty(ExistingPlug.GetVariableValue("ToolPath")))
        {
            _activeTabIndex = 1;
            ManualToolPath = ExistingPlug.GetVariableValue("ToolPath");
            ManualToolName = ExistingPlug.ToolName;
            await NotifyCommandDisplayChanged();
        }
        // 从工具库选择模式：根据 ToolId 恢复
        else if (ExistingPlug.ToolId.HasValue)
        {
            _activeTabIndex = 0;
            var tool = Tools.FirstOrDefault(t => t.Id == ExistingPlug.ToolId);
            if (tool != null)
            {
                await OnSelectedToolChanged(tool);
            }
        }
        // 无法匹配任何已有配置方式时，默认选中第一个页签
        else
        {
            _activeTabIndex = 0;
        }
    }

    private async Task OnSelectedToolChanged(Tool tool)
    {
        SelectedTool = tool;
        ToolVariablesFromSelectedTool = tool?.GetVariablesFromToolCommand() ?? new List<BaseVariable>();
        await NotifyCommandDisplayChanged();
    }

    private async Task OnManualToolPathChanged(string value)
    {
        ManualToolPath = value;
        await NotifyCommandDisplayChanged();
    }

    private async Task OnFolderEntryFileChanged(string value)
    {
        FolderEntryFile = value;
        await NotifyCommandDisplayChanged();
    }

    private async Task OpenServerFilePicker()
    {
        var parameters = new DialogParameters<ChooseServerFiles>
        {
            { c => c.IsChooseBusinessTool, false }
        };
        var dialog = await DialogService.ShowAsync<ChooseServerFiles>("选择入口程序", parameters);
        var result = await dialog.Result;
        if (!result.Canceled && result.Data is string selectedPath && !string.IsNullOrWhiteSpace(selectedPath))
        {
            FolderEntryFile = selectedPath;
        }
    }

    private string? _commandDisplay;
    private async Task NotifyCommandDisplayChanged()
    {
        string? newDisplay = null;
        if (SelectedTool != null)
            newDisplay = SelectedTool.CommandParameter;
        else if (!string.IsNullOrEmpty(ManualToolPath))
            // 编辑模式回显已保存的完整命令，新建模式默认 [ToolPath]
            newDisplay = ExistingPlug?.ToolCommandLineShema ?? "[ToolPath]";
        else if (_folderUploader?.HasSelection == true || !string.IsNullOrEmpty(FolderEntryFile))
            newDisplay = ExistingPlug?.ToolCommandLineShema ?? "[ToolPath]";

        if (_commandDisplay != newDisplay)
        {
            _commandDisplay = newDisplay;
            await CommandDisplayChanged.InvokeAsync(_commandDisplay);
        }
    }

    private async Task OnFolderPicked((string FolderName, int FileCount) args)
    {
        _selectedUploadFolderName = args.FolderName;
        await NotifyCommandDisplayChanged();
        StateHasChanged();
    }

    /// <summary>
    /// 将当前桌面类配置写入 Plug 对象。
    /// </summary>
    public void ApplyToPlug(Plug plug)
    {
        // plug.PlugTypeKey = "CMDPlug";

        if (SelectedTool != null)
        {
            plug.ToolId = SelectedTool.Id;
            plug.ToolName = SelectedTool.ToolName;
            plug.ToolVersion = SelectedTool.ToolVersion;
            plug.ToolDisplayName = SelectedTool.Id == null ? null : $"{SelectedTool.ToolName}({SelectedTool.ToolVersion})";
            plug.ToolCommandLineShema = SelectedTool.CommandParameter;
        }
        else if (!string.IsNullOrEmpty(ManualToolPath))
        {
            plug.ToolId = null; // 切换为手动路径模式，清除旧的ToolId
            plug.ToolName = ManualToolName ?? "自定义工具";
            plug.SetVariableValue("ToolPath", ManualToolPath);
            plug.ToolCommandLineShema = $"[{ManualToolPath}] ";
        }
        else if (_folderUploader?.HasSelection == true || !string.IsNullOrEmpty(FolderEntryFile))
        {
            plug.ToolId = null; // 切换为上传文件夹模式，清除旧的ToolId
            plug.ToolName = FolderToolName ?? "上传的工具";
            // uploaded:// 路径存储实际文件夹路径：uploaded://{userOrSystem}/{folderName}
            var userOrSystem = IsSystemPlug ? "0System" : Username;
            // 优先使用当前捕获的文件夹名 → FolderUploader 实例状态 → 从已有路径提取 → 回退
            var folderName = _selectedUploadFolderName
                ?? _folderUploader?.SelectedFolderName;
            if (string.IsNullOrEmpty(folderName) && plug.ToolVersionPath?.StartsWith("uploaded://") == true)
            {
                var existingPart = plug.ToolVersionPath["uploaded://".Length..];
                var existingParts = existingPart.Split('/');
                if (existingParts.Length >= 2)
                    folderName = existingParts[1];
            }
            folderName = folderName ?? FolderToolName ?? "unknown";
            plug.ToolVersionPath = $"uploaded://{userOrSystem}/{folderName}";
            if (!string.IsNullOrEmpty(FolderEntryFile))
            {
                // entryFile 已包含在合成 Tool.ToolPath 中（完整 exe 路径）
                // ToolCommandLineShema 只用 [ToolPath]，不再重复拼接 \entryFile
                // 同时存入 PlugSettings 供编辑回显
                plug.ToolCommandLineShema = $"[ToolPath] ";
                plug.SetPlugSetting("UploadedEntryFile", FolderEntryFile);
            }
        }

        // 桌面类默认参数（与CMD插头一致）
        // plug.AddVariable("CMDCommand", VariableTypeEnum.String.ToString());
        // plug.AddVariable("ResultString", VariableTypeEnum.String.ToString());
        // plug.AddVariable("ExecutionTimeout", VariableTypeEnum.String.ToString());
        // plug.AddVariable("WaitType", VariableTypeEnum.String.ToString());
        // plug.AddVariable("WatchProcessType", VariableTypeEnum.String.ToString());
        // plug.AddVariable("WatchProcessName", VariableTypeEnum.String.ToString());
        // plug.AddVariable("AutoCloseProcess", VariableTypeEnum.String.ToString());
        // plug.AddVariable("CloseProcessWhenError", VariableTypeEnum.String.ToString());
        // plug.AddVariable("ShowConsole", VariableTypeEnum.String.ToString());
        // plug.AddVariable("RedirectOutput", VariableTypeEnum.String.ToString());
        // plug.AddVariable("RedirectWorkPath", VariableTypeEnum.String.ToString());

        plug.SetPlugSetting(PlugSettingKey.SupportRemoteView.ToString(), SupportRemoteView.ToString().ToLower());
    }

    /// <summary>将选中工具的变量附加到 Plug</summary>
    public void ApplyToolVariables(Plug plug)
    {
        if (SelectedTool == null) return;
        foreach (var variable in ToolVariablesFromSelectedTool)
        {
            if (variable.Name == "ToolPath")
            {
                continue; // ToolPath 由用户手动输入，不在此处添加到 Plug 变量中
            }
            plug.PlugVariables.Add(new PlugVariable
            {
                Name = variable.Name.TrimStart('[').TrimEnd(']'),
                Value = variable.Value,
                IsInitVariable = true,
                Type = variable.Type,
                IsInput = variable.IsInput,
                IsOutput = variable.IsOutput,
            });
        }
    }

    /// <summary>文件夹上传是否已有选中文件</summary>
    public bool HasFolderSelection => _folderUploader?.HasSelection == true;

    /// <summary>触发文件夹上传到服务器</summary>
    public async Task<int> UploadFolderAsync()
    {
        return _folderUploader != null ? await _folderUploader.UploadAsync() : 0;
    }

    /// <summary>
    /// 确保桌面类插头有关联的 Tool 记录。
    /// 手动路径和上传文件夹模式会自动创建 Tool，避免运行时动态合成。
    /// </summary>
    public async Task EnsureToolAsync(Plug plug)
    {
        // 已经有 ToolId（工具库选择模式），无需处理
        if (plug.ToolId.HasValue) return;

        Tool? tool = null;
        string toolName;
        string toolVersion = "1.0";

        // 手动输入路径模式
        if (!string.IsNullOrEmpty(ManualToolPath))
        {
            toolName = ManualToolName ?? "自定义工具";
            var displayName = $"{toolName}({toolVersion})";

            // 查重：避免重复创建同名 Tool
            try { tool = await MainApiClient.GetToolByDisplayNameAsync(displayName); } catch { }

            if (tool == null)
            {
                tool = new Tool
                {
                    ToolName = toolName,
                    ToolVersion = toolVersion,
                    ToolPath = ManualToolPath, // 不等于 ToolName，CreateToolAsync 不会重写
                    ToolBasePath = Path.Combine("Tools", IsSystemPlug ? "0System" : Username, toolName),
                    CommandParameter = plug.ToolCommandLineShema ?? $"[ToolPath]",
                    SkipDownloadToStation = true,
                    IsBrowsable = false,
                    ToolType = ToolTypeEnum.桌面类_自研.ToString(),
                    ToolDescription = $"由插头「{plug.Name}」自动创建",
                };
                tool = await MainApiClient.CreateToolAsync(tool);
            }
        }
        // 上传文件夹模式
        else if (_folderUploader?.HasSelection == true || !string.IsNullOrEmpty(FolderEntryFile))
        {
            var userOrSystem = IsSystemPlug ? "0System" : Username;
            // 确定文件夹名（与 ApplyToPlug 逻辑一致）
            var folderName = _selectedUploadFolderName
                ?? _folderUploader?.SelectedFolderName;
            if (string.IsNullOrEmpty(folderName) && plug.ToolVersionPath?.StartsWith("uploaded://") == true)
            {
                var existingPart = plug.ToolVersionPath["uploaded://".Length..];
                var existingParts = existingPart.Split('/');
                if (existingParts.Length >= 2)
                    folderName = existingParts[1];
            }
            toolName = folderName ?? FolderToolName ?? "unknown";
            if (toolName == "unknown") return; // 无法确定文件夹名，跳过

            // 预计算工具路径，使用前端传入的登录用户名而非依赖后端 GetCurrentUserName()
            var prebuiltToolPath = Path.Combine("Tools", userOrSystem, toolName);

            var displayName = $"{toolName}({toolVersion})";
            try { tool = await MainApiClient.GetToolByDisplayNameAsync(displayName); } catch { }

            if (tool == null)
            {
                tool = new Tool
                {
                    ToolName = toolName,
                    ToolVersion = toolVersion,
                    ToolPath = prebuiltToolPath,
                    ToolBasePath = prebuiltToolPath,
                    CommandParameter = plug.ToolCommandLineShema ?? "[ToolPath]",
                    SkipDownloadToStation = false,
                    IsBrowsable = false,
                    IsSystemInitTool = IsSystemPlug,
                    ToolType = ToolTypeEnum.桌面类_自研.ToString(),
                    ToolDescription = $"由插头「{plug.Name}」自动创建",
                };
                tool = await MainApiClient.CreateToolAsync(tool);
            }
        }
        else
        {
            return; // 无工具配置模式（不应出现在桌面类插头中）
        }

        if (tool != null)
        {
            plug.ToolId = tool.Id;
            plug.ToolDisplayName = $"{tool.ToolName}({tool.ToolVersion})";
            // 同步 Plug 上的冗余属性以保持向后兼容
            plug.ToolName = tool.ToolName;
            plug.ToolVersion = tool.ToolVersion;
        }
    }
}
