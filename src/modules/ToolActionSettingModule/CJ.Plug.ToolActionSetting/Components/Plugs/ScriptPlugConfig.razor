@using CJ.Plug.Models.Plug
@using CJ.Plug.Models.Shared
@using CJ.Plug.Models.VariableType
@using Microsoft.AspNetCore.Components.Forms

<MudDivider Class="my-2"></MudDivider>

<MudStack Row AlignItems="AlignItems.Center" Class="mb-2">
    <MudText Typo="Typo.subtitle2" Color="Color.Primary" Style="margin-right:16px;">脚本类型</MudText>
    <MudSelect @bind-Value="@ScriptType" Label="选择脚本类型" Style="width:200px;"
               Margin="Margin.Dense" Dense Variant="Variant.Outlined">
        <MudSelectItem Value="@("Java")">Java</MudSelectItem>
        <MudSelectItem Value="@("Python")">Python</MudSelectItem>
        <MudSelectItem Value="@("JavaScript")">JavaScript</MudSelectItem>
        <MudSelectItem Value="@("CSharp")">C#</MudSelectItem>
        <MudSelectItem Value="@("Go")">Go</MudSelectItem>
        <MudSelectItem Value="@("Rust")">Rust</MudSelectItem>
        <MudSelectItem Value="@("Shell")">Shell</MudSelectItem>
        <MudSelectItem Value="@("PowerShell")">PowerShell</MudSelectItem>
    </MudSelect>
</MudStack>

<MudText Typo="Typo.subtitle2" Color="Color.Primary">脚本配置</MudText>

<MudTabs Elevation="0" ApplyEffectsToContainer="true" PanelClass="pa-2">
    <MudTabPanel Text="上传脚本文件">
        <MudStack>
            <MudFileUpload T="IBrowserFile" FilesChanged="@OnScriptFileSelected">
                <ActivatorContent>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload">
                        选择@(ScriptType)脚本文件
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>

            @if (!string.IsNullOrEmpty(ScriptFileName))
            {
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                    @ScriptFileName
                </MudChip>
            }
        </MudStack>
    </MudTabPanel>
    <MudTabPanel Text="编辑器编写">
        <MudTextField @bind-Value="@ScriptContent" Margin="Margin.Dense" Label="@($"{ScriptType}脚本")"
                      Placeholder="@($"在此编写{ScriptType}脚本...")" Variant="Variant.Outlined" Lines="10"
                      HelperText="@($"直接在编辑器中编写{ScriptType}脚本代码")"></MudTextField>
    </MudTabPanel>
</MudTabs>

@code {
    [Parameter] public EventCallback<string> OnError { get; set; }
    [Parameter] public EventCallback<string> OnInfo { get; set; }
    [Parameter] public Plug? Plug { get; set; }

    private string? ScriptContent { get; set; }
    private string? ScriptFileName { get; set; }
    private string ScriptType { get; set; } = "Python";

    protected override void OnParametersSet()
    {
        if (Plug != null)
        {
            // 从插头参数 Script 加载已保存的脚本内容
            ScriptContent = Plug.GetVariableValue("Script");

            // 从插头配置加载脚本类型，未配置则默认 Python
            var savedType = Plug.GetPlugSetting("ScriptType");
            if (!string.IsNullOrEmpty(savedType))
            {
                ScriptType = savedType;
            }
        }
    }

    private async Task OnScriptFileSelected(IBrowserFile file)
    {
        if (file == null) return;

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            ScriptContent = await reader.ReadToEndAsync();
            ScriptFileName = file.Name;
            if (OnInfo.HasDelegate)
                await OnInfo.InvokeAsync($"已加载脚本文件: {file.Name}");
        }
        catch (Exception ex)
        {
            if (OnError.HasDelegate)
                await OnError.InvokeAsync($"读取脚本文件失败: {ex.Message}");
        }
    }

    /// <summary>
    /// 将脚本类配置写入 Plug 对象。
    /// </summary>
    public void ApplyToPlug(Plug plug)
    {
        // plug.PlugTypeKey = "PythonPlug";

        // 保存脚本类型到插头配置
        plug.SetPlugSetting("ScriptType", ScriptType);

        // 同步写入 PlugVariables，确保执行时 VariableResolver 可解析
        plug.AddVariable("ScriptType", VariableTypeEnum.String.ToString());
        plug.SetVariableValue("ScriptType", ScriptType);

        // 添加脚本类默认参数
        plug.AddVariable("Script", VariableTypeEnum.String.ToString());
        plug.AddVariable("InputData", VariableTypeEnum.String.ToString());
        plug.AddVariable("ResultString", VariableTypeEnum.String.ToString());

        // 设置脚本内容到插头参数 Script
        if (!string.IsNullOrEmpty(ScriptContent))
        {
            plug.SetVariableValue("Script", ScriptContent);
        }
    }
}
