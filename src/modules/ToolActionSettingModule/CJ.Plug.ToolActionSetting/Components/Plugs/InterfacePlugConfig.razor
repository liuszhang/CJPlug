@using CJ.Plug.Models.Plug
@using CJ.Plug.Models.Shared
@using CJ.Plug.Models.VariableType

<MudDivider Class="my-2"></MudDivider>
<MudText Typo="Typo.subtitle2" Color="Color.Primary">接口配置</MudText>

<MudStack Row>
    <MudSelect T="string" @bind-Value="@HttpMethod" Label="请求方式" Style="width:180px;"
               Margin="Margin.Dense" Dense Variant="Variant.Outlined">
        <MudSelectItem Value="@("GET")">GET</MudSelectItem>
        <MudSelectItem Value="@("POST")">POST</MudSelectItem>
        <MudSelectItem Value="@("PUT")">PUT</MudSelectItem>
        <MudSelectItem Value="@("DELETE")">DELETE</MudSelectItem>
        <MudSelectItem Value="@("HEAD")">HEAD</MudSelectItem>
        <MudSelectItem Value="@("OPTIONS")">OPTIONS</MudSelectItem>
        <MudSelectItem Value="@("PATCH")">PATCH</MudSelectItem>
    </MudSelect>
    <MudTextField T="string" @bind-Value="@InterfaceUrl" Margin="Margin.Dense" Label="请求地址"
                  Placeholder="例如：http://api.example.com/v1/resource" Variant="Variant.Outlined"
                  HelperText="输入完整的接口URL地址"></MudTextField>
</MudStack>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Style="padding:0">
    <MudStack Row AlignItems="AlignItems.Center" Class="mb-2">
        <MudText Typo="Typo.subtitle2">服务参数</MudText>
        <MudButton StartIcon="@Icons.Material.Outlined.Add"
                   Variant="Variant.Filled" Size="Size.Small"
                   OnClick="AddServiceParam"
                   Color="Color.Primary">添加服务参数</MudButton>
    </MudStack>

    <MudDataGrid T="PDZVariable" Items="@ServiceParams" ReadOnly="false"
                 EditMode="MudBlazor.DataGridEditMode.Cell" Dense="true"
                 EditTrigger="@(DataGridEditTrigger.Manual)">
        <Columns>
            <PropertyColumn Property="x => x.Type" Title="类型">
                <EditTemplate>
                    <MudSelect @bind-Value="context.Item.Type" Required Dense Margin="@Margin.Dense">
                        <MudSelectItem Value="@("Header")">Header(请求头参数)</MudSelectItem>
                        <MudSelectItem Value="@("Path")">Path(路径参数)</MudSelectItem>
                        <MudSelectItem Value="@("Query")">Query(查询参数)</MudSelectItem>
                        <MudSelectItem Value="@("Body")">Body(请求体参数)</MudSelectItem>
                        <MudSelectItem Value="@("Form")">Form(表单参数)</MudSelectItem>
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Name" Title="名称"></PropertyColumn>
            <TemplateColumn Title="默认值">
                <EditTemplate>
                    <MudStack Row Spacing="0" AlignItems="AlignItems.Center" Justify="Justify.Center">
                        @if (context.Item.IsValueFromOtherVariable)
                        {
                            <MudAutocomplete T="string"
                                Value="@context.Item.DisplayValue"
                                ValueChanged="@((v) => OnBindVariableSelected(context.Item, v))"
                                SearchFunc="@SearchVariablesForBinding"
                                CoerceValue="false"
                                CoerceText="false"
                                Dense Clearable
                                MinWidth="120px" />
                        }
                        else
                        {
                            <MudTextField T="string" @bind-Value="context.Item.Value"
                                Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" />
                        }
                        <MudCheckBox T="bool" Label="绑定" Dense Size="Size.Small"
                            Value="@context.Item.IsValueFromOtherVariable"
                            ValueChanged="@((bool b) => ChangedIsFromOtherValue(context.Item, b))" />
                    </MudStack>
                </EditTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.IsRequired" Title="必需">
                <EditTemplate>
                    <MudSwitch @bind-Value="context.Item.IsRequired" Color="Color.Primary"
                               Label="@context.Item.IsRequired.ToString()"></MudSwitch>
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="操作">
                <EditTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                   Color="Color.Error" OnClick="@(() => RemoveServiceParam(context.Item))" />
                </EditTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
</MudContainer>

@code {
    [Parameter] public Plug? Plug { get; set; }

    private string? InterfaceUrl { get; set; }
    private string HttpMethod { get; set; } = "GET";
    private List<PDZVariable> ServiceParams { get; set; } = new();
    private bool _loaded;

    protected override void OnParametersSet()
    {
        if (Plug != null && !_loaded)
        {
            LoadFromPlug();
            _loaded = true;
        }
    }

    private void AddServiceParam()
    {
        ServiceParams.Add(new PDZVariable { Type = "Header", Name = "header1" });
    }

    private void RemoveServiceParam(PDZVariable param)
    {
        ServiceParams.Remove(param);
    }

    private void ChangedIsFromOtherValue(PDZVariable item, bool value)
    {
        item.IsValueFromOtherVariable = value;
        if (!value)
        {
            item.SourceValueVariableName = null;
            item.DisplayValue = null;
        }
    }

    private async Task<IEnumerable<string>> SearchVariablesForBinding(string searchText, CancellationToken cancellationToken)
    {
        if (Plug?.PlugVariables == null)
            return Enumerable.Empty<string>();

        var names = Plug.PlugVariables
            .Select(v => v.Name)
            .Where(n => n != null)
            .Cast<string>();

        if (string.IsNullOrEmpty(searchText))
            return names;

        return names.Where(n => n.Contains(searchText, StringComparison.OrdinalIgnoreCase));
    }

    private void OnBindVariableSelected(PDZVariable item, string? value)
    {
        if (string.IsNullOrEmpty(value))
        {
            // 清空选择 → 解除绑定
            ChangedIsFromOtherValue(item, false);
            return;
        }

        // 判断输入值是否匹配已有变量名
        var existingVar = Plug?.PlugVariables?.FirstOrDefault(v =>
            v.Name != null && v.Name.Equals(value, StringComparison.OrdinalIgnoreCase));

        if (existingVar != null)
        {
            // 选中已有变量 → 标记为引用
            item.IsValueFromOtherVariable = true;
            item.SourceValueVariableName = existingVar.Name;
            item.Value = null;
            item.DisplayValue = existingVar.Name;
        }
        else
        {
            // 手动输入的新变量名 → 自动创建并绑定
            Plug?.AddVariable(value, "String");
            item.IsValueFromOtherVariable = true;
            item.SourceValueVariableName = value;
            item.Value = null;
            item.DisplayValue = value;
        }
    }

    private void LoadFromPlug()
    {
        if (Plug == null) return;

        var method = Plug.GetVariableValue("Method");
        if (!string.IsNullOrEmpty(method))
            HttpMethod = method;

        InterfaceUrl = Plug.GetVariableValue("Url");

        var headersJson = Plug.GetVariableValue("RequestHeaders");
        if (!string.IsNullOrEmpty(headersJson))
        {
            try
            {
                ServiceParams = System.Text.Json.JsonSerializer.Deserialize<List<PDZVariable>>(headersJson) ?? new();
            }
            catch
            {
                ServiceParams = new();
            }
        }
    }

    /// <summary>
    /// 将接口类配置写入 Plug 对象。
    /// </summary>
    public void ApplyToPlug(Plug plug)
    {
        // plug.PlugTypeKey = "RESTPlug";

        // 添加接口类默认参数（与REST插头一致），使用 AddVariable 避免重复添加
        plug.AddVariable("Url", VariableTypeEnum.String.ToString(), IsInitVariable: true);
        plug.AddVariable("Method", VariableTypeEnum.String.ToString(), IsInitVariable: true);
        plug.AddVariable("RequestHeaders", VariableTypeEnum.String.ToString(), IsInitVariable: true);

        // 设置 IsBrowsable 为 false（AddVariable 不管理此属性，需单独设置）
        var urlVar = plug.PlugVariables.FirstOrDefault(v => v.Name == "Url");
        if (urlVar != null) urlVar.IsBrowsable = false;
        var methodVar = plug.PlugVariables.FirstOrDefault(v => v.Name == "Method");
        if (methodVar != null) methodVar.IsBrowsable = false;
        var headersVar = plug.PlugVariables.FirstOrDefault(v => v.Name == "RequestHeaders");
        if (headersVar != null) headersVar.IsBrowsable = false;

        // 设置URL默认值
        if (!string.IsNullOrEmpty(InterfaceUrl))
        {
            plug.SetVariableValue("Url", InterfaceUrl);
        }
        plug.SetVariableValue("Method", HttpMethod);

        // 将用户配置的服务参数序列化为 JSON 存入 RequestHeaders 变量
        if (ServiceParams.Count > 0)
        {
            var paramsJson = System.Text.Json.JsonSerializer.Serialize(ServiceParams.Select(p => new
            {
                p.Type,
                p.Name,
                p.Value,
                p.IsRequired,
                p.IsValueFromOtherVariable,
                p.SourceValueVariableName,
                p.SourceValueVariableId,
                p.SourceValuePlugDefinitionId,
                p.DisplayValue
            }));
            plug.SetVariableValue("RequestHeaders", paramsJson);
        }
    }
}
