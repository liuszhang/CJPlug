@using MudBlazor

@inject ITASApiClient TASApiClient
@inject IEnumerable<IPlugCommonSettingContent> PlugCommonSettingContent

@if (true)
{
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.Center">
        @if (HasBuiltInSettingContent)
        {
            <MudText>插头配置界面（@SelectedPlug?.Name）</MudText>
        }
        else
        {
            <MudText>自定义插头执行界面（@SelectedPlug?.Name）</MudText>
        }
        <MudSpacer></MudSpacer>
        @if (!HasBuiltInSettingContent)
        {
            <MudButton OnClick="EditGui" Size="Size.Small" Variant=Variant.Outlined Color=Color.Primary>编辑</MudButton>
            <MudButton OnClick="SaveGui" Size="Size.Small" Variant=Variant.Outlined Color=Color.Primary>保存</MudButton>
            <MudButton OnClick="ShowAmis" Size="Size.Small" Variant=Variant.Outlined Color=Color.Primary>Amis</MudButton>
        }
        <MudToggleIconButton Toggled="IsGuiDesignerMaximized"
        ToggledChanged="MaxGuiDesigner"
        Icon="@Icons.Material.Filled.ZoomOutMap"
        Color="@Color.Primary"
        ToggledIcon="@Icons.Material.Filled.ZoomInMap"
        ToggledColor="@Color.Primary"/>
    </MudStack>
    @if (HasBuiltInSettingContent)
    {
        @BuiltInSettingContent
    }
    else if(ShowGuiDesigner)
    {
        <CascadingValue Value="_draggedType">
            <MudStack Row>
                <GuiItemPicker></GuiItemPicker>
                <MyDiagramDesigner IsReadOnly="false" OnSelectedNodeChanged="OnSelectedNodeChanged" OnGuiChanged="OnGuiChanged"></MyDiagramDesigner>
                <ItemProperties SelectedNode="SelectedNode"></ItemProperties>
            </MudStack>
        </CascadingValue>
    }
    else if (!ShowGuiDesigner && !ShowAmisEditor)
    {
        <Amis @key="@($"amis-{SelectedPlug?.Id}")" JsonStringData="@PlugGuiJsonData"></Amis>
    }
    else if (ShowAmisEditor)
    {
        <iframe id="amis-editor" style="width:100%;height:100%;" src="_content/CJ.Plug.GUIDesigner/demo-6.7.0/index.html#/edit/0"></iframe>
    }


}
else
{
}




