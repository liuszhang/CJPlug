@code{

    [CascadingParameter]
    public DragDropManager _draggedType { get; set; } = new();
    [CascadingParameter]
    public SetMenuNotify? SetMenuNotify { get; set; }
    [CascadingParameter]
    public SetMaxGuiDesignerNotify? SetMaxGuiDesignerNotify { get; set; }


    public BaseGuiItemModel? SelectedNode { get; set; }

    private bool ShowGuiDesigner { get; set; } = false;
    private bool ShowAmisEditor { get; set; } = false;

    [CascadingParameter]
    public Plug? SelectedPlug { get; set; }
    public string? PlugGuiJsonData { get; set; }
    private bool IsGuiDesignerMaximized { get; set; } = false;
    private bool HasBuiltInSettingContent { get; set; } = false;
    private RenderFragment? BuiltInSettingContent { get; set; }


    private Plug? _lastSelectedPlug;
    private bool _isEditingGui;

    protected override async Task OnParametersSetAsync()
    {
        // 只在 SelectedPlug 真正变化时，才从数据库读取 GuiJsonData
        if (!ReferenceEquals(_lastSelectedPlug, SelectedPlug))
        {
            _lastSelectedPlug = SelectedPlug;
            _isEditingGui = false;
            GetJsonStringData();
            await ResolveBuiltInSettingContent();
        }
        StateHasChanged();
    }

    private async Task ResolveBuiltInSettingContent()
    {
        BuiltInSettingContent = null;
        HasBuiltInSettingContent = false;

        if (SelectedPlug == null || string.IsNullOrWhiteSpace(SelectedPlug.PlugTypeKey))
            return;

        foreach (var pcsc in PlugCommonSettingContent)
        {
            var context = new GetSettingContext(SelectedPlug.PlugTypeKey, SelectedPlug.DefinitionId, null, SelectedPlug);
            var content = await pcsc.GetPlugCommonSettingContent(context);
            if (content != null)
            {
                BuiltInSettingContent = content;
                HasBuiltInSettingContent = true;
                return;
            }
        }
    }

    public Task OnSelectedNodeChanged(BaseGuiItemModel? selectedNode)
    {
        SelectedNode = selectedNode;
        return Task.CompletedTask;
    }

    public Task OnGuiChanged(string? jsonData)
    {
        PlugGuiJsonData = jsonData;
        return Task.CompletedTask;
    }

    public async Task EditGui()
    {
        ShowGuiDesigner = true;
        ShowAmisEditor = false;
    }

    public async Task SaveGui()
    {
        if (SelectedPlug != null)
        {
            SelectedPlug.GuiJsonData = PlugGuiJsonData;
            await TASApiClient.UpdatePlugAsync(SelectedPlug.Id, SelectedPlug);
        }
        StateHasChanged();
        ShowGuiDesigner = false;
        ShowAmisEditor = false;

    }

    public async Task ShowAmis()
    {
        ShowGuiDesigner = false;
        ShowAmisEditor = true;
    }

    public async Task MaxGuiDesigner(bool isMax)
    {
        IsGuiDesignerMaximized = isMax;
        SetMenuNotify.Invoke(!IsGuiDesignerMaximized);
        SetMaxGuiDesignerNotify?.Invoke(IsGuiDesignerMaximized);

    }

