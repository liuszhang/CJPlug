@page "/LlmConfig"
@using CJ.Plug.LlmConfigApiClient
@using CJ.Plug.LlmConfigModel.Models
@using MudBlazor

@inject ILlmConfigApiClient LlmConfigApiClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>LLM 配置管理</PageTitle>

<MudContainer MaxWidth="MaxWidth.False">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.SmartToy" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h5">LLM 配置管理</MudText>
        <MudSpacer />
        @if (_activeConfig != null)
        {
            <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Variant="Variant.Outlined">
                当前: @_activeConfig.Value.ProviderName / @_activeConfig.Value.ModelName
            </MudChip>
        }
        else
        {
            <MudChip T="string" Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" Variant="Variant.Outlined">
                未配置默认模型
            </MudChip>
        }
    </MudStack>

    <MudGrid>
        @* ---- 左侧：供应商列表 ---- *@
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-4" Style="height: calc(100vh - 220px); overflow-y: auto;">
                <MudStack Row AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">供应商</MudText>
                    <MudSpacer />
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small"
                                   OnClick="CreateProvider" Title="添加供应商" />
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                   OnClick="LoadProviders" Title="刷新" />
                </MudStack>

                @if (_providers == null)
                {
                    <MudProgressCircular Indeterminate="true" />
                }
                else if (!_providers.Any())
                {
                    <MudText Color="Color.Secondary">暂无供应商，请点击上方 + 添加</MudText>
                }
                else
                {
                    @foreach (var provider in _providers)
                    {
                        <MudPaper Elevation="@(provider.Id == _selectedProviderId ? 4 : 1)"
                                  Class="pa-3 mb-2 cursor-pointer"
                                  Style="@(provider.Id == _selectedProviderId ? "border-left: 4px solid var(--mud-palette-primary);" : "")"
                                  @onclick="() => SelectProvider(provider.Id)">
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Cloud" Color="@(provider.IsEnabled ? Color.Primary : Color.Default)" />
                                <div style="flex:1;">
                                    <MudText Typo="Typo.subtitle1">@provider.DisplayName</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@provider.ApiBaseUrl</MudText>
                                </div>
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small">
                                    <MudMenuItem Icon="@Icons.Material.Outlined.Edit" OnClick="@(() => EditProvider(provider))">编辑</MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Outlined.Delete" OnClick="@(() => DeleteProvider(provider))">删除</MudMenuItem>
                                </MudMenu>
                            </MudStack>
                        </MudPaper>
                    }
                }
            </MudPaper>
        </MudItem>

        @* ---- 右侧：模型配置列表 ---- *@
        <MudItem xs="12" md="8">
            <MudPaper Elevation="2" Class="pa-4" Style="height: calc(100vh - 220px); overflow-y: auto;">
                <MudStack Row AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">
                        模型配置
                        @if (_selectedProvider != null)
                        {
                            <span> - @_selectedProvider.DisplayName</span>
                        }
                    </MudText>
                    <MudSpacer />
                    @if (_selectedProviderId > 0)
                    {
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add" OnClick="CreateModelConfig">
                            添加模型
                        </MudButton>
                    }
                </MudStack>

                @if (_selectedProviderId <= 0)
                {
                    <MudText Color="Color.Secondary" Class="mt-4">← 请先选择左侧供应商</MudText>
                }
                else if (_modelConfigs == null)
                {
                    <MudProgressCircular Indeterminate="true" />
                }
                else if (!_modelConfigs.Any())
                {
                    <MudText Color="Color.Secondary">该供应商下暂无模型配置</MudText>
                }
                else
                {
                    <MudDataGrid T="LlmModelConfig" Items="@_modelConfigs" Dense="true" Hover="true" Elevation="0">
                        <Columns>
                            <PropertyColumn Property="x => x.DisplayName" Title="显示名称" />
                            <PropertyColumn Property="x => x.ModelName" Title="模型标识" />
                            <TemplateColumn Title="类型">
                                <CellTemplate>
                                    <MudChip Label="true" Size="Size.Small">@context.Item.ModelType</MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="默认">
                                <CellTemplate>
                                    @if (context.Item.IsDefault)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                                    }
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="状态">
                                <CellTemplate>
                                    <MudSwitch T="bool" Value="@context.Item.IsEnabled" Disabled="true" Color="Color.Primary" Size="Size.Small" />
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="温度">
                                <CellTemplate>
                                    @(context.Item.Temperature?.ToString("F1") ?? "-")
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Style="text-align:right">
                                <CellTemplate>
                                    <MudStack Row Spacing="1" Justify="Justify.FlexEnd">
                                        <MudIconButton Icon="@(context.Item.IsDefault ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                                                       Size="Size.Small"
                                                       Color="@(context.Item.IsDefault ? Color.Warning : Color.Default)"
                                                       OnClick="@(() => SetDefaultModel(context.Item))"
                                                       Title="使用此模型" />
                                        <MudIconButton Icon="@Icons.Material.Filled.NetworkCheck" Size="Size.Small"
                                                       Color="Color.Info" OnClick="@(() => TestConnection(context.Item))"
                                                       Title="测试连接" />
                                        <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small"
                                                       OnClick="@(() => EditModelConfig(context.Item))" Title="编辑" />
                                        <MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Small"
                                                       Color="Color.Error" OnClick="@(() => DeleteModelConfig(context.Item))" Title="删除" />
                                    </MudStack>
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <NoRecordsContent>
                            <MudText>暂无模型配置</MudText>
                        </NoRecordsContent>
                    </MudDataGrid>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ---- MCP Server 配置 ---- *@
    <MudPaper Elevation="2" Class="pa-4 mt-4">
        <MudStack Row AlignItems="AlignItems.Center" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.h6">MCP Server 配置</MudText>
            <MudSpacer />
            @if (_mcpConfig != null)
            {
                <MudChip T="string" Icon="@(_mcpConfig.IsEnabled ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                         Color="@(_mcpConfig.IsEnabled ? Color.Success : Color.Default)" Size="Size.Small" Variant="Variant.Outlined">
                    @(_mcpConfig.IsEnabled ? "已启用" : "已禁用")
                </MudChip>
            }
        </MudStack>

        @if (_mcpLoading)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        }
        else if (_mcpConfig == null)
        {
            <MudText Color="Color.Secondary">暂未配置 MCP Server</MudText>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="CreateMcpServerConfig" Class="mt-2">
                添加 MCP Server
            </MudButton>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" sm="3">
                    <MudText Typo="Typo.subtitle2">连接状态</MudText>
                    <MudSwitch T="bool" Value="@_mcpConfig.IsEnabled" Disabled="true" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" sm="9">
                    <MudText Typo="Typo.subtitle2">连接字符串</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="word-break:break-all;">
                        @(string.IsNullOrEmpty(_mcpConfig.ConnectionString) ? "（未设置）" : _mcpConfig.ConnectionString)
                    </MudText>
                </MudItem>
                @if (!string.IsNullOrEmpty(_mcpConfig.Description))
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2">描述</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_mcpConfig.Description</MudText>
                    </MudItem>
                }
            </MudGrid>
            <MudStack Row Spacing="2" Justify="Justify.FlexEnd" Class="mt-3">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                           StartIcon="@Icons.Material.Outlined.Edit" OnClick="EditMcpServerConfig">编辑</MudButton>
            </MudStack>
        }
    </MudPaper>
</MudContainer>

@code {
    private List<LlmProvider>? _providers;
    private List<LlmModelConfig>? _modelConfigs;
    private int _selectedProviderId;
    private LlmProvider? _selectedProvider;
    private (string ProviderName, string ModelName)? _activeConfig;

    // MCP Server
    private McpServerConfig? _mcpConfig;
    private bool _mcpLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadProviders();
        UpdateActiveConfig();
        await LoadMcpConfig();
    }

    private void UpdateActiveConfig()
    {
        _activeConfig = null;
        Console.WriteLine($"[UpdateActiveConfig] _providers is null? {_providers == null}, count={_providers?.Count ?? 0}");

        if (_providers == null) { InvokeAsync(StateHasChanged); return; }

        foreach (var p in _providers)
        {
            Console.WriteLine($"[UpdateActiveConfig] Provider={p.Name}, IsEnabled={p.IsEnabled}, ModelConfigs={p.ModelConfigs?.Count ?? 0}");
        }

        // 优先查找 IsDefault 模型（不限供应商启用状态 — 即使供应商禁用，IsDefault 模型仍应被识别）
        foreach (var p in _providers)
        {
            var defaultModel = p.ModelConfigs?.FirstOrDefault(m => m.IsDefault && m.IsEnabled);
            if (defaultModel != null)
            {
                _activeConfig = (p.DisplayName, defaultModel.DisplayName);
                Console.WriteLine($"[UpdateActiveConfig] 默认模型: {p.DisplayName}(IsEnabled={p.IsEnabled}) / {defaultModel.DisplayName}");
                InvokeAsync(StateHasChanged);
                return;
            }
        }

        // 没有 IsDefault 模型，取第一个启用的供应商+模型
        var firstProvider = _providers.FirstOrDefault(p => p.IsEnabled && p.ModelConfigs?.Any(m => m.IsEnabled) == true);
        if (firstProvider != null)
        {
            var firstModel = firstProvider.ModelConfigs!.First(m => m.IsEnabled);
            _activeConfig = (firstProvider.DisplayName, firstModel.DisplayName);
            Console.WriteLine($"[UpdateActiveConfig] 兜底: {firstProvider.DisplayName} / {firstModel.DisplayName}");
        }
        else
        {
            Console.WriteLine("[UpdateActiveConfig] 兜底也失败: 没有启用的供应商或没有启用的模型");
        }

        InvokeAsync(StateHasChanged);
    }

    private async Task LoadProviders()
    {
        _providers = (await LlmConfigApiClient.GetAllProvidersAsync()).ToList();
        if (_selectedProviderId > 0 && _providers.All(p => p.Id != _selectedProviderId))
        {
            _selectedProviderId = 0;
            _selectedProvider = null;
            _modelConfigs = null;
        }
        UpdateActiveConfig();
    }

    private async Task SelectProvider(int providerId)
    {
        _selectedProviderId = providerId;
        _selectedProvider = _providers?.FirstOrDefault(p => p.Id == providerId);
        await LoadModelConfigs();
    }

    private async Task LoadModelConfigs()
    {
        if (_selectedProviderId <= 0) { _modelConfigs = null; return; }
        _modelConfigs = (await LlmConfigApiClient.GetModelConfigsByProviderAsync(_selectedProviderId)).ToList();
    }

    // ---- 供应商操作 ----

    private async Task CreateProvider()
    {
        var dialog = await DialogService.ShowAsync<Dialogs.ProviderDialog>("新建供应商",
            new DialogParameters { ["Provider"] = new LlmProvider() });
        var result = await dialog.Result;
        if (result != null && !result.Canceled && result.Data is LlmProvider provider)
        {
            await LlmConfigApiClient.CreateProviderAsync(provider);
            await LoadProviders();
            UpdateActiveConfig();
            Snackbar.Add("供应商创建成功", Severity.Success);
        }
    }

    private async Task EditProvider(LlmProvider provider)
    {
        var full = await LlmConfigApiClient.GetProviderByIdAsync(provider.Id);
        if (full == null) return;

        var dialog = await DialogService.ShowAsync<Dialogs.ProviderDialog>("编辑供应商",
            new DialogParameters { ["Provider"] = full });
        var result = await dialog.Result;
        if (result != null && !result.Canceled && result.Data is LlmProvider updated)
        {
            await LlmConfigApiClient.UpdateProviderAsync(updated);
            await LoadProviders();
            UpdateActiveConfig();
            if (_selectedProviderId == provider.Id)
                await SelectProvider(provider.Id);
            Snackbar.Add("供应商更新成功", Severity.Success);
        }
    }

    private async Task DeleteProvider(LlmProvider provider)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync("确认删除",
            $"确定要删除供应商 '{provider.DisplayName}' 吗？这将同时删除其下所有模型配置。",
            yesText: "删除", cancelText: "取消");
        if (confirmed == true)
        {
            var success = await LlmConfigApiClient.DeleteProviderAsync(provider.Id);
            if (success)
            {
                if (_selectedProviderId == provider.Id)
                {
                    _selectedProviderId = 0;
                    _selectedProvider = null;
                    _modelConfigs = null;
                }
                await LoadProviders();
                UpdateActiveConfig();
                Snackbar.Add("删除成功", Severity.Success);
            }
            else
            {
                Snackbar.Add("删除失败", Severity.Error);
            }
        }
    }

    // ---- 模型配置操作 ----

    private async Task CreateModelConfig()
    {
        var config = new LlmModelConfig { LlmProviderId = _selectedProviderId };
        var dialog = await DialogService.ShowAsync<Dialogs.ModelConfigDialog>("新建模型配置",
            new DialogParameters { ["ModelConfig"] = config });
        var result = await dialog.Result;
        if (result != null && !result.Canceled && result.Data is LlmModelConfig created)
        {
            await LlmConfigApiClient.CreateModelConfigAsync(created);
            await LoadModelConfigs();
            UpdateActiveConfig();
            Snackbar.Add("模型配置创建成功", Severity.Success);
        }
    }

    private async Task EditModelConfig(LlmModelConfig config)
    {
        var full = await LlmConfigApiClient.GetModelConfigByIdAsync(config.Id);
        if (full == null) return;

        var dialog = await DialogService.ShowAsync<Dialogs.ModelConfigDialog>("编辑模型配置",
            new DialogParameters { ["ModelConfig"] = full });
        var result = await dialog.Result;
        if (result != null && !result.Canceled && result.Data is LlmModelConfig updated)
        {
            await LlmConfigApiClient.UpdateModelConfigAsync(updated);
            await LoadModelConfigs();
            UpdateActiveConfig();
            Snackbar.Add("模型配置更新成功", Severity.Success);
        }
    }

    private async Task DeleteModelConfig(LlmModelConfig config)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync("确认删除",
            $"确定要删除模型配置 '{config.DisplayName}' 吗？",
            yesText: "删除", cancelText: "取消");
        if (confirmed == true)
        {
            var success = await LlmConfigApiClient.DeleteModelConfigAsync(config.Id);
            if (success)
            {
                await LoadModelConfigs();
                UpdateActiveConfig();
                Snackbar.Add("删除成功", Severity.Success);
            }
            else
            {
                Snackbar.Add("删除失败", Severity.Error);
            }
        }
    }

    private async Task SetDefaultModel(LlmModelConfig config)
    {
        var success = await LlmConfigApiClient.SetDefaultModelAsync(config.Id);
        if (success)
        {
            await LoadModelConfigs();
            await LoadProviders();
            UpdateActiveConfig();
            Snackbar.Add($"已将 '{config.DisplayName}' 设为默认模型", Severity.Success);
        }
        else
        {
            Snackbar.Add("设置默认模型失败", Severity.Error);
        }
    }

    private async Task TestConnection(LlmModelConfig config)
    {
        Snackbar.Add("正在测试连接...", Severity.Info);
        var (success, message) = await LlmConfigApiClient.TestConnectionAsync(config.Id);
        if (success)
            Snackbar.Add($"✅ {message}", Severity.Success);
        else
            Snackbar.Add($"❌ {message}", Severity.Error, c => c.SnackbarVariant = Variant.Filled);
    }

    // ---- MCP Server 操作 ----

    private async Task LoadMcpConfig()
    {
        _mcpLoading = true;
        try
        {
            _mcpConfig = await LlmConfigApiClient.GetMcpServerConfigAsync();
        }
        catch
        {
            _mcpConfig = null;
        }
        finally
        {
            _mcpLoading = false;
        }
    }

    private async Task CreateMcpServerConfig()
    {
        var config = new McpServerConfig { IsEnabled = true };
        var dialog = await DialogService.ShowAsync<Dialogs.McpServerDialog>("新建 MCP Server",
            new DialogParameters { ["Config"] = config });
        var result = await dialog.Result;
        if (result != null && !result.Canceled && result.Data is McpServerConfig created)
        {
            _mcpConfig = await LlmConfigApiClient.SaveMcpServerConfigAsync(created);
            Snackbar.Add("MCP Server 配置已保存", Severity.Success);
        }
    }

    private async Task EditMcpServerConfig()
    {
        if (_mcpConfig == null) return;
        var dialog = await DialogService.ShowAsync<Dialogs.McpServerDialog>("编辑 MCP Server",
            new DialogParameters { ["Config"] = _mcpConfig });
        var result = await dialog.Result;
        if (result != null && !result.Canceled && result.Data is McpServerConfig updated)
        {
            _mcpConfig = await LlmConfigApiClient.SaveMcpServerConfigAsync(updated);
            Snackbar.Add("MCP Server 配置已更新", Severity.Success);
        }
    }
}
