@using CJ.Plug.ElsaIntegration.Pages
@using CJ.Plug.Models.Plug
@using CJ.Plug.Models.PlugProcess
@using System.Text.Json
@using CJ.Plug.SharedPages
@using CJ.Plug.SharedPages.Layout
@using Elsa.Api.Client.Resources.WorkflowDefinitions.Models
@using System.Text.Json.Nodes


@inject IDialogService DialogService
@inject MainApiClient WorkflowApiClient
@inject ISnackbar Snackbar
@* <VerticalWell ExtraPadding="60"> *@


<MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-0" Style="height:100%">
    <MudTabPanel Text="参数" Style="height:100%">

        <VerticalPercentWell SplitterPanelPercent="HeightPercent">
            <ParametersData OnOnlyVariableUpdated="OnOnlyVariableUpdated" SelectedActivity="SelectedActivity" Plug="Plug"></ParametersData>

        </VerticalPercentWell>


    </MudTabPanel>
</MudTabs>
@* </VerticalWell> *@


@code{
    [Parameter]
    public double HeightPercent { get; set; } = 50.00;

    [Parameter]
    public Process? Process { get; set; }
    [Parameter]
    public Plug? Plug { get; set; }
    [Parameter]
    public JsonObject? SelectedActivity { get; set; }

    [Parameter]
    public EventCallback<PlugVariable> OnOnlyVariableUpdated { get; set; }

    private List<PlugVariable>? SelectedProcessVariables = new List<PlugVariable>();

}