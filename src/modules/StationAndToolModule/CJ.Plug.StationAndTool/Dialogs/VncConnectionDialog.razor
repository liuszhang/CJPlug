@using CJ.Plug.Models.Station
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6">
                远程可视化 - @(Tool?.ToolName ?? "未知工具")
            </MudText>
            @if (_selectedStation != null)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                    目标图站: @_selectedStation.StationIp
                </MudChip>
            }
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (!_initialized)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-4" />
        }
        else
        {
            <MudStack Spacing="4">

                @* 图站选择 *@
                <MudText Typo="Typo.subtitle1" Color="Color.Primary">选择目标图站</MudText>
                <MudSelect @bind-Value="_selectedStation" For="@(() => _selectedStation)"
                           Label="请选择在线图站" Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var station in Stations ?? new())
                    {
                        <MudSelectItem Value="station">
                            @station.StationName (@station.StationIp) -
                            @(station.GuacamoleEnabled ? "远程桌面已启" : "远程桌面未启")
                        </MudSelectItem>
                    }
                </MudSelect>

                @* 工具信息 *@
                <MudPaper Elevation="0" Class="pa-3">
                    <MudStack Spacing="2">
                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">工具名称</MudText>
                            <MudText Typo="Typo.body2" Style="font-weight:600;">@Tool?.ToolName</MudText>
                        </MudStack>
                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">版本</MudText>
                            <MudText Typo="Typo.body2">v@(Tool?.ToolVersion)</MudText>
                        </MudStack>
                        <MudDivider />
                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">可视化方式</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Text="VNC 远程连接" />
                        </MudStack>
                    </MudStack>
                </MudPaper>

                @* Guacamole 连接状态 *@
                @if (_selectedStation != null)
                {
                    <MudAlert Severity="@(_selectedStation.GuacamoleEnabled ? Severity.Success : Severity.Warning)"
                              Variant="Variant.Filled" Class="pa-2">
                        @if (_selectedStation.GuacamoleEnabled)
                        {
                            <MudText>图站 @_selectedStation.StationIp 远程桌面已启用</MudText>
                            <MudText Typo="Typo.body2">
                                协议: @_selectedStation.GuacamoleProtocol?.ToUpperInvariant() |
                                端口: @_selectedStation.GuacamolePort
                            </MudText>
                        }
                        else
                        {
                            <MudText>该图站未启用远程桌面功能，请先在图站配置中开启 Guacamole 远程桌面</MudText>
                        }
                    </MudAlert>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        @if (_connecting)
        {
            <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Small" Class="mr-2" />
            <MudText Typo="Typo.body2">正在启动工具...</MudText>
        }
        else
        {
            <MudButton OnClick="Cancel" Color="Color.Secondary">取消</MudButton>
            <MudButton OnClick="LaunchAndConnect"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       Disabled="@(!CanLaunch)">
                启动并连接
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public Tool? Tool { get; set; }

    [Parameter]
    public List<Station>? Stations { get; set; } = new();

    private Station? _selectedStation;
    private bool _initialized;
    private bool _connecting;
    private bool CanLaunch => _selectedStation != null && !_connecting;

    protected override async Task OnInitializedAsync()
    {
        _initialized = true;

        // 默认选择第一个启用了 Guacamole 的在线图站
        _selectedStation = Stations?.FirstOrDefault(s => s.GuacamoleEnabled)
                        ?? Stations?.FirstOrDefault();
    }

    private async Task LaunchAndConnect()
    {
        if (_selectedStation == null || Tool == null)
        {
            Snackbar.Add("请先选择目标图站", Severity.Warning);
            return;
        }

        if (!_selectedStation.GuacamoleEnabled)
        {
            Snackbar.Add("目标图站未启用远程桌面，无法连接", Severity.Error);
            return;
        }

        _connecting = true;
        StateHasChanged();

        try
        {
            // 构建 Guacamole 连接 URL
            var guacUrl = BuildGuacamoleUrl(_selectedStation, Tool);

            // 在新窗口中打开 VNC 连接
            await JSRuntime.InvokeVoidAsync("window.open",
                guacUrl, "_blank",
                "width=1280,height=800,menubar=no,toolbar=no,location=no,status=no");

            Snackbar.Add($"已启动远程可视化连接: {Tool.ToolName}", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"启动失败: {ex.Message}", Severity.Error);
            _connecting = false;
            StateHasChanged();
        }
    }

    private string BuildGuacamoleUrl(Station station, Tool tool)
    {
        // Guacamole 标准 URL 格式:
        // http://{guac-server}/#/client/{connection-id}?token={token}
        // 或 http://{guac-server}/guacamole/#/client/{protocol}?hostname={ip}&port={port}&username={user}&password={pass}

        var protocol = station.GuacamoleProtocol?.ToLower() ?? "vnc";
        var port = station.GuacamolePort ?? (protocol == "vnc" ? 5900 : protocol == "rdp" ? 3389 : 22);
        var hostname = station.StationIp ?? "127.0.0.1";
        var username = station.GuacamoleUsername ?? "";
        var password = station.GuacamolePassword ?? "";

        // 默认 Guacamole 服务器地址 (可在配置中覆盖)
        var guacServer = "http://localhost:8080/guacamole";

        // 如果图站有 Guacamole Connection ID，直接使用
        if (!string.IsNullOrEmpty(station.GuacamoleConnectionId))
        {
            return $"{guacServer}/#/client/{Uri.EscapeDataString(station.GuacamoleConnectionId)}";
        }

        // 否则通过参数构建连接 URL
        var paramsStr = $"hostname={Uri.EscapeDataString(hostname)}"
                      + $"&port={port}"
                      + $"&username={Uri.EscapeDataString(username)}"
                      + $"&password={Uri.EscapeDataString(password)}";

        return $"{guacServer}/#/client/{protocol}?{paramsStr}";
    }

    private void Cancel() => MudDialog.Cancel();
}

