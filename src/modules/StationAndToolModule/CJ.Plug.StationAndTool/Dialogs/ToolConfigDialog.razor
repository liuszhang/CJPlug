@code {

    [CascadingParameter] IMudDialogInstance _MudDialog { get; set; }
    [Parameter] public Station? Station { get; set; }

    public List<ToolConfig> ToolConfigs { get; set; } = new List<ToolConfig>();

    //public StationConfigTable? toolAgentToolConfig { get; set; } = new StationConfigTable();
    public IBrowserFile? File { get; set; }
    DialogOptions diaOption = new DialogOptions() { MaxWidth = MaxWidth.Large, Position = DialogPosition.Center, FullWidth=true};


    private bool isVisible = false;
    private string searchString = "";
    private TableApplyButtonPosition applyButtonPosition = TableApplyButtonPosition.End;
    private TableEditButtonPosition editButtonPosition = TableEditButtonPosition.End;
    private TableEditTrigger editTrigger = TableEditTrigger.RowClick;
    private MudTextField<string> filechooser;
    //private string tmpToolPath;
    private ToolConfig selectedItem1 = null;


    protected override async Task OnInitializedAsync()
    {
        await _MudDialog.SetOptionsAsync(diaOption);

        var relations = await MainApiClient.GetRealationByFilterAsync(new RelationFilter() { RoleBId = Station.Id, RelationCategory = RelationCategory.ToolToStation.ToString() });

        foreach (var r in relations)
        {
            var toolDeploySetting = JsonSerializer.Deserialize<ToolDeploySettingModel>(r.RelationSetting);
            var tool = await MainApiClient.GetToolByIdAsync(r.RoleAId);
            if (toolDeploySetting.IsDeployed)
            {
                var newToolConfig = new ToolConfig()
                {
                    ToolId = r.RoleAId,
                    ToolName = r.RoleAName,
                    ToolVersion = tool?.ToolVersion,
                    //ToolPath = r.GetRelationSetting("ToolPath"),
                    ToolPath = toolDeploySetting?.SpecialToolPath,
                    CommandParameter = tool?.CommandParameter,
                };
                ToolConfigs.Add(newToolConfig);
            }            
        }
    }


    private bool FilterFunc(ToolConfig element)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        // if (element.Id.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        //     return true;
        if (element.ToolName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if ($"{element.ToolPath} {element.ToolVersion}".Contains(searchString))
            return true;
        return false;
    }

