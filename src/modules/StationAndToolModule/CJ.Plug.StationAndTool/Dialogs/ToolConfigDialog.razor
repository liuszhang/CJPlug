    private async Task OnFilesSelected(IBrowserFile file)
    {       
        await filechooser.FocusAsync();
        selectedItem1.ToolPath = file.Name;    
    }

    private async Task NewCommonConfig(string name,string version,string path,string? command)
    {
        ToolConfigs.Add(new ToolConfig(){ToolName=name,ToolVersion=version,ToolPath=path,CommandParameter=command});
        //StateHasChanged();
    }

    private async Task NewConfig()
    {
        ToolConfigs.Add(new ToolConfig());
        StateHasChanged();
    }

    private async Task DeleteConfig(ToolConfig ToolConfig)
    {
        //Console.WriteLine(ToolConfig.ToolName);
        var result = ToolConfigs.Remove(ToolConfig);
        //Console.WriteLine(result.ToString());
        //Console.WriteLine(toolAgentToolConfig.ToolConfigs.Count());
