@using CJ.Plug.ElsaIntegration.Contracts
@using CJ.Plug.Models.Plug
@using CJ.Plug.Models.PlugAction
@using CJ.Plug.Models.Shared
@using CJ.Plug.Models.Station
@using CJ.Plug.SharedPages
@using CJ.Plug.StationAndToolApiClient
@using Elsa.Api.Client.Resources.WorkflowDefinitions.Models
@using System.Text.Json.Nodes
@using System.Text.Json
@using Microsoft.JSInterop
@using Serilog

@inject IStationAndToolApiClient MainApiClient
@inject IJSRuntime JsRuntime
@inject IDialogService DialogService
@inject IElsaDomToolService ElsaDomToolService



<input class="d-none" type="file" id="filepicker" name="file" webkitdirectory />
<script>
    window.initFilePicker = (dotNet,toolAgentIp) => {
    //console.log("初始化");
    document.getElementById("filepicker").addEventListener(
    "change",
    (event) => {
    const fileInfos = [];
    for (const file of event.target.files) {
    fileInfos.push(file.webkitRelativePath);
    uploadFileToServer(file, toolAgentIp);
    //console.log(file);
    dotNet.invokeMethodAsync('ProcessSelectedFiles',file.webkitRelativePath);
    }
    dotNet.invokeMethodAsync('ShowSelectedFilesStatus');
    },
    false
    );

    };

    async function uploadFileToServer(file, toolAgentIp) {
    console.log(file);
    const formData = new FormData();
    var username = localStorage.getItem('username');
    //formData.append('file', file);
    //下面三个字段是API接口需要的三个字段，最好保持大小写也一致
    formData.append('UploadPath', username+'//Tools');
    formData.append('FileName', file.webkitRelativePath);
    formData.append('FileStream', file);
    try {
    const response = await fetch(toolAgentIp + '/api/file/Upload', {
    method: 'POST',
    body: formData,
    headers: {
    'Accept': 'application/json'
    },
    mode: 'no-cors' // 确保启用CORS
    });

    // if (!response.ok) {
    //     throw new Error(`文件上传失败，状态码：${response.status}`);
    // }
    // console.log(file.name + '文件上传成功');
    } catch (error) {
    console.error('文件上传时发生错误:', error);
    }
    };


</script>



<MudDialog>
    <DialogContent>
        <MudStack>
            <MudStack Row AlignItems="AlignItems.Center">
                <MudTextField @bind-Value="@Tool.ToolName" Required Margin="Margin.Dense" Label="工具名称" Variant="Variant.Outlined"></MudTextField>
                <MudTextField @bind-Value="@Tool.ToolVersion" Margin="Margin.Dense" Label="工具版本" Variant="Variant.Outlined"></MudTextField>
                <MudTextField @bind-Value="@Tool.ToolCompany" Margin="Margin.Dense" Label="工具厂商" Variant="Variant.Outlined"></MudTextField>
                @* <MudTextField @bind-Value="@Type" Margin="Margin.Dense" Label="类型" Variant="Variant.Outlined"></MudTextField> *@
                <MudTooltip Text="系统工具只有管理员能够创建，创建后所有人可见">
                    <MudSwitch @bind-Value="@Tool.IsSystemInitTool" Label="是否系统工具" Size="Size.Small" Color="Color.Primary"></MudSwitch>
                </MudTooltip>
            </MudStack>


            <MudSelect @bind-Value="@Tool.ToolType" T="string" Label="工具类型" Margin="Margin.Dense" Dense FullWidth Variant="Variant.Outlined">
                @foreach (var c in Enum.GetNames(typeof(ToolTypeEnum)).ToList())
                {
                    <MudSelectItem T="string" Value=@c>@c</MudSelectItem>
                }
            </MudSelect>
            @if (Tool.ToolType.Contains("桌面类"))
            {       
                <MudTextField @bind-Value="@Tool.CommandParameter" Margin="Margin.Dense" Label="命令行配置" Variant="Variant.Outlined"></MudTextField>

                <MudStack Row AlignItems="AlignItems.Center">
                    <MudTextField T="string" @bind-Value="Tool.ToolPath" Margin="Margin.Dense" Label="工具路径" Variant="Variant.Outlined"></MudTextField>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="CheckRemoteFiles">选择</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="UploadToolFiles">上传程序包</MudButton>
                </MudStack>
                <MudText Align="Align.Center">运行环境包 @RunTimeFiles.Count() 个文件已经上传成功</MudText>
                @foreach (var file in RunTimeFiles)
                {
                    <MudText>@file</MudText>
                }

            }
            else if (Tool.ToolType.Contains("接口类"))
            {
                <MudStack Row Justify="Justify.Center">
                    <MudSelect T="string" Style="width:200px !important;" Label="请求方法" Variant="Variant.Outlined" Required RequiredError="请选择一个子分类" Margin="Margin.Dense">
                        <MudSelectItem Value="@("GET")">GET</MudSelectItem>
                        <MudSelectItem Value="@("POST")">POST</MudSelectItem>
                        <MudSelectItem Value="@("PUT")">PUT</MudSelectItem>
                        <MudSelectItem Value="@("DELETE")">DELETE</MudSelectItem>
                        <MudSelectItem Value="@("HEAD")">HEAD</MudSelectItem>
                        <MudSelectItem Value="@("OPTIONS")">OPTIONS</MudSelectItem>
                        <MudSelectItem Value="@("PATCH")">PATCH</MudSelectItem>
                    </MudSelect>
                    <MudTextField T="string" FullWidth Label="请求地址" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudStack>

                <MudContainer MaxWidth="MaxWidth.ExtraLarge" Style="padding:0">
                    <MudButton StartIcon="@Icons.Material.Outlined.Add"
                               Variant="Variant.Filled"     
                               OnClick="NewInput"
                               Color="Color.Primary" Class="align-self-end">添加服务参数</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="Testing">
                        @if (Testing)
                        {
                            <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate></MudProgressCircular>
                        }
                        else
                        {
                            <div>请求测试</div>
                        }

                    </MudButton>
                    <MudDataGrid T="PDZVariable" Items="@RequestDatas" ReadOnly="false" EditMode="MudBlazor.DataGridEditMode.Cell" Dense="true"
                                 EditTrigger="@(DataGridEditTrigger.Manual)">
                        <Columns>
                            @* <PropertyColumn Property="x => x.Id" Title="序号" IsEditable="false"></PropertyColumn> *@
                            <PropertyColumn Property="x => x.Type" Title="类型">
                                <EditTemplate>
                                    <MudSelect @bind-Value="context.Item.Type" Required Dense Margin="@Margin.Dense">
                                        <MudSelectItem Value="@("Header")">Header(请求头参数)</MudSelectItem>
                                        <MudSelectItem Value="@("Path")">Path(路径参数)</MudSelectItem>
                                        <MudSelectItem Value="@("Query")">Query(查询参数)</MudSelectItem>
                                        <MudSelectItem Value="@("Body")">Body(请求体参数)</MudSelectItem>
                                        <MudSelectItem Value="@("Form")">Form(表单参数)</MudSelectItem>
                                    </MudSelect>
                                </EditTemplate>
                            </PropertyColumn>
                            <PropertyColumn Property="x => x.Name" Title="名称"></PropertyColumn>
                            <PropertyColumn Property="x => x.IsRequired" Title="必需">
                                <EditTemplate>
                                    <MudSwitch @bind-Value="context.Item.IsRequired" Color="Color.Primary" Label="@context.Item.IsRequired.ToString()"></MudSwitch>
                                </EditTemplate>
                            </PropertyColumn>
                            <PropertyColumn Property="x => x.DefaultValue" Title="操作">
                                <EditTemplate>
                                    <MudStack Row>
                                        <MudButton Variant="Variant.Filled">
                                            <MudText Class="ms-2">删除</MudText>
                                        </MudButton>
                                    </MudStack>
                                </EditTemplate>
                            </PropertyColumn>
                        </Columns>
                    </MudDataGrid>
                </MudContainer>
            }
            else
            {
                <MudTextField T="string" @bind-Value="Tool.ToolPath" Margin="Margin.Dense" Label="工具路径" Variant="Variant.Outlined"></MudTextField>
            }

        </MudStack>
    </DialogContent>
    <DialogActions>
        @if (SubmitDisabled)
        {
            <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Small"></MudProgressCircular>
        }
        else
        {
            <MudButton Disabled="@SubmitDisabled" OnClick="Cancel">取消</MudButton>
            <MudButton Disabled="@SubmitDisabled" Color="Color.Primary" OnClick="Submit">提交</MudButton>
        }
        
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }
    private bool SubmitDisabled = false;
    private Tool Tool { get; set; } = new();
    private bool Testing = false;
    public List<PDZVariable>? RequestDatas { get; set; } = new List<PDZVariable>();

    List<string>? RunTimeFiles = new List<string>();

    protected override async Task OnInitializedAsync()
    {
        //PlugSettings = Plug.GetPlugSettings();
        //ToolPath = PlugSettings.GetSetting(ExePlugSettingKey.ToolPath.ToString());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            //await JsRuntime.InvokeVoidAsync("initFilePicker");
            //var Apiserver=await MainApiClient.
            await JsRuntime.InvokeVoidAsync("initFilePicker", DotNetObjectReference.Create(this), GlobalData.MainApiServer);
            //MyCon1sole.WriteLine("完成初始化2");
        }
    }
    async Task CheckRemoteFiles()
    {
        //MyCon1sole.WriteLine("open new dialog");
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium ,FullWidth=true};
        var dialog = await DialogService.ShowAsync<ChooseServerFiles>("选择服务端文件", options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            Tool.ToolPath = result.Data.ToString();
        }
    }
    private Task UploadToolFiles()
    {
        return ElsaDomToolService.ClickElementAsync("#filepicker");
    }

    [JSInvokable]
    public async Task ProcessSelectedFiles(string file)
    {
        //MyCon1sole.WriteLine(file);
        RunTimeFiles.Add(file);
        StateHasChanged();
    }
    [JSInvokable]
    public async Task ShowSelectedFilesStatus()
    {
        //MyCon1sole.WriteLine(RunTimeFiles.Count());
        //Log.Information("RunTimeFiles.Count()={0}", RunTimeFiles.Count());
    }



    private void NewInput()
    {
        //string inputName = CommonActions.GetUniqueInputName(element);
        RequestDatas.Add(new PDZVariable() { Type = "Header", Name = "header1" });
    }


    private async Task Submit()
    {        
        SubmitDisabled = true;
        await MainApiClient.CreateToolAsync(Tool);
        Console.WriteLine($"succuse create plug:{Tool.ToolName}");
        MudDialog.Close(DialogResult.Ok(Tool));
    }

    private void Cancel() => MudDialog.Cancel();
}
