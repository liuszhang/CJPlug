    protected override async Task OnParametersSetAsync()
    {
        if (AllStations != null && AllStations.Count > 0)
        {
            Loading = false;
            //StationsToShow = ShowAllToolAgents? AllStations : OnlineStations;
        }
    }

    private async Task ProcessStationList(string ip)
    {
        foreach(var station in AllStations!)
        {
            if (station.StationIp == ip)
            {
                station.IsStarted = true;
                if (!stationStatus!.Contains(ip))
                {
                    stationStatus.Add(ip);
                }
            }
            else
            {
                station.IsStarted = false;
            }
        }
    }

    private async Task GetStationStatus()
    {
        await OnGetStationStatus.InvokeAsync();
        // AllStations = await MainApiClient.GetAllStationsAsync() ?? new List<Station>();
        // await HubConnectionManagerService.ConnectAsync();
        // await HubConnectionManagerService.InvokeAsync<string>("TellMeStatus", null);
    }


    async Task SetToolAgentToUse(string ip)
    {
        if (ip != null)
        {
            // await ToolAgentStatus.SetToolAgentToUse(ip);
            // _HttpHostIp.ToolAgentHostIp = ip;
            ToolAgentToUse = ip;
        }
        else
        {
            //ToolAgentToUse = await ToolAgentConnect.GetToolAgentToUse();
        }
        StateHasChanged();
    }

    async Task ClearUserSetToolAgent()
    {
        ToolAgentToUse = "";
    }

    async Task ConfigTools(Station? station)
    {
        var parameters = new DialogParameters<ToolConfigDialog> { { x => x.Station, station } };
        var dialog = await DialogService.ShowAsync<ToolConfigDialog>(null, parameters);
    }

