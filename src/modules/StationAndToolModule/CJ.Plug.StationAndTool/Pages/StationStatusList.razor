    public EventCallback OnGetStationStatus { get; set; }
    [Parameter]
    public List<Station>? AllStations { get; set; } = new();
    [Parameter]
    public List<Station>? OnlineStations { get; set; } = new();

    private List<Station>? StationsToShow {
        get
        {
            return ShowAllToolAgents ? AllStations : OnlineStations;
        }
    }


    private bool Loading = true;
    public string TextValue { get; set; } = "";
    public string ToolAgentToUse { get; set; } = "";
    public string? tmpToolAgentToUse { get; set; }
