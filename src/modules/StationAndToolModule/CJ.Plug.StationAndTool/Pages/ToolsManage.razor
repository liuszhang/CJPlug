    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 这里可以添加一些初始化代码
            await RefreshTools();
            StateHasChanged();
        }
    }

    private async Task RefreshTools()
    {
        var tools = await StationAndToolApiClient.GetAllToolsAsync();
        Tools.Clear();
        //Tools.AddRange(DefaultTools);
        Tools.InsertRange(0, tools);

        foreach (var tool in Tools)
        {
            //获取工具当前可用的图站列表
            var usableStations = new List<Station>();
            var allStations = await StationAndToolApiClient.GetAllStationsAsync();
        }

        Loading = false;
    }

    private async Task OpenMenuContent(DataGridRowClickEventArgs<Tool> args)
    {
        _contextRow = args.Item;
        await _contextMenu.OpenMenuAsync(args.MouseEventArgs);
    }

    private async Task DeleteTool()
    {
        if (_contextRow is not null)
        {            
            await StationAndToolApiClient.DeleteToolAsync(_contextRow.Id);
            Snackbar.Add($"删除{_contextRow.ToolName}成功", Severity.Info);
            Tools.Remove(_contextRow);
            //await RefreshTools();
            StateHasChanged();
        }
    }

    async Task AddItem()
    {
        var options = new DialogOptions { CloseOnEscapeKey = false, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<NewTool>("新建工具", options);
        var result = await dialog.Result;
        if (result != DialogResult.Cancel())
        {
            await RefreshTools();
            StateHasChanged();
        }
        //_items.Add(new Model("New Person", 44, Severity.Warning, 85_000.00M, new DateTime(2022, 1, 1), true));
    }
    private async Task ImportTools()
    {
        foreach (var t in DefaultTools)
        {
            await StationAndToolApiClient.CreateToolAsync(t);
        }
        await RefreshTools();
        StateHasChanged();
    }

    async Task<DataGridEditFormAction> CommittedItemChanges(Tool item)
    {
        //Console.WriteLine(item.ToolName);
        await StationAndToolApiClient.UpdateToolAsync(item);
        Snackbar.Add($"更新成功{item.ToolName}");

        return DataGridEditFormAction.Close;
    }

    private async Task ToolDeploySetting(Tool Tool)
    {
        var parameters = new DialogParameters<ToolDeploySettingDialog> { { x => x.Tool, Tool } };
        var dialog = await DialogService.ShowAsync<ToolDeploySettingDialog>($"{Tool.ToolName}({Tool.ToolVersion})部署配置",parameters);
    }
