@using System.Net.Http.Json
@using System.Collections.ObjectModel
@using CJ.Plug.Models.Station
@using CJ.Plug.StationAndTool.Dialogs
@using CJ.Plug.StationAndToolApiClient
@inject HttpClient httpClient

@inject IDialogService DialogService
@inject IStationAndToolApiClient StationAndToolApiClient
@inject ISnackbar Snackbar

<PageTitle>工具配置</PageTitle>

<MudStack Row AlignItems="AlignItems.Center">
    <MudButton OnClick="@AddItem" Color="@Color.Primary" Class="add-item-btn" Variant="Variant.Outlined">添加工具</MudButton>
    <MudButton OnClick="ImportTools" Variant="Variant.Outlined">导入默认</MudButton>
    <MudButton Variant="Variant.Outlined">导入</MudButton>
    <MudButton Variant="Variant.Outlined">导出</MudButton>
    <MudSpacer />
    <MudTextField Margin="Margin.Dense" Label="Search" @bind-Value="@searchTerm" Variant="Variant.Outlined" />
</MudStack>
@if (Loading)
{
    <MudProgressLinear Indeterminate Color="Color.Primary"></MudProgressLinear>
}

<MudDataGrid T="Tool" Items="@Tools" Hover CommittedItemChanges="@(async (e)=>await CommittedItemChanges(e))"
RowContextMenuClick="OpenMenuContent"
ColumnResizeMode="ResizeMode.Column" SortMode="SortMode.None" ShowColumnOptions="false"
ReadOnly="false" EditMode="DataGridEditMode.Cell" EditTrigger="DataGridEditTrigger.Manual">
    <Columns>
        <HierarchyColumn T="Tool" />
        <PropertyColumn Property="x => x.ToolName" CellStyle="width:160px" Title="工具名称"/>
        <PropertyColumn Property="x => x.ToolVersion" Title="工具版本" CellStyle="width:100px" />
        <PropertyColumn Property="x => x.ToolPath" Title="默认路径" Required="false" >
            <EditTemplate>
                <MudTextField Margin="Margin.Dense" FullWidth Value="@context.Item.ToolPath" AutoGrow
                ValueChanged="@(async(string e)=>{context.Item.ToolPath=e;await CommittedItemChanges(context.Item);})">
                </MudTextField>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.ToolType" Title="工具类型" CellStyle="width:150px">
            <EditTemplate>
                <MudSelect Dense Margin="Margin.Dense" Value="@context.Item.ToolType" ValueChanged="@(async(string e)=>{context.Item.ToolType=e;await CommittedItemChanges(context.Item);})">
                    @foreach (var c in Enum.GetNames(typeof(ToolTypeEnum)).ToList())
                    {
                        <MudSelectItem T="string" Value=@c>@c</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.ToolCompany" Title="工具厂商" Required="false" CellStyle="width:100px" />
        <PropertyColumn Property="x => x.CommandParameter" Title="命令行配置" Required="false" CellStyle="width:220px" >
            <EditTemplate>
                <MudTextField Margin="Margin.Dense" FullWidth Value="@context.Item.CommandParameter" AutoGrow MaxLines=6 Variant="Variant.Outlined"
                ValueChanged="@(async(string e)=>{context.Item.CommandParameter=e;await CommittedItemChanges(context.Item);})">
                </MudTextField>
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="可用图站" CellStyle="width:280px">
            <EditTemplate>
                <MudList Dense>
                    @foreach (var station in OnlineStations)
                    {
                        <MudListItem>
                            <MudStack Row Spacing="0" AlignItems="AlignItems.Center">
                                <MudToggleIconButton @bind-Toggled="@context.Item.IsEnabled"
                                                     Icon="@Icons.Material.Outlined.DeveloperBoardOff"
                                                     Size="Size.Small"
                                                     Color="@Color.Error"
                                                     ToggledIcon="@Icons.Material.Outlined.DeveloperBoard"
                                                     ToggledColor="@Color.Success" />
                                <MudText Typo="Typo.body2">@($"{station.StationIp}(DSBLSZ)")</MudText>
                            </MudStack>
                        </MudListItem>
                    }
                    @* <MudListItem>
                        <MudStack Row Spacing="0" AlignItems="AlignItems.Center">
                            <MudToggleIconButton @bind-Toggled="@context.Item.IsEnabled"
                                                 Icon="@Icons.Material.Outlined.DeveloperBoardOff"
                            Size="Size.Small"
                            Color="@Color.Error"
                                                 ToggledIcon="@Icons.Material.Outlined.DeveloperBoard"
                            ToggledColor="@Color.Success" />
                            <MudText Typo="Typo.body2">192.168.101.101:6060(DSBLSZ)</MudText>
                        </MudStack>
                    </MudListItem>
                    <MudListItem>
                        <MudStack Row Spacing="0" AlignItems="AlignItems.Center">
                            <MudToggleIconButton @bind-Toggled="@context.Item.IsEnabled"
                                                 Icon="@Icons.Material.Outlined.DeveloperBoardOff"
                            Size="Size.Small"
                            Color="@Color.Error"
                                                 ToggledIcon="@Icons.Material.Outlined.DeveloperBoard"
                            ToggledColor="@Color.Success" />
                            <MudText Typo="Typo.body2">192.168.101.101:6061(DSBLSZ)</MudText>
                        </MudStack>
                    </MudListItem> *@
                </MudList>
            </EditTemplate>
        </TemplateColumn>
        <TemplateColumn CellClass="justify-end" Title="操作" CellStyle="width:120px">
            <EditTemplate>
                <MudStack Spacing="1">
                    <MudButton OnClick="@(()=>ToolDeploySetting(context.Item))" Size="@Size.Small" Variant="@Variant.Outlined" Color="@Color.Primary">部署配置</MudButton>
                    <MudButton Size="@Size.Small" Variant="@Variant.Filled" Color="@Color.Primary">编辑工具</MudButton>
                    <MudButton Size="@Size.Small" Variant="@Variant.Filled" Color="@Color.Error">删除工具</MudButton>
                </MudStack>
            </EditTemplate>
        </TemplateColumn>
    </Columns>
    <ChildRowContent>
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">工具描述</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField Value="@context.Item.ToolDescription" ValueChanged="@(async(string e)=>{context.Item.ToolDescription=e;await CommittedItemChanges(context.Item);})"></MudTextField>
            </MudCardContent>
        </MudCard>
    </ChildRowContent>
</MudDataGrid>
<MudMenu PositionAtCursor="true" @ref="_contextMenu" id="_contextMenu">
    <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="@DeleteTool">
        删除 @_contextRow?.ToolName
    </MudMenuItem>
</MudMenu>

