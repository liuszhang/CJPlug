@using Elsa.Studio.DomInterop.Contracts
@using System.Net.Http.Json
@using System.Collections.ObjectModel
@using System.Text.Json
@using CJ.Plug.Models.Station
@using CJ.Plug.StationAndTool.Dialogs
@using CJ.Plug.StationAndToolApiClient
@using CJ.Plug.StationAndToolApi.Services
@inject IDialogService DialogService
@inject MainApiClient MainApiClient
@inject ISnackbar Snackbar
@inject IFiles Files
@implements IDisposable

<PageTitle>工具配置</PageTitle>

<MudStack Row AlignItems="AlignItems.Center" Class="mb-4">
    <MudButton OnClick="@AddItem" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add">添加工具</MudButton>
    <MudButton OnClick="ImportTools" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download">导入默认</MudButton>
    <MudSpacer />
    <MudTextField @bind-Value="@_searchTerm" Placeholder="搜索工具..." Variant="Variant.Outlined"
                  Immediate="true" Style="width:280px;" AdornmentIcon="@Icons.Material.Filled.Search"
                  Adornment="Adornment.Start" />
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate Color="Color.Primary" />
}

@if (_filteredTools == null || !_filteredTools.Any())
{
    <MudPaper Class="pa-10 d-flex flex-column align-center" Elevation="0">
        <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Large" Style="opacity:0.4;" />
        <MudText Typo="Typo.h6" Color="Color.Default" Class="mt-3">暂无工具</MudText>
        <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-1">点击"添加工具"创建新的工具配置</MudText>
    </MudPaper>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var tool in _filteredTools)
        {
            <MudItem xs="12" sm="6" md="4" lg="4">
                <MudCard Elevation="2" Class="tool-card">
                    @* 卡片头部 *@
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudIconButton Icon="@GetToolIcon(tool.ToolType)" Color="Color.Primary"
                                           Size="Size.Small" DisableRipple="true" />
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.h6" Style="font-weight:600;">
                                    @(tool.ToolName ?? "未命名")
                                </MudText>
                                <MudStack Row Spacing="1">
                                    @if (tool.SupportsRemoteVisualization)
                                    {
                                        <MudTooltip Text="支持远程可视化">
                                            <MudIcon Icon="@Icons.Material.Filled.Tv" Size="Size.Small" Color="Color.Info" />
                                        </MudTooltip>
                                    }
                                    @if (tool.SkipDownloadToStation)
                                    {
                                        <MudTooltip Text="无需下载至图站">
                                            <MudIcon Icon="@Icons.Material.Filled.CloudOff" Size="Size.Small" Color="Color.Warning" />
                                        </MudTooltip>
                                    }
                                    @if (tool.IsSystemInitTool)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                            系统
                                        </MudChip>
                                    }
                                </MudStack>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>

                    @* 卡片内容 *@
                    <MudCardContent Class="pa-3">
                        <MudStack Spacing="2">
                            @* 版本 + 厂商 *@
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text">
                                    v@(tool.ToolVersion)
                                </MudChip>
                                <MudText Typo="Typo.body2">
                                    @(string.IsNullOrEmpty(tool.ToolCompany) ? "-" : tool.ToolCompany)
                                </MudText>
                            </MudStack>

                            @* 启用状态 *@
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@(tool.IsEnabled ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                                         Size="Size.Small"
                                         Color="@(tool.IsEnabled ? Color.Success : Color.Error)" />
                                <MudText Typo="Typo.body2">
                                    @(tool.IsEnabled ? "已启用" : "已禁用")
                                </MudText>
                            </MudStack>

                            @* 工具路径 (可折叠) *@
                            @if (!string.IsNullOrEmpty(tool.ToolPath))
                            {
                                <MudText Typo="Typo.caption" Class="text-muted text-truncate" Style="max-width:100%;">
                                    路径: @tool.ToolPath
                                </MudText>
                            }

                            @* 工具描述 (截断显示) *@
                            @if (!string.IsNullOrEmpty(tool.ToolDescription))
                            {
                                <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    @tool.ToolDescription
                                </MudText>
                            }
                        </MudStack>
                    </MudCardContent>

                    @* 卡片操作区 *@
                    <MudCardActions Class="card-actions">
                        <MudStack Row Spacing="1" Wrap="Wrap.Wrap">
                            @if (tool.SupportsRemoteVisualization)
                            {
                                <MudTooltip Text="启动工具并打开远程可视化窗口">
                                    <MudButton OnClick="@(() => LaunchToolWithVisualization(tool))"
                                               Variant="Variant.Filled" Size="Size.Small" Color="Color.Info"
                                               StartIcon="@Icons.Material.Filled.PlayArrow">
                                        启动
                                    </MudButton>
                                </MudTooltip>
                            }
                            <MudTooltip Text="编辑工具配置">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               OnClick="@(() => EditToolItem(tool))" />
                            </MudTooltip>
                            <MudTooltip Text="部署配置">
                                <MudIconButton Icon="@Icons.Material.Filled.Dns" Size="Size.Small"
                                               OnClick="@(() => ToolDeploySetting(tool))" Color="Color.Primary" />
                            </MudTooltip>
                            <MudTooltip Text="下载工具包">
                                <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small"
                                               OnClick="@(() => DownloadToolItem(tool))" />
                            </MudTooltip>
                            @if (!tool.IsSystemInitTool)
                            {
                                <MudTooltip Text="删除工具">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                   Color="Color.Error" OnClick="@(() => DeleteToolItem(tool))" />
                                </MudTooltip>
                            }
                        </MudStack>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

<style>
    .tool-card {
        transition: all 0.25s ease;
        border-radius: 12px;
        border: 1px solid var(--mud-palette-divider);
    }
    .tool-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.12);
    }
    .card-actions {
        background: var(--mud-palette-background-grey);
        padding: 8px 12px;
        border-top: 1px solid var(--mud-palette-divider);
    }
    .text-muted {
        color: var(--mud-palette-text-secondary);
    }
    .text-truncate {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

@code {
    [Parameter]
    public List<Station>? OnlineStations { get; set; } = new();

    private MudMenu? _contextMenu;
    private Tool? _contextRow;
    private string _searchTerm = "";
    private bool _loading = true;
    private List<Tool> _allTools = new();

    private List<Tool> _filteredTools => string.IsNullOrWhiteSpace(_searchTerm)
        ? _allTools
        : _allTools.Where(t =>
            (t.ToolName?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (t.ToolCompany?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (t.ToolVersion?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (t.ToolDescription?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
        ).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshTools();
            StateHasChanged();
        }
    }

    public void Dispose()
    {
    }

    private async Task RefreshTools()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var tools = await MainApiClient.GetAllToolsAsync();
            _allTools.Clear();
            if (tools != null)
                _allTools.AddRange(tools);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"加载工具列表失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private string GetToolIcon(string? toolType)
    {
        if (string.IsNullOrEmpty(toolType)) return Icons.Material.Filled.Build;
        return toolType.Contains("桌面") ? Icons.Material.Filled.DesktopWindows
             : toolType.Contains("接口") ? Icons.Material.Filled.Api
             : Icons.Material.Filled.Build;
    }

    private async Task AddItem()
    {
        var options = new DialogOptions { CloseOnEscapeKey = false, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<NewTool>("新建工具", options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await RefreshTools();
        }
    }

    private async Task ImportTools()
    {
        try
        {
            var count = await MainApiClient.ImportDefaultToolsAsync();
            Snackbar.Add($"导入默认工具完成，共处理 {count} 个工具", Severity.Success);
            await RefreshTools();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"导入失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task EditToolItem(Tool tool)
    {
        var parameters = new DialogParameters<NewTool> { { x => x.ExistingTool, tool } };
        var options = new DialogOptions { CloseOnEscapeKey = false, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<NewTool>("编辑工具", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await RefreshTools();
        }
    }

    private async Task DeleteToolItem(Tool tool)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "确认删除",
            $"确定要删除工具「{tool.ToolName}」吗？此操作不可撤销。",
            yesText: "删除", cancelText: "取消");

        if (confirmed != true) return;

        try
        {
            await MainApiClient.DeleteToolAsync(tool.Id);
            Snackbar.Add($"已删除工具「{tool.ToolName}」", Severity.Success);
            _allTools.Remove(tool);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"删除失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task DownloadToolItem(Tool tool)
    {
        try
        {
            var toolName = tool.ToolName ?? "";
            var toolVersion = tool.ToolVersion ?? "latest";

            using var stream = await MainApiClient.DownloadToolAsync(toolName, toolVersion);
            var fileName = $"{tool.ToolName}_{tool.ToolVersion}.zip";

            await Files.DownloadFileFromStreamAsync(fileName, stream);
            Snackbar.Add($"工具 {tool.ToolName} 下载成功", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"下载异常: {ex.Message}", Severity.Error);
        }
    }

    private async Task ToolDeploySetting(Tool tool)
    {
        var parameters = new DialogParameters<ToolDeploySettingDialog> { { x => x.Tool, tool } };
        await DialogService.ShowAsync<ToolDeploySettingDialog>(
            $"{tool.ToolName}({tool.ToolVersion}) 部署配置", parameters);
    }

    private async Task LaunchToolWithVisualization(Tool tool)
    {
        if (!tool.SupportsRemoteVisualization)
        {
            Snackbar.Add("该工具不支持远程可视化", Severity.Warning);
            return;
        }

        // 获取可用图站供选择
        var stations = await MainApiClient.GetAllStationsAsync();
        var onlineStations = stations?.Where(s => s.IsStarted || s.IsOnline).ToList() ?? new();

        if (onlineStations.Count == 0)
        {
            Snackbar.Add("没有可用的在线图站", Severity.Warning);
            return;
        }

        // 弹出VNC远程连接对话框
        var parameters = new DialogParameters<VncConnectionDialog>
        {
            { x => x.Tool, tool },
            { x => x.Stations, onlineStations }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };
        await DialogService.ShowAsync<VncConnectionDialog>($"远程可视化 - {tool.ToolName}", parameters, options);
    }
}
