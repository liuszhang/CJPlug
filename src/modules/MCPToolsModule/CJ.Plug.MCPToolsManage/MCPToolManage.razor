@page "/MCPToolManage"

@using CJ.Plug.MCPToolsManage.Dialogs
@using CJ.Plug.Models.MCPTools
@using CJ.Plug.Models.Plug
@using CJ.Plug.Models.PlugProcess
@using Elsa.Api.Client.Resources.WorkflowDefinitions.Models
@using Elsa.Api.Client.Resources.WorkflowDefinitions.Requests
@using System.Text.Json.Nodes
@using System.Text.Json
@using Elsa.Api.Client.Shared.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using MudBlazor
@using Radzen.Blazor
@using Serilog
@using Size=MudBlazor.Size
@inject IDialogService DialogService
@using Microsoft.AspNetCore.Components
@using System.Threading.Tasks

@inject MainApiClient MainApiClient
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime




<PageTitle>MCPTool管理</PageTitle>

<MudDataGrid Items="mcpTools" T="MCPTool">
    <ToolBarContent>
        <MudText Typo="Typo.h6">MCPTool 列表</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Refresh">刷新</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="OpenDeployGuide" Class="ms-2">配置指南</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Tertiary" OnClick="ConfigureTrae" Class="ms-2" StartIcon="@Icons.Material.Filled.CloudUpload">配置 Trae</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="ConfigureClaude" Class="ms-2">配置 Claude Code</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="ConfigureWorkBuddy" Class="ms-2">配置 WorkBuddy</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="ConfigureCodex" Class="ms-2">配置 Codex</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Dark" OnClick="ConfigureHermes" Class="ms-2">配置 Hermes</MudButton>
        @* <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="OpenDeployGuide" Class="ms-2">发布为Skill</MudButton> *@
    </ToolBarContent>
    <Columns>
        <TemplateColumn Title="工具名称">
            <CellTemplate>
                <MudLink Href="javascript:void(0)" OnClick="() => OpenDetailDialog(context.Item)" Typo="Typo.body2">
                    @context.Item.Name
                </MudLink>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.Description" Title="工具描述" />
        @* <PropertyColumn Property="x => x.SourcePlugId" Title="源插头ID" /> *@
        <TemplateColumn Title="源插头ID">
            <CellTemplate>
                @if (!string.IsNullOrEmpty(context.Item.SourcePlugId))
                {
                    <MudLink Href="@($"/ProcessEdit/{context?.Item?.SourcePlugId}")" Target="_blank">
                        @context.Item.SourcePlugId
                    </MudLink>
                }

            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.Author" Title="发布人" />
        <PropertyColumn Property="x=>x.CreatedAt" Title="发布时间"/>
        <TemplateColumn Title="是否启用">
            <CellTemplate>
                <MudSwitch T="bool" Value="@context.Item.IsEnabled" Color="Color.Primary" ValueChanged="(e) => UpdateTool(context.Item, e)" />
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="操作">
            <CellTemplate>
                <MudButton OnClick="()=>DeleteTool(context.Item.Id)" Variant="Variant.Outlined" Color="Color.Error">删除</MudButton>
            </CellTemplate>
        </TemplateColumn>
        @* <PropertyColumn Property="x => x.PublishTime" Title="发布时间" />
        <PropertyColumn Property="x => x.Publisher" Title="发布人" /> *@
            
            
    </Columns>
    <NoRecordsContent>
        <MudText Typo="Typo.body2">未找到任何MCPTool。</MudText>
    </NoRecordsContent>
</MudDataGrid>



@code {
    private List<MCPTool>? mcpTools = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSampleData();
    }

    private async Task LoadSampleData()
    {
        var result = await MainApiClient.GetAllMCPToolsAsync();
        mcpTools = result?.ToList();
    }

    private async Task Refresh()
    {
        await LoadSampleData();
        try { await MainApiClient.NotifyRefreshAsync(); } catch { }
        Snackbar.Add("已通知 McpServer 刷新工具列表", Severity.Info);
    }

    private async Task DeleteTool(int id)
    {
        await MainApiClient.DeleteMCPToolAsync(id);
        Snackbar.Add("DeleteTool clicked.");
        await LoadSampleData();
    }

    private async Task UpdateTool(MCPTool tool,bool isEnable)
    {
        tool.IsEnabled = isEnable;
        await MainApiClient.UpdateMCPToolAsync(tool);
        Snackbar.Add($"MCPTool '{tool.Name}' 已更新。", Severity.Success);
    }

    private async Task OpenDeployGuide()
    {
        
        // Assign a fixed JSON string directly instead of serializing `sample`.
        var json = @"{
  ""mcpServers"": {
    ""cj-mcpserver"": {
      ""type"": ""streamableHttp"",
      ""url"": ""http://localhost:3001""
    }
  }
}";

        var parameters = new DialogParameters { { "JsonContent", json } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<DeployGuideDialog>("配置指南", parameters, options);
        //return Task.CompletedTask;
    }

    private async Task OpenDetailDialog(MCPTool tool)
    {
        var parameters = new DialogParameters { { "Tool", tool } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<MCPToolDetailDialog>($"MCPTool 详情 — {tool.Name}", parameters, options);
    }

    private async Task ConfigureTrae()
    {
        try
        {
            var (config, filePath) = await MainApiClient.GetTraePreviewAsync();
            await OpenMcpConfigDialog("配置 Trae MCP Server", null, filePath, config,
                (editedJson, _) => MainApiClient.ConfigureTraeMcpAsync(editedJson),
                "Trae");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"配置 Trae 失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task ConfigureClaude()
    {
        try
        {
            var (config, filePath) = await MainApiClient.GetClaudePreviewAsync();
            await OpenMcpConfigDialog("配置 Claude Code MCP Server", null, filePath, config,
                (editedJson, _) => MainApiClient.ConfigureClaudeMcpAsync(editedJson),
                "Claude Code");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"配置 Claude Code 失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task ConfigureWorkBuddy()
    {
        await OpenMcpConfigDialogPersisted("WorkBuddy", "配置 WorkBuddy MCP Server");
    }

    private async Task ConfigureCodex()
    {
        await OpenMcpConfigDialogPersisted("Codex", "配置 Codex MCP Server");
    }

    private async Task ConfigureHermes()
    {
        await OpenMcpConfigDialogPersisted("Hermes", "配置 Hermes MCP Server");
    }

    private async Task OpenMcpConfigDialogPersisted(string key, string title)
    {
        try
        {
            var savedPath = await MainApiClient.GetConfigPathAsync(key);

            string config = "{}";
            string filePath = savedPath ?? "";

            if (!string.IsNullOrWhiteSpace(savedPath))
            {
                try
                {
                    (config, filePath) = await MainApiClient.GetPreviewAsync(savedPath);
                }
                catch
                {
                    config = "{}";
                }
            }

            await OpenMcpConfigDialog(title, key, filePath, config,
                (editedJson, fp) => MainApiClient.ConfigureMcpAsync(fp, editedJson),
                key);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"配置 {key} 失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenMcpConfigDialog(string title, string? configKey,
        string configFilePath, string configContent,
        Func<string, string, Task<string>> saveFunc, string errorLabel)
    {
        try
        {
            var parameters = new DialogParameters
            {
                { "Title", title },
                { "ConfigFilePath", configFilePath },
                { "ConfigContent", configContent },
            };
            if (!string.IsNullOrWhiteSpace(configKey))
            {
                parameters.Add("ConfigKey", configKey);
            }

            var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<McpConfigDialog>(title, parameters, options);
            var dialogResult = await dialog.Result;

            if (dialogResult == null || dialogResult.Canceled)
                return;

            var (editedJson, filePath) = ((string, string))dialogResult.Data!;
            var message = await saveFunc(editedJson, filePath);
            Snackbar.Add(message, Severity.Success);

            // 持久化路径（WorkBuddy/Codex/Hermes）
            if (!string.IsNullOrWhiteSpace(configKey) && !string.IsNullOrWhiteSpace(filePath))
            {
                await MainApiClient.SaveConfigPathAsync(configKey, filePath);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"配置 {errorLabel} 失败: {ex.Message}", Severity.Error);
        }
    }

    // private class MCPToolDto
    // {
    //     public string Name { get; set; } = string.Empty;
    //     public string Description { get; set; } = string.Empty;
    //     public DateTime PublishTime { get; set; }
    //     public string Publisher { get; set; } = string.Empty;
    //     public bool IsEnabled { get; set; }
    // }
}



