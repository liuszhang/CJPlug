@using CJ.Plug.AIChat.Components.Pages.Chat
@using CJ.Plug.ApiClient.Contracts
@using CJ.Plug.DeekSeekIn
@using CJ.Plug.LlmConfigApiClient
@using CJ.Plug.SharedPages.Contracts
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@using MudX
@using Radzen.Blazor


@inject IDeepSeekService DeepSeekService
@inject ILlmConfigApiClient LlmConfigApiClient

<MudTextField @bind-Value="@Question" Immediate
              Placeholder="智能命令" Margin="Margin.Dense" Variant="Variant.Outlined"
              Adornment="Adornment.End"
              AdornmentIcon="@Icons.Material.Filled.PlayArrow"
              AdornmentColor="Color.Secondary"
              Disabled="@visible"
              OnKeyDown="OnTextFieldKeyPressed"
              OnAdornmentClick="() => OpenAndAnswer(Question)"></MudTextField>

<MudOverlay Visible="visible" DarkBackground="true" ZIndex="9999">
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center">
        <MudPaper MaxWidth="60%" MaxHeight="80vh" MinWidth="1200px">
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center">
                <CJ.Plug.SharedPages.Layout.VerticalWell ExtraPadding="100">
                    <RadzenChat @ref="basicChat"
                                Title="智能命令"
                                CurrentUserId="user1"
                                Users="@users"
                                ShowUsers="false"
                                Messages="@messages"
                                MessagesChanged="@OnMessagesChanged"
                                Placeholder="咨询或命令执行..."
                                Style="height: 500px;width:1150px;"
                                ShowTypingIndicator="true"
                                MessageAdded="@OnMessageAdded"
                                MessageSent="@OnMessageSent"
                                ChatCleared="@OnChatCleared"
                                TypingChanged="@OnTypingChanged" />

                </CJ.Plug.SharedPages.Layout.VerticalWell>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(e => ToggleOverlay(false))">关闭</MudButton>
                    @if (_defaultModelInfo != null)
                    {
                        <MudChip T="string" Icon="@Icons.Material.Filled.SmartToy" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined">
                            当前模型：@_defaultModelInfo.ProviderDisplayName / @_defaultModelInfo.ModelDisplayName
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" Variant="Variant.Outlined">
                            未配置默认模型
                        </MudChip>
                    }
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudOverlay>



@code{
    private string? Question { get; set; }
    private string? Answer { get; set; }
    private bool visible = false;
    RadzenChat basicChat;
    private List<ChatUser> users = new();
    private List<ChatMessage> messages = new();
    ChatMessage TmpMessage = new ChatMessage();
    private DefaultModelInfoResponse? _defaultModelInfo;

    protected override async Task OnInitializedAsync()
    {
        // Initialize users
        users.AddRange(new[]
        {
            new ChatUser { Id = "user1", Name = "ME", Color = "#1976d2" },
            new ChatUser { Id = "user2", Name = "AI", Color = "#388e3c" },
        });

        messages.AddRange(new[]
        {
            new ChatMessage { Content = "wake up!", UserId = "user1", Timestamp = DateTime.Now.AddMinutes(-30) },
        });

        // 从 LLM 配置加载默认模型信息
        try
        {
            _defaultModelInfo = await LlmConfigApiClient.GetDefaultModelInfoAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AskAI] 加载默认模型配置失败: {ex.Message}");
        }
    }

    void OnMessageAdded(ChatMessage message)
    {
        var participant = users.FirstOrDefault(p => p.Id == message.UserId);
        var participantName = participant?.Name ?? "Unknown";
    }

    async void OnMessageSent(ChatMessage message)
    {
        await TestDeepSeek(message.Content);
    }

    void OnMessagesChanged(IEnumerable<ChatMessage> newMessages)
    {
        messages = newMessages.ToList();
        StateHasChanged();
    }

    void OnChatCleared()
    {
    }

    async Task SimulateJaneTyping()
    {
        if (basicChat == null)
        {
            return;
        }

        await basicChat.SetUserTyping("user2", true);
        await Task.Delay(1500);
        await basicChat.SetUserTyping("user2", false);
    }

    void OnTypingChanged(ChatTypingEventArgs args)
    {
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
        }
    }

    private async Task OnTextFieldKeyPressed(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await OpenAndAnswer(Question);
        }
    }

    private async Task OpenAndAnswer(string? Question)
    {
        if (string.IsNullOrEmpty(Question))
        {
            return;
        }
        visible = true;
        await RefreshDefaultModelInfo();
        messages.AddRange(new[]
        {
            new ChatMessage { Content = Question, UserId = "user1", Timestamp = DateTime.Now.AddMinutes(-29) }
        });
        await TestDeepSeek(Question);
    }

    private async Task RefreshDefaultModelInfo()
    {
        try
        {
            _defaultModelInfo = await LlmConfigApiClient.GetDefaultModelInfoAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AskAI] 加载默认模型配置失败: {ex.Message}");
        }
    }

    private async Task TestDeepSeek(string? Question)
    {
        var TmpMessage = new ChatMessage { Content = "", UserId = "user2", Timestamp = DateTime.Now.AddMinutes(-28) };
        messages.Add(TmpMessage);
        StateHasChanged();
        Answer += "AI:";

        // 诊断日志：记录当前模型配置
        if (_defaultModelInfo != null)
        {
            Console.WriteLine($"[AskAI] ProviderName={_defaultModelInfo.ProviderName}, ApiBaseUrl={_defaultModelInfo.ApiBaseUrl}, ModelName={_defaultModelInfo.ModelName}, ApiKey={(string.IsNullOrEmpty(_defaultModelInfo.ApiKey) ? "(empty)" : (_defaultModelInfo.ApiKey.Length > 8 ? _defaultModelInfo.ApiKey[..8] + "..." : _defaultModelInfo.ApiKey))}");
        }
        else
        {
            Console.WriteLine("[AskAI] _defaultModelInfo is null, will fallback to default Ollama");
        }

        if (_defaultModelInfo == null)
        {
            // 无可用模型配置，回退到默认 Ollama
            Console.WriteLine("[AskAI] Branch: NULL → fallback Ollama");
            await foreach (var response in DeepSeekService.AskWithTool(Question))
            {
                Answer += response;
                TmpMessage.Content += response;
                StateHasChanged();
            }
        }
        else if (_defaultModelInfo.ProviderName.Contains("ollama", StringComparison.OrdinalIgnoreCase))
        {
            // Ollama 类型供应商 - 使用配置的端点和模型
            Console.WriteLine($"[AskAI] Branch: OLLAMA → endpoint={_defaultModelInfo.ApiBaseUrl}, model={_defaultModelInfo.ModelName}");
            var endpoint = new Uri(_defaultModelInfo.ApiBaseUrl);
            await foreach (var response in DeepSeekService.AskWithTool(Question, endpoint, _defaultModelInfo.ModelName))
            {
                Answer += response;
                TmpMessage.Content += response;
                StateHasChanged();
            }
        }
        else
        {
            // 通用 OpenAI 兼容供应商（OpenRouter / LM Studio / vLLM / 自定义端点等）
            // 使用配置的 ApiBaseUrl + ApiKey + ModelName 发起请求
            Console.WriteLine($"[AskAI] Branch: GENERIC → url={_defaultModelInfo.ApiBaseUrl}, model={_defaultModelInfo.ModelName}");
            await foreach (var response in DeepSeekService.StreamChatCompletionAsync(
                Question,
                _defaultModelInfo.ApiBaseUrl,
                _defaultModelInfo.ApiKey ?? string.Empty,
                _defaultModelInfo.ModelName))
            {
                Answer += response;
                TmpMessage.Content += response;
                StateHasChanged();
            }
        }

        Answer += "\n以上。";
        messages.AddRange(new[]
        {
            new ChatMessage { Content = "以上。👋", UserId = "user2", Timestamp = DateTime.Now.AddMinutes(-26) }
        });
        StateHasChanged();
    }

    public void ToggleOverlay(bool value)
    {
        Answer = "";
        visible = value;
    }
}
