@page "/AskAI"
@using CJ.Plug.AIChat.Components.Pages.Chat
@using CJ.Plug.ApiClient.Contracts
@using CJ.Plug.DeekSeekIn
@using CJ.Plug.LlmConfigApiClient
@using CJ.Plug.SharedPages.Contracts
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@using MudX
@using Radzen.Blazor

@inject IDeepSeekService DeepSeekService
@inject ILlmConfigApiClient LlmConfigApiClient

<PageTitle>AI 对话</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="mt-4">
        <CJ.Plug.SharedPages.Layout.VerticalWell ExtraPadding="100">
            <RadzenChat @ref="basicChat"
                        Title="AI 对话"
                        CurrentUserId="user1"
                        Users="@users"
                        ShowUsers="false"
                        Messages="@messages"
                        MessagesChanged="@OnMessagesChanged"
                        Placeholder="咨询或命令执行..."
                        Style="height: 500px;width:1150px;"
                        ShowTypingIndicator="true"
                        MessageAdded="@OnMessageAdded"
                        MessageSent="@OnMessageSent"
                        ChatCleared="@OnChatCleared"
                        TypingChanged="@OnTypingChanged" />
        </CJ.Plug.SharedPages.Layout.VerticalWell>

        <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mt-2 mb-4">
            @* <MudTextField @bind-Value="@Question" Immediate
                          Placeholder="输入问题或命令，按 Enter 发送"
                          Margin="Margin.Dense" Variant="Variant.Outlined"
                          Style="width: 800px;"
                          OnKeyDown="OnTextFieldKeyPressed">
            </MudTextField>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="@(() => SendMessage(Question))">
                发送
            </MudButton> *@
            @if (_defaultModelInfo != null)
            {
                <MudChip T="string" Icon="@Icons.Material.Filled.SmartToy" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined">
                    当前模型：@_defaultModelInfo.ProviderDisplayName / @_defaultModelInfo.ModelDisplayName
                </MudChip>
            }
            else
            {
                <MudChip T="string" Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" Variant="Variant.Outlined">
                    未配置默认模型
                </MudChip>
            }
        </MudStack>
    </MudStack>
</MudContainer>

@code {
    private string? Question { get; set; }
    private string? Answer { get; set; }
    RadzenChat basicChat;
    private List<ChatUser> users = new();
    private List<ChatMessage> messages = new();
    ChatMessage TmpMessage = new ChatMessage();
    private DefaultModelInfoResponse? _defaultModelInfo;
    private string? _mcpConnectionString;

    protected override async Task OnInitializedAsync()
    {
        users.AddRange(new[]
        {
            new ChatUser { Id = "user1", Name = "ME", Color = "#1976d2" },
            new ChatUser { Id = "user2", Name = "AI", Color = "#388e3c" },
        });

        messages.AddRange(new[]
        {
            new ChatMessage { Content = "你好！我是 AI 助手，有什么可以帮你的？", UserId = "user2", Timestamp = DateTime.Now },
        });

        try
        {
            _defaultModelInfo = await LlmConfigApiClient.GetDefaultModelInfoAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AskAIPage] 加载默认模型配置失败: {ex.Message}");
        }

        await LoadMcpConfigAsync();
    }

    private async Task LoadMcpConfigAsync()
    {
        try
        {
            var mcpConfig = await LlmConfigApiClient.GetMcpServerConfigAsync();
            if (mcpConfig != null && mcpConfig.IsEnabled && !string.IsNullOrEmpty(mcpConfig.ConnectionString))
            {
                _mcpConnectionString = mcpConfig.ConnectionString;
                Console.WriteLine($"[AskAIPage] MCP Server 已启用: {_mcpConnectionString}");
            }
            else
            {
                _mcpConnectionString = null;
                Console.WriteLine($"[AskAIPage] MCP Server 未启用或未配置");
            }
        }
        catch (Exception ex)
        {
            _mcpConnectionString = null;
            Console.WriteLine($"[AskAIPage] 加载 MCP 配置失败: {ex.Message}");
        }
    }

    void OnMessageAdded(ChatMessage message)
    {
        var participant = users.FirstOrDefault(p => p.Id == message.UserId);
        var participantName = participant?.Name ?? "Unknown";
    }

    async void OnMessageSent(ChatMessage message)
    {
        await TestDeepSeek(message.Content);
    }

    void OnMessagesChanged(IEnumerable<ChatMessage> newMessages)
    {
        messages = newMessages.ToList();
        StateHasChanged();
    }

    void OnChatCleared()
    {
    }

    void OnTypingChanged(ChatTypingEventArgs args)
    {
    }

    private async Task OnTextFieldKeyPressed(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await SendMessage(Question);
        }
    }

    private async Task SendMessage(string? question)
    {
        if (string.IsNullOrEmpty(question))
        {
            return;
        }

        await RefreshDefaultModelInfo();

        messages.AddRange(new[]
        {
            new ChatMessage { Content = question, UserId = "user1", Timestamp = DateTime.Now }
        });

        Question = "";
        await TestDeepSeek(question);
    }

    private async Task RefreshDefaultModelInfo()
    {
        try
        {
            _defaultModelInfo = await LlmConfigApiClient.GetDefaultModelInfoAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AskAIPage] 加载默认模型配置失败: {ex.Message}");
        }

        await LoadMcpConfigAsync();
    }

    private async Task TestDeepSeek(string? Question)
    {
        var TmpMessage = new ChatMessage { Content = "", UserId = "user2", Timestamp = DateTime.Now };
        messages.Add(TmpMessage);
        StateHasChanged();
        Answer += "AI:";

        Console.WriteLine($"[AskAIPage] MCP status: _mcpConnectionString='{(_mcpConnectionString == null ? "(null)" : (_mcpConnectionString.Length == 0 ? "(empty)" : _mcpConnectionString[..Math.Min(60, _mcpConnectionString.Length)]))}'");
        if (_defaultModelInfo != null)
        {
            Console.WriteLine($"[AskAIPage] ProviderName={_defaultModelInfo.ProviderName}, ApiBaseUrl={_defaultModelInfo.ApiBaseUrl}, ModelName={_defaultModelInfo.ModelName}, ApiKey={(string.IsNullOrEmpty(_defaultModelInfo.ApiKey) ? "(empty)" : (_defaultModelInfo.ApiKey.Length > 8 ? _defaultModelInfo.ApiKey[..8] + "..." : _defaultModelInfo.ApiKey))}");
        }
        else
        {
            Console.WriteLine("[AskAIPage] _defaultModelInfo is null, will fallback to default Ollama");
        }

        if (_defaultModelInfo == null)
        {
            Console.WriteLine("[AskAIPage] Branch: NULL → fallback Ollama");
            await foreach (var response in DeepSeekService.AskWithTool(Question, _mcpConnectionString))
            {
                Answer += response;
                TmpMessage.Content += response;
                StateHasChanged();
            }
        }
        else if (_defaultModelInfo.ProviderName.Contains("ollama", StringComparison.OrdinalIgnoreCase))
        {
            Console.WriteLine($"[AskAIPage] Branch: OLLAMA → endpoint={_defaultModelInfo.ApiBaseUrl}, model={_defaultModelInfo.ModelName}");
            var endpoint = new Uri(_defaultModelInfo.ApiBaseUrl);
            await foreach (var response in DeepSeekService.AskWithTool(Question, endpoint, _defaultModelInfo.ModelName, _mcpConnectionString))
            {
                Answer += response;
                TmpMessage.Content += response;
                StateHasChanged();
            }
        }
        else
        {
            Console.WriteLine($"[AskAIPage] Branch: GENERIC → url={_defaultModelInfo.ApiBaseUrl}, model={_defaultModelInfo.ModelName}");
            await foreach (var response in DeepSeekService.StreamChatCompletionAsync(
                Question,
                _defaultModelInfo.ApiBaseUrl,
                _defaultModelInfo.ApiKey ?? string.Empty,
                _defaultModelInfo.ModelName,
                _mcpConnectionString))
            {
                Answer += response;
                TmpMessage.Content += response;
                StateHasChanged();
            }
        }

        Answer += "\n以上。";
        messages.AddRange(new[]
        {
            new ChatMessage { Content = "以上。", UserId = "user2", Timestamp = DateTime.Now }
        });
        StateHasChanged();
    }
}
