{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndPoints": {
      "Http": {
        "Url": "http://*:5010"
      }
    }
  },
  "Backend": {
    "Url": "http://localhost:5001/elsa/api"
  },
  "Localization": {
    "DefaultCulture": "zh-Hans",
    "SupportedCultures": [
      "en-GB",
      "nl-NL",
      "en-US"
    ]
  }
}
