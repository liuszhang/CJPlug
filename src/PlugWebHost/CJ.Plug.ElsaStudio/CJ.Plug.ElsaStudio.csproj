<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>CJ.Plug_Aspire.ElsaStudio</RootNamespace>
	  <BaseOutputPath>..\..\..\02.Publish\$(MSBuildProjectName)</BaseOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <Content Remove="wwwroot\Translations.resx" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Resources\Translations.ar.resx" />
    <Content Include="Resources\Translations.ca.resx" />
    <Content Include="Resources\Translations.de.resx" />
    <Content Include="Resources\Translations.es.resx" />
    <Content Include="Resources\Translations.fa.resx" />
    <Content Include="Resources\Translations.fr.resx" />
    <Content Include="Resources\Translations.it.resx" />
    <Content Include="Resources\Translations.nl.resx" />
    <Content Include="Resources\Translations.pl.resx" />
    <Content Include="Resources\Translations.pt.resx" />
    <Content Include="Resources\Translations.ru.resx" />
    <Content Include="Resources\Translations.sv.resx" />
    <Content Include="Resources\Translations.tr.resx" />
    <Content Include="Resources\Translations.uk.resx" />
    <Content Include="Resources\Translations.vi.resx" />
    <Content Include="Resources\Translations.zh-Hans.resx">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Resources\Translations.zh-Hant.resx" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Elsa.Api.Client" />
    <PackageReference Include="Elsa.Studio" />
    <PackageReference Include="Elsa.Studio.Agents" />
    <PackageReference Include="Elsa.Studio.Core.BlazorServer" />
    <PackageReference Include="Elsa.Studio.Localization.BlazorServer" />
    <PackageReference Include="Elsa.Studio.Login.BlazorServer" />
    <PackageReference Include="Elsa.Studio.Translations" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Framework\CJ.Plug.AspireHost.ServiceDefaults\CJ.Plug.AspireHost.ServiceDefaults.csproj" />
  </ItemGroup>

</Project>
