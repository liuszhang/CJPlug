@page "/download-package"

@using MudBlazor
@using System.Timers
@using System.Net.Http.Json
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@implements IDisposable

<PageTitle>下载本地启动包</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" />
        下载本地部署包
    </MudText>
    
    <MudText Typo="Typo.body1" Class="mb-6">
        下载完整的CJPlug本地部署包（主程序 + 图站），在您的私有环境中运行系统，与AI Client集成。
    </MudText>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">选择平台</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudRadioGroup T="string" @bind-SelectedOption="_selectedPlatform">
                        <MudRadio T="string" Option="@("win-x64")" Color="Color.Primary">
                            <MudText>Windows x64</MudText>
                            <MudText Typo="Typo.caption">适用于Windows 64位系统</MudText>
                        </MudRadio>
                        <MudRadio T="string" Option="@("linux-x64")" Color="Color.Primary">
                            <MudText>Linux x64</MudText>
                            <MudText Typo="Typo.caption">适用于Linux 64位系统</MudText>
                        </MudRadio>
                        <MudRadio T="string" Option="@("osx-x64")" Color="Color.Primary">
                            <MudText>macOS x64</MudText>
                            <MudText Typo="Typo.caption">适用于macOS Intel处理器</MudText>
                        </MudRadio>
                        <MudRadio T="string" Option="@("win-arm64")" Color="Color.Primary">
                            <MudText>Windows ARM64</MudText>
                            <MudText Typo="Typo.caption">适用于Windows ARM64系统</MudText>
                        </MudRadio>
                        <MudRadio T="string" Option="@("linux-arm64")" Color="Color.Primary">
                            <MudText>Linux ARM64</MudText>
                            <MudText Typo="Typo.caption">适用于Linux ARM64系统</MudText>
                        </MudRadio>
                        <MudRadio T="string" Option="@("osx-arm64")" Color="Color.Primary">
                            <MudText>macOS ARM64</MudText>
                            <MudText Typo="Typo.caption">适用于macOS Apple Silicon处理器</MudText>
                        </MudRadio>
                    </MudRadioGroup>
                </MudCardContent>
            </MudCard>
        </MudItem>
        
        <MudItem xs="12" md="6">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">高级选项</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudSwitch T="bool" @bind-Checked="_includeDocker" 
                               Label="包含Docker配置" 
                               Color="Color.Primary" />
                    <MudText Typo="Typo.caption" Class="mt-2">
                        包含docker-compose.yml和Docker启动脚本，适合熟悉Docker的用户。
                    </MudText>
                    
                    <MudDivider Class="my-4" />
                    
                    <MudText Typo="Typo.subtitle2" Class="mb-2">启动包内容：</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            核心服务程序（自包含.NET应用）
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            跨平台启动脚本（bat/sh）
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            配置文件模板
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            默认SQLite数据库
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            使用文档和说明
                        </MudListItem>
                        @if (_includeDocker)
                        {
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                                Docker配置文件
                            </MudListItem>
                        }
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>
        
        <MudItem xs="12" Class="mt-6">
            <MudCard>
                <MudCardContent>
                    <div class="d-flex align-center flex-wrap">
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick="StartDownloadAsync"
                                   Disabled="_isDownloading || _isStationDownloading">
                            @if (_isDownloading)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                <MudText Class="ms-2">正在生成主程序部署包...</MudText>
                            }
                            else
                            {
                                <MudText>下载主程序部署包</MudText>
                            }
                        </MudButton>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Secondary"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick="StartStationDownloadAsync"
                                   Disabled="_isDownloading || _isStationDownloading"
                                   Class="ml-4">
                            @if (_isStationDownloading)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                <MudText Class="ms-2">正在生成图站部署包...</MudText>
                            }
                            else
                            {
                                <MudText>下载图站部署包</MudText>
                            }
                        </MudButton>

                        <MudText Typo="Typo.caption" Class="ml-4">
                            文件大小约 100-200 MB，生成时间约 1-3 分钟
                        </MudText>
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* 进度监控区域 *@
        @if (_currentTaskId != null)
        {
            <MudItem xs="12" Class="mt-6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.Assessment" Class="mr-2" />
                                打包进度监控
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            @if (_progress?.Status == "Completed")
                            {
                                <MudButton Variant="Variant.Filled" 
                                           Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.Download"
                                           OnClick="DownloadCompletedFileAsync">
                                    下载文件
                                </MudButton>
                            }
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_progress != null)
                        {
                            @* 进度条 *@
                            <div class="mb-4">
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2">@_progress.Message</MudText>
                                    <MudText Typo="Typo.body2">@_progress.Progress%</MudText>
                                </div>
                                <MudProgressLinear Value="@_progress.Progress" 
                                                   Color="@GetProgressColor()" 
                                                   Size="Size.Large" />
                            </div>

                            @* 状态信息 *@
                            <div class="d-flex gap-4 mb-4">
                                <MudChip T="string" Icon="@GetStatusIcon()" 
                                         Color="@GetStatusColor()" 
                                         Size="Size.Small">
                                    @GetStatusText()
                                </MudChip>
                                <MudText Typo="Typo.caption">
                                    开始时间: @_progress.StartTime.ToLocalTime().ToString("HH:mm:ss")
                                </MudText>
                                @if (_progress.EndTime.HasValue)
                                {
                                    <MudText Typo="Typo.caption">
                                        结束时间: @_progress.EndTime.Value.ToLocalTime().ToString("HH:mm:ss")
                                    </MudText>
                                }
                            </div>

                            @* 日志区域 *@
                            <MudExpansionPanels>
                                <MudExpansionPanel Text="@($"执行日志 ({_progress.Logs.Count} 条)")" IsExpanded="_showLogs">
                                    <div class="log-container" style="max-height: 400px; overflow-y: auto; background: #f5f5f5; padding: 12px; border-radius: 4px; font-family: monospace; font-size: 12px;">
                                        @foreach (var log in _progress.Logs)
                                        {
                                            <div class="log-entry mb-1">
                                                <span class="log-time" style="color: #666;">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                                <span class="log-level mx-2" style="color: @GetLogLevelColor(log.Level);">[@log.Level]</span>
                                                <span class="log-message">@log.Message</span>
                                            </div>
                                        }
                                    </div>
                                </MudExpansionPanel>
                            </MudExpansionPanels>
                        }
                        else
                        {
                            <MudProgressCircular Indeterminate="true" />
                            <MudText Class="ml-2">正在获取进度信息...</MudText>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
        
        <MudItem xs="12" Class="mt-6">
            <MudExpansionPanels>
                <MudExpansionPanel Text="使用说明">
                    <MudText Typo="Typo.body2" Class="mb-2">
                        <strong>Windows 用户：</strong>
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mb-4">
                        1. 解压下载的ZIP文件到任意目录<br/>
                        2. 双击运行 <code>start.bat</code><br/>
                        3. 等待服务启动完成<br/>
                        4. 访问 <code>http://localhost:8687</code>
                    </MudText>
                    
                    <MudText Typo="Typo.body2" Class="mb-2">
                        <strong>Linux/macOS 用户：</strong>
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mb-4">
                        1. 解压下载的ZIP文件到任意目录<br/>
                        2. 打开终端，进入解压目录<br/>
                        3. 运行命令：<code>./start.sh</code><br/>
                        4. 等待服务启动完成<br/>
                        5. 访问 <code>http://localhost:8687</code>
                    </MudText>
                    
                    <MudText Typo="Typo.body2" Class="mb-2">
                        <strong>与AI Client集成：</strong>
                    </MudText>
                    <MudText Typo="Typo.body2">
                        MCP服务地址：<code>http://localhost:8690/mcp</code><br/>
                        在您的AI Client中配置MCP Server地址为上述地址即可。
                    </MudText>
                </MudExpansionPanel>
                
                <MudExpansionPanel Text="系统要求">
                    <MudList T="string" Dense="true">
                        <MudListItem Icon="@Icons.Material.Filled.Computer">
                            操作系统：Windows 10/11, Linux 或 macOS
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.Memory">
                            内存：至少 4GB 可用内存
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.Storage">
                            磁盘：至少 2GB 可用空间
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.Code">
                            运行时：.NET 10.0（自包含版本已包含）
                        </MudListItem>
                    </MudList>
                </MudExpansionPanel>
                
                <MudExpansionPanel Text="常见问题">
                    <MudText Typo="Typo.body2" Class="mb-2">
                        <strong>Q: 启动后无法访问Web界面？</strong>
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mb-4">
                        A: 请检查端口是否被占用，可以修改 config/appsettings.json 中的端口配置。
                    </MudText>
                    
                    <MudText Typo="Typo.body2" Class="mb-2">
                        <strong>Q: 如何停止所有服务？</strong>
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mb-4">
                        A: 在启动脚本的命令行窗口中按任意键（Windows）或按 Ctrl+C（Linux/macOS）。
                    </MudText>
                    
                    <MudText Typo="Typo.body2" Class="mb-2">
                        <strong>Q: 数据存储在哪里？</strong>
                    </MudText>
                    <MudText Typo="Typo.body2">
                        A: 所有数据存储在启动包的 data/ 目录中，包括SQLite数据库文件。
                    </MudText>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private string _selectedPlatform = "win-x64";
    private bool _includeDocker = false;
    private bool _isDownloading = false;
    private bool _isStationDownloading = false;
    private string? _currentTaskId;
    private PackageProgressInfo? _progress;
    private Timer? _progressTimer;
    private bool _showLogs = true;

    private class PackageProgressInfo
    {
        public string TaskId { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public int Progress { get; set; }
        public string Message { get; set; } = string.Empty;
        public DateTime StartTime { get; set; }
        public DateTime? EndTime { get; set; }
        public List<LogEntryInfo> Logs { get; set; } = new();
    }

    private class LogEntryInfo
    {
        public DateTime Timestamp { get; set; }
        public string Message { get; set; } = string.Empty;
        public string Level { get; set; } = "Info";
    }

    protected override void OnInitialized()
    {
        // 初始化定时器，每2秒刷新一次进度
        _progressTimer = new Timer(2000);
        _progressTimer.Elapsed += async (sender, e) => await RefreshProgressAsync();
    }

    private async Task StartDownloadAsync()
    {
        try
        {
            _isDownloading = true;
            _currentTaskId = null;
            _progress = null;
            StateHasChanged();

            // 构建API地址
            var apiBaseUrl = $"http://{new Uri(NavigationManager.Uri).Host}:8687";
            var url = $"{apiBaseUrl}/api/package/download?platform={_selectedPlatform}&includeDocker={_includeDocker}";
            
            // 发送POST请求启动任务
            using var httpClient = new HttpClient();
            var response = await httpClient.PostAsync(url, null);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<StartDownloadResponse>();
                _currentTaskId = result?.TaskId;
                
                if (_currentTaskId != null)
                {
                    // 开始轮询进度
                    _progressTimer?.Start();
                    Snackbar.Add("主程序部署包打包任务已启动", Severity.Info);
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"启动失败: {error}", Severity.Error);
                _isDownloading = false;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"请求失败: {ex.Message}", Severity.Error);
            _isDownloading = false;
        }
        
        StateHasChanged();
    }

    private async Task StartStationDownloadAsync()
    {
        try
        {
            _isStationDownloading = true;
            _currentTaskId = null;
            _progress = null;
            StateHasChanged();

            var apiBaseUrl = $"http://{new Uri(NavigationManager.Uri).Host}:8687";
            var url = $"{apiBaseUrl}/api/package/download-station?platform={_selectedPlatform}";

            using var httpClient = new HttpClient();
            var response = await httpClient.PostAsync(url, null);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<StartDownloadResponse>();
                _currentTaskId = result?.TaskId;

                if (_currentTaskId != null)
                {
                    _progressTimer?.Start();
                    Snackbar.Add("图站部署包打包任务已启动", Severity.Info);
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"启动失败: {error}", Severity.Error);
                _isStationDownloading = false;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"请求失败: {ex.Message}", Severity.Error);
            _isStationDownloading = false;
        }

        StateHasChanged();
    }

    private async Task RefreshProgressAsync()
    {
        if (_currentTaskId == null) return;

        try
        {
            var apiBaseUrl = $"http://{new Uri(NavigationManager.Uri).Host}:8687";
            var url = $"{apiBaseUrl}/api/package/progress/{_currentTaskId}";
            
            using var httpClient = new HttpClient();
            var progress = await httpClient.GetFromJsonAsync<PackageProgressInfo>(url);
            
            if (progress != null)
            {
                _progress = progress;
                
                // 如果任务完成或失败，停止轮询
                if (progress.Status == "Completed" || progress.Status == "Failed")
                {
                    _progressTimer?.Stop();
                    _isDownloading = false;
                    _isStationDownloading = false;
                    
                    if (progress.Status == "Completed")
                    {
                        Snackbar.Add("打包完成！", Severity.Success);
                    }
                    else
                    {
                        Snackbar.Add($"打包失败: {progress.Message}", Severity.Error);
                    }
                }
                
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // 忽略轮询错误
        }
    }

    private async Task DownloadCompletedFileAsync()
    {
        if (_currentTaskId == null) return;

        try
        {
            var apiBaseUrl = $"http://{new Uri(NavigationManager.Uri).Host}:8687";
            var url = $"{apiBaseUrl}/api/package/download/{_currentTaskId}";
            
            await JSRuntime.InvokeVoidAsync("open", url, "_blank");
            Snackbar.Add("开始下载文件", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"下载失败: {ex.Message}", Severity.Error);
        }
    }

    private Color GetProgressColor()
    {
        if (_progress == null) return Color.Primary;
        return _progress.Status switch
        {
            "Completed" => Color.Success,
            "Failed" => Color.Error,
            _ => Color.Primary
        };
    }

    private string GetStatusIcon()
    {
        if (_progress == null) return Icons.Material.Filled.HourglassEmpty;
        return _progress.Status switch
        {
            "Pending" => Icons.Material.Filled.HourglassEmpty,
            "Processing" => Icons.Material.Filled.Sync,
            "Completed" => Icons.Material.Filled.CheckCircle,
            "Failed" => Icons.Material.Filled.Error,
            _ => Icons.Material.Filled.HourglassEmpty
        };
    }

    private Color GetStatusColor()
    {
        if (_progress == null) return Color.Default;
        return _progress.Status switch
        {
            "Pending" => Color.Warning,
            "Processing" => Color.Info,
            "Completed" => Color.Success,
            "Failed" => Color.Error,
            _ => Color.Default
        };
    }

    private string GetStatusText()
    {
        if (_progress == null) return "未知";
        return _progress.Status switch
        {
            "Pending" => "等待中",
            "Processing" => "处理中",
            "Completed" => "已完成",
            "Failed" => "失败",
            _ => "未知"
        };
    }

    private string GetLogLevelColor(string level)
    {
        return level switch
        {
            "Error" => "#f44336",
            "Warning" => "#ff9800",
            "Info" => "#2196f3",
            _ => "#666"
        };
    }

    public void Dispose()
    {
        _progressTimer?.Stop();
        _progressTimer?.Dispose();
    }

    private class StartDownloadResponse
    {
        public string TaskId { get; set; } = string.Empty;
    }
}
