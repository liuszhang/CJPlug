            ValuePresenter="ValuePresenter.Chip"
            SelectedValues="@SelectedWorkflowDefinitions"
            SelectedValuesChanged="OnSelectedWorkflowDefinitionsChanged"
            ToStringFunc="@GetWorkflowDefinitionDisplayText">
