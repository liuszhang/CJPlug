            MultiSelection="true"
            Variant="Variant.Outlined"
            AnchorOrigin="Origin.BottomCenter"
            Dense="true"
            ChipSize="Size.Small"
            ChipVariant="Variant.Filled"
            ChipCloseable="true"
            Clearable="true"
            PopoverClass="mw-300"
            InputClass="me-3"
