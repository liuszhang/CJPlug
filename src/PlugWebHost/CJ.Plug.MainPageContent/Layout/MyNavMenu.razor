
@using CJ.Plug.Models.Contracts
@using CJ.Plug.Models.Shared
@using Microsoft.AspNetCore.Components.Routing
@using MudBlazor

@inject IEnumerable<IMenuService> MenuServices

<MudNavMenu>
    @* 管理分组 *@
    @{
        var manageItems = _menuItems.Where(x => x.GroupName == MenuGroupEnum.管理.ToString()).ToList();
    }
    @if (manageItems.Any())
    {
        <MudNavGroup Title="管理" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="true">
            @foreach (var menu in manageItems)
            {
                <MudNavLink Match="NavLinkMatch.All" Href="@menu.Href" Icon="@menu.Icon" IconColor="Color.Primary">@menu.Text</MudNavLink>
            }
        </MudNavGroup>
    }

    @* 其他非调试菜单 *@
    @foreach (var menu in _menuItems)
    {
        if (menu.GroupName != MenuGroupEnum.调试.ToString() && menu.GroupName != MenuGroupEnum.管理.ToString())
        {
            <MudNavLink Match="NavLinkMatch.All" Href="@menu.Href" Icon="@menu.Icon" IconColor="Color.Primary">@menu.Text</MudNavLink>
        }
    }

    @* 调试分组 *@
    <MudNavGroup Title="调试" Icon="@Icons.Material.Filled.Settings" Expanded="true">
        <MudNavLink Match="NavLinkMatch.All" Href="/JobManageList2" Icon="@Icons.Material.Filled.Task" IconColor="Color.Primary">作业列表2</MudNavLink>

        @foreach (var menu in _menuItems)
        {
            if (menu.GroupName == MenuGroupEnum.调试.ToString())
            {
                <MudNavLink Match="NavLinkMatch.All" Href="@menu.Href" Icon="@menu.Icon" IconColor="Color.Primary">@menu.Text</MudNavLink>
            }
        }
        <MudNavLink Match="NavLinkMatch.All" Href="/remote/vnc/localhost" Icon="@Icons.Material.Filled.Task" IconColor="Color.Primary">VNC测试</MudNavLink>
        <MudNavLink Match="NavLinkMatch.All" Href="/remote/capture/localhost" Icon="@Icons.Material.Filled.Task" IconColor="Color.Primary">VNC测试（capture）</MudNavLink>

    </MudNavGroup>
</MudNavMenu>


@code
{
    private List<MenuItem> _menuItems = new List<MenuItem>();

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        foreach (var menu in MenuServices)
        {
            var menuItems = await menu.GetMenuItemsAsync();
            _menuItems.AddRange(menuItems);
        }
    }
}
