
@using CJ.Plug.ApiClient.Contracts

@using CJ.Plug.ElsaIntegration.Contracts
@using CJ.Plug.MainPageContent.Layout
@using CJ.Plug.Models.Contracts
@using Elsa.Studio
@using Elsa.Studio.Components
@using Elsa.Studio.Contracts
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Routing
@using Microsoft.Extensions.Options
@using System.Reflection

@implements IDisposable

@inject NavigationManager NavigationManager
@inject IEnumerable<IModule> Modules
@inject IElsaStudioService ElsaStudioService


<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(MainLayout).Assembly" AdditionalAssemblies="@AdditionalAssemblies">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@_currentLayout" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@_currentLayout">
                <p role="alert">Sorry, there's nothing at this address.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>


@code{
    public IEnumerable<Assembly> AdditionalAssemblies { get; set; } = null!;

    private Type _currentLayout = typeof(MainLayout);

    protected override async Task OnInitializedAsync()
    {
        //前端初始化模块以注册路由和工具栏
        AdditionalAssemblies = Modules.Select(x => x.GetType().Assembly).Distinct().ToList();

        foreach (var m in Modules)
        {
            await m.InitializeAsync();
        }

        // 检测 URL 查询参数，动态选择布局
        NavigationManager.LocationChanged += OnLocationChanged;
        DetectLayout(NavigationManager.Uri);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        DetectLayout(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void DetectLayout(string url)
    {
        try
        {
            var uri = new Uri(url);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            _currentLayout = query["hideMenu"] == "true"
                ? typeof(EmbeddedLayout)
                : typeof(MainLayout);
        }
        catch
        {
            _currentLayout = typeof(MainLayout);
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ElsaStudioService.LoginToElsaEngine();
            StateHasChanged();
        }
    }
}
