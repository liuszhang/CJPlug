<Window x:Class="CJ.Plug.Desktop.Views.UpgradeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:CJ.Plug.Desktop.Converters"
        Title="升级授权" Width="420" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </Window.Resources>

    <Border CornerRadius="12" Background="#2A2A3E" BorderBrush="#4A4A6E" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Background="Transparent" Padding="0,0,0,12">
                <Grid>
                    <TextBlock Text="升级授权" FontSize="18" FontWeight="Bold"
                               Foreground="#E0E0F0" VerticalAlignment="Center"/>
                    <Button Content="&#x2715;" Width="28" Height="28"
                            HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#8080A0" FontSize="14" Cursor="Hand"
                            Click="CloseButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            <!-- 功能列表 -->
            <Border Grid.Row="1" Background="#35355F" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="升级后可解锁以下功能：" FontSize="13"
                               Foreground="#B0B0D0" Margin="0,0,0,8"/>
                    <TextBlock Text="&#x2714; 多图站管理 — 同时管理多个图片站点" FontSize="13"
                               Foreground="#D0D0F0" Margin="0,0,0,4"/>
                    <TextBlock Text="&#x2714; 远程可视化 — VNC / SSH 远程连接" FontSize="13"
                               Foreground="#D0D0F0"/>
                </StackPanel>
            </Border>

            <!-- 价格 -->
            <TextBlock Grid.Row="2" TextAlignment="Center"
                       FontSize="28" FontWeight="Bold" Foreground="#FFD700"
                       Margin="0,0,0,12">
                <Run Text="￥"/><Run Text="{Binding AmountText}"/>
            </TextBlock>

            <!-- 二维码区域 -->
            <Border Grid.Row="3" Background="#1E1E30" CornerRadius="8"
                    Margin="20,0" VerticalAlignment="Center">
                <Grid>
                    <!-- 已加载二维码图片 -->
                    <Image Source="{Binding QrCodeImage}" Stretch="Uniform"
                           Margin="12"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- 加载中占位 -->
                    <Border Background="#35355F" CornerRadius="6" Margin="40"
                            Visibility="{Binding IsWaiting, Converter={StaticResource BoolToVis}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#x25A3;" FontSize="48"
                                       Foreground="#5C5C8F"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="正在生成支付二维码..."
                                       FontSize="12" Foreground="#8080A0"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 状态文字 -->
            <Border Grid.Row="4" Padding="0,12" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}" FontSize="14"
                               Foreground="#B0B0D0"
                               HorizontalAlignment="Center"/>

                    <!-- 等待中动画点 -->
                    <TextBlock Text="● ○ ○" FontSize="12"
                               Foreground="#7C7CF0"
                               HorizontalAlignment="Center" Margin="0,6,0,0"
                               Visibility="{Binding IsWaiting, Converter={StaticResource BoolToVis}}"/>

                    <!-- 激活完成 -->
                    <TextBlock Text="&#x2714; 授权已激活！" FontSize="14"
                               Foreground="#50E890"
                               HorizontalAlignment="Center" Margin="0,6,0,0"
                               Visibility="{Binding IsActivated, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="5" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,4,0,0">
                <!-- 等待中：创建订单 + 取消 -->
                <Button Width="110" Height="34"
                        Content="创建订单"
                        Background="#5C5C8F" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding CreateOrderCommand}"
                        Visibility="{Binding IsWaiting, Converter={StaticResource BoolToVis}}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <!-- 未激活时始终显示取消按钮 -->
                <Button Width="110" Height="34"
                        Content="取消"
                        Background="#3D3D5F" Foreground="#B0B0D0"
                        BorderThickness="0" Cursor="Hand"
                        Click="CloseButton_Click"
                        Visibility="{Binding IsActivated, Converter={StaticResource InverseBoolToVis}}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <!-- 激活后显示关闭窗口 -->
                <Button Width="110" Height="34"
                        Content="关闭窗口"
                        Background="#50E890" Foreground="#1A1A2E"
                        BorderThickness="0" Cursor="Hand" FontWeight="Bold"
                        Click="CloseButton_Click"
                        Visibility="{Binding IsActivated, Converter={StaticResource BoolToVis}}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
