<UserControl x:Class="CJ.Plug.Desktop.Views.DatabaseConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#1E1E2E">
    <UserControl.Resources>
        <!-- 布尔值到可见性转换器 -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 标签文本样式 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B0B0C8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="MdTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#3D3D5F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="#E0E0F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#7C7CF0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#5A5A80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 密码框样式 -->
        <Style x:Key="MdPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#3D3D5F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="#E0E0F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#7C7CF0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#5A5A80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉框样式 -->
        <Style x:Key="MdComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#3D3D5F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <TextBlock x:Name="DisplayText"
                                                           Text="{TemplateBinding Content}"
                                                           Foreground="#E0E0F0"
                                                           Margin="8,0,24,0"
                                                           VerticalAlignment="Center"/>
                                                <Path x:Name="Arrow"
                                                      Data="M0,0 L4,4 L8,0"
                                                      Fill="#B0B0C8"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="8,0,24,0"
                                              IsHitTestVisible="False"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      MinWidth="{TemplateBinding ActualWidth}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#2D2D3F"
                                            BorderBrush="#3D3D5F"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2D2D3F"/>
                        <Setter Property="Foreground" Value="#E0E0F0"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3D3D5F"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#4A4A70"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 按钮样式 -->
        <Style x:Key="MdButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="Background" Value="#3D3D5F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A4A70"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2D2D4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveButton" TargetType="Button" BasedOn="{StaticResource MdButton}">
            <Setter Property="Background" Value="#2D5A3D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A7048"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E3D28"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RestoreButton" TargetType="Button" BasedOn="{StaticResource MdButton}">
            <Setter Property="Background" Value="#5C4A1E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7A6328"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3D3214"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <TabControl Background="#1E1E2E"
                BorderBrush="#35355F"
                BorderThickness="0">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Background" Value="#2D2D3F"/>
                <Setter Property="Foreground" Value="#B0B0C8"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Padding" Value="24,10"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="TabBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0,0,0,3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter Content="{TemplateBinding Header}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="#1E1E2E"/>
                                    <Setter TargetName="TabBorder" Property="BorderBrush" Value="#7C7CF0"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="#303050"/>
                                    <Setter Property="Foreground" Value="#D0D0E8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.Resources>

        <!-- Tab 1: ApiServer 数据库 -->
        <TabItem Header="ApiServer 数据库">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,20">
                    <!-- 标题 -->
                    <TextBlock Text="ApiServer 数据库连接配置"
                               Foreground="#E0E0F0"
                               FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,20"/>

                    <!-- 数据库类型 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="数据库类型:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource MdComboBox}"
                                  SelectedValue="{Binding ApiDbType, Mode=TwoWay}"
                                  SelectedValuePath="Content">
                            <ComboBoxItem Content="SQLite"/>
                            <ComboBoxItem Content="PostgreSQL"/>
                            <ComboBoxItem Content="SqlServer"/>
                        </ComboBox>
                    </Grid>

                    <!-- 连接字符串 (仅 SQLite) -->
                    <Grid Margin="0,0,0,14"
                          Visibility="{Binding IsApiSqlite, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="连接字符串:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource MdTextBox}"
                                 Text="{Binding ApiConnectionString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="50"/>
                    </Grid>

                    <!-- 服务器地址 (非 SQLite) -->
                    <Grid Margin="0,0,0,14"
                          Visibility="{Binding IsApiNotSqlite, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="服务器地址:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource MdTextBox}"
                                 Text="{Binding ApiServer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="2" Text="端口:" Style="{StaticResource FieldLabel}" MinWidth="40"/>
                        <TextBox Grid.Column="3"
                                 Style="{StaticResource MdTextBox}"
                                 Text="{Binding ApiPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- 数据库名 (非 SQLite) -->
                    <Grid Margin="0,0,0,14"
                          Visibility="{Binding IsApiNotSqlite, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="数据库名:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource MdTextBox}"
                                 Text="{Binding ApiDatabase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- 用户名 (非 SQLite) -->
                    <Grid Margin="0,0,0,14"
                          Visibility="{Binding IsApiNotSqlite, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="用户名:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource MdTextBox}"
                                 Text="{Binding ApiUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- 密码 (非 SQLite) -->
                    <Grid Margin="0,0,0,20"
                          Visibility="{Binding IsApiNotSqlite, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="密码:" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox Grid.Column="1"
                                     Style="{StaticResource MdPasswordBox}"
                                     PasswordChanged="OnApiPasswordChanged"/>
                    </Grid>

                    <!-- 按钮行 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="保存配置"
                                Style="{StaticResource SaveButton}"
                                Command="{Binding SaveApiConfigCommand}"
                                Margin="0,0,12,0"/>
                        <Button Grid.Column="1"
                                Content="恢复默认"
                                Style="{StaticResource RestoreButton}"
                                Command="{Binding RestoreApiDefaultsCommand}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ApiSaveMessage}"
                                   Foreground="#80E080"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Tab 2: ElsaApiServer 数据库 -->
        <TabItem Header="ElsaApiServer 数据库">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,20">
                    <!-- 标题 -->
                    <TextBlock Text="ElsaApiServer 数据库连接配置"
                               Foreground="#E0E0F0"
                               FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,20"/>

                    <!-- 数据库类型 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="数据库类型:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource MdComboBox}"
                                  SelectedValue="{Binding ElsaDbType, Mode=TwoWay}"
                                  SelectedValuePath="Content">
                            <ComboBoxItem Content="SQLite"/>
                            <ComboBoxItem Content="PostgreSQL"/>
                            <ComboBoxItem Content="SqlServer"/>
                        </ComboBox>
                    </Grid>

                    <!-- 连接字符串 (仅 SQLite) -->
                    <Grid Margin="0,0,0,14"
                          Visibility="{Binding IsElsaSqlite, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="连接字符串:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource MdTextBox}"
                                 Text="{Binding ElsaConnectionString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="50"/>
                    </Grid>

                    <!-- 服务器地址 (非 SQLite) -->
                    <Grid Margin="0,0,0,14"
                          Visibility="{Binding IsElsaNotSqlite, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="服务器地址:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource MdTextBox}"
                                 Text="{Binding ElsaServer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="2" Text="端口:" Style="{StaticResource FieldLabel}" MinWidth="40"/>
                        <TextBox Grid.Column="3"
                                 Style="{StaticResource MdTextBox}"
                                 Text="{Binding ElsaPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- 数据库名 (非 SQLite) -->
                    <Grid Margin="0,0,0,14"
                          Visibility="{Binding IsElsaNotSqlite, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="数据库名:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource MdTextBox}"
                                 Text="{Binding ElsaDatabase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- 用户名 (非 SQLite) -->
                    <Grid Margin="0,0,0,14"
                          Visibility="{Binding IsElsaNotSqlite, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="用户名:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource MdTextBox}"
                                 Text="{Binding ElsaUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- 密码 (非 SQLite) -->
                    <Grid Margin="0,0,0,20"
                          Visibility="{Binding IsElsaNotSqlite, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="密码:" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox Grid.Column="1"
                                     Style="{StaticResource MdPasswordBox}"
                                     PasswordChanged="OnElsaPasswordChanged"/>
                    </Grid>

                    <!-- 按钮行 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="保存配置"
                                Style="{StaticResource SaveButton}"
                                Command="{Binding SaveElsaConfigCommand}"
                                Margin="0,0,12,0"/>
                        <Button Grid.Column="1"
                                Content="恢复默认"
                                Style="{StaticResource RestoreButton}"
                                Command="{Binding RestoreElsaDefaultsCommand}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ElsaSaveMessage}"
                                   Foreground="#80E080"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>
