<UserControl x:Class="CJ.Plug.Desktop.Views.ServiceControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#1E1E2E">
    <UserControl.Resources>
        <!-- MaterialDesign 风格按钮样式 -->
        <Style x:Key="MdButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="Background" Value="#3D3D5F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A4A70"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2D2D4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource MdButton}">
            <Setter Property="Background" Value="#6B2C2C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8B3A3A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#4A1E1E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RestartButton" TargetType="Button" BasedOn="{StaticResource MdButton}">
            <Setter Property="Background" Value="#5C4A1E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7A6328"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3D3214"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部：状态指示面板 -->
        <Border Grid.Row="0" Padding="20,14"
                BorderBrush="#35355F" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 状态圆点 -->
                <Ellipse Grid.Column="0"
                         Width="10" Height="10"
                         Fill="{Binding StatusColor}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"/>

                <!-- 状态文本 -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           Foreground="#E0E0F0"
                           FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <!-- 按钮组 -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="启动"
                            Style="{StaticResource MdButton}"
                            Command="{Binding StartCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="停止"
                            Style="{StaticResource StopButton}"
                            Command="{Binding StopCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="重启"
                            Style="{StaticResource RestartButton}"
                            Command="{Binding RestartCommand}"
                            Margin="0,0,12,0"/>
                    <Button Content="清除"
                            Style="{StaticResource MdButton}"
                            Command="{Binding ClearOutputCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 下方：控制台输出区域 -->
        <TextBox Grid.Row="1"
                 x:Name="ConsoleTextBox"
                 Text="{Binding ConsoleOutput, Mode=OneWay}"
                 Background="#0D0D1A"
                 Foreground="#A0E0A0"
                 FontFamily="Consolas"
                 FontSize="13"
                 IsReadOnly="True"
                 BorderThickness="0"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Padding="16,12"
                 TextChanged="OnConsoleTextChanged"/>
    </Grid>
</UserControl>
