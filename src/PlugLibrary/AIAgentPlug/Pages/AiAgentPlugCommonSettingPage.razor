@using System.Text.Json
@using CJ.Plug.Models.Plug
@using CJ.Plug.Models.Shared
@using CJ.Plug.PlugBaseCore.Models
@using MudBlazor

<MudStack Spacing="4">
    <MudText Typo="Typo.h6">模型选择</MudText>
    <MudSelect T="string" @bind-Value="_selectedModel" @bind-Value:after="SaveSettings" 
    Label="选择大模型" Dense AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined">
        @foreach (var model in _availableModels)
        {
            <MudSelectItem Value="@model">@model</MudSelectItem>
        }
    </MudSelect>

    <MudDivider />

    <MudText Typo="Typo.h6">输入参数</MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary">配置AI请求中可用的输入参数，可在提示词中使用 [参数名] 引用</MudText>
    @foreach (var param in _inputParameters)
    {
        var p = param;
        <MudStack Row AlignItems="AlignItems.Center" Style="margin-bottom:4px;">
            <MudTextField T="string" Value="@p.Name"
                          ValueChanged="@(async (string v) => { p.Name = v; await SaveSettings(); })"
                          Label="参数名" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:200px;" />
            <MudTextField T="string" Value="@p.Value"
                          ValueChanged="@(async (string v) => { p.Value = v; await SaveSettings(); })"
                          Label="默认值" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:200px;" />
            <MudIconButton OnClick="@(() => RemoveInputParameter(p))"
                           Icon="@Icons.Material.Filled.RemoveCircleOutline" Size="Size.Small" Color="Color.Error" />
        </MudStack>
    }
    <MudButton OnClick="AddInputParameter" Size="Size.Small" Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.Add">添加输入参数</MudButton>

    <MudDivider />

    <MudText Typo="Typo.h6">系统提示词</MudText>
    <MudTextField T="string" @bind-Value="_systemPrompt" @bind-Value:after="SaveSettings"
                  Lines="5" Variant="Variant.Outlined"
                  Label="输入系统提示词，定义AI的行为角色"
                  Style="width:100%;" />

    <MudDivider />

    <MudText Typo="Typo.h6">用户提示词</MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary">可使用 [参数名] 引用输入参数的值，如：请分析 [文件路径] 中的内容</MudText>
    <MudTextField T="string" @bind-Value="_userPrompt" @bind-Value:after="SaveSettings"
                  Lines="5" Variant="Variant.Outlined"
                  Label="输入用户提示词"
                  Style="width:100%;" />

    <MudDivider />

    <MudText Typo="Typo.h6">输出绑定</MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary">选择接收AI回复内容的输出参数，可将结果传递给下游插头</MudText>
    <MudSelect T="string" @bind-Value="_outputVariable" @bind-Value:after="SaveSettings"
               Label="选择输出参数" Dense Clearable AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined">
        @if (VariablesOfPlug != null)
        {
            @foreach (var v in VariablesOfPlug)
            {
                <MudSelectItem Value="@v.Name">@v.Name</MudSelectItem>
            }
        }
    </MudSelect>
</MudStack>

@code {
    [CascadingParameter]
    public PlugDataZone? PlugDataZone { get; set; }
    [Parameter]
    public GetSettingContext? SettingContext { get; set; }
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    private string? DefinitionId { get; set; }

    private string _selectedModel = "qwen3:4b";
    private string _systemPrompt = "";
    private string _userPrompt = "";
    private string? _outputVariable;
    private List<InputParam> _inputParameters = new();

    private static List<string> _availableModels = new()
    {
        "qwen3:4b",
        "qwen3:1.7b",
        "deepseek-r1:1.5b",
        "deepseek-r1:7b",
        "deepseek-r1:14b",
        "llama3.2",
        "openrouter/free",
    };

    public List<PlugVariableData>? VariablesOfPlug => PlugDataZone?.GetVariablesOfPlug(DefinitionId);

    private class InputParam
    {
        public string Name { get; set; } = "";
        public string Value { get; set; } = "";
    }

    protected override Task OnInitializedAsync()
    {
        DefinitionId = SettingContext?.PlugDefinitionId;

        if (DefinitionId != null)
        {
            _selectedModel = PlugDataZone?.GetVariableValue(DefinitionId, "AIModelName") ?? "qwen3:4b";
            _systemPrompt = PlugDataZone?.GetVariableValue(DefinitionId, "AISystemPrompt") ?? "";
            _userPrompt = PlugDataZone?.GetVariableValue(DefinitionId, "AIUserPrompt") ?? "";
            _outputVariable = PlugDataZone?.GetVariableValue(DefinitionId, "AIOutputVariable");

            var inputParamsJson = PlugDataZone?.GetVariableValue(DefinitionId, "AIInputParameters");
            if (!string.IsNullOrEmpty(inputParamsJson))
            {
                _inputParameters = JsonSerializer.Deserialize<List<InputParam>>(inputParamsJson) ?? new();
            }
        }

        return Task.CompletedTask;
    }

    private async Task SaveSettings()
    {
        if (PlugDataZone == null || DefinitionId == null) return;

        PlugDataZone.SetVariableValue(DefinitionId, "AIModelName", _selectedModel);
        PlugDataZone.SetVariableValue(DefinitionId, "AISystemPrompt", _systemPrompt);
        PlugDataZone.SetVariableValue(DefinitionId, "AIUserPrompt", _userPrompt);
        PlugDataZone.SetVariableValue(DefinitionId, "AIOutputVariable", _outputVariable);
        PlugDataZone.SetVariableValue(DefinitionId, "AIInputParameters", JsonSerializer.Serialize(_inputParameters));
    }

    private async Task AddInputParameter()
    {
        _inputParameters.Add(new InputParam());
        await SaveSettings();
    }

    private async Task RemoveInputParameter(InputParam param)
    {
        _inputParameters.Remove(param);
        await SaveSettings();
    }
}
