@using System.Text
@using System.Text.Json
@using System.Text.Json.Nodes
@using BlazorMonaco.Editor
@using CJ.Plug.Models.Plug
@using CJ.Plug.PlugBaseCore.Models
@using Elsa.Api.Client.Extensions
@using Elsa.Api.Client.Resources.ActivityDescriptors.Models
@using Elsa.Api.Client.Shared.Models
@using Humanizer
@using JavaScriptPlug
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using MudBlazor

@inject IJSRuntime JSRuntime

<MudStack Row AlignItems="AlignItems.Center" StretchItems="StretchItems.None">
    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Settings">导入本地文件</MudButton>
    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AirlineSeatFlat">导入系统文件</MudButton>
    <MudBadge Color="@(_isDirty ? Color.Warning : Color.Success)" Dot="true" Overlap="true" Origin="Origin.BottomRight" Bordered="true" Class="elsa-toolbar-icon">
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" OnClick="@OnSaveClick" StartIcon="@Icons.Material.Filled.Save">保存</MudButton>
    </MudBadge>
    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ResetCode" StartIcon="@Icons.Material.Filled.LockReset">重置</MudButton>
    <MudTooltip Text="参数集成说明:setpara(name,value)\getpara(name)">
        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Help" />
    </MudTooltip>
</MudStack>
<MudStack Row Justify="Justify.SpaceBetween">

    <MudStack Style="width:100%">

        <StandaloneCodeEditor CssClass="studio-monaco-editor-large-border"
                              @ref="_editor"
                              Id="my-javascript-editor"
                              OnDidChangeModelContent="TextChanged"
                              OnDidInit="EditorOnDidInit"
                              ConstructionOptions="EditorConstructionOptions" />

    </MudStack>

    <MudStack>
        <MudStack Row Style="width:188px;">
            <MudButton OnClick="TestJS" Variant="Variant.Outlined" Color="Color.Primary">执行测试</MudButton>
            <MudButton OnClick="@(()=>{jsExeResult="";})" Variant="Variant.Outlined" Color="Color.Primary">清空</MudButton>
        </MudStack>
        <MudTextField T="string" Label="结果预览" ReadOnly Variant="Variant.Outlined" Text="@jsExeResult" Lines="12" />
    </MudStack>

</MudStack>

@code{
    [CascadingParameter]
    public PlugDataZone PlugDataZone { get; set; }
    [Parameter]
    public GetSettingContext? SettingContext { get; set; }

    public string? DefinitionId { get; set; }

    private StandaloneCodeEditor _editor = null!;
    private string jsCode = "console.log('Hello World')";
    private string jsExeResult = "";
    private string iniValue = "";
    private bool _isDirty = false;


    protected override Task OnParametersSetAsync()
    {
        if (SettingContext != null)
        {
            DefinitionId = SettingContext.PlugDefinitionId;
        }
        var savedCode = PlugDataZone?.GetVariableValue(DefinitionId, InitVariableNames.Script.ToString());
        if (!string.IsNullOrEmpty(savedCode))
        {
            iniValue = savedCode;
        }
        return base.OnParametersSetAsync();
    }

    private async void TextChanged()
    {
        _isDirty = true;
    }

    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {
        return new StandaloneEditorConstructionOptions
            {
                AutomaticLayout = true,
                GlyphMargin = true,
                Language = "javascript",
                Value = iniValue
            };
    }

    private async Task EditorOnDidInit()
    {
        if (string.IsNullOrEmpty(iniValue))
        {
            iniValue = jsCode;
        }
        if (iniValue != null)
        {
            await _editor.SetValue(iniValue);
        }
    }

    private async Task TestJS()
    {
        var model = await _editor.GetModel();
        jsCode = await model.GetValue(EndOfLinePreference.CRLF, default);
        var result = await JSRuntime.InvokeAsync<object>("executeCode", jsCode);
        jsExeResult += result?.ToString() + "\n";
    }

    private async Task ResetCode()
    {
        await _editor.SetValue("console.log('Hello World')");
        _isDirty = true;
        StateHasChanged();
    }

    private async Task OnSaveClick()
    {
        if (_editor != null)
        {
            var model = await _editor.GetModel();
            jsCode = await model.GetValue(EndOfLinePreference.CRLF, default);
            this.PlugDataZone?.SetVariableValue(DefinitionId, InitVariableNames.Script.ToString(), jsCode);
            _isDirty = false;
            StateHasChanged();
        }
    }
}


<script type="text/javascript">
    function executeCode(code) {
        try {
            // 使用 IIFE 包装 eval 代码
            var result = (function () {
                return eval(code);
            })();
            return result;
        } catch (error) {
            // 捕获并处理错误
            console.error("执行代码时发生错误:", error);
            return { error: true, message: error.message };
        }
    }
</script>
