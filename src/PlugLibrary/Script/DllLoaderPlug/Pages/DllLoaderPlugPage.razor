    // Use a scoped per-user cache service to store loaded methods so component re-instantiation
    // doesn't cause transient UI flash. This avoids static cross-user sharing in Blazor Server.
    private List<DllLoaderPlug.Services.MethodDescriptor> loadedMethods => MethodCache.GetMethods();

    // 不在渲染周期自动加载 DLL，避免重复/重入。用户通过按钮显式触发加载。
    private bool isLoading = false;

    private async Task LoadDllAsync()
    {
        if (isLoading) return;
        isLoading = true;
        // ensure UI shows loading state asap
        Console.WriteLine("DllLoaderPlugPage: Start LoadDllAsync");
        await InvokeAsync(StateHasChanged);

        try
        {
            // loadedMethods = await DllMethodReader.DllReader(null);
            // foreach (var method in loadedMethods)
            // {
            //     codeResult += $"方法：{method.Name}，返回类型：{method.ReturnType}\n";
            // }
            // initValue = codeResult;

            var task = DllMethodReader.DllReader(null);
            var completed = await Task.WhenAny(task, Task.Delay(TimeSpan.FromSeconds(15)));
            if (completed == task)
            {
                var methods = await task; //already completed
                // only replace existing list when we actually found methods; avoid replacing with an empty collection which causes UI to 'flash' empty
                if (methods != null && methods.Count > 0)
                {
                    MethodCache.SetMethods(methods);
                }

                Console.WriteLine($"DllLoaderPlugPage: reader returned {methods?.Count ?? 0} methods");
                // refresh result preview from current loadedMethods
                codeResult = string.Empty;
                foreach (var method in loadedMethods)
                {
                    codeResult += $"方法：{method.Name}，返回类型：{method.ReturnType}\n";
                }
                initValue = codeResult;
                if (loadedMethods == null || loadedMethods.Count == 0)
                {
                    codeResult = "未解析到任何托管类型。请使用“选择文件”上传一个 .NET 程序集（DLL），以便进行解析与测试执行。";
                }
                await InvokeAsync(StateHasChanged);
                Console.WriteLine($"DllLoaderPlugPage: loadedMethods.Count = {loadedMethods.Count}");
            }
            else
            {
                Console.WriteLine("加载 DLL 超时，可能正在被另一个进程读取或文件过大。请稍后重试。");
                // keep previously loadedMethods instead of clearing, to avoid flashing empty list
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载 DLL 方法失败：{ex.Message}");
            // on error do not aggressively clear previous results so UI won't flash empty
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

