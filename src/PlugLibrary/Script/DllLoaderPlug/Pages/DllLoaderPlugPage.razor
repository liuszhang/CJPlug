    private void SelectMethod(DllLoaderPlug.Services.MethodDescriptor method)
    {
        selectedMethod = method;
        // generate a simple C# snippet that calls the selected method (best-effort)
        if (selectedMethod != null)
        {
            var paramList = string.Join(", ", selectedMethod.Parameters.Select(p => p?.Name ?? "arg"));
            var callTarget = selectedMethod.IsStatic ? selectedMethod.DeclaringType : ($"new {selectedMethod.DeclaringType}()");

            if (!string.IsNullOrEmpty(selectedMethod.ReturnType) && selectedMethod.ReturnType == "native export")
            {
                // For native exports, provide P/Invoke template guidance
                initValue = $"// 本方法来自本地 DLL 导出 (native export)\n" +
                            $"// 示例 P/Invoke 模板：\n" +
                            $"[System.Runtime.InteropServices.DllImport(\"{selectedMethod.SourcePath ?? "your.dll"}\", EntryPoint=\"{selectedMethod.Name}\")]\n" +
                            $"public static extern int {selectedMethod.Name}();\n\n// 然后直接调用：\nvar r = {selectedMethod.Name}();\nreturn r;";
            }
            else
            {
                initValue = $"// 调用: {selectedMethod.DeclaringType}.{selectedMethod.Name}({paramList})\n" +
                            "// TODO: 填充参数值\n" +
                            (selectedMethod.IsStatic ? "var result = " : "var instance = ") +
                            $"{callTarget}.{selectedMethod.Name}({paramList});\nreturn result;";
            }
            editor?.SetValue(initValue);
        }
    }

    private async Task TestExecuteSelectedMethodAsync()
    {
        // generate preview
        if (selectedMethod == null)
        {
            codeResult = "未选择方法";
            await InvokeAsync(StateHasChanged);
            return;
        }

        SelectMethod(selectedMethod);

        try
        {
            if (!string.IsNullOrEmpty(selectedMethod.ReturnType) && selectedMethod.ReturnType == "native export")
            {
                if (editor != null)
                {
                    var model = await editor.GetModel();
                    var pinvokeSource = await model.GetValue(EndOfLinePreference.CRLF, default);
                    var invokeResult = await DllInvoker.InvokeNativeAsync(selectedMethod, pinvokeSource);
                    if (invokeResult.Success)
                        codeResult = invokeResult.Result == null ? "(null)" : invokeResult.Result.ToString();
                    else
                        codeResult = invokeResult.ErrorMessage ?? "未知错误";
                }
                else
                {
                    codeResult = "编辑器不可用，无法读取 P/Invoke 模板";
                }
            }
            else
            {
                // Use the invoker service which can dynamically load the assembly and invoke
                var invokeResult = await DllInvoker.InvokeAsync(selectedMethod);
                if (invokeResult.Success)
                {
                    codeResult = invokeResult.Result == null ? "(null)" : invokeResult.Result.ToString();
                }
                else
                {
                    codeResult = invokeResult.ErrorMessage ?? "未知错误";
                }
            }
        }
        catch (Exception ex)
        {
            codeResult = $"执行失败: {ex.Message}";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task TestCode()
    {
