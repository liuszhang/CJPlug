            //Log.Information($"执行代码：{code}");
            codeResult = "测试成功";
        }
    }

    private async Task OnDllFileChange(InputFileChangeEventArgs e)
    {
        Console.WriteLine("DllLoaderPlugPage: OnDllFileChange");
        var file = e.File;
        if (file == null) return;

        try
        {
            var fileName = Path.GetFileName(file.Name);
            var tempPath = Path.Combine(Path.GetTempPath(), Guid.NewGuid().ToString() + "_" + fileName);
            await using (var fs = System.IO.File.Create(tempPath))
            await using (var stream = file.OpenReadStream(long.MaxValue))
            {
                await stream.CopyToAsync(fs);
            }

            // Use the uploaded file path to read methods
            var task = DllMethodReader.DllReader(tempPath);
            var completed = await Task.WhenAny(task, Task.Delay(TimeSpan.FromSeconds(15)));
            if (completed == task)
            {
                var methods = await task;
                if (methods != null && methods.Count > 0)
                {
                    // ensure SourcePath is set for each method (DllMethodReader should set it, but double-check)
                    foreach (var m in methods)
                    {
                        if (string.IsNullOrEmpty(m.SourcePath)) m.SourcePath = tempPath;
                    }
                    MethodCache.SetMethods(methods);
                }

                codeResult = string.Empty;
                foreach (var method in loadedMethods)
                {
                    codeResult += $"方法：{method.Name}，返回类型：{method.ReturnType}\n";
                }
                initValue = codeResult;
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                codeResult = "上传并解析 DLL 超时";
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            codeResult = $"上传并解析 DLL 失败：{ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

