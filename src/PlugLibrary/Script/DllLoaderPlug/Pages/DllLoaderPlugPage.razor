<MudStack Row AlignItems="AlignItems.Center">
    
    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.LockReset">导入脚本</MudButton>
    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.LockReset">导出脚本</MudButton>
    <MudButton OnClick="TestExecuteSelectedMethodAsync" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.RunCircle">测试调用</MudButton>
</MudStack>

<RadzenSplitter >
    <RadzenSplitterPane Size="60%">
        <MonacoEditorWrapper @ref="editor" Id="@PlugDefinitionId" Language="csharp" InitValue="@initValue"></MonacoEditorWrapper>
        <MudTextField Lines="12" @bind-Value="codeResult" Variant="Variant.Outlined" ReadOnly Label="结果预览"></MudTextField>
    </RadzenSplitterPane>
    <RadzenSplitterPane Size="600px" MinSize="200px" Style="border-left:1px solid #ccc;">
        <MudTabs>
            <MudTabPanel Text="目标DLL">
                <MudButton OnClick="LoadDllAsync" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.LockReset">解析Dll</MudButton>
                <InputFile OnChange="OnDllFileChange" />
                <MudList T="string" Dense Style="width:100%;max-height:600px;overflow:auto;">
                    <MudListItem>加载的Dll方法列表：</MudListItem>
                    @foreach (var method in loadedMethods)
                    {
                        <MudListItem OnClick="@(() => SelectMethod(method))" Class="@(selectedMethod == method ? "mud-list-item-active" : null)">@method.Name</MudListItem>
                    }
                </MudList>
            </MudTabPanel>
            <MudTabPanel Text="依赖库列表">

            </MudTabPanel>
        </MudTabs>
        
    </RadzenSplitterPane>
    
</RadzenSplitter>






