@using System.Text
@using System.Text.Json
@using System.Text.Json.Nodes
@using BlazorMonaco.Editor
@using CJ.Plug.Models.LogModels

@using CJ.Plug.Models.Plug
@using CJ.Plug.Models.Shared
@using CJ.Plug.Models.Station
@using CJ.Plug.PlugBaseCore.Models
@using CJ.Plug.SharedPages.SharedComponents
@using Elsa.Api.Client.Extensions
@using Elsa.Api.Client.Resources.ActivityDescriptors.Models
@using Elsa.Api.Client.Shared.Models
@using Humanizer
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.SignalR.Client
@using MudBlazor
@using Serilog

@inject MainApiClient MainApiClient
@inject HubConnectionManagerService HubConnectionManagerService


<MudStack Row AlignItems="AlignItems.Center" StretchItems="StretchItems.None">

    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Settings">导入BAT脚本</MudButton>
    <MudButton OnClick="ClearCommand" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AirlineSeatFlat">清空脚本</MudButton>
    <MudButton OnClick="TestCMD" Disabled="Loading" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowCircleRight">
        
        @if (Loading)
        {
            <MudProgressCircular Indeterminate Size="Size.Small"></MudProgressCircular>
            <MudText>执行中</MudText>
        }
        else
        {
            <MudText>执行测试</MudText>
        }
    </MudButton>
    <MudButton Onclick="@(()=>{CMDExeResult="";})" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ClearAll">清空日志</MudButton>
    <MudCheckBox T="bool" Color="Color.Primary">bat方式运行</MudCheckBox>
    <MudSpacer></MudSpacer>
    <MudCheckBox Value="showConsole" ValueChanged="@((bool a)=>OnValueChanged(a))">显示执行窗口</MudCheckBox>
    <MudCheckBox Value="redirectOutput" ValueChanged="@((bool a)=>OnValueChanged(a))">重定向输出信息</MudCheckBox>
    <MudCheckBox Value="redirectWorkPath" ValueChanged="@((bool a)=>OnValueChanged(a))">重定向工作目录</MudCheckBox>
</MudStack>
<MudStack Row AlignItems="AlignItems.Center">
    <MudText>编辑脚本内容</MudText>
    <MudButtonGroup Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
        <MudButton Size="Size.Small">插入参数</MudButton>
        <MudMenu Size="Size.Small" Dense Icon="@Icons.Material.Filled.ArrowDropDown" Style="align-self: auto;">
            <MudMenuItem >value0</MudMenuItem>
            <MudMenuItem >value1</MudMenuItem>
        </MudMenu>
    </MudButtonGroup>
    <MudCheckBox @bind-Value="AutoSaveCode" T="bool" Size="Size.Small" Color="Color.Primary">自动保存</MudCheckBox>
    <MudIconButton OnClick="OnSaveClick" Disabled="AutoSaveCode" Icon="@Icons.Material.Filled.Save" Size="Size.Small" Color="Color.Primary">保存</MudIconButton>
</MudStack>
<MudStack Row Style="width:100%;height:320px" StretchItems="StretchItems.Start">
    <StandaloneCodeEditor CssClass="studio-monaco-editor-large-border"
    Id="my-cmd-editor"
    @ref="_editor"
    ConstructionOptions="EditorConstructionOptions" 
    OnDidInit="EditorOnDidInit"
    OnDidChangeModelContent="TextChanged" />

    @* <MonacoEditorWrapper InitValue="@CMDCommand" Language="python">
    </MonacoEditorWrapper> *@

    <MudTextField @bind-Value="CMDExeResult" ReadOnly Style="width:200px" Label="执行日志" Variant="Variant.Outlined" Lines="12" HelperText="捕获标准控制台输出" />
</MudStack>
<MudStack Row>
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">执行超时设置</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudStack Spacing="0">
                <MudGrid Style="margin-left:-12px;">
                    <MudItem xs="12" md="12">
                        <MudRadioGroup Value="waitType" ValueChanged="@((string a)=>OnValueChanged2(a))">
                            <MudRadio Color="Color.Primary" Value="@("waitforever")">无限等待</MudRadio>
                            <MudRadio Color="Color.Primary" Value="@("waitsometime")">
                                <ChildContent>
                                    <MudStack Row AlignItems="AlignItems.Center">
                                        指定超时
                                        <MudTextField Value="waitTime" ValueChanged="@((string a)=>OnValueChanged2(a))" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                                        秒
                                    </MudStack>
                                </ChildContent>
                            </MudRadio>
                        </MudRadioGroup>
                    </MudItem>
                </MudGrid>
                <MudCheckBox Value="autoCloseProcess" ValueChanged="@((bool a)=>OnValueChanged(a))">超时自动关闭</MudCheckBox>

            </MudStack>
        </MudCardContent>
    </MudCard>
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">执行监控设置</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudStack Spacing="0">
                <MudGrid Style="margin-left:-12px;">
                    <MudItem xs="12" md="12">
                        <MudRadioGroup Value="watchProcessType" ValueChanged="@((string a)=>OnValueChanged2(a))">
                            <MudRadio Color="Color.Primary" Value="@("default")">默认调用的进程</MudRadio>
                            <MudRadio Color="Color.Primary" Value="@("custome")">
                                <ChildContent>
                                    <MudStack Row AlignItems="AlignItems.Center">
                                        进程名称（不带后缀，多个进程用|分隔）
                                        <MudTextField Value="watchProcessName" ValueChanged="@((string a)=>OnValueChanged2(a))" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>

                                    </MudStack>
                                </ChildContent>
                            </MudRadio>
                        </MudRadioGroup>
                    </MudItem>
                </MudGrid>
                <MudStack Row>
                    <MudCheckBox Value="autoCloseProcess" ValueChanged="@((bool a)=>OnValueChanged(a))">执行完成关闭进程</MudCheckBox>
                    <MudCheckBox Value="closeProcessWhenError" ValueChanged="@((bool a)=>OnValueChanged(a))">执行错误或终止时关闭进程</MudCheckBox>
                </MudStack>

            </MudStack>
        </MudCardContent>
    </MudCard>
</MudStack>

@code {
    [CascadingParameter]
    public PlugDataZone PlugDataZone { get; set; }
    [Parameter]
    public GetSettingContext? SettingContext { get; set; }

    //[Parameter]
    public string? DefinitionId { get; set; }
    //[Parameter]
    public JsonObject? Activity { get; set; }
    //[Parameter]
    public ActivityDescriptor? ActivityDescriptor { get; set; }    


    public Plug? Plug { get; set; } = new();

    //模型类参数
    private StandaloneCodeEditor _editor = null!;
    private string editorCode = "";
    private string CMDCommand = "";
    private string CMDExeResult = "";
    private string iniValue = "";
    private string DefaultValue = "";
    private bool AutoSaveCode = true;
    private bool _isDirty = false;
    public Placement Placement { get; set; } = Placement.Top;

    private string? waitType = "waitforever";
    private string? waitTime = "0";
    private string? watchProcessType = "default";
    private string? watchProcessName = "";
    private bool autoCloseProcess = false;
    private bool closeProcessWhenError = false;
    private bool showConsole = true;
    private bool redirectOutput = true;
    private bool redirectWorkPath = true;




    private List<PlugVariable> TmpInputs = new List<PlugVariable>();
    //private PlugVariable TmpInput = new PlugVariable();
    private bool _readOnly;
    private bool _isCellEditMode = true;
    private List<string> _events = new();
    private bool _editTriggerRowClick;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    List<PlugVariable> rootPlugVariables = new List<PlugVariable>();
    private IBrowserFile File;
    private string? RealFilePath;
    private bool Loading = false;
    private bool showProgress = false;
    private bool IsInput = false;
    private bool IsOutput = false;
    private PlugSettings? PlugSettings;


    DialogOptions diaOption = new DialogOptions()
        {
            MaxWidth = MaxWidth.Large,
            Position = DialogPosition.TopCenter,
            BackdropClick = false,
            FullWidth = true
        };


    protected override async Task OnInitializedAsync()
    {
        //Console.WriteLine(">>>>>>>>>>>>>>start init");
        await MudDialog.SetOptionsAsync(diaOption);

        //Log.Information(Plug.Value);
        if(Plug.GetPlugSettings()?.Settings.Count==0)
        {
            PlugSettings = new PlugSettings();
            PlugSettings.SetSetting("WaitType", "waitforever");
            PlugSettings.SetSetting("WaitTime", "0");
            PlugSettings.SetSetting("WatchProcessType", "default");
            PlugSettings.SetSetting("WatchProcessName", "");
            PlugSettings.SetSetting("AutoCloseProcess", "false");
            PlugSettings.SetSetting("CloseProcessWhenError", "false");
            PlugSettings.SetSetting("ShowConsole", "true");
            PlugSettings.SetSetting("RedirectOutput", "true");
            PlugSettings.SetSetting("RedirectWorkPath", "true");
        }
        else
        {
            PlugSettings = JsonSerializer.Deserialize<PlugSettings>(Plug.PlugSettingsJson);
        }

        waitType = PlugSettings.GetSetting("WaitType");
        waitTime = PlugSettings.GetSetting("WaitTime");
        watchProcessType = PlugSettings.GetSetting("WatchProcessType");
        watchProcessName = PlugSettings.GetSetting("WatchProcessName");
        autoCloseProcess = string.IsNullOrEmpty(PlugSettings.GetSetting("AutoCloseProcess")) ? false : bool.Parse(PlugSettings.GetSetting("AutoCloseProcess"));
        closeProcessWhenError = string.IsNullOrEmpty(PlugSettings.GetSetting("CloseProcessWhenError")) ? false : bool.Parse(PlugSettings.GetSetting("CloseProcessWhenError"));
        showConsole = string.IsNullOrEmpty(PlugSettings.GetSetting("ShowConsole")) ? false : bool.Parse(PlugSettings.GetSetting("ShowConsole"));
        redirectOutput = string.IsNullOrEmpty(PlugSettings.GetSetting("RedirectOutput")) ? true : bool.Parse(PlugSettings.GetSetting("RedirectOutput"));
        redirectWorkPath = string.IsNullOrEmpty(PlugSettings.GetSetting("RedirectWorkPath")) ? true : bool.Parse(PlugSettings.GetSetting("RedirectWorkPath"));

        Plug.Value = Plug.GetVariableValue(InitVariableNames.CMDCommand.ToString());
        CMDCommand = Plug.Value ?? "notepad";

        DefinitionId = SettingContext.PlugDefinitionId;
        //Log.Information(PlugSettings.GetSettingsJson());
        //stlPath = null;
        //JsRuntime.InvokeVoidAsync("updateAndReloadIframe", stlPath2);
        HubConnectionManagerService._hubConnection.On<string>("ReceiveLog", (message) =>
           {
               var logModel = JsonSerializer.Deserialize<LogModel>(message);
               //Console.WriteLine($"[客户端2收到消息]NewLogs2：{logModel.Description}");
               // 将新日志添加到本地列表并触发UI更新
               InvokeAsync(() =>
               {
                   CMDExeResult += logModel.Description;
                   CMDExeResult += "\n";
                   StateHasChanged();
               });
           });

    }

    protected override Task OnParametersSetAsync()
    {
        //CLog.Information($"当前PDZ：{PlugDataZone.PDZId}");
        //CLog.Information($"当前PLug：{DefinitionId}");
        CMDCommand = PlugDataZone.GetVariableValue(DefinitionId, InitVariableNames.CMDCommand.ToString());
        //MyCon1sole.WriteLine($"CMDCommand:{CMDCommand}");
        if (string.IsNullOrEmpty(CMDCommand))
        {
            CMDCommand = "powershell";
        }
        return base.OnParametersSetAsync();
    }

    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {
        //MyCon1sole.WriteLine("编辑器开始构造");
        return new StandaloneEditorConstructionOptions
            {
                AutomaticLayout = true,
                GlyphMargin = true,
                Language = "python",
                Value = iniValue
            };
    }
    private async void TextChanged()
    {
        _isDirty = true;
        if (AutoSaveCode == true)
        {
            //await Task.Delay(500);
            //MyCon1sole.WriteLine("开始自动保存");
            await OnSaveClick();
            //StateHasChanged();
            //Log.Information("自动保存完成");
        }
    }
    private async Task EditorOnDidInit()
    {
        iniValue = CMDCommand;

        if (iniValue != null)
        {
            await _editor.SetValue(iniValue);
        }
    }


    private async Task TestCMD()
    {
        Loading = true;
        try
        {
            PlugExecutionRequest stationExecutionRequest = new PlugExecutionRequest();
            stationExecutionRequest.PlugType = PlugKeySetting.CommonExecuteKey;
            stationExecutionRequest.ExecuteMode = ExecuteMode.Standalone;
            stationExecutionRequest.ToolName = "CMD";
            stationExecutionRequest.RequestCommand = editorCode;
            //stationExecutionRequest.InputVariables.Add(new() { Name = InitVariableNames.CMDCommand.ToString(), Value = editorCode });
            //stationExecutionRequest.ExecuteResultData.Ids.PDZId = PlugDataZone.PDZId;
            //var result = await MainApiClient.ExecuteToolCommand(stationExecutionRequest);
            //await MainApiClient.ExecutePlugWithRequest(Plug.DefinitionId,stationExecutionRequest);
            //var result = await MainApiClient.ExecuteOnStation().ExecutePlugByType(stationExecutionRequest);
            var result = await MainApiClient.ExecuteOnStation(stationExecutionRequest);
            CLog.Information($"执行结果：{result.ResultString}");
            CMDExeResult += result.ResultString;
        }
        catch(Exception ex)
        {
            CLog.Information(ex.Message);
        }
        Loading = false;
        StateHasChanged();
    }

    private async Task ClearCommand()
    {
        await _editor.SetValue("");
    }


    private async void GetDefaultValue()
    {
        await _editor.SetValue(DefaultValue);
        StateHasChanged();
    }

    private async Task OnSaveClick()
    {
        //_isDirty = false;
        if (_editor != null)
        {
            var model = await _editor.GetModel();
            editorCode = await model.GetValue(EndOfLinePreference.CRLF, default);
            this.PlugDataZone.SetVariableValue(DefinitionId, InitVariableNames.CMDCommand.ToString(), editorCode);
            _isDirty = false;
            StateHasChanged();
        }
        //await _editor.SetValue(DefaultValue);
        //StateHasChanged();
    }

    private async Task OnValueChanged(bool value)
    {
        UpdatePlugSettings();         
    }
    private async Task OnValueChanged2(string value)
    {
        UpdatePlugSettings();
    }

    private async void UpdatePlugSettings()
    {
        PlugSettings.SetSetting("WaitType", waitType);
        PlugSettings.SetSetting("WaitTime", waitTime);
        PlugSettings.SetSetting("WatchProcessType", watchProcessType);
        PlugSettings.SetSetting("WatchProcessName", watchProcessName);
        PlugSettings.SetSetting("AutoCloseProcess", autoCloseProcess.ToString());
        PlugSettings.SetSetting("CloseProcessWhenError", closeProcessWhenError.ToString());
        PlugSettings.SetSetting("ShowConsole", showConsole.ToString());
        PlugSettings.SetSetting("RedirectOutput", redirectOutput.ToString());
        PlugSettings.SetSetting("RedirectWorkPath", redirectWorkPath.ToString());
        Plug.PlugSettingsJson = JsonSerializer.Serialize(PlugSettings);
        //await MainApiClient.UpdatePlugAsync(Plug.Id, Plug);
    }

}
