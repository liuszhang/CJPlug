                //Plug.SetVariableValue(InitVariableNames.TextFile.ToString(), browserFile.Name + ":" + fileId);
                PlugDataZone.SetVariableValue(PlugDefinitionId, InitVariableNames.TextFile.ToString(), browserFile.Name + ":" + fileId);

