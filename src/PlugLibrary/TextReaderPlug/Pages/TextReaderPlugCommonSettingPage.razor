                //browserFile = null;
            }
            catch (Exception ex)
            {
                CLog.Error(ex.Message);
                CLog.Error(ex.StackTrace);
            }
        }
    }



    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {
        //MyCon1sole.WriteLine("编辑器开始构造");
        return new StandaloneEditorConstructionOptions
            {
                AutomaticLayout = true,
                GlyphMargin = true,
                Language = "json",
                Value = ""
            };
    }


    private async Task GetFileContent()
    {
        Processing = true;
        FileId = PlugDataZone?.GetVariableValue(PlugDefinitionId, InitVariableNames.TextFile.ToString()).GetFileIdFromFileVariable();
        if (string.IsNullOrEmpty(FileId))
        {
            Processing = false;
            return;
        }
        FileContent = await MainApiClient.GetFileContentByFileId(FileId);
        await _editor.SetValue(FileContent);
        
        //await AddAction();
        Processing = false;
    }

    private async Task GetValue()
    {
        var range = await _editor.GetSelection();
        var model = await _editor.GetModel();
        var val = await model.GetValueInRange(range, EndOfLinePreference.LF);
        //MyCon1sole.WriteLine($"value is: {val}");
        tmpTextMapping.Keywords = val;

        await CheckKeywords();
    }

    private async Task CheckKeywords()
    {
        if (string.IsNullOrEmpty(tmpTextMapping.Keywords))
        {
            return;
        }
        var _modelResult = await _editor.GetModel();
        var range = await _modelResult.GetFullModelRange();
        var matchs = await _modelResult.FindMatches(tmpTextMapping.Keywords, range, false, true, "", true, 100);
        Log.Information("匹配数：" + matchs.Count);
        if (matchs.Count > 0)
        {
            BlazorMonaco.Position position = new BlazorMonaco.Position();
            position.LineNumber = matchs[0].Range.EndLineNumber;
            position.Column = matchs[0].Range.EndColumn;
            var newDecorations = new ModelDeltaDecoration[]
            {
                new ModelDeltaDecoration
                {
                    Range = matchs[0].Range,
                    Options = new ModelDecorationOptions
                    {
                        //IsWholeLine = true,
                        ClassName = "decorationContentClass",
                        GlyphMarginClassName = "decorationGlyphMarginClass"
                    }
                }
            };
            await _editor.ResetDeltaDecorations();
            decorationIds = await _editor.DeltaDecorations(null, newDecorations);
            tmpTextMapping.Position[0] = matchs[0].Range.StartLineNumber;
            tmpTextMapping.Position[1] = matchs[0].Range.StartColumn;
            tmpTextMapping.Position[2] = matchs[0].Range.EndLineNumber;
            tmpTextMapping.Position[3] = matchs[0].Range.EndColumn;

            BlazorMonaco.Selection selection = new Selection();
            selection.SelectionStartLineNumber = tmpTextMapping.Position[0] + tmpTextMapping.PositionOffset[0];
            selection.SelectionStartColumn = tmpTextMapping.Position[1] + tmpTextMapping.PositionOffset[1];
            selection.PositionLineNumber = tmpTextMapping.Position[2] + tmpTextMapping.PositionOffset[2];
            selection.PositionColumn = tmpTextMapping.Position[3] + tmpTextMapping.PositionOffset[3];
            await _editor.Focus();
            await _editor.SetPosition(position, "");
            await _editor.SetSelection(selection, "");
            var offset = await _modelResult.GetOffsetAt(position);
            //MyCon1sole.WriteLine(offset);
            //获取关键字开始和结束的绝对偏移
            position.LineNumber = matchs[0].Range.StartLineNumber;
            position.Column = matchs[0].Range.StartColumn;
            var offset1 = await _modelResult.GetOffsetAt(position);
            //MyCon1sole.WriteLine("关键字起始：" + offset1);
            position.LineNumber = matchs[0].Range.EndLineNumber;
            position.Column = matchs[0].Range.EndColumn;
            var offset2 = await _modelResult.GetOffsetAt(position);
            //MyCon1sole.WriteLine("关键字结束：" + offset2);
            //获取替换起始位置相对于关键字起始位置的偏移
            position.LineNumber = selection.SelectionStartLineNumber;
            position.Column = selection.SelectionStartColumn;
            var valueoffset1 = await _modelResult.GetOffsetAt(position);
            //MyCon1sole.WriteLine("替换区域开始：" + valueoffset1);
            //MyCon1sole.WriteLine("相对于关键字起始：" + (valueoffset1 - offset1));
            tmpTextMapping.StartOffset = valueoffset1 - offset1;
            //获取替换结束位置相对于关键字起始位置的偏移
            position.LineNumber = selection.PositionLineNumber;
            position.Column = selection.PositionColumn;
            var valueoffset2 = await _modelResult.GetOffsetAt(position);
            //MyCon1sole.WriteLine("替换区域结束：" + valueoffset2);
            //MyCon1sole.WriteLine("相对于关键字起始：" + (valueoffset2 - offset1));
            tmpTextMapping.EndOffset = valueoffset2 - offset1;
        }
        else
        {
            Log.Information("未能找到关键字匹配，请调整关键字重试");
        }
        //MyCon1sole.WriteLine("修改完成");
        //return 1;

    }

    private async Task GetNewSelection(int offset, int index)
    {
        tmpTextMapping.PositionOffset[index] = offset;
        EditorSelection.SelectionStartLineNumber = tmpTextMapping.Position[0] + tmpTextMapping.PositionOffset[0];
        EditorSelection.SelectionStartColumn = tmpTextMapping.Position[1] + tmpTextMapping.PositionOffset[1];
        EditorSelection.PositionLineNumber = tmpTextMapping.Position[2] + tmpTextMapping.PositionOffset[2];
        EditorSelection.PositionColumn = tmpTextMapping.Position[3] + tmpTextMapping.PositionOffset[3];

        await _editor.SetSelection(EditorSelection, "");

        //StateHasChanged();
    }

