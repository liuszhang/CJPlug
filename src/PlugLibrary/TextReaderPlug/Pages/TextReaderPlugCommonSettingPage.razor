    protected override async Task OnInitializedAsync()
    {
        if (SettingContext != null)
        {
            PlugDefinitionId = SettingContext.PlugDefinitionId;
            PlugData = PlugDataZone?.GetPlugData(PlugDefinitionId);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        FileId = PlugDataZone?.GetVariableValue(PlugDefinitionId, InitVariableNames.TextFile.ToString()).GetFileIdFromFileVariable();
        FileContent = await MainApiClient.GetFileContentByFileId(FileId);
        PlugVariablesInPDZ = PlugDataZone?.PlugVariableDatas?.Where(x => x.PlugDefinitionId == PlugDefinitionId).ToList() ?? new();
        TextMappingVariable = PlugVariablesInPDZ?.Where(v => v.Name == InitVariableNames.TextMapping.ToString()).FirstOrDefault();
        var value = TextMappingVariable?.Value;
        try
        {
            TextMappings = JsonSerializer.Deserialize<List<TextMapping>?>(value);
        }
        catch (Exception ex)
        {
            TextMappings = new List<TextMapping>();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(500); // 等待渲染完成
            await GetFileContent();
        }
    }

    private async Task UploadFiles(IBrowserFile browserFile)
    {        
        //TODO upload the files to the server
        if (browserFile != null)
