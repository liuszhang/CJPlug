<MudStack Row Justify="Justify.SpaceBetween">

    @* <MudStack Style="width:100%">

        <StandaloneCodeEditor CssClass="studio-monaco-editor-large-border"
        Id="my-text-editor"
        @ref="_editor"
        ConstructionOptions="EditorConstructionOptions" />

    </MudStack> *@
    <MonacoEditorWrapper @ref="_editor" Id="@("text-editor-"+PlugDefinitionId)"></MonacoEditorWrapper>

    <CascadingValue Value="_editor">

        

        <MudStack Justify="Justify.FlexStart" AlignItems="AlignItems.Stretch" Style="min-width:280px">

            <MudSelect Margin="Margin.Dense" Dense @bind-Value="@ReadType" Variant="Variant.Filled">
                <MudSelectItem Value="@ReadSchemaMode.关键字">@ReadSchemaMode.关键字.ToString()</MudSelectItem>
                <MudSelectItem Value="@ReadSchemaMode.键值对">@ReadSchemaMode.键值对.ToString()</MudSelectItem>
                <MudSelectItem Value="@ReadSchemaMode.表格">@ReadSchemaMode.表格.ToString()</MudSelectItem>
            </MudSelect>
            @if (ReadType == ReadSchemaMode.关键字)
            {
                <KeyWordsReader 
                tmpTextMapping="tmpTextMapping"
                PlugVariablesInPDZ="PlugVariablesInPDZ"
                GetValue="GetValue" 
                CheckKeywords="CheckKeywords" 
                OnInsertTextMapping="InsertMapping"></KeyWordsReader>
            }
            else if (ReadType == ReadSchemaMode.键值对)
            {
                <KeyValueReader 
                tmpTextMapping="tmpTextMapping"
                PlugVariablesInPDZ="PlugVariablesInPDZ"
                OnInsertTextMapping="InsertMapping"></KeyValueReader>

            }
            else if (ReadType == ReadSchemaMode.表格)
            {
                <TableReader tmpTextMapping="tmpTextMapping"
                             PlugVariablesInPDZ="PlugVariablesInPDZ"
                             OnInsertTextMapping="InsertMapping"></TableReader>
            }

        </MudStack>

    </CascadingValue>


</MudStack>


<MudDataGrid T="TextMapping" Items="TextMappings" Dense ReadOnly="false"
EditTrigger="@(DataGridEditTrigger.Manual)" EditMode="DataGridEditMode.Cell">
    <ToolBarContent>
        <MudText Typo="Typo.h6">已配置关键字映射清单</MudText>
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x=>x.Id" Title="序号" Editable="false" />
        <PropertyColumn Property="x=>x.BindingVariableName" Title="参数名称" Editable="false" />
        <PropertyColumn Property="x=>x.Keywords" Title="关键字" />
        <PropertyColumn Property="x=>x.ReadSchemaMode" Title="识别模式">
            <EditTemplate>
                <MudSelect Margin="Margin.Dense" Dense @bind-Value="context.Item.ReadSchemaMode">
                    <MudSelectItem Value="@ReadSchemaMode.关键字">@ReadSchemaMode.关键字.ToString()</MudSelectItem>
                    <MudSelectItem Value="@ReadSchemaMode.键值对">@ReadSchemaMode.键值对.ToString()</MudSelectItem>
                    <MudSelectItem Value="@ReadSchemaMode.表格">@ReadSchemaMode.表格.ToString()</MudSelectItem>
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x=>x.ReadSchemaValue" Title="识别值" />
        @* <PropertyColumn Property="x=>(String.Join(',', x.Position))" Title="关键字区域" IsEditable="false" /> *@
        @* <PropertyColumn Property="x=>(String.Join(',', x.PositionOffset))" Title="区域偏移量" /> *@
        <PropertyColumn Property="x => x.EndOffset" Title="操作">
            <EditTemplate>
                <MudStack Row Justify="Justify.FlexStart" Style="width:100%;">
                    <MudButton Size="Size.Small" OnClick="@(() => CheckMapping(context.Item))" Variant="Variant.Filled">查看</MudButton>
                    <MudIconButton Size="Size.Small" OnClick="@(() => DeleteMapping(context.Item))" Icon="@Icons.Material.Filled.Delete" Color="Color.Error"></MudIconButton>

                </MudStack>
            </EditTemplate>
        </PropertyColumn>
    </Columns>

</MudDataGrid>

