@using BlazorMonaco
@using BlazorMonaco.Editor
@using CJ.Plug.Models.Plug
@using Elsa.Api.Client.Extensions
@using Elsa.Api.Client.Resources.ActivityDescriptors.Models
@using Elsa.Api.Client.Shared.Models
@using Humanizer
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@using System.Text.Json.Nodes
@using System.Text.Json
@using System.Text
@using PythonPlug.Services
@using CJ.Plug.Models.LogModels
@using CJ.Plug.PlugBaseCore.Models
@using CJ.Plug.Models.Shared
@using Size=MudBlazor.Size

@inject MainApiClient MainApiClient

<MudStack Row AlignItems="AlignItems.Center">
                    <MudTooltip>
                        <ChildContent>
                            <MudIconButton Icon="@Icons.Material.Filled.MedicalInformation" />
                        </ChildContent>
                        <TooltipContent>
                            <MudText Typo="Typo.h6">参数集成格式说明</MudText>
                            <MudText Typo="Typo.body2">方式一：使用通配符 ${参数名}（推荐），示例：'a=${p1}'，执行时自动替换为参数值</MudText>
                            <MudText Typo="Typo.body2">方式二：使用函数格式 'get参数名()'，示例：'a=getInput1()'</MudText>
                            <MudText Typo="Typo.body2">设置输出参数值：'setOutput("Output1","test")'</MudText>
                            <MudText Typo="Typo.body2">获取输出参数值：'getOutput("Output1")'</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.Star" />
                        </TooltipContent>
                    </MudTooltip>
                    <MudSwitch @bind-Value="@AutoSaveCode" Color="Color.Primary" Label="自动保存" />
                    <MudBadge Color="@(_isDirty ? Color.Warning : Color.Success)" Dot="true" Overlap="true" Origin="Origin.BottomRight" Bordered="true" Class="elsa-toolbar-icon">
                        <MudButton OnClick="@OnSaveClick" Variant="Variant.Outlined" Color="Color.Primary">保存</MudButton>
                    </MudBadge>
                    <MudMenu EndIcon="@Icons.Material.Filled.ArrowDropDown"
                             Label="插入参数" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                        <ChildContent>
                            @if (Plug?.PlugVariables?.Count > 0)
                            {
                                @foreach (var v in Plug.PlugVariables)
                                {
                                    if (v.Name == InitVariableNames.Script.ToString() || v.Name == InitVariableNames.ResultString.ToString())
                                        continue;
                                    <MudMenuItem OnClick="@(() => InsertParameterAtCursor(v.Name))">
                                        <MudText>@v.Name <MudText Typo="Typo.caption" Color="Color.Default">@("${" + v.Name + "}")</MudText></MudText>
                                    </MudMenuItem>
                                }
                            }
                            else
                            {
                                <MudMenuItem Disabled="true">（暂无输入参数）</MudMenuItem>
                            }
                        </ChildContent>
                    </MudMenu>
                    <MudButton OnClick="GetDefaultValue" Variant="Variant.Outlined" Color="Color.Primary">重置</MudButton>

                    <MudText>@Plug?.RealValuePath</MudText>

                </MudStack>

<MudStack Row Justify="Justify.SpaceBetween">
                    <MudStack Style="width:100%;">
                        <StandaloneCodeEditor @ref="_editor"
                                              CssClass="studio-monaco-editor-large-border"
                                              Id="my-python-editor"
                                              ConstructionOptions="EditorConstructionOptions"
                                              OnDidInit="EditorOnDidInit"
                                              OnDidChangeModelContent="TextChanged" />
                    </MudStack>

                    <MudStack>
                        <MudStack Row Style="width:188px;">
                            <MudButton OnClick="TestPython" Disabled="Loading" Variant="Variant.Outlined" Color="Color.Primary">
                                @if (Loading)
                                {
                                    <MudProgressCircular Indeterminate Size="MudBlazor.Size.Small"></MudProgressCircular>
                                    <MudText>执行中</MudText>
                                }
                                else
                                {
                                    <MudText>执行测试</MudText>
                                }
                            </MudButton>
                            <MudButton OnClick="@(()=>{pythonExeResult="";})" Variant="Variant.Outlined" Color="Color.Primary">清空</MudButton>
                        </MudStack>
                        <MudTextField T="string" Label="结果预览" ReadOnly Variant="Variant.Outlined" Text="@pythonExeResult" Lines="12" />
                    </MudStack>

                </MudStack>

@code {
    [CascadingParameter]
    public PlugDataZone PlugDataZone { get; set; }
    [Parameter]
    public GetSettingContext? SettingContext { get; set; }

    public string? DefinitionId { get; set; }
    public JsonObject? Activity { get; set; }
    public ActivityDescriptor? ActivityDescriptor { get; set; }

    //模型类参数
    private StandaloneCodeEditor _editor = null!;
    private string editorCode = "";
    private string pythonExeResult = "";
    private string iniValue = "";
    private string DefaultValue = "";
    private bool AutoSaveCode = true;
    private bool _isDirty = false;

    public Plug? Plug { get; set; } = new();
    private List<PlugVariable> TmpInputs = new List<PlugVariable>();
    private bool _readOnly;
    private bool _isCellEditMode = true;
    private List<string> _events = new();
    private bool _editTriggerRowClick;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    List<PlugVariable> rootPlugVariables = new List<PlugVariable>();
    private IBrowserFile File;
    private string? RealFilePath;
    private bool Loading = false;
    private bool showProgress = false;
    private bool IsInput = false;
    private bool IsOutput = false;


    DialogOptions diaOption = new DialogOptions()
        {
            MaxWidth = MaxWidth.Large,
            Position = DialogPosition.TopCenter,
            BackdropClick = false,
            FullWidth = true
        };


    protected override async Task OnInitializedAsync()
    {
        if (MudDialog != null)
            await MudDialog.SetOptionsAsync(diaOption);
    }

    protected override Task OnParametersSetAsync()
    {
        if (SettingContext != null)
        {
            DefinitionId = SettingContext.PlugDefinitionId;
            Plug = SettingContext.Plug;
        }
        var pythonScript = PlugDataZone?.GetVariableValue(DefinitionId, InitVariableNames.Script.ToString());
        if (!string.IsNullOrEmpty(pythonScript))
        {
            iniValue = pythonScript;
        }
        return base.OnParametersSetAsync();
    }

    private static WrappedInput? ToWrappedInput(object? value)
    {
        var converterOptions = new ObjectConverterOptions(serializerOptions => { serializerOptions.PropertyNamingPolicy = JsonNamingPolicy.CamelCase; });
        return value.ConvertTo<WrappedInput>(converterOptions);
    }

    async Task OnCheckIsInputChanged(CellContext<PlugVariable> cellContext, bool isInput)
    {
        if (isInput)
        {
            cellContext.Item.IsInput = true;
            var tmpName = cellContext.Item.Name;
            foreach (var input in Plug.PlugVariables)
            {
                if (input.Name == tmpName)
                {
                    return;
                }
            }
            Plug.PlugVariables.Add(new PlugVariable() { Name = tmpName, Type = "string", Value = cellContext.Item.Value });
        }
        else
        {
            cellContext.Item.IsInput = false;
            var tmpName = cellContext.Item.Name;
            foreach (var input in Plug.PlugVariables)
            {
                if (input.Name == tmpName)
                {
                    Plug.PlugVariables.Remove(input);
                    return;
                }
            }
        }
    }
    async Task OnCheckIsOutputChanged(CellContext<PlugVariable> cellContext, bool isOutput)
    {
        if (isOutput)
        {
            cellContext.Item.IsOutput = true;
            foreach (var output in Plug.PlugVariables)
            {
                if (output.Name == cellContext.Item.Name)
                {
                    return;
                }
            }
            Plug.PlugVariables.Add(new PlugVariable() { Name = cellContext.Item.Name, Type = "string" });
        }
        else
        {
            cellContext.Item.IsOutput = false;
            foreach (var output in Plug.PlugVariables)
            {
                if (output.Name == cellContext.Item.Name)
                {
                    Plug.PlugVariables.Remove(output);
                    return;
                }
            }
        }
    }

    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {
        return new StandaloneEditorConstructionOptions
            {
                AutomaticLayout = true,
                GlyphMargin = true,
                Language = "python",
                Value = iniValue
            };
    }
    private async void TextChanged()
    {
        _isDirty = true;
        if (AutoSaveCode == true)
        {
            await Task.Delay(500);
            await OnSaveClick();
            StateHasChanged();
        }
    }
    private async Task EditorOnDidInit()
    {
        if (string.IsNullOrEmpty(iniValue))
        {
            iniValue = @"a=1
if a == 1:
    print(2)";
        }
        if (iniValue != null)
        {
            await _editor.SetValue(iniValue);
        }
    }


    private async Task TestPython()
    {
        Loading = true;
        try
        {
            var model = await _editor.GetModel();
            editorCode = await model.GetValue(EndOfLinePreference.CRLF, default);

            // 先替换参数通配符 ${参数名}，再用替换后的脚本执行测试
            var substitutedCode = PythonPlugCommonExecuteService.SubstituteParameters(editorCode, paramName =>
            {
                // 优先级1: PlugDataZone（用户在参数配置页填入的实际值）
                if (PlugDataZone != null && DefinitionId != null)
                {
                    var pdzVal = PlugDataZone.GetVariableValue(DefinitionId, paramName);
                    if (!string.IsNullOrEmpty(pdzVal))
                        return pdzVal;
                }
                // 优先级2: 根插头定义中的 Value
                var v = Plug?.PlugVariables?.FirstOrDefault(p =>
                    string.Equals(p.Name, paramName, StringComparison.OrdinalIgnoreCase));
                if (v != null && !string.IsNullOrEmpty(v.Value))
                    return v.Value;
                return null;
            });

            PlugExecutionRequest stationExecutionRequest = new PlugExecutionRequest();
            stationExecutionRequest.PlugTypeKey = PlugKeySetting.CommonExecuteKey;
            stationExecutionRequest.ExecuteMode = ExecuteMode.Standalone;
            stationExecutionRequest.ToolName = "Python";
            var base64Script = Convert.ToBase64String(Encoding.UTF8.GetBytes(substitutedCode));
            stationExecutionRequest.RequestCommand = "$d=[System.Text.Encoding]::UTF8.GetString([System.Convert]::FromBase64String('" 
                 + base64Script + "'));"
                 + "$f=$env:TEMP + '\\py_' + (Get-Random) + '.py';"
                 + "Set-Content -Path $f -Value $d -Encoding UTF8;"
                 + "python $f;"
                 + "Remove-Item $f -Force";

            var result = await MainApiClient.ExecuteOnStation(stationExecutionRequest);
            CLog.Information($"执行结果：{result.ResultString}");
            pythonExeResult += result.ResultString;
        }
        catch (Exception ex)
        {
            CLog.Information(ex.Message);
        }
        Loading = false;
        StateHasChanged();
    }


    private async void GetDefaultValue()
    {
        await _editor.SetValue(DefaultValue);
        StateHasChanged();
    }

    private async Task OnSaveClick()
    {
        if (_editor != null)
        {
            var model = await _editor.GetModel();
            editorCode = await model.GetValue(EndOfLinePreference.CRLF, default);
            this.PlugDataZone?.SetVariableValue(DefinitionId, InitVariableNames.Script.ToString(), editorCode);
            _isDirty = false;
            StateHasChanged();
        }
    }



    async Task SavePlugAndCloseDialog(Plug plug)
    {
        Activity.SetProperty(JsonSerializer.SerializeToNode(TmpInputs, new JsonSerializerOptions { WriteIndented = true }), "InputDatas");
        MudDialog?.Close(Activity);
    }

    public async Task ExecuteActivity(Plug plug)
    {
        Console.WriteLine(">>>>>>>>>>>>start to execute activity:" + JsonSerializer.Serialize(Activity));
    }

    /// <summary>
    /// 在Monaco编辑器光标位置插入参数通配符 ${paramName}
    /// </summary>
    private async Task InsertParameterAtCursor(string paramName)
    {
        try
        {
            if (_editor == null) return;

            var selection = await _editor.GetSelection();
            var insertText = "${" + paramName + "}";

            var editOp = new IdentifiedSingleEditOperation
            {
                Range = selection,
                Text = insertText
            };

            // 计算插入后的光标位置（在插入文本之后）
            var newPosition = new BlazorMonaco.Position
            {
                LineNumber = selection.SelectionStartLineNumber,
                Column = selection.SelectionStartColumn + insertText.Length
            };
            var endSelection = new Selection
            {
                SelectionStartLineNumber = newPosition.LineNumber,
                SelectionStartColumn = newPosition.Column,
                PositionLineNumber = newPosition.LineNumber,
                PositionColumn = newPosition.Column
            };

            await _editor.ExecuteEdits("insert-parameter",
                new List<IdentifiedSingleEditOperation> { editOp },
                new List<Selection> { endSelection });
            await _editor.Focus();
            _isDirty = true;
        }
        catch (Exception ex)
        {
            CLog.Error($"插入参数失败: {ex.Message}");
        }
    }

}
