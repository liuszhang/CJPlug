                        @* <MudIconButton Icon="@Icons.Material.Outlined.Save" OnClick="@OnSaveClick" /> *@
                        <MudButton OnClick="@OnSaveClick" Variant="Variant.Outlined" Color="Color.Primary">保存</MudButton>
                    </MudBadge>
                    <MudMenu EndIcon="@Icons.Material.Filled.ArrowDropDown"
                             Label="插入参数" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                        <ChildContent>
                            @if (Plug?.PlugVariables?.Count > 0)
                            {
                                @foreach (var v in Plug.PlugVariables)
                                {
                                    if (v.Name == InitVariableNames.Script.ToString() || v.Name == InitVariableNames.ResultString.ToString())
                                        continue;
                                    <MudMenuItem OnClick="@(() => InsertParameterAtCursor(v.Name))">
                                        <MudText>@v.Name <MudText Typo="Typo.caption" Color="Color.Default">@("${" + v.Name + "}")</MudText></MudText>
                                    </MudMenuItem>
                                }
