    private async void TestPython()
    {
        Loading = true;
        try
        {
            var model = await _editor.GetModel();
            editorCode = await model.GetValue(EndOfLinePreference.CRLF, default);

            // 先替换参数通配符 ${参数名}，再用替换后的脚本执行测试
            var substitutedCode = PythonPlugCommonExecuteService.SubstituteParameters(editorCode, paramName =>
            {
                // 优先级1: PlugDataZone（用户在参数配置页填入的实际值）
                if (PlugDataZone != null && DefinitionId != null)
                {
                    var pdzVal = PlugDataZone.GetVariableValue(DefinitionId, paramName);
                    if (!string.IsNullOrEmpty(pdzVal))
                        return pdzVal;
                }
                // 优先级2: 根插头定义中的 Value
                var v = Plug?.PlugVariables?.FirstOrDefault(p =>
                    string.Equals(p.Name, paramName, StringComparison.OrdinalIgnoreCase));
                if (v != null && !string.IsNullOrEmpty(v.Value))
                    return v.Value;
                return null;
            });

            PlugExecutionRequest stationExecutionRequest = new PlugExecutionRequest();
            stationExecutionRequest.PlugTypeKey = PlugKeySetting.CommonExecuteKey;
            stationExecutionRequest.ExecuteMode = ExecuteMode.Standalone;
            stationExecutionRequest.ToolName = "Python";
            var base64Script = Convert.ToBase64String(Encoding.UTF8.GetBytes(substitutedCode));
            stationExecutionRequest.RequestCommand = "$d=[System.Text.Encoding]::UTF8.GetString([System.Convert]::FromBase64String('" 
                 + base64Script + "'));"
                 + "$f=$env:TEMP + '\\py_' + (Get-Random) + '.py';"
                 + "Set-Content -Path $f -Value $d -Encoding UTF8;"
                 + "python $f;"
                 + "Remove-Item $f -Force";

            var result = await MainApiClient.ExecuteOnStation(stationExecutionRequest);
            CLog.Information($"执行结果：{result.ResultString}");
            pythonExeResult += result.ResultString;
        }
        catch (Exception ex)
        {
            CLog.Information(ex.Message);
        }
        Loading = false;
        StateHasChanged();
    }


