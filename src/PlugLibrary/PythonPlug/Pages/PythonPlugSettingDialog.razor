    /// <summary>
    /// 在Monaco编辑器光标位置插入参数通配符 ${paramName}
    /// </summary>
    private async Task InsertParameterAtCursor(string paramName)
    {
        try
        {
            if (_editor == null) return;

            var selection = await _editor.GetSelection();
            var insertText = "${" + paramName + "}";

            var editOp = new IdentifiedSingleEditOperation
            {
                Range = selection,
                Text = insertText
            };

            // 计算插入后的光标位置（在插入文本之后）
            var newPosition = new BlazorMonaco.Position
            {
                LineNumber = selection.SelectionStartLineNumber,
                Column = selection.SelectionStartColumn + insertText.Length
            };
            var endSelection = new Selection
            {
                SelectionStartLineNumber = newPosition.LineNumber,
                SelectionStartColumn = newPosition.Column,
                PositionLineNumber = newPosition.LineNumber,
                PositionColumn = newPosition.Column
            };

            await _editor.ExecuteEdits("insert-parameter",
                new List<IdentifiedSingleEditOperation> { editOp },
                new List<Selection> { endSelection });
            await _editor.Focus();
            _isDirty = true;
        }
        catch (Exception ex)
        {
            CLog.Error($"插入参数失败: {ex.Message}");
        }
    }

