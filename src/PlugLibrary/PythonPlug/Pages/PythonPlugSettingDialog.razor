    protected override async Task OnInitializedAsync()
    {
        //Console.WriteLine(">>>>>>>>>>>>>>start init");
        await MudDialog.SetOptionsAsync(diaOption);
        if (Plug != null)
        {
            rootPlugVariables = new List<PlugVariable>(Plug.PlugVariables!);            
        }

        foreach (var t in ActivityDescriptor?.Inputs)
        {
            //Console.WriteLine(JsonSerializer.Serialize(t));
            //Console.WriteLine($"{t.TypeName}-{t.Name}-{t.Category}");
            var inputName = t.Name.Camelize();
            var value = Activity.GetProperty(inputName);
            var wrappedInput = t.IsWrapped ? ToWrappedInput(value) : default;
            var input = t.IsWrapped ? wrappedInput : (object?)value;
            //Console.WriteLine($"{t.TypeName}-{t.Name}-{wrappedInput.Expression.Value}");
            if (t.Name=="InputDatas")
            {
                if (string.IsNullOrEmpty(wrappedInput?.Expression?.Value?.ToString()))
                {
                    return;
                }
                // 配置 JsonSerializerOptions 以忽略大小写
                var options = new JsonSerializerOptions
                    {
                        PropertyNameCaseInsensitive = true
                    };
                var inputDatas = JsonSerializer.Deserialize<List<PlugVariable>?>(wrappedInput?.Expression?.Value?.ToString(),options);
                foreach (var i in inputDatas)
                {
                    Console.WriteLine(JsonSerializer.Serialize(i));
                    TmpInputs.Add(i);
                }
            }
        }


        //stlPath = null;
        //JsRuntime.InvokeVoidAsync("updateAndReloadIframe", stlPath2);

    }

    private static WrappedInput? ToWrappedInput(object? value)
    {
        var converterOptions = new ObjectConverterOptions(serializerOptions => { serializerOptions.PropertyNamingPolicy = JsonNamingPolicy.CamelCase; });

        return value.ConvertTo<WrappedInput>(converterOptions);
    }

    async Task OnCheckIsInputChanged(CellContext<PlugVariable> cellContext, bool isInput)
    {
        //Console.WriteLine(cellContext.Item.Name);
        if (isInput)
        {
            //Console.WriteLine("设为输入");
            cellContext.Item.IsInput = true;
            //var tmpName = char.ToUpper(cellContext.Item.Name[0]) + cellContext.Item.Name.Substring(1);
            var tmpName = cellContext.Item.Name;
            foreach (var input in Plug.PlugVariables)
            {
                if (input.Name == tmpName)
                {
                    //Console.WriteLine("已有该输入");
                    return;
                }
            }
            Plug.PlugVariables.Add(new PlugVariable() { Name = tmpName, Type = "string", DefaultValue = cellContext.Item.DefaultValue });

        }
        else
        {
            //MyCon1sole.WriteLine("取消输入");
            cellContext.Item.IsInput = false;
            //var tmpName = char.ToUpper(cellContext.Item.Name[0]) + cellContext.Item.Name.Substring(1);
            var tmpName = cellContext.Item.Name;
            foreach (var input in Plug.PlugVariables)
            {
                if (input.Name == tmpName)
                {
                    Plug.PlugVariables.Remove(input);
                    return;
                }
            }

        }
    }
    async Task OnCheckIsOutputChanged(CellContext<PlugVariable> cellContext, bool isOutput)
    {
        //Console.WriteLine(cellContext.Item.Name);
        if (isOutput)
        {
            //Console.WriteLine("设为输入");
            cellContext.Item.IsOutput = true;
            foreach (var output in Plug.PlugVariables)
            {
                if (output.Name == cellContext.Item.Name)
                {
                    //Console.WriteLine("已有该输出");
                    return;
                }
            }
            Plug.PlugVariables.Add(new PlugVariable() { Name = cellContext.Item.Name, Type = "string" });

        }
        else
        {
            //MyCon1sole.WriteLine("取消输入");
            cellContext.Item.IsOutput = false;
            foreach (var output in Plug.PlugVariables)
            {
                if (output.Name == cellContext.Item.Name)
                {
                    Plug.PlugVariables.Remove(output);
                    return;
                }
            }

        }
    }

