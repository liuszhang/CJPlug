@using System.Text
@using System.Text.Json
@using System.Text.Json.Nodes
@using System.Text.RegularExpressions
@using BlazorMonaco.Editor
@using CJ.Plug.ApiClient.Contracts
@using CJ.Plug_Aspire.Models.Plug
@using CJ.Plug_Aspire.Models.PlugAction
@using CJ.Plug_Aspire.Models.Relation
@using CJ.Plug_Aspire.Models.Shared
@using CJ.Plug_Aspire.Models.Shared.LogModels
@using CJ.Plug_Aspire.Models.Station
@using CJ.Plug_Aspire.SharedPages
@using Elsa.Api.Client.Extensions
@using Elsa.Api.Client.Resources.ActivityDescriptors.Models
@using Elsa.Api.Client.Resources.WorkflowDefinitions.Requests
@using Elsa.Api.Client.Shared.Models
@using Humanizer
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.Extensions.DependencyInjection
@using MudBlazor
@using Radzen.Blazor
@using Size=MudBlazor.Size

@inject ISnackbar Snackbar
@inject MainApiClient MainApiClient
@inject IEnumerable<IPlugCommonSettingContent> PlugCommonSettingContent
@inject IEnumerable<IPlugActionSettingContent> PlugActionSettingContent
@inject IDialogService DialogService
@inject HubConnectionManagerService HubConnectionManagerService



<MudDialog Class="stack-resize">
    <TitleContent>
        <MudStack Row>
            <MudText>@Activity.GetDisplayText()</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Row>
            <RadzenSplitter Orientation="Radzen.Orientation.Horizontal">
                <RadzenSplitterPane Size="@LogPercent">
                    <MudStack>
                        <MudText>执行日志</MudText>
                        <MudStack Row Style="width:268px;" AlignItems="AlignItems.Center" Justify="Justify.Center">
                            <MudButton OnClick="@(()=>{LogContent="";})" Variant="Variant.Outlined" Color="Color.Primary">清空</MudButton>
                            <MudButton OnClick="@(()=>{StateHasChanged();})" Variant="Variant.Outlined" Color="Color.Primary">刷新</MudButton>
                            <MudButton OnClick="@(()=>{LogPercent="0%";})" Variant="Variant.Outlined" Color="Color.Primary">隐藏</MudButton>
                        </MudStack>
                        <MudTextField T="string" Label="结果预览" ReadOnly Variant="Variant.Outlined" Text="@LogContent" Lines="12" AutoGrow MaxLines="25" />
                    </MudStack>
                </RadzenSplitterPane>
                <RadzenSplitterPane Size="@MainPercent" Min="200px">
                    <MudTabs Elevation="2" ApplyEffectsToContainer="true" PanelClass="pa-6" Style="width:100%">
                        <MudTabPanel Text="基础属性">
                            @if (Loading)
                            {
                                <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate></MudProgressCircular>
                            }
                            <MudTextField T="string" FullWidth Margin="Margin.Dense" Label="编号" @bind-Text="@Plug.DefinitionId" ReadOnly Variant="Variant.Filled"></MudTextField>
                            <MudTextField T="string" FullWidth Margin="Margin.Dense" Label="类型" @bind-Text="@Plug.Type" ReadOnly Variant="Variant.Filled"></MudTextField>
                            <MudTextField T="string" FullWidth Margin="Margin.Dense" Label="核心类型" @bind-Text="@Plug.CoreType" ReadOnly Variant="Variant.Filled"></MudTextField>
                            <MudTextField T="string" FullWidth Margin="Margin.Dense" Label="KEY" @bind-Text="@Plug.PlugTypeKey" ReadOnly Variant="Variant.Filled"></MudTextField>
                            <MudTextField T="string" FullWidth Margin="Margin.Dense" Label="名称" @bind-Text="@Plug.Name" Variant="Variant.Outlined"></MudTextField>
                            <MudTextField T="string" FullWidth Margin="Margin.Dense" Label="描述" @bind-Text="@Plug.Description" Variant="Variant.Outlined" Lines="3"></MudTextField>
                        </MudTabPanel>
                        <MudTabPanel Text="参数配置">
                            <ParametersData Plug="Plug"></ParametersData>
                        </MudTabPanel>
                        <MudTabPanel Text="插头配置">
                            @PlugCommonExecuteSettingContent
                        </MudTabPanel>
                        <MudTabPanel Text="动作配置">
                            <MudStack Row AlignItems="AlignItems.Center" StretchItems="StretchItems.None">
                                @if (ToolVersions.Count > 0)
                                {
                                    <MudSelect Margin="Margin.Dense" Dense T="string" Clearable Label="工具版本" PopoverClass="mw-300" Variant="Variant.Outlined" OuterClass="mud-select-has-incidents select-tool-version">
                                        @foreach (var v in ToolVersions)
                                        {
                                            <MudSelectItem T="string" Value="v">@v</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                @if (RootPlugActions.Count > 0)
                                {
                                    <MudSelect Margin="Margin.Dense" Clearable Dense T="PlugAction" @bind-Value="TmpSelectedToolAction" Label="选择支持的工具动作" Class="me-3" PopoverClass="mw-300" Variant="Variant.Outlined" OuterClass="mud-select-has-incidents">
                                        @foreach (var a in RootPlugActions)
                                        {
                                            <MudSelectItem Value="@a">@a.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                    <MudButton OnClick="AddActionToPlug" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AirlineSeatFlat">添加动作</MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AirlineSeatFlat">清空动作</MudButton>

                                }




                            </MudStack>
                            <MudExpansionPanels MultiExpansion="true">
                                @foreach (var a in PlugActionsToExecute)
                                {
                                    foreach (var pasc in PlugActionSettingContent)
                                    {
                                        var TMPContent = pasc.GetPlugActionSettingContent(a).Result;
                                        if (TMPContent != null)
                                        {
                                            PlugActionExecuteSettingContent = TMPContent;
                                            break;
                                        }
                                    }


                                    <MudExpansionPanel>
                                        <TitleContent>
                                            <MudStack Row AlignItems="AlignItems.Center">
                                                <MudIcon Icon="@Icons.Material.Filled.ResetTv" class="mr-3"></MudIcon>
                                                <MudText>@a.Name</MudText>
                                                <MudSpacer></MudSpacer>
                                                <MudIconButton OnClick="()=>RemoveActionFromPlug(a)" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" aria-label="delete"></MudIconButton>
                                            </MudStack>
                                        </TitleContent>
                                        <ChildContent>
                                            @if (PlugActionExecuteSettingContent == null)
                                            {
                                                <MudText>工作命令行：@(a.PlugSettingsJson)</MudText>
                                            }
                                            else
                                            {
                                                @PlugActionExecuteSettingContent
                                            }
                                        </ChildContent>
                                    </MudExpansionPanel>
                                }
                            </MudExpansionPanels>
                        </MudTabPanel>
                    </MudTabs>
                </RadzenSplitterPane>
            </RadzenSplitter>
            @if(LogShow)
            {

            }            


        </MudStack>


    </DialogContent>
    <DialogActions>
        <MudButton Disabled="Processing" OnClick="@(()=>MudDialog.Close(DialogResult.Cancel()))">取消</MudButton>
        <MudButton Disabled="Processing" Color="Color.Primary" OnClick="@(()=>ExecuteActivity(Plug))">执行</MudButton>
        <MudButton Disabled="Processing" Color="Color.Primary" OnClick="@(()=>SavePlug(Plug))">应用</MudButton>
        <MudButton Disabled="Processing" Color="Color.Primary" OnClick="@(()=>SavePlugAndCloseDialog(Plug))">
            @if (Processing)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>        
            }
            else
            {
                <MudText>确定</MudText>
            }
        </MudButton>
    </DialogActions>

</MudDialog>

