    private string MainPercent = "100%";


    DialogOptions diaOption = new DialogOptions()
        {
            MaxWidth = MaxWidth.Large,
            Position = DialogPosition.TopCenter,
            BackdropClick = false,
            FullWidth=true            
        };


    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        MudDialog.SetOptionsAsync(diaOption);
        //Console.WriteLine($"activity definition id is:{Activity.GetId()}");
        //Console.WriteLine(JsonSerializer.Serialize(Plug));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Plug = await MainApiClient.GetPlugByDefinitionIdAsync(Activity.GetId());
            var rootPlug = await MainApiClient.GetPlugByTypeNameAsync(Plug.Type);
            ToolVersions = rootPlug?.ToolVersions ?? new();
            RootPlugActions = await MainApiClient.GetPlugActionsByPlugIdAsync(rootPlug?.Id) ?? new();
            PlugActionsToExecute = await MainApiClient.GetPlugActionsToExecuteByPlugId(Plug.Id) ?? new();
            foreach (var pcsc in PlugCommonSettingContent)
            {
                var tmpContent = await pcsc.GetPlugCommonSettingContent(Plug);
                if (tmpContent != null)
                {
                    PlugCommonExecuteSettingContent = tmpContent;                    
                    break;
                }
            }
            HubConnectionManagerService._hubConnection.On<string>("ReceiveLog", (message) =>
           {
               var logModel = JsonSerializer.Deserialize<LogModel>(message);
               //Console.WriteLine($"[客户端2收到消息]NewLogs2：{logModel.Description}");
               // 将新日志添加到本地列表并触发UI更新
               InvokeAsync(() =>
               {
                   LogContent += logModel.Description;
                   LogContent += "\n";
                   StateHasChanged();
               });
           });
            
        }
        Loading = false;    
        StateHasChanged();
    }

    async Task SavePlugAndCloseDialog(Plug plug)
    {
        Processing = true;
        //Activity.SetName(plug.Name);
        foreach (var v in plug.PlugVariables)
        {
            Activity.SetProperty(JsonSerializer.SerializeToNode(v.Value, new JsonSerializerOptions { WriteIndented = true }), v.Name);
        }
        Activity.SetDisplayText(plug.Name);
        await SavePlug(plug);
        Console.WriteLine($"the new activity is:{Activity}");
        MudDialog.Close(Activity);
    }

    async Task SavePlug(Plug plug)
    {
        Processing = true;
        //Console.WriteLine($"prepare to update plug:{JsonSerializer.Serialize(plug.PlugVariables)}");
        //更新插头基本信息
        await MainApiClient.UpdatePlugAsync(plug.Id, plug);
        //更新插头执行动作关系表
        //await MainApiClient.SetExecutePlugActionsToPlug(plug, PlugActionsToExecute);
        Processing = false;
    }

