    private async Task NewVariable()
    {        
        var tmpVariables = new PlugVariable() { Name = "p1", Type = "string", IsInput = true, IsOutput = true };
        Plug.PlugVariables.Add(tmpVariables);        
        //await MainApiClient.UpdateToolItemAsync(SelectedToolItem.Id, SelectedToolItem);
