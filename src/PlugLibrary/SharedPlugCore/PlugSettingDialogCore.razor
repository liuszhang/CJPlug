        LogPercent = "30%";
        MainPercent = "70%";
        //Console.WriteLine(">>>>>>>>>>>>start to execute activity:"+JsonSerializer.Serialize(Activity));
        




        await MainApiClient.ExecutePlugByDefifnitionId(plug.DefinitionId);
        StateHasChanged();
    }


