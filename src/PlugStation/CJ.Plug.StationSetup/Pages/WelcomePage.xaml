<Page x:Class="CJ.Plug.StationSetup.Pages.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FontFamily="Microsoft YaHei UI" FontSize="14"
      Background="White">
    <Grid Margin="40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="欢迎使用图站安装向导"
                   FontSize="24" FontWeight="Bold" Foreground="#1565C0"/>

        <Rectangle Grid.Row="1" Height="1" Fill="#E0E0E0" Margin="0,12,0,0"/>

        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="本向导将帮助您安装图站所需的以下组件：" Margin="0,0,0,16"/>
            <StackPanel Margin="20,0,0,0">
                <TextBlock Margin="0,0,0,8">
                    <Run FontWeight="Bold">StationAgent</Run>
                    <Run Foreground="Gray"> — 工具执行代理，负责启动和监控工具进程</Run>
                </TextBlock>
                <TextBlock Margin="0,0,0,8">
                    <Run FontWeight="Bold">StationApiServer</Run>
                    <Run Foreground="Gray"> — 图站 API 服务，提供文件管理、任务调度等功能</Run>
                </TextBlock>
                <TextBlock Margin="0,0,0,8">
                    <Run FontWeight="Bold">StationSettingUI</Run>
                    <Run Foreground="Gray"> — 图站配置工具，用于设置服务器地址、工具路径等</Run>
                </TextBlock>
            </StackPanel>
            <TextBlock Margin="0,20,0,0" Foreground="Gray" TextWrapping="Wrap">
                安装完成后，您可以通过 StationSettingUI 配置图站参数，StationApiServer 将作为后台服务运行。
            </TextBlock>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="点击「下一步」继续" Foreground="Gray" VerticalAlignment="Bottom"/>
    </Grid>
</Page>
