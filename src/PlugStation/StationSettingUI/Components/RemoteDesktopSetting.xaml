<UserControl x:Class="StationSettingUI.Components.RemoteDesktopSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Loaded="UserControl_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="远程桌面服务管理" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- 服务状态卡片 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- VNC 服务卡片 -->
            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Ellipse Width="12" Height="12" Fill="{Binding VncStatusColor}" Margin="0,0,10,0"/>
                        <TextBlock Text="VNC 远程桌面" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="状态:" Foreground="Gray" Margin="0,0,0,5"/>
                    <TextBlock Grid.Row="2" Text="{Binding VncStatusText}" FontSize="14" Margin="0,0,0,15"/>

                    <TextBlock Grid.Row="3" Text="端口: 5900" Foreground="Gray" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="4" Text="{Binding VncDescription}" TextWrapping="Wrap" Foreground="#666" VerticalAlignment="Center"/>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{Binding VncButtonText}" Width="120" Height="36" Margin="5"
                                Click="InstallVnc_Click" Style="{StaticResource PrimaryButton}"/>
                        <Button Content="启动 VNC" Width="100" Height="36" Margin="5"
                                Click="StartVnc_Click" IsEnabled="{Binding VncCanStart}"/>
                        <Button Content="停止 VNC" Width="100" Height="36" Margin="5"
                                Click="StopVnc_Click" IsEnabled="{Binding VncCanStop}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- SSH 服务卡片 -->
            <Border Grid.Column="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Ellipse Width="12" Height="12" Fill="{Binding SshStatusColor}" Margin="0,0,10,0"/>
                        <TextBlock Text="SSH 终端" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="状态:" Foreground="Gray" Margin="0,0,0,5"/>
                    <TextBlock Grid.Row="2" Text="{Binding SshStatusText}" FontSize="14" Margin="0,0,0,15"/>

                    <TextBlock Grid.Row="3" Text="端口: 22" Foreground="Gray" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="4" Text="{Binding SshDescription}" TextWrapping="Wrap" Foreground="#666" VerticalAlignment="Center"/>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="安装 SSH 服务" Width="120" Height="36" Margin="5"
                                Click="InstallSsh_Click" Style="{StaticResource PrimaryButton}"/>
                        <Button Content="启动 SSH" Width="100" Height="36" Margin="5"
                                Click="StartSsh_Click" IsEnabled="{Binding SshCanStart}"/>
                        <Button Content="停止 SSH" Width="100" Height="36" Margin="5"
                                Click="StopSsh_Click" IsEnabled="{Binding SshCanStop}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部操作栏 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="刷新状态" Width="100" Height="32" Margin="5"
                    Click="RefreshStatus_Click"/>
            <Button Content="测试连接" Width="100" Height="32" Margin="5"
                    Click="TestConnection_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
