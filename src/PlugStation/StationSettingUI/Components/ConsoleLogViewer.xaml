<UserControl x:Class="StationSettingUI.Components.ConsoleLogViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="StationApiServer 控制台日志" FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,15,0"/>
            <TextBlock x:Name="TxtLogCount" Text="共 0 条" FontSize="12"
                       Foreground="Gray" VerticalAlignment="Center"/>
            <Button x:Name="BtnClear" Content="清空" Width="60" Margin="15,0,0,0"
                    Click="BtnClear_Click"/>
            <CheckBox x:Name="ChkAutoScroll" Content="自动滚动" IsChecked="True"
                      VerticalAlignment="Center" Margin="10,0,0,0"/>
            <TextBlock Text="来源:" FontSize="12" Foreground="Gray"
                       VerticalAlignment="Center" Margin="15,0,4,0"/>
            <ComboBox x:Name="CmbLogSource" Width="80"
                      VerticalAlignment="Center"
                      SelectedIndex="1"
                      SelectionChanged="CmbLogSource_SelectionChanged">
                <ComboBoxItem Content="全部"/>
                <ComboBoxItem Content="Station"/>
                <ComboBoxItem Content="Api"/>
            </ComboBox>
        </StackPanel>

        <!-- 日志列表 -->
        <ListBox x:Name="LogListBox" Grid.Row="1"
                 Background="#1E1E1E" Foreground="#DCDCDC"
                 FontFamily="Consolas" FontSize="12"
                 BorderThickness="0"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Visible"
                 SelectionMode="Single"
                 IsSynchronizedWithCurrentItem="False">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="IsSelected" Value="False"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0">
                        <TextBox Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}"
                                 Foreground="#6A9955" Width="100" FontFamily="Consolas"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Padding="0" Margin="0"
                                 IsHitTestVisible="True" Cursor="IBeam"
                                 SelectionBrush="#FF3399FF"/>
                        <TextBox Text="{Binding Text}"
                                 Foreground="{Binding DisplayColor}"
                                 FontFamily="Consolas" TextWrapping="NoWrap"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Padding="0" Margin="0"
                                 IsHitTestVisible="True" Cursor="IBeam"
                                 SelectionBrush="#FF3399FF"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 底部状态栏 -->
        <StatusBar Grid.Row="2" Background="#2D2D2D" Height="24" Margin="0,4,0,0">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="等待服务启动..." 
                           FontSize="11" Foreground="#888"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
