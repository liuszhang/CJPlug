<UserControl x:Class="StationSettingUI.Components.ServiceSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StationSettingUI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: 平台服务地址 -->
            <RowDefinition Height="Auto"/>
            <!-- 1: 图站程序路径 -->
            <RowDefinition Height="Auto"/>
            <!-- 2: 运行状态 -->
            <RowDefinition Height="Auto"/>
            <!-- 3: 服务控制 -->
            <RowDefinition Height="Auto"/>
            <!-- 4: 本地端口 -->
            <RowDefinition Height="Auto"/>
            <!-- 5: 版本 -->
            <RowDefinition Height="Auto"/>
            <!-- 6: 工具路径 -->
            <RowDefinition Height="Auto"/>
            <!-- 7: 自动启动 -->
            <RowDefinition Height="Auto"/>
            <!-- 8: 保存按钮 -->
            <RowDefinition Height="*"/>
            <!-- 9: 底部状态栏 -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: 平台服务地址 -->
        <Label Grid.Row="0" Grid.Column="0" Content="平台服务地址：" 
               VerticalAlignment="Center" Margin="0,10,10,10"/>
        <DockPanel Grid.Row="0" Grid.Column="1" Margin="0,10,0,10">
            <Button x:Name="BtnTestConnection" Content="测试连接" 
                    DockPanel.Dock="Right" Width="80" Margin="5,0,0,0"
                    Click="BtnTestConnection_Click"/>

            <TextBox x:Name="TxtMainServerUrl" Text="http://127.0.0.1:8080" 
                     VerticalAlignment="Center" MinWidth="200"
                     TextChanged="ConfigField_TextChanged"/>
        </DockPanel>

        <!-- Row 1: 图站程序所在文件夹 -->
        <Label Grid.Row="1" Grid.Column="0" Content="图站程序路径：" 
               VerticalAlignment="Center" Margin="0,5,10,5"/>
        <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,5,0,5">
            <Button x:Name="BtnBrowseStation" Content="浏览..." Width="60" 
                    DockPanel.Dock="Right" Margin="5,0,0,0"
                    Click="BtnBrowseStation_Click"/>
            <TextBox x:Name="TxtStationFolder" Text="" 
                     VerticalAlignment="Center"
                     ToolTip="StationApiServer 可执行程序所在文件夹，留空则自动查找"
                     TextChanged="ConfigField_TextChanged"/>
        </DockPanel>

        <!-- Row 2: 图站服务状态 + 平台连接 -->
        <Label Grid.Row="2" Grid.Column="0" Content="运行状态：" 
               VerticalAlignment="Center" Margin="0,5,10,5"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,5,0,5">
            <!-- 本地服务 -->
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="10" Height="10" Margin="0,0,8,0" 
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtServiceStatus" Text="检测中..." 
                           VerticalAlignment="Center" FontWeight="Bold" FontSize="13" Margin="0,0,20,0"/>
                <TextBlock x:Name="TxtStationApiUrl" Text="" 
                           VerticalAlignment="Center" Foreground="Gray" FontSize="11"/>
            </StackPanel>
            <!-- 平台 WebSocket 连接 -->
            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                <Ellipse x:Name="HubStatusDot" Width="10" Height="10" Margin="0,0,8,0" 
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtHubStatus" Text="" 
                           VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- Row 3: 服务控制按钮 -->
        <Label Grid.Row="3" Grid.Column="0" Content="服务控制：" 
               VerticalAlignment="Center" Margin="0,5,10,5"/>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,5,0,5">
            <Button x:Name="BtnStartService" Content="启动服务" Width="80" Margin="0,0,5,0"
                    Click="BtnStartService_Click"/>
            <Button x:Name="BtnStopService" Content="停止服务" Width="80" Margin="0,0,5,0"
                    Click="BtnStopService_Click"/>
            <Button x:Name="BtnRestartService" Content="重启服务" Width="80" Margin="0,0,5,0"
                    Click="BtnRestartService_Click"/>
            <Button x:Name="BtnServiceTest" Content="服务测试" Width="80"
                    Click="BtnServiceTest_Click"/>
        </StackPanel>

        <!-- Row 4: 本地服务端口 -->
        <Label Grid.Row="4" Grid.Column="0" Content="本地服务端口：" 
               VerticalAlignment="Center" Margin="0,5,10,5"/>
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,5,0,5">
            <TextBox x:Name="TxtStationPort" Text="7660" Width="80"
                     VerticalAlignment="Center" Margin="0,0,10,0"
                     TextChanged="ConfigField_TextChanged"/>
            <TextBlock Text="（修改后需重启服务生效）" 
                       VerticalAlignment="Center" Foreground="Gray" FontSize="11"/>
        </StackPanel>

        <!-- Row 5: 工具版本和更新 -->
        <Label Grid.Row="5" Grid.Column="0" Content="工具版本：" 
               VerticalAlignment="Center" Margin="0,5,10,5"/>
        <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,5,0,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtVersion" Text="0.2.0" 
                           VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,15,0"/>
                <Button x:Name="BtnCheckUpdate" Content="检查更新" Width="80"
                        Click="BtnCheckUpdate_Click"/>
                <Button x:Name="BtnDownloadUpdate" Content="下载包" Width="80"
                        Visibility="Visible" Margin="5,0,0,0"
                        Click="BtnDownloadUpdate_Click"/>
                <TextBlock x:Name="TxtUpdateStatus" Text="" 
                           VerticalAlignment="Center" Margin="10,0,0,0" Foreground="RoyalBlue"/>
            </StackPanel>
            <!-- 下载进度条 -->
            <StackPanel x:Name="PanelDownloadProgress" Visibility="Collapsed" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock x:Name="TxtProgressLabel" Text="正在生成部署包..." 
                               VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11"/>
                    <TextBlock x:Name="TxtProgressPercent" Text="0%" 
                               VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                </StackPanel>
                <ProgressBar x:Name="ProgressDownload" Height="16" 
                             Minimum="0" Maximum="100" Value="0"/>
            </StackPanel>
        </StackPanel>

        <!-- Row 6: 工具安装路径 -->
        <Label Grid.Row="6" Grid.Column="0" Content="工具安装路径：" 
               VerticalAlignment="Center" Margin="0,5,10,5"/>
        <DockPanel Grid.Row="6" Grid.Column="1" Margin="0,5,0,5">
            <Button x:Name="BtnBrowsePath" Content="浏览..." Width="60" 
                    DockPanel.Dock="Right" Margin="5,0,0,0"
                    Click="BtnBrowsePath_Click"/>
            <TextBox x:Name="TxtToolsRootPath" Text="C:\Program Files\CJTools" 
                     VerticalAlignment="Center"
                     TextChanged="ConfigField_TextChanged"/>
        </DockPanel>

        <!-- Row 7: 自动启动 -->
        <Label Grid.Row="7" Grid.Column="0" Content="开机自启：" 
               VerticalAlignment="Center" Margin="0,5,10,5"/>
        <CheckBox x:Name="ChkAutoStart" Grid.Row="7" Grid.Column="1" 
                  Content="图站服务随系统自动启动" VerticalAlignment="Center" 
                  Margin="0,5,0,5" Checked="ChkAutoStart_Changed" 
                  Unchecked="ChkAutoStart_Changed"/>

        <!-- Row 8: 配置操作按钮 -->
        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="保存配置" Width="80"
                    Click="BtnSave_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnImport" Content="导入配置" Width="80"
                    Click="BtnImport_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnExport" Content="导出配置" Width="80"
                    Click="BtnExport_Click"/>
        </StackPanel>

        <!-- Row 9: 底部状态栏 -->
        <Border Grid.Row="9" Grid.ColumnSpan="2" Background="#F5F5F5" 
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" 
                VerticalAlignment="Bottom" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtStatusMessage" Text="就绪" 
                           Foreground="Gray" FontSize="12" VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
