<UserControl x:Class="StationSettingUI.Components.ToolRegistration"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StationSettingUI.Components"
             xmlns:models="clr-namespace:StationSettingUI.Models"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="8" 
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnRefresh" Content="刷新列表" Width="80" Margin="0,0,5,0"
                        Click="BtnRefresh_Click"/>
                <Button x:Name="BtnAutoSearch" Content="自动搜索" Width="80" Margin="0,0,5,0"
                        Click="BtnAutoSearch_Click"/>
                <Button x:Name="BtnFetchFromServer" Content="配置下载" Width="80" Margin="0,0,5,0"
                        Click="BtnFetchFromServer_Click"/>
                <Separator Width="1" Margin="10,0,10,0"/>
                <Button x:Name="BtnAddTool" Content="添加工具" Width="80" Margin="0,0,5,0"
                        Click="BtnAddTool_Click"/>
                <Button x:Name="BtnEditTool" Content="编辑工具" Width="80" Margin="0,0,5,0"
                        Click="BtnEditTool_Click"/>
                <Button x:Name="BtnDeleteTool" Content="删除工具" Width="80" Margin="0,0,5,0"
                        Click="BtnDeleteTool_Click"/>
                <Separator Width="1" Margin="10,0,10,0"/>
                <Button x:Name="BtnApply" Content="应用" Width="60"
                        Click="BtnApply_Click" FontWeight="Bold"/>
                <TextBlock x:Name="TxtToolbarStatus" Text="" 
                           VerticalAlignment="Center" Margin="15,0,0,0" Foreground="Gray" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- 工具列表 DataGrid -->
        <DataGrid x:Name="GridTools" Grid.Row="1" 
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  CanUserDeleteRows="False" IsReadOnly="False"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  AlternatingRowBackground="#F9F9F9"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  SelectedCellsChanged="GridTools_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="编号" Binding="{Binding Id}" Width="50"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="工具名称" Binding="{Binding ToolName}" 
                                    Width="120"/>
                <DataGridTextColumn Header="工具类型" Binding="{Binding ToolType}" 
                                    Width="100"/>
                <DataGridTextColumn Header="版本" Binding="{Binding ToolVersion}" 
                                    Width="80"/>
                <DataGridTextColumn Header="安装路径" Binding="{Binding ToolPath}" 
                                    Width="140"/>
                <DataGridTextColumn Header="启动命令" Binding="{Binding CommandParameter}" 
                                    Width="*" MinWidth="150"/>
                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" 
                                        Width="55"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="8"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtToolCount" Text="共 0 个工具" 
                           VerticalAlignment="Center" Foreground="Gray" FontSize="12"/>
                <TextBlock x:Name="TxtSelectedTool" Text="" 
                           VerticalAlignment="Center" Margin="20,0,0,0" 
                           Foreground="DimGray" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
