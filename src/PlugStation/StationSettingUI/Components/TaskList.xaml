<UserControl x:Class="StationSettingUI.Components.TaskList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="8" 
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button x:Name="BtnRefresh" Content="刷新" Width="70" Margin="0,0,10,0"
                            Click="BtnRefresh_Click"/>
                    <Button x:Name="BtnClearDone" Content="清除已完成" Width="90"
                            Click="BtnClearDone_Click"/>
                    <TextBlock x:Name="TxtStatus" Text="" 
                               VerticalAlignment="Center" Margin="15,0,0,0" 
                               Foreground="Gray" FontSize="12"/>
                </StackPanel>

                <!-- 筛选条件栏 -->
                <Border Background="White" Padding="6" CornerRadius="3"
                        BorderBrush="#D0D0D0" BorderThickness="1">
                    <WrapPanel>
                        <TextBlock Text="状态:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
                        <ComboBox x:Name="CmbStatusFilter" Width="90" Height="24" FontSize="12"
                                  SelectionChanged="Filter_Changed">
                            <ComboBoxItem Content="全部" Tag="all" IsSelected="True"/>
                            <ComboBoxItem Content="待执行" Tag="pending"/>
                            <ComboBoxItem Content="执行中" Tag="running"/>
                            <ComboBoxItem Content="已完成" Tag="completed"/>
                            <ComboBoxItem Content="失败" Tag="failed"/>
                        </ComboBox>

                        <TextBlock Text="工具:" VerticalAlignment="Center" Margin="12,0,4,0" FontSize="12"/>
                        <TextBox x:Name="TxtToolFilter" Width="100" Height="24" FontSize="12"
                                 TextChanged="Filter_Changed"/>

                        <TextBlock Text="类型:" VerticalAlignment="Center" Margin="12,0,4,0" FontSize="12"/>
                        <TextBox x:Name="TxtTypeFilter" Width="80" Height="24" FontSize="12"
                                 TextChanged="Filter_Changed"/>

                        <TextBlock Text="关键词:" VerticalAlignment="Center" Margin="12,0,4,0" FontSize="12"/>
                        <TextBox x:Name="TxtKeywordFilter" Width="140" Height="24" FontSize="12"
                                 TextChanged="Filter_Changed"/>

                        <Button x:Name="BtnClearFilter" Content="清除筛选" Width="70" Height="24"
                                FontSize="11" Margin="12,0,0,0" Click="BtnClearFilter_Click"/>
                    </WrapPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- 任务列表 -->
        <DataGrid x:Name="GridTasks" Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True" SelectionMode="Single"
                  AlternatingRowBackground="#F9F9F9"
                  RowHeaderWidth="0" GridLinesVisibility="Horizontal"
                  VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="停止" Width="44" Height="22"
                                    FontSize="11" Padding="0"
                                    Click="BtnStop_Click" Tag="{Binding Id}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="running">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="45"/>
                <DataGridTextColumn Header="工具" Binding="{Binding ToolName}" Width="100"/>
                <DataGridTextColumn Header="类型" Binding="{Binding PlugTypeKey}" Width="80"/>
                <DataGridTextColumn Header="状态" Binding="{Binding StatusDisplay}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="running">
                                    <Setter Property="Foreground" Value="RoyalBlue"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="completed">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="failed">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="子状态" Binding="{Binding SubStatus}" Width="80"/>
                <DataGridTextColumn Header="命令" Binding="{Binding Command}" Width="*" MinWidth="150"/>
                <DataGridTextColumn Header="关联ID" Binding="{Binding CorrelationId}" Width="120"/>
                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="55"/>
                <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt}" Width="145"/>
                <DataGridTextColumn Header="耗时" Binding="{Binding Duration}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部统计 -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="8"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtSummary" Text="共 0 个任务" 
                           VerticalAlignment="Center" Foreground="Gray" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
