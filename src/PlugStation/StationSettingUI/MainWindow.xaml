<Window x:Class="StationSettingUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StationSettingUI" 
        xmlns:components="clr-namespace:StationSettingUI.Components"
        mc:Ignorable="d"
        Title="图站管理工具 v0.2.0" 
        Height="580" Width="900"
        MinHeight="450" MinWidth="650"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
    </Window.Resources>
    <Grid>
        <TabControl x:Name="MainTabControl" Background="White">
            <TabItem Header="服务配置">
                <Grid Background="White">
                    <components:ServiceSetting x:Name="ServiceSettingCtrl"/>
                </Grid>
            </TabItem>
            <TabItem Header="工具注册">
                <Grid Background="White">
                    <components:ToolRegistration x:Name="ToolRegistrationCtrl"/>
                </Grid>
            </TabItem>
            <TabItem Header="任务列表">
                <Grid Background="White">
                    <components:TaskList x:Name="TaskListCtrl"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar VerticalAlignment="Bottom" Background="#F0F0F0" Height="28">
            <StatusBarItem>
                <TextBlock x:Name="GlobalStatusText" Text="就绪" FontSize="12" Foreground="Gray"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="ClockText" Text="" FontSize="11" Foreground="DimGray"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
