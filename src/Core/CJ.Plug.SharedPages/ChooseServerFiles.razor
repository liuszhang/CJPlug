@using System.Text.Json
@using System.Text.Json.Serialization
@using Blazored.LocalStorage
@using CJ.Plug.ApiClient.Contracts
@using CJ.Plug.Models.LogModels
@using CJ.Plug.Models.Shared
@using CJ.Plug.SharedPages.Contracts
@using MudBlazor

@inject MainApiClient MainApiClient
@inject IDomInteropService DomInteropService

<MudDialog Class="stack-resize">
    <DialogContent>     
        <MudContainer Style="max-height: 350px; overflow-y: scroll">
            <MudPaper Class="pa-4">
                <MudTreeView @bind-SelectedValue="SelectedNode" Hover="true" Color="Color.Success">
                    @foreach (var rootItem in TreeItems)
                    {
                        <ServerFileTreeItem Node="rootItem" ToolAgentHostToUse="ToolAgentHostToUse" />
                    }
                </MudTreeView>
            </MudPaper>
        </MudContainer>
        <MudDivider></MudDivider>
        <MudText>已选择：@(SelectedNode == null ? "无" : SelectedNode.FullPath)</MudText>
        <MudDivider></MudDivider>
        @if (IsChooseBusinessTool)
        {
            <MudTextField @bind-Value="ToolName" Label="工具名称" HelperText="可直接输入工具名称(如CMD),将优先使用您的输入" Variant="Variant.Outlined" />
        }        
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">取消</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">确认</MudButton>
    </DialogActions>
</MudDialog>

@code {

    private FileSystemNode[] FileTreeNodes { get; set; } = new FileSystemNode[0];
    private List<TreeItemData<FileSystemNode>>? TreeItems { get; set; } = new ();

    private FileSystemNode? SelectedNode { get; set; }
    private string ToolName;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public bool IsChooseBusinessTool { get; set; } = true;
    [Parameter] public string ToolAgentHostToUse { get; set; }

    //void Submit() => MudDialog.Close(DialogResult.Ok(SelectedNode.FullPath));
    void Cancel() => MudDialog.Cancel();

    protected override async Task OnInitializedAsync()
    {
        CLog.Information("ChooseServerFiles OnInitializedAsync");
        var currentUser = await DomInteropService.GetCurrentUserName();

        // 根节点1：用户工具目录（Tools/{userName}）
        var userToolsRelPath = Path.GetRelativePath(
            GlobalData.MainFileServerPathRoot,
            GlobalData.GetUserToolsPath(currentUser));
        var userRootNode = new FileSystemNode(userToolsRelPath, currentUser, true);
        var userRootItem = new TreeItemData<FileSystemNode> { Value = userRootNode, Expandable = true, Text = userToolsRelPath };
        var userChildren = await MainApiClient.GetFolderFiles(userRootNode, currentUser, ToolAgentHostToUse);
        if (userChildren != null)
        {
            userRootItem.Children = userChildren
                .Select(c => new TreeItemData<FileSystemNode>
                {
                    Value = c,
                    Expandable = c.IsDirectory,
                    Text = c.Name
                })
                .ToHashSet();
        }
        TreeItems.Add(userRootItem);

        // 根节点2：系统工具目录（Tools/0System）
        var systemToolsRelPath = Path.GetRelativePath(
            GlobalData.MainFileServerPathRoot,
            GlobalData.SystemToolsPath);
        var systemRootNode = new FileSystemNode(systemToolsRelPath, "0System", true);
        var systemRootItem = new TreeItemData<FileSystemNode> { Value = systemRootNode, Expandable = true, Text = systemToolsRelPath };
        var systemChildren = await MainApiClient.GetFolderFiles(systemRootNode, currentUser, ToolAgentHostToUse);
        if (systemChildren != null)
        {
            systemRootItem.Children = systemChildren
                .Select(c => new TreeItemData<FileSystemNode>
                {
                    Value = c,
                    Expandable = c.IsDirectory,
                    Text = c.Name
                })
                .ToHashSet();
        }
        TreeItems.Add(systemRootItem);
    }

    protected async Task Submit()
    {
        if (ToolName == null || ToolName == "")
        {
            MudDialog.Close(DialogResult.Ok(SelectedNode?.FullPath ?? ""));
        }
        else
        {
            MudDialog.Close(DialogResult.Ok(ToolName));
        }

    }


}
