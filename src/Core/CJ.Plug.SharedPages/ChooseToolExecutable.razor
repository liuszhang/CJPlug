@using System.Text.Json
@using System.Text.Json.Serialization
@using Blazored.LocalStorage
@using CJ.Plug.ApiClient.Contracts
@using CJ.Plug.Models.LogModels
@using CJ.Plug.Models.Shared
@using CJ.Plug.SharedPages.Contracts
@using MudBlazor

@inject MainApiClient MainApiClient
@inject IDomInteropService DomInteropService

<MudDialog Class="stack-resize">
    <DialogContent>     
        <MudContainer Style="max-height: 350px; overflow-y: scroll">
            <MudPaper Class="pa-4">
                <MudTreeView @bind-SelectedValue="SelectedNode" Hover="true" Color="Color.Success">
                    @foreach (var rootItem in TreeItems)
                    {
                        <ServerFileTreeItem Node="rootItem" ToolAgentHostToUse="ToolAgentHostToUse" />
                    }
                </MudTreeView>
            </MudPaper>
        </MudContainer>
        <MudDivider></MudDivider>
        <MudText>已选择：@(SelectedNode == null ? "无" : SelectedNode.FullPath)</MudText>
        <MudDivider></MudDivider>
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            <MudAlertTitle>提示</MudAlertTitle>
            <MudText>请从临时工具包文件夹中选择一个可执行文件（如.exe文件）。创建工具时路径将自动转换为正式存储路径。</MudText>
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">取消</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(SelectedNode == null || SelectedNode.IsDirectory)">确认</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private FileSystemNode[] FileTreeNodes { get; set; } = new FileSystemNode[0];
    private List<TreeItemData<FileSystemNode>>? TreeItems { get; set; } = new ();

    private FileSystemNode? SelectedNode { get; set; }

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public string ToolAgentHostToUse { get; set; }
    [Parameter] public bool IsTemporaryToolPackage { get; set; } = false;

    void Cancel() => MudDialog.Cancel();

    protected override async Task OnInitializedAsync()
    {
        CLog.Information("ChooseToolExecutable OnInitializedAsync");
        var currentUser = await DomInteropService.GetCurrentUserName();

        if (IsTemporaryToolPackage)
        {
            // 显示临时工具包文件夹
            var tmpToolsPath = Path.Combine(GlobalData.ToolsRootPath, "Tmp");
            var tmpRootNode = new FileSystemNode(tmpToolsPath, "临时工具包", true);
            var tmpRootItem = new TreeItemData<FileSystemNode> { Value = tmpRootNode, Expandable = true, Text = "临时工具包文件夹" };
            var tmpChildren = await MainApiClient.GetFolderFiles(tmpRootNode, currentUser, ToolAgentHostToUse);
            tmpRootItem.Children = ConvertToTreeItems(tmpChildren);
            TreeItems.Add(tmpRootItem);
        }
        else
        {
            // 显示用户工具目录
            var userToolsPath = GlobalData.GetUserToolsPath(currentUser);
            var userRootNode = new FileSystemNode(userToolsPath, currentUser, true);
            var userRootItem = new TreeItemData<FileSystemNode> { Value = userRootNode, Expandable = true, Text = "用户工具包" };
            var userChildren = await MainApiClient.GetFolderFiles(userRootNode, currentUser, ToolAgentHostToUse);
            userRootItem.Children = ConvertToTreeItems(userChildren);
            TreeItems.Add(userRootItem);

            // 显示系统工具目录
            var systemToolsPath = GlobalData.SystemToolsPath;
            var systemRootNode = new FileSystemNode(systemToolsPath, "0System", true);
            var systemRootItem = new TreeItemData<FileSystemNode> { Value = systemRootNode, Expandable = true, Text = "系统工具包" };
            var systemChildren = await MainApiClient.GetFolderFiles(systemRootNode, currentUser, ToolAgentHostToUse);
            systemRootItem.Children = ConvertToTreeItems(systemChildren);
            TreeItems.Add(systemRootItem);
        }
    }

    /// <summary>
    /// 将 FileSystemNode 列表递归转换为 TreeItemData 树
    /// </summary>
    private static HashSet<TreeItemData<FileSystemNode>> ConvertToTreeItems(List<FileSystemNode>? nodes)
    {
        if (nodes == null || nodes.Count == 0) return new HashSet<TreeItemData<FileSystemNode>>();
        return nodes.Select(ConvertNode).ToHashSet();
    }

    private static TreeItemData<FileSystemNode> ConvertNode(FileSystemNode node)
    {
        var item = new TreeItemData<FileSystemNode>
        {
            Value = node,
            Expandable = node.IsDirectory,
            Text = node.Name
        };
        if (node.Children is { Count: > 0 })
        {
            item.Children = node.Children.Select(ConvertNode).ToHashSet();
        }
        return item;
    }

    protected async Task Submit()
    {
        if (SelectedNode == null)
        {
            MudDialog.Cancel();
            return;
        }

        // 直接返回原始 Tmp 路径，不做转换。路径转换在 NewTool.Submit() 中完成。
        MudDialog.Close(DialogResult.Ok(SelectedNode.FullPath));
    }
}