    <MudTextField FullWidth T="string" @bind-text="tmpVersionPath" Margin="Margin.Dense" Variant="Variant.Outlined" Label="@Plug.ToolVersion" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"></MudTextField>
