@using CJ.Plug.Models.Plug
@using System.Text.Json
@using CJ.Plug.Models.VariableType
@using MudBlazor

@* @if(Plug.ToolVersions.Count==0)
{
    <MudTextField FullWidth T="string" @bind-text="ToolPath" Margin="Margin.Dense" Variant="Variant.Outlined" Label="工具路径" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"></MudTextField>
