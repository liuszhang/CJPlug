<script>
    // 用于获取点击位置的元素信息
    window.getClickedElementInfo = function (x, y) {
    // 根据坐标获取被点击的元素
    const element = document.elementFromPoint(x, y);
    if (!element) return null; // 元素不存在时返回 null

    // 如果点击的是 path 元素，查找其父级 g 标签的 id
    if (element.tagName.toString() === 'path') {
    // 逐级向上查找父元素中的 g 标签
    let parent = element.parentNode;
    while (parent) {
    // 找到 g 标签且有 id 时返回
    if (parent.tagName.toString() === 'g' && parent.id) {
    return parent.id;
    }
    // 继续向上查找父级的父级
    parent = parent.parentNode;
    }
    // 如果没找到带 id 的 g 标签，返回提示信息或 null
    return 'path-no-g-id';
    }

    // 非 path 元素，直接返回标签名（保持原逻辑）
    return element.tagName.toString();
    };
</script>


