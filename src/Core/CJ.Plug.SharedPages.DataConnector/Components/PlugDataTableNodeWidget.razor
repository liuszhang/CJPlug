@using Blazor.Diagrams.Components.Renderers
@using Blazor.Diagrams.Core.Models
@using CJ.Plug.SharedPages.DataConnector.Models
@using MudBlazor




<MudPaper Width="200px">
    <MudList T="string" Dense Gutters=false>
        <MudListSubheader>
            @Node?.PlugName
        </MudListSubheader>
        <MudDivider />
        @foreach(var v in Node?.PlugVariables)
        {

            <MudListItem Style="padding-left:0px;padding-right:0px;" Dense="true">
                <PlugVariableItemWidget @key="v" Node="Node" Variable="v"></PlugVariableItemWidget>
            </MudListItem>
        }
    </MudList>
</MudPaper>

