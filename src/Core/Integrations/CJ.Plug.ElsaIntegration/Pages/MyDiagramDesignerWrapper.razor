            <MudIconButton Size="MudBlazor.Size.Small" Icon="@Icons.Material.Outlined.FitScreen" OnClick="ZoomToFitAsync"></MudIconButton>
            <MudIconButton Size="MudBlazor.Size.Small" Icon="@Icons.Material.Filled.FilterCenterFocus" OnClick="CenterContentAsync"></MudIconButton>
