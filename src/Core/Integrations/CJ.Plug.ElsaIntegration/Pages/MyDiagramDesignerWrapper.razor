            </MudToggleGroup>
            <MudSpacer />
            @* <MudSwitch T="bool?" Color="Color.Primary" Label="自动保存" LabelPosition="LabelPosition.Start" /> *@
            <MudTooltip Text="打开工作目录">
                <MudIconButton OnClick="OpenFileExplorer" Size="MudBlazor.Size.Small" Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" Style="margin-right:10px"></MudIconButton>
            </MudTooltip>
            <MudTooltip Text="自动保存">
                <MudCheckBox ReadOnly Size="MudBlazor.Size.Small" T="bool" Color="Color.Primary" Dense Value="true" Style="margin-right:10px">自动</MudCheckBox>
            </MudTooltip>
            <MudTooltip Text="保存" Delay="1000">
