                    <MudIconButton OnClick="PublishWorkflow" Size="MudBlazor.Size.Small" Icon="@Icons.Material.Filled.CloudUpload" Color="Color.Primary" />
                    
                    <MudMenu Size="MudBlazor.Size.Small" Icon="@Icons.Material.Filled.ArrowDropDown">
