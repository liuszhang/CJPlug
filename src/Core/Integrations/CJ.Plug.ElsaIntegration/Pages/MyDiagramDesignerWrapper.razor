@code
{
    string _value = "逻辑流";
    bool ExeButtonDisabled = false;

    [CascadingParameter]
    public PlugDataZone? PlugDataZone { get; set; }
    [CascadingParameter]
    public IDictionary<string, ActivityStats> ActivityStats { get; set; }
    [Parameter]
    public string? ProcessDefinitionId { get; set; }

    private ElsaFlowchartDesigner Designer { get; set; } = default!;

    [Parameter]
    public Plug? Process { get; set; } = default!;
    public PlugData? PlugData { get; set; }

    public JsonObject? Flowchart { get; set; }

    [Parameter]
    public bool IsProgressing { get; set; }
    /// Whether the designer is read-only.
    [Parameter] public bool IsReadOnly { get; set; }

    private bool DataDirty = false;

    protected override async Task OnParametersSetAsync()
    {
        Flowchart = PlugDataZone?.GetFlowchartData(ProcessDefinitionId);
        PlugData = PlugDataZone?.GetPlugData(ProcessDefinitionId);
    }

    // protected override async Task OnAfterRenderAsync(bool firstRender)
    // {
    //     Console.WriteLine("load done 1");
    // }

    private async Task OnSave(bool IsDirty)
    {
        // 使用InvokeAsync确保在UI线程更新状态
        await InvokeAsync(() =>
        {
            DataDirty = IsDirty;
            StateHasChanged(); // 显式通知组件状态已更改（在某些场景下可能需要）
        });

    }

    public async Task ZoomToFitAsync() => await Designer.ZoomToFitAsync();
    public async Task CenterContentAsync() => await Designer.CenterContentAsync();
    public async Task AutoLayoutAsync() => await Designer.AutoLayoutAsync();
    public async Task SaveAsync() => await Designer.SaveAsync();
    public async Task LoadActivityAsync(JsonObject root) => await Designer.LoadActivityAsync(root);



    /// <summary>
    /// 暴露给外部的接口，用于更新活动
    /// </summary>
    /// <param name="activity"></param>
    /// <returns></returns>
    public async Task UpdateActivity(JsonObject activity)
    {        
        //Log.Information($"开始更新活动：{activity}");
        //Console.WriteLine(">>>>>>>>>>start update activity");
        //await Designer.UpdateActivityAsync(activity.GetId(), activity);
        //Console.WriteLine(">>>>>>>>>>end update activity");
    }

    private async Task OpenFileExplorer()
    {
        var options = new DialogOptions { CloseOnEscapeKey = false , FullScreen=false,MaxWidth=MaxWidth.False,CloseButton=true,Position=DialogPosition.TopCenter};
        var parameters = new DialogParameters<OpenFileExplorer> { { x => x.PlugDataZone, PlugDataZone } };

        await DialogService.ShowAsync<OpenFileExplorer>("工作目录", parameters, options);
    }


    private async Task ExecuteOption()
    {

    }

    private void ClearActivityStatus()
    {
        foreach (var acs in ActivityStats)
        {
            ActivityStats[acs.Key] = null; //清除活动状态
        }
    }

    private async Task ExecuteOrStopFlow()
    {
        if (ExeButtonDisabled)
        {
            //如果正在执行，则停止
            ExeButtonDisabled = false;
            IsProgressing = false;
            IsReadOnly = false;
            Snackbar.Add("流程已停止", Severity.Warning);
            Log.Information($"流程已停止：{Process.DefinitionId}");
        }
        else
        {
            //如果未执行，则开始执行
            await ExecuteFlow();
        }
    }

    private async Task ExecuteFlow()
    {
        ExeButtonDisabled = true;
        IsProgressing = true;
        IsReadOnly = true;

        ClearActivityStatus();

        var TriggerActivityId = PlugDataZone?.TriggerPlugDefinitionId;
        //创建执行作业PDZ
        var currentUser = await DomInteropService.GetCurrentUserName();
        (var PDZId,var JobDefinitionId) = await MainApiClient.SubmitExecute(PlugData, currentUser, PlugDataZone, PDZTypeEnum.Job1);
        CLog.Information($"{PlugDataZone?.PDZId}:开始执行流程：{Process.DefinitionId}", PDZId);

        //使用引擎执行流程，利用引擎的逻辑调度、后台长时间执行等特性
        //var result = await ElsaEngineService.ExecuteAsync(Process);
        //var result = await ElsaEngineService.ExecuteWithCorrelationIdAsync(Plug,PlugDataZone.PDZId);
        //var result = await ElsaApiClient.ExecutePlugWithCorrelationIdAsync(Plug,PlugDataZone.PDZId);
        //var result = await ElsaApiClient.ExecuteJsonWithCorrelationIdAsync(Plug.ToActivityJson(),PlugDataZone.PDZId);
        var executeSetting = new ExecuteSetting
        {
                CorrelationId = PDZId,
                TriggerActivityId = TriggerActivityId,
        };
        var FlowchartJson = PlugDataZone.GetFlowchartData(Process.DefinitionId);
        var result = await ElsaApiClient.ExecuteWorkflowWithExecuteSetting(FlowchartJson, executeSetting);
        //Log.Information(JsonSerializer.Serialize(result));

        Snackbar.Add("成功启动流程", Severity.Success);
        //Log.Information($"执行流程：{Plug.DefinitionId}。作业实例号：{result.ExecuteResultMessage}");

        ExeButtonDisabled = false;
        IsProgressing = false;
        IsReadOnly = false;
    }

    private async Task ExportWorkflow()
    {
        await ElsaDomToolService.ExportFromJsonDataAsync(Process.Name+".json",PlugDataZone.GetFlowchartData(Process.DefinitionId).ToString());
    }

    private async Task ImportWorkflow(IBrowserFile? file)
    {
        if (file == null)
            return;
        // 创建文件流
        using var stream = file.OpenReadStream();

        // 使用StreamReader读取为字符串
        using var reader = new StreamReader(stream);
        var content = await reader.ReadToEndAsync();
        // 先解析为 JsonDocument，再转换为 JsonObject
        using var jsonDoc = JsonDocument.Parse(content);
        JsonObject jsonObject = JsonObject.Create(jsonDoc.RootElement);
        jsonObject.SetId(ProcessDefinitionId);
        jsonObject.SetNodeId(ProcessDefinitionId);
        jsonObject.SetProperty(ProcessDefinitionId, "definitionId");
        jsonObject.SetName(Process.Name);
        //var newFlowchartData = PlugDataZone?.SetFlowchartData(ProcessDefinitionId, jsonObject);
        //await MainApiClient.UpdateFlowchartData(newFlowchartData);

        PlugDataZone?.SetFlowchartData(ProcessDefinitionId, jsonObject);
        await Designer.LoadActivityAsync(jsonObject);

        //还需要添加PlugData和PlugVariableData
        var plugDatas = jsonObject.GetActivities();
        //PlugDataZone.PlugDatas.Clear();
        PlugDataZone.PlugVariableDatas.Clear();
        PlugDataZone.PlugDatas.Clear();
        PlugDataZone?.PlugDatas.Add(new PlugData
        {
            PlugDefinitionId = ProcessDefinitionId,
            Name = Process.Name,
            WorkPath = PlugDataZone.PDZWorkPath,
            PlugPosition = $"0.0 0.0",//记录插头坐标值，用于绘制数据流等功能
        });
        foreach (var plugData in plugDatas)
        {
            var x = plugData.GetDesignerMetadata().Position.X;
            var y = plugData.GetDesignerMetadata().Position.Y;
            PlugDataZone?.PlugDatas.Add(new PlugData
            {
                PlugDefinitionId = plugData.GetId(),
                ParentPlugDefinitionId = ProcessDefinitionId,
                Name = plugData.GetName(),
                PlugType = plugData.GetTypeName(),
                PlugTypeKey = plugData?.GetTypeName(),
                WorkPath = Path.Combine(PlugDataZone.PDZWorkPath, plugData.GetId()),
                PlugPosition = $"{x} {y}",//记录插头坐标值，用于绘制数据流等功能
            });
            //添加PlugVariableData
            var rootPlug = await MainApiClient.GetRootPlugByTypeNameAsync(plugData.GetTypeName());
            if (rootPlug != null)
            {
                foreach (var p in rootPlug.PlugVariables)
                {
                    PlugDataZone.PlugVariableDatas.Add(new PlugVariableData()
                    {
                        PlugDefinitionId = plugData.GetId(),
                        Name = p.Name,
                        Value = p.Value,
                        DefaultValue = p.DefaultValue,
                        Type = p.Type,
                        IsInitVariable = p.IsInitVariable,
                        IsBrowsable = p.IsBrowsable,
                        IsArray = p.IsArray,
                    });
                }
            }
        }

        await MainApiClient.CreateOrUpdatePDZ(PlugDataZone);

        StateHasChanged();
    }

    private async Task ImportWorkflows(IReadOnlyList<IBrowserFile>? files)
    {
        if (files == null || files.Count == 0)
            return;
        var options = new ImportOptions
        {
            DefinitionId = ProcessDefinitionId,
            ImportedCallback = async definition =>
            {
                //await SetWorkflowDefinitionAsync(definition);
                var newFlowchartData = PlugDataZone?.SetFlowchartData(ProcessDefinitionId, definition.Root);
                await MainApiClient.UpdateFlowchartData(newFlowchartData);
                await Designer.LoadActivityAsync(definition.Root);
            },
            ErrorCallback = ex =>
            {
                CLog.Error($"Failed to import workflow definition: {ex.Message}", PlugDataZone.PDZId);
                return Task.CompletedTask;
            }
        };
        await ElsaDomToolService.ImportFromJsonAsync(files, options);
        StateHasChanged();
    }


    private async Task PublishWorkflow()
    {
        Process.ShowInPlugLibrary = true;
        await MainApiClient.UpdatePlugAsync(Process.Id, Process);
        //WorkflowDefinition.IsPublished = true;
        Snackbar.Add("发布成功！");
        StateHasChanged();
    }

    private async Task UnPublishWorkflow()
    {
        Process.ShowInPlugLibrary = false;
        await MainApiClient.UpdatePlugAsync(Process.Id, Process);
        //WorkflowDefinition.IsPublished = false;
        Snackbar.Add("取消发布成功！");
        StateHasChanged();
    }


}