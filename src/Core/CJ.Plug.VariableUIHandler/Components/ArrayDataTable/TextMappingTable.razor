
@using CJ.Plug.Models.VariableType
@using CJ.Plug.VariableUIHandler.Models
@using MudBlazor
@using System.Text.Json
@using Serilog
<MudTable Items="@dataList" Hover="true" Striped="true" Dense>
    <HeaderContent>
        <MudTh>名称</MudTh>
        <MudTh>绑定参数</MudTh>
        <MudTh>关键字</MudTh>
        <MudTh>识别模式</MudTh>                    
        <MudTh>识别值</MudTh>                    
    </HeaderContent>
    <RowTemplate>
        <MudTd>@($"{@EditorContext.Variable.Type}[{@dataList.IndexOf(context)}]")</MudTd>
        <MudTd>@context.BindingVariableName</MudTd>
        <MudTd>@context.Keywords</MudTd>
        <MudTd>@context.ReadSchemaMode.ToString()</MudTd>
        <MudTd>@context.ReadSchemaValue</MudTd>
        @* <MudTd>@String.Join(',', context.PositionOffset)</MudTd> *@

    </RowTemplate>
</MudTable>

@code {
    [Parameter]
    public DisplayInputEditorContext EditorContext { get; set; } = null!;

    private List<TextMapping> dataList = new();


    protected override async Task OnParametersSetAsync()
    {
        try
        {
            dataList = JsonSerializer.Deserialize<List<TextMapping>?>(EditorContext.Variable.Value);
            //Log.Information(JsonSerializer.Serialize(dataList));
        }
        catch (Exception ex)
        {
            Log.Information(ex.Message);
        }
        StateHasChanged();
    }
}
