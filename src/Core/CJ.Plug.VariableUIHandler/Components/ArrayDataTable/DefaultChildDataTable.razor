
@using CJ.Plug.Models.Shared
@using CJ.Plug.Models.VariableType
@using CJ.Plug.VariableUIHandler.Models
@using MudBlazor
@using System.Text.Json
@using Serilog
<MudTable Items="@dataList" Hover="true" Striped="true" Dense>
    <HeaderContent>
        <MudTh>名称</MudTh>
        <MudTh>值</MudTh>                
    </HeaderContent>
    <RowTemplate>
        <MudTd>@($"{@EditorContext.Variable.Type}[{@dataList.IndexOf(context)}]")</MudTd>
        <MudTd>@context.Value</MudTd>

    </RowTemplate>
</MudTable>

@code {
    [Parameter]
    public DisplayInputEditorContext EditorContext { get; set; } = null!;

    private List<BaseVariable> dataList = new();


    protected override async Task OnParametersSetAsync()
    {
        try
        {
            dataList = JsonSerializer.Deserialize<List<BaseVariable>?>(EditorContext.Variable.Value);
            //Log.Information(JsonSerializer.Serialize(dataList));
        }
        catch (Exception ex)
        {
            Log.Information(ex.Message);
        }
        StateHasChanged();
    }
}
