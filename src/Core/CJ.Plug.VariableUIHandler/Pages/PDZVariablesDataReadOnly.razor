@using CJ.Plug.Models.Plug
@using CJ.Plug.Models.Shared
@using CJ.Plug.VariableUIHandler.Models
@using MudBlazor
@using System.Text.Json
@using Size=MudBlazor.Size


<MudDataGrid T="PlugVariableData" Items="@_allVariables" ReadOnly="true"
    SortMode="SortMode.None" Height="100%" SelectedItemChanged="SelectVariable"
    Bordered="true" Dense="true" ColumnResizeMode="ResizeMode.Column" LoadingProgressColor="Color.Primary"
    Groupable="@_enableGrouping" GroupExpanded="@_enableGrouping">
    <ToolBarContent>
        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh">刷新</MudButton>
    </ToolBarContent>
    <Columns>
        <SelectColumn T="PlugVariableData" />
        <PropertyColumn Property="x => x.Name" Title="名称" />
        <PropertyColumn Property="x => x.Type" Title="类型" />
        <TemplateColumn>
            <CellTemplate>
                <MudTextField T="string" ReadOnly Style="max-width:300px" Size="@Size.Small" Text="@context.Item.Value" Lines="1" AutoGrow></MudTextField>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.InputAndOutput" Title="输入输出"/>
        @if (_enableGrouping)
        {
            <TemplateColumn Title="所属插头" Groupable="true" Grouping="true" GroupBy="@((PlugVariableData x) => GetPlugName(x.PlugDefinitionId))">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@GetPlugName(context.Item.PlugDefinitionId)</MudText>
                </CellTemplate>
            </TemplateColumn>
        }
    </Columns>
</MudDataGrid>


@code {
    [Parameter]
    public DisplayInputEditorContext? EditorContext { get; set; }

    [Parameter]
    public string? SelectedPlugDefinitionId { get; set; }

    [Parameter]
    public EventCallback<PlugVariableData> SelectedVariableChanged { get; set; }

    private List<PlugVariableData> _allVariables = new();
    private bool _enableGrouping => string.IsNullOrEmpty(SelectedPlugDefinitionId);


    protected override async Task OnParametersSetAsync()
    {
        var variables = EditorContext?.PlugDataZone.GetVariablesOfPlug(SelectedPlugDefinitionId) ?? new();
        var selfId = EditorContext?.Variable?.Id;
        if (selfId != null)
        {
            variables = variables.Where(v => v.Id != selfId).ToList();
        }
        _allVariables = variables;
        StateHasChanged();
    }

    private string GetPlugName(string? plugDefId)
    {
        if (string.IsNullOrEmpty(plugDefId)) return "未归属";
        var plugData = EditorContext?.PlugDataZone?.PlugDatas
            ?.FirstOrDefault(p => p.PlugDefinitionId == plugDefId);
        return plugData?.Name ?? plugDefId;
    }

    private async Task SelectVariable(PlugVariableData PDZVariable)
    {
        Console.WriteLine(">>>>>>>>>selected variable:" + JsonSerializer.Serialize(PDZVariable));
        await SelectedVariableChanged.InvokeAsync(PDZVariable);
    }
}
