@using CJ.Plug.Models.Plug
@using CJ.Plug.Models.PlugAction
@using CJ.Plug.SharedPages
@using MudBlazor

<CascadingValue Value="PlugDataZone">
    <MudDialog>
        <TitleContent>
            <MudText Typo="Typo.h6">配置动作 - @ActionItem?.Name</MudText>
        </TitleContent>
        <DialogContent>
            <MudTabs Elevation="0" ApplyEffectsToContainer="true" PanelClass="pa-4">
                <MudTabPanel Text="基础信息">
                    <MudTextField T="string" FullWidth Margin="Margin.Dense" Label="动作名称" @bind-Value="ActionItem.Name" Variant="Variant.Outlined"></MudTextField>
                    <MudTextField T="string" FullWidth Margin="Margin.Dense" Label="序号" Value="@ActionItem.SN.ToString()" ReadOnly Variant="Variant.Filled"></MudTextField>
                    <MudTextField T="string" FullWidth Margin="Margin.Dense" Label="动作类型" Value="@ActionItem.ActionPlugType" ReadOnly Variant="Variant.Filled"></MudTextField>
                </MudTabPanel>
                <MudTabPanel Text="参数配置">
                    <PDZVariableDataGrid PDZId="@PDZId" ActionIdentityId="@ActionItem.ActionIdentityId"></PDZVariableDataGrid>
                </MudTabPanel>
            </MudTabs>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="Cancel">取消</MudButton>
            <MudButton Color="Color.Primary" OnClick="OK">确定</MudButton>
        </DialogActions>
    </MudDialog>
</CascadingValue>

@code {
    /// <summary>
    /// MudDialog 实例，由 MudBlazor 框架注入
    /// </summary>
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    /// <summary>
    /// 当前要配置的动作数据
    /// </summary>
    [Parameter]
    public ActionData ActionItem { get; set; }

    /// <summary>
    /// 所属的 PlugDataZone 实例
    /// </summary>
    [Parameter]
    public PlugDataZone PlugDataZone { get; set; }

    /// <summary>
    /// PDZ ID，用于 PDZVariableDataGrid 查询参数数据
    /// </summary>
    [Parameter]
    public string PDZId { get; set; }

    /// <summary>
    /// 取消操作，关闭对话框
    /// </summary>
    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }

    /// <summary>
    /// 确认操作，关闭对话框并返回当前动作数据
    /// </summary>
    private void OK()
    {
        MudDialog.Close(DialogResult.Ok(ActionItem));
    }
}
